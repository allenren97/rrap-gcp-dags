proc sql noprint;
   CREATE TABLE LATEST_MOR_LIST AS SELECT  
		  t1.EFF_TM_ID,
		  t1.ks_acct_id, 
          t1.PRIM_CUST_CID, 
          t1.PRIM_CUST_ID, 
          t1.hd_ACCT_ID, 
          t1.hd_ACCT_NUM,
		  t2.*,
		  (1) as mo_count,
		  "mor" as product_code
      FROM MOR_LIST t1  
           INNER JOIN LATEST_MOR t2 on (t2.ACCT_ID = t1.hd_ACCT_ID);
