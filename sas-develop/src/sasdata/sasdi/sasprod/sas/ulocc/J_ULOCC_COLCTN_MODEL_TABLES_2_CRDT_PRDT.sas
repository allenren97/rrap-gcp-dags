proc sql noprint;
   CREATE TABLE acct_products AS SELECT distinct
		  t1.EFF_TM_ID, 
          t1.ACCT_ID as ks_acct_id, 
          t1.PRIM_CUST_CID, 
          t1.PRIM_CUST_ID, 
          t2.ACCT_ID AS hd_ACCT_ID, 
          t2.ACCT_NUM as hd_ACCT_NUM,
          t2.PRIM_CUST_JOIN_ID, 
          t2.CIS_PRD_CD, 
          t2.CUST_JOIN_ID, 
          t2.CUST_ID, 
          t2.SRC_APP_ID
      FROM dev.KS_DELQ_PRI_CUST t1
           INNER JOIN dev.ACCT_CUST_REL t2 ON (t1.PRIM_CUST_ID = t2.CUST_ID);
		   /*INNER JOIN dev.ACCT_CUST_REL t2 ON (t1.PRIM_CUST_ID = t2.CUST_ID);*/
QUIT;


*break the previous dataset into 3 parts - one for each product group;
