      GROUP BY t1.EFF_TM_ID,
               t1.ks_acct_id;
QUIT;


proc sql noprint;
   CREATE TABLE dev.LAST_3M_CUST_KS_OSBAL_AVG AS 
   SELECT t1.EFF_TM_ID, 
          t1.ks_acct_id, 
          /* AVG_of_osbal */
            (AVG(t1.osbal)) FORMAT=19.2 AS AVG_of_osbal
      FROM LAST_6M_KS_LIST t1
      WHERE t1.hd_EFF_TM_ID >= &dti_p03mb. and ks_acct_id=hd_ACCT_ID
      GROUP BY t1.EFF_TM_ID,
               t1.ks_acct_id;
QUIT;


proc sql noprint;
create table last_3m_mor as select distinct
ks_acct_id, 
hd_acct_id,
        osbal
	,hd_EFF_TM_ID
	,min(hd_EFF_TM_ID) as min_dt		  
	,max(hd_EFF_TM_ID) as max_dt
from LAST_6M_MOR_LIST
where hd_EFF_TM_ID >= &dti_p03me_mor.
group by ks_acct_id
having (hd_EFF_TM_ID=calculated min_dt or hd_EFF_TM_ID=calculated max_dt)
order by ks_acct_id, hd_EFF_TM_ID;
quit;



proc sql noprint;
   CREATE TABLE last_3m_mor_sum AS 
   SELECT distinct t1.ks_acct_id, 
            (SUM(t1.osbal)) AS tot_mo_bal_cust, 
          t1.hd_EFF_TM_ID, 
          t1.min_dt, 
          t1.max_dt
      FROM LAST_3M_MOR t1
      GROUP BY t1.ks_acct_id,
               t1.hd_EFF_TM_ID 
			   order by ks_acct_id, hd_EFF_TM_ID asc
;
QUIT;


data dev.LAST_3M_MOR_SLOPE;
SET last_3m_mor_sum;

lag_cust_acct=lag(ks_acct_id);
lag_mo_bal=lag(tot_mo_bal_cust);

tot_mo_bal_custslp3m=.;


if ks_acct_id=lag_cust_acct and min_dt <= "&dt_p03me_mor.:0:0:0"dt then do;
	tot_mo_bal_custslp3m  =(tot_mo_bal_cust - lag_mo_bal)/2;
end;

if hd_EFF_TM_ID= max_dt;
run;


