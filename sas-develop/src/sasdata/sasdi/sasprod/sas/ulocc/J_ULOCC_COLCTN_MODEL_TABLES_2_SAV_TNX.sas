proc sql noprint;
	connect to db2 (dsn=DM1DBT authdomain=db2_auth);
	create table dev.SAV_ACCT_REL  as select distinct * 
	from connection to db2 
	(SELECT T1.ACCT_ID, 
		  	T1.ACCT_NUM,
			t1.PRIM_CUST_JOIN_ID,
			t1.CIS_PRD_CD, 
			t2.CUST_JOIN_ID, 
          	t2.CRNT_F, 
          	t2.PRIM_F,
			t2.EFF_FROM_TMSTMP, 
          	t2.EFF_TO_TMSTMP, 
	    	t3.CUST_ID, 
		    t3.SRC_APP_ID,
            t3.EFF_FROM_TMSTMP AS EFF_FROM_CUST,
            t3.EFF_TO_TMSTMP AS EFF_TO_CUST
	FROM EDEDW.ACCT_DIM t1, 
		 EDEDW.ACCT_CUST_RLTNP t2, 
		 EDEDW.CUST_DIM t3
      WHERE (t1.ACCT_ID = t2.ACCT_ID AND t2.CUST_JOIN_ID = t3.CUST_JOIN_ID) 
				AND t1.CIS_PRD_CD IN ('SAV') 
				AND t2.EFF_FROM_TMSTMP <=&dt_db2. 
				AND t2.EFF_TO_TMSTMP >=&dt_db2.
			    AND SRC_SYSTEM_END_TMSTMP is null 
			 WITH UR);
DISCONNECT FROM DB2;
QUIT;

proc sql noprint;
connect to db2(database=dm1dbt authdomain=db2_auth);
create table dev.sav_acct_sum as
select * from connection to db2
(select    b.acct_id,
           b.acct_join_id,
           b.prd_join_id,
           b.eff_dt_tm_id,
           b.eff_dt, 
           b.crnt_book_val, 
           a.acct_stat_cd,
           a.cust_join_id,
           a.prim_own_cif_id,
			&max_ti_sav. as eff_dt_ss
from edrds.sav_acct_dim a, edrds.sav_acct_fact_s b
     where b.eff_dt_tm_id =&max_ti_sav.
     and a.acct_join_id=b.acct_join_id 
     and b.eff_dt>=date(a.eff_from_tmstmp) 
     and b.eff_dt<=date(a.eff_to_tmstmp) 
     and  acct_stat_cd in ('A')  with UR) ;
disconnect from db2;
quit;

PROC SQL ;
   CREATE TABLE CUST_SAV_ACCT  AS SELECT distinct
		  t1.prim_cust_id as cust_id,
		  t2.ACCT_ID, 
		  t2.SRC_APP_ID,
          t2.PRIM_F
      FROM dev.KS_DELQ_PRI_CUST t1, dev.SAV_ACCT_REL t2
      WHERE (t1.prim_cust_id = t2.CUST_ID);
QUIT;


proc sql noprint;
create table sav_acct_bal as select distinct
t1.cust_id,
t1.PRIM_F,
t1.ACCT_ID, 
t1.SRC_APP_ID,
t2.acct_join_id,
t2.eff_dt_tm_id,
t2.crnt_book_val, 
t2.acct_stat_cd,
t2.cust_join_id as cust_join_id2,
t2.prim_own_cif_id  
from CUST_SAV_ACCT t1 
inner join dev.sav_acct_sum t2 on (t1.acct_id=t2.acct_id) ;
quit;


proc sql noprint;
create table pri_cust_bal as select 
cust_id,sum(CRNT_BOOK_VAL) as d2dbal, count(unique acct_id) as n_sav from sav_acct_bal
/*where PRIM_F  <> "N"*/
where PRIM_OWN_CIF_ID=SRC_APP_ID
group by cust_id;
quit;

proc sql noprint;
create table sec_cust_bal as select 
cust_id,sum(CRNT_BOOK_VAL) as sec_d2dbal, count(unique acct_id) as sec_n_sav from sav_acct_bal
where PRIM_F = "N"
group by cust_id;
quit;

proc sort data=pri_cust_bal;
by cust_id;
run;

proc sort data=sec_cust_bal;
by cust_id;
run;

data dev.LOC_d2d;
merge pri_cust_bal (in=a)
      sec_cust_bal (in=b);
by CUST_ID;
if a or b;
total_d2dbal=coalesce(d2dbal,0)+coalesce(sec_d2dbal,0);
total_n_d2d=coalesce(n_sav,0) + coalesce(sec_n_sav,0);
run;


