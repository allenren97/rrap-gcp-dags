proc sql noprint;
	connect to db2 (dsn=OWSTAR authdomain=db2_auth);
	create table sas.ulocc_cust_tnx_nsf  as select * 
	from connection to db2
 	(select b.cust_id,
			a.acct_id,
			a.EFF_DT_TM,
			a.POSTED_DT, 
			a.AMT, 
			a.TXN_CD
		from ededtt.saving_and_dda_txn_fact a 
			 INNER JOIN EDRTLRMDT.ULOCC_CUST_SAV_ACCT b ON (a.ACCT_ID = b.ACCT_ID)
		where   a.EFF_DT_TM >= &db2_p12mb. AND 
				a.EFF_DT_TM <=&db2_lday. AND 
	   			a.TXN_CD in ('804','894') with UR);
DISCONNECT FROM DB2;
QUIT;
 
proc sql noprint;
   CREATE TABLE nsf_cust_acct_11 AS 
   SELECT cust_id, 
          ACCT_ID, 
		  (COUNT(ACCT_ID)) AS COUNT_of_ACCT_ID, 
          (SUM(AMT)) FORMAT=14.2 AS SUM_of_AMT, 
		 (year(datepart(EFF_DT_TM))) AS Y_EFF_DT_TM,
		 (month(datepart(EFF_DT_TM))) AS M_EFF_DT_TM
      FROM sas.ulocc_cust_tnx_nsf
	  where eff_dt_tm le "&dt_p01me."d
      GROUP BY cust_id,
               ACCT_ID,
			   calculated Y_EFF_DT_TM,
			   calculated M_EFF_DT_TM;
QUIT;


%put &dt_p00mb.;
%put &dt_p01md.;

%macro mth_nsf_day;
proc sql noprint;
   CREATE TABLE nsf_cust_acct_12 AS 
   SELECT cust_id, 
          ACCT_ID, 
		  (COUNT(ACCT_ID)) AS COUNT_of_ACCT_ID, 
          (SUM(AMT)) FORMAT=14.2 AS SUM_of_AMT,
		  9999 as Y_EFF_DT_TM,
		  99 as M_EFF_DT_TM
      FROM sas.ulocc_cust_tnx_nsf
	  where eff_dt_tm gt "&dt_p01md."d
      GROUP BY cust_id,
               ACCT_ID,
			   calculated Y_EFF_DT_TM,
			   calculated M_EFF_DT_TM;
QUIT;
%mend mth_nsf_day;

%macro mth_nsf_mo_end;
proc sql noprint;
   CREATE TABLE nsf_cust_acct_12 AS 
   SELECT cust_id, 
          ACCT_ID, 
		  (COUNT(ACCT_ID)) AS COUNT_of_ACCT_ID, 
          (SUM(AMT)) FORMAT=14.2 AS SUM_of_AMT,
		 (year(datepart(EFF_DT_TM))) AS Y_EFF_DT_TM,
		 (month(datepart(EFF_DT_TM))) AS M_EFF_DT_TM
      FROM sas.ulocc_cust_tnx_nsf
	  where EFF_DT_TM ge "&dt_p00mb."d
