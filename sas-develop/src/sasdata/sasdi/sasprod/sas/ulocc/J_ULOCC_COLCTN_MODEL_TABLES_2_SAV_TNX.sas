proc sql noprint;
   CREATE TABLE dep_cust_date AS SELECT 
		  cust_id,
 		  M_EFF_DT_TM,
          sum(SUM_of_AMT) AS SUM_of_SUM_of_amt
   FROM dep_cust_acct_date 
   GROUP BY cust_id, M_EFF_DT_TM;
QUIT;

proc sql noprint;
   CREATE TABLE dep_cust_var AS SELECT
		cust_id, 
        min(abs(SUM_of_SUM_of_amt)) AS min_dep_3mos
   FROM dep_CUST_date
   GROUP BY cust_id;
QUIT;

proc sql noprint;
   CREATE TABLE dev.CUST_SAV_VAR AS SELECT DISTINCT 
		  t1.CUST_ID, 
		  t4.total_d2dbal,
		  t3.tot_amt_dep,
		  t2.min_dep_3mos,
		  t5.avg_nb_nsf_12mos
   FROM CUST_SAV_ACCT t1
   		   inner join sav_acct_bal t7 on (t1.ACCT_ID=t7.ACCT_ID)
           LEFT JOIN DEP_CUST_VAR t2 ON (t1.CUST_ID = t2.CUST_ID)
           LEFT JOIN DEP_CUST_VAR_DT_SS t3 ON (t1.CUST_ID = t3.CUST_ID)
           LEFT JOIN dev.LOC_D2D t4 ON (t1.CUST_ID = t4.CUST_ID)
           LEFT JOIN NSF_CUST_VAR t5 ON (t1.CUST_ID = t5.CUST_ID)
           /*LEFT JOIN NSF_CUST_VAR_DT_SS t6 ON (t1.CUST_ID = t6.CUST_ID)*/;
QUIT;


%macro hist_used(no,name,key,tm_id,dataset);
proc sql noprint;
   CREATE TABLE dev.hist_used_&no. AS 
   SELECT   &no as no,
			  ("&name") AS dataset length=10, 
			  	count(&key.) as freq,
             (MIN(&tm_id.)) FORMAT=FMT_TID. AS MIN_TM_ID, 
             (MAX(&tm_id.)) FORMAT=FMT_TID. AS MAX_TM_ID
      FROM &dataset. t1;
QUIT;
%mend;


