proc sql noprint;
CREATE TABLE nsf_cust_acct_date AS 
SELECT * FROM NSF_CUST_ACCT_11
 OUTER UNION CORR 
SELECT * FROM NSF_CUST_ACCT_12
;
Quit;

proc sql noprint;
   CREATE TABLE nsf_cust_var AS 
   SELECT 	cust_id, 
            (sum(COUNT_of_ACCT_ID)/12) AS avg_nb_nsf_12mos, 
            (sum(abs(SUM_of_AMT))/12) AS avg_amt_nsf_12mos
      FROM nsf_cust_acct_date
	  group by cust_id;
QUIT;

proc delete data=sas.ulocc_cust_tnx_dep;
run;

proc sql noprint;
	connect to db2 (dsn=OWSTAR authdomain=db2_auth);
	create table sas.ulocc_cust_tnx_dep as select * 
	from connection to db2
 	(select b.cust_id,
			a.acct_id,
			a.POSTED_DT,
			a.EFF_DT_TM,
			a.AMT, 
			a.TXN_CD,
			a.TXN_JOIN_ID,
			c.DLVY_KEY
		from ededtt.saving_and_dda_txn_fact a 
			 INNER JOIN EDRTLRMDT.ULOCC_CUST_SAV_ACCT b ON (a.ACCT_ID = b.ACCT_ID)
			 left join  ededt.sav_dda_txn_rtl_dm_rltnp c on (a.txn_join_id  = c.txn_join_id)
		where   a.EFF_DT_TM >= &db2_p03mb. AND 
				a.EFF_DT_TM <=&db2_lday. AND 
	   	a.TXN_CD in ('110','120','140','141','202','220','292','321','552','730','740','895','898',
              '900','901','903','905','933','934','935','941','942','943','944','946','947','951','952',
              '953','954','959','960','975','983','988','990','991','992','993','994','995') 
with UR);
DISCONNECT FROM DB2;
QUIT;

%macro mth_dep_day;
proc sql noprint;
   CREATE TABLE dep_cust_acct_dt_ss AS SELECT 
		cust_id, 
        ACCT_ID, 
        (COUNT(ACCT_ID)) AS COUNT_of_ACCT_ID, 
        (SUM(AMT)) FORMAT=14.2 AS SUM_of_AMT,
	   	9999 as Y_EFF_DT_TM,
		99 as M_EFF_DT_TM
      FROM sas.ulocc_cust_tnx_dep t1
	  INNER JOIN sas.IWD_CHNL_RM t2 ON (t1.DLVY_KEY = t2.DLVY_KEY)
	  where EFF_DT_TM gt "&dt_p01md."d and TXN_GRP_KEY_RM NOT = 'W'
      GROUP BY 	cust_id,
               	ACCT_ID,
				calculated Y_EFF_DT_TM,
			 	CALCULATED M_EFF_DT_TM;
QUIT;
%mend mth_dep_day;

%macro mth_dep_mo_end;
proc sql noprint;
   CREATE TABLE dep_cust_acct_dt_ss AS SELECT 
		cust_id, 
        ACCT_ID, 
        (COUNT(ACCT_ID)) AS COUNT_of_ACCT_ID, 
        (SUM(AMT)) FORMAT=14.2 AS SUM_of_AMT,
		(year(datepart(EFF_DT_TM))) AS Y_EFF_DT_TM,
		(month(datepart(EFF_DT_TM))) AS M_EFF_DT_TM
      FROM sas.ulocc_cust_tnx_dep t1
	  INNER JOIN sas.IWD_CHNL_RM t2 ON (t1.DLVY_KEY = t2.DLVY_KEY)
	  where EFF_DT_TM ge "&dt_p00mb."d and TXN_GRP_KEY_RM NOT = 'W'
      GROUP BY 	cust_id,
               	ACCT_ID,
			 	calculated Y_EFF_DT_TM,
			 	CALCULATED M_EFF_DT_TM;
QUIT;
%mend mth_dep_mo_end;

%macro curr_dep;
  %if &mti_dt_run. ge 0 %then %do;
  		%mth_dep_mo_end;
     %end;
  %else %do;
   		%mth_dep_day;
  %end;
%mend curr_dep;

%curr_dep;

proc sql noprint;
   CREATE TABLE dep_cust_var_dt_ss AS SELECT 
		  cust_id, 
		  M_EFF_DT_TM,
          sum(COUNT_of_ACCT_ID) as tot_num_dep,
		  sum(abs(SUM_of_AMT)) as tot_amt_dep
    FROM dep_cust_acct_dt_ss
 	GROUP BY cust_id,M_EFF_DT_TM;
QUIT;

proc sql noprint;
   CREATE TABLE dep_cust_acct_2 AS 
   SELECT cust_id, 
          ACCT_ID, 
		  (COUNT(ACCT_ID)) AS COUNT_of_ACCT_ID, 
          (SUM(AMT)) FORMAT=14.2 AS SUM_of_AMT, 
		 (year(datepart(EFF_DT_TM))) AS Y_EFF_DT_TM,
		 (month(datepart(EFF_DT_TM))) AS M_EFF_DT_TM
      FROM sas.ulocc_cust_tnx_dep t1
	  INNER JOIN sas.IWD_CHNL_RM t2 ON (t1.DLVY_KEY = t2.DLVY_KEY)
	  where TXN_GRP_KEY_RM NOT = 'W'
	  and eff_dt_tm le "&dt_p01me."d
      GROUP BY cust_id,
               ACCT_ID,
			   calculated Y_EFF_DT_TM,
			   calculated M_EFF_DT_TM;
QUIT;


proc sql noprint;
CREATE TABLE dep_cust_acct_date AS 
SELECT * FROM dep_CUST_ACCT_2
 OUTER UNION CORR 
SELECT * FROM dep_cust_acct_dt_ss
;
