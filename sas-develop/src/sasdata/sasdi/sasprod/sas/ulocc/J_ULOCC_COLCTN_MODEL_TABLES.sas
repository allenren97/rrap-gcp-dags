PROC SQL;
   CREATE TABLE LATEST_KS AS SELECT
	ACCT_ID,
	ACCT_NUM,
    PRIM_CUST_ID,
	DLQNT_DAY as Bns_DAY_DLQNT,
	CR_LMT_AMT as auth_limit,
	TOT_NEW_BAL_AMT as osbal,
	EFF_TM_ID,
	Prd_Cd as product_code,
    Sub_Prd_Cd,
	TOT_UNPAID_FINANCE_CHRG_AMT as Tot_Unpaid_Fncl_Chrg,
	CSH_ADVNC_CRNT_CYCL_BAL_AMT as Csh_Advnc_crnt_cycl_Bal,
    (case when compress(CHRG_OFF_CD) in ('1')  then 1 else 0 end ) AS ind_chgoff, 
    (case when (DLQNT_DAY >= 120) 
		or CHRG_OFF_CD in ("N","Q") 
		or (cats(BLOCK_CD,RECL_CD)  in ('B5')) then 1 else 0 end) AS ind_dft
FROM d_cr_tb.ULOC_REVLVNG_CR_DLY_SNAPSHOT
     where  EFF_TM_ID eq  &dti_lday.
		and (CR_LMT_AMT >0 or TOT_NEW_BAL_AMT >0)
		and prd_cd not in ('BLV')
		and (compress(sub_prd_cd) not in ('CC'));
QUIT;

proc sql;
create table latest_ks_list as select distinct
		  t1.EFF_TM_ID, 
          t1.ks_acct_id, 
          t1.PRIM_CUST_CID, 
          t1.PRIM_CUST_ID, 
          t1.hd_ACCT_ID, 
          t1.hd_ACCT_NUM,
		  t2.ACCT_ID, 
          t2.ACCT_NUM, 
          t2.BNS_DAY_DLQNT, 
          t2.auth_limit, 
          t2.osbal, 
          t2.EFF_TM_ID as hd_EFF_TM_ID, 
          (1) as ks_count, 
          t2.product_code, 
          t2.SUB_PRD_CD, 
          t2.TOT_UNPAID_FNCL_CHRG, 
          t2.CSH_ADVNC_CRNT_CYCL_BAL, 
		  (case when ind_chgoff eq 1 then "CHG"
		  	when ind_dft eq 1 then "DFT" 
			else "CUR" end) as SELECT_STAT_NEW_C4
FROM ks_LIST t1
	inner join	LATEST_KS t2 on (t1.hd_ACCT_ID = t2.ACCT_ID);
QUIT;


data latest_ks_sum;
set latest_ks_list;

format chrg_off_bal 14.;
format def_bal 14.;
format delq_bal 14.;
format curr_bal 14.;

if select_stat_new_c4 ='CHG' then do;
status_as = 4; chrg_off_count =1; chrg_off_bal = osbal; end;

else if select_stat_new_c4 ='DEF' then do;
status_as =3; def_count = 1; def_bal = osbal; end;

else if Bns_DAY_DLQNT >=1 then do; 
status_as = 2; delq_count = 1; delq_bal = osbal; end;

else do;
status_as = 1; curr_bal = osbal; curr_count = 1; end;

delq_bal = sum(delq_bal,def_bal);
delq_count = sum(delq_count,def_count);
ks_bal = osbal;

run;

data latest_allaccounts;
set latest_mor_sum  latest_ks_sum(in=a) latest_spl_sum;
time_key = hd_eff_tm_id;
if a then revl_bal = osbal;
run;

proc sql;
    create table latest_loc_forsum as
		select distinct  
			EFF_TM_ID, 
          	ks_acct_id, 
           	/*time_key,*/
	        count(*) as tot_accts_cust,
		    sum(osbal) as tot_osbal_cust,
			sum(auth_limit) as tot_limit_cust,

			sum(revl_bal)/sum(auth_limit) as cust_utilization,
			max(status_as) as Worst_select_status,
			sum(Csh_Advnc_crnt_cycl_Bal) as Cash_adv_tot_bal_curr_cust,
			sum(Tot_Unpaid_Fncl_Chrg) as Tot_Unpaid_Fin_Chrg_cust,

			max(Bns_DAY_DLQNT) as worst_Dlqdays_ks,
			max(Daysover) as worst_Dlqdays_spl,
			max(dlqnt_day) as worst_Dlqdays_mo,

			sum(mo_count) as num_mo_accts_cust,
			sum(spl_count) as num_spl_accts_cust,
			sum(ks_count) as num_ks_accts_cust,

			sum(curr_bal) as tot_cur_bal_cust,
			sum(delq_bal) as tot_delq_bal_cust,
			sum(def_bal) as tot_def_bal_cust,
			sum(chrg_off_bal ) as tot_chg_bal_cust,
			sum(delq_count) as num_delq_accts_cust,
			sum(def_count) as num_def_accts_cust,
			sum(curr_count) as num_cur_accts_cust,
			sum(chrg_off_count) as num_chrg_off_accts_cust,
			sum(ks_bal) as tot_ks_bal_cust,
			sum(spl_bal) as tot_spl_bal_cust,
			sum(mo_bal) as tot_mo_bal_cust

     	from latest_allaccounts
	 	group by 1,2/*,3*/
;
quit;


