proc sql;
	connect to db2 (dsn=DM1DBT);
	create table ACCT_CUST_REL  as select distinct * 
	from connection to db2 
	(SELECT T1.ACCT_ID, 
		  	T1.ACCT_NUM,
			t1.PRIM_CUST_JOIN_ID,
			t1.CIS_PRD_CD, 
			t2.CUST_JOIN_ID, 
          	/*t2.CRNT_F, */
          	t2.PRIM_F,
			t2.EFF_FROM_TMSTMP, 
	    	t3.CUST_ID, 
		    t3.SRC_APP_ID
	FROM EDEDW.ACCT_DIM t1, EDEDW.ACCT_CUST_RLTNP t2, EDEDW.CUST_DIM t3
      WHERE (t1.ACCT_ID = t2.ACCT_ID AND t2.CUST_JOIN_ID = t3.CUST_JOIN_ID) AND 
              t1.CIS_PRD_CD IN ('SCL', 'VLR', 'MOR', 'VGD', 'VCL', 'VAX', 'VZX', 'SSL', 'VIC', 'SPL', 'LOC')
    			AND t2.EFF_FROM_TMSTMP <=&dt_db2. 
				AND t2.EFF_TO_TMSTMP >=&dt_db2.);
DISCONNECT FROM DB2;
QUIT;


/*for each primary customer (CUST_ID), get the others product they hold*/
*need to clean up the relationship table.  Duplicate for CRNT_F and PRIM_F;
PROC SQL;
   CREATE TABLE acct_products AS SELECT distinct
		  t1.EFF_TM_ID, 
          t1.ACCT_ID as ks_acct_id, 
          t1.PRIM_CUST_CID, 
          t1.PRIM_CUST_ID, 
          t2.ACCT_ID AS hd_ACCT_ID, 
          t2.ACCT_NUM as hd_ACCT_NUM,
          t2.PRIM_CUST_JOIN_ID, 
          t2.CIS_PRD_CD, 
          t2.CUST_JOIN_ID, 
          /*t2.CRNT_F, 
          t2.PRIM_F, 
          t2.EFF_FROM_TMSTMP,*/
          t2.CUST_ID, 
          t2.SRC_APP_ID
      FROM KS_DELQ_PRI_CUST t1
           INNER JOIN ACCT_CUST_REL t2 ON (t1.PRIM_CUST_ID = t2.CUST_ID);
QUIT;


*break the previous dataset into 3 parts - one for each product group;
data ks_list spl_list mor_list;
set acct_products;
if CIS_PRD_CD in ('VIC','SCL','VLR','VGD','VCL','LOC','SSL','VAX','VZX','')then output ks_list;
else if CIS_PRD_CD = 'MOR' then output mor_list;
else if CIS_PRD_CD = 'SPL' then output spl_list;
run;


*getting the latest snapshot date for SPL, KS and MOR;

PROC SQL;
   CREATE TABLE latest_SPL AS SELECT 
		  t1.EFF_TM_ID, 
          t1.RISK_ACCT_ID, 
          t1.CAB, 
          t1.LOAN_NUM, 
          t1.ACCT_NUM, 
          t1.DAY_OVERDUE, 
          t1.PRNCPL_BAL_AMT, 
          t1.AD_INTR_AMT, 
		  t1.ACCR_INTR_AMT,
          t1.PROC_TRANSIT, 
          t1.RECD_STAT_Cd
   FROM crdm.PSNL_LOAN_DLY_SNAPSHOT t1
	  where compress(PROC_TRANSIT) not in ('4036','71506','95042','99432') 
		and compress(RECD_STAT_CD) in ('4','7','8') 
		and EFF_TM_ID eq &max_ti_spl.;
QUIT;


PROC SQL;
   CREATE TABLE latest_spl_list AS 
   SELECT t1.EFF_TM_ID, 
          t1.ks_acct_id, 
          t1.PRIM_CUST_CID, 
          t1.PRIM_CUST_ID, 
          t1.hd_ACCT_ID, 
          t1.hd_ACCT_NUM,
		  t2.EFF_TM_ID as hd_EFF_TM_ID,
          t2.DAY_OVERDUE as DAYSOVER, 
          t2.PRNCPL_BAL_AMT  as PRNCPL_BAL, 
          t2.AD_INTR_AMT as AD_BAL, 
          t2.ACCR_INTR_AMT as ACCR_INTR, 
		  t2.PRNCPL_BAL_AMT+ t2.AD_INTR_AMT + t2.ACCR_INTR_AMT as osbal,
          t2.PROC_TRANSIT as BR_LOCTN_TRNST, 
          t2.RECD_STAT_Cd as RECSTAT_CODE, 
          (1) as spl_count,
		  "spl" as product_code
      FROM SPL_LIST t1
		inner join	latest_SPL t2 on (t1.hd_ACCT_NUM = t2.ACCT_NUM) /*(t1.hd_ACCT_ID = t2.ACCT_ID)*/;
QUIT;


data latest_spl_sum; 
set latest_spl_list;

format delq_bal 14.;
format curr_bal 14.;

if recstat_code in (6,7,8) then do; 
status_as = 4; chrg_off_bal = osbal; chrg_off_count=1; end;

else if (daysover > 90 or recstat_code = 5) then do;
status_as =3; def_bal = osbal; def_count=1; end;

else if daysover  >=1 then do;
status_as = 2; delq_bal = osbal; delq_count=1; end;

else do;
status_as = 1; curr_bal = osbal; curr_count=1; end;


delq_bal = sum(delq_bal,def_bal);
delq_count = sum(delq_count,def_count);
spl_bal = osbal;
run;


proc sql;
create table latest_mor as select
	ACCT_ID,
	/*PRIM_CUST_ID,*/
 	Crnt_Bal + Inerest_accr_Amt as osbal,
