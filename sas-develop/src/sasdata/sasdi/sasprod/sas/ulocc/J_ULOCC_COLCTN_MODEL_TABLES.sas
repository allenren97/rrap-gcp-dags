PROC SQL;
   CREATE TABLE LAST_6M_KS_SUM_GR_MTH AS 
   SELECT t1.EFF_TM_ID, 
          t1.ks_acct_id, 
          t1.hd_ACCT_ID, 
          t1.hd_ACCT_NUM, 
          /* MAX_of_delq_count */
            (MAX(t1.delq_count)) AS MAX_of_delq_count, 
          t2.MTH_CLNDR_CD, 
          t2.FNCL_MTH_KEY, 
          /* MIN_of_TM_LVL_END_DT */
            (MIN(t2.TM_LVL_END_DT)) FORMAT=DATE9. AS MIN_of_TM_LVL_END_DT, 
          /* MAX_of_TM_LVL_END_DT */
            (MAX(t2.TM_LVL_END_DT)) FORMAT=DATE9. AS MAX_of_TM_LVL_END_DT
      FROM LAST_6M_KS_SUM t1
           INNER JOIN CRDM.TM_DIM t2 ON (t1.hd_EFF_TM_ID = t2.TM_ID)
      GROUP BY t1.EFF_TM_ID,
               t1.ks_acct_id,
               t1.hd_ACCT_ID,
               t1.hd_ACCT_NUM,
               t2.MTH_CLNDR_CD,
               t2.FNCL_MTH_KEY;
QUIT;

