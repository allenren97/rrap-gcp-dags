quit;

PROC SQL;
   CREATE TABLE LATEST_MOR_LIST AS 
   SELECT t1.EFF_TM_ID,
		  t1.ks_acct_id, 
          t1.PRIM_CUST_CID, 
          t1.PRIM_CUST_ID, 
          t1.hd_ACCT_ID, 
          t1.hd_ACCT_NUM,
