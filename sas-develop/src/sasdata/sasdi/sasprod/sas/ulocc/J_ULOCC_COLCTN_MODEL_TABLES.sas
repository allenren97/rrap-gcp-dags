PROC SQL;
   CREATE TABLE KS_DELQ_PRI_CUST AS SELECT 
		  t1.EFF_TM_ID, 
          t1.ACCT_ID, 
          t1.EFF_DT, 
          t1.ACCT_NUM, 
          t1.PRIM_CUST_CID, 
