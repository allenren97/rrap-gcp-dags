PROC SQL;
   CREATE TABLE ks_delq AS SELECT 
		 *,
         (case when sub_prd_cd  in ('RS') or STEP_IND in ('Y','R')  then 1 else 0 end) AS ind_heloc
      FROM d_cr_tb.ULOC_REVLVNG_CR_DLY_SNAPSHOT t1
      WHERE eff_tm_id eq &dti_lday.
			and t1.PRD_CD IN ('VIC','SCL') 
			AND t1.DLQNT_DAY BETWEEN 30 AND 119 
			AND calculated ind_heloc eq 0 
			AND t1.TOT_NEW_BAL_AMT > 0 AND t1.CR_LMT_AMT > 0 
			AND compress(t1.CHRG_OFF_CD) not in ('1','2','C','N', 'P','Q')  
			AND cats(t1.BLOCK_CD,t1.RECL_CD) not in ('B4','SF','S','SS','XS','SP','B5','D','SR');
QUIT;

