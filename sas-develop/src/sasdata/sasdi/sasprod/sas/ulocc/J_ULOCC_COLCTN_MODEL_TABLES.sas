          t2.MIN_of_BC33_TOT_BAL_TP_BNKCARD, 
          t3.MAX_of_SUM_of_MAX_of_delq_count as MAX_of_num_delq_accts_cust, 
          t4.MAX_of_worst_Dlqdays_ks, 
          t4.num_cur_accts_cust, 
