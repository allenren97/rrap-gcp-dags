PROC SQL;
   CREATE TABLE LAST_6M_CUST_MTH_DELQ_SUM AS 
   SELECT t1.EFF_TM_ID, 
          t1.ks_acct_id, 
          t1.FNCL_MTH_KEY, 
          t1.MTH_CLNDR_CD, 
          /* SUM_of_MAX_of_delq_count */
            (SUM(t1.MAX_of_delq_count)) AS SUM_of_MAX_of_delq_count
      FROM LAST_6M_ALL_SUM_GR_MTH t1
      GROUP BY t1.EFF_TM_ID,
               t1.ks_acct_id,
               t1.FNCL_MTH_KEY,
