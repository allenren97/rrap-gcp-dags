PROC SQL;
   CREATE TABLE CB_VAR_3MOS AS SELECT 
			t1.CUST_CID, 
           (MIN(t1.BC33_TOT_BAL_TP_BNKCARD)) FORMAT=11. AS MIN_of_BC33_TOT_BAL_TP_BNKCARD
      FROM  CB_flag t1
      WHERE t1.flag3m = 1
      GROUP BY CUST_CID;
QUIT;

PROC SQL;
   CREATE TABLE CB_VAR_6MOS as SELECT distinct 
		  t1.CUST_CID,
 		  mth_tm_id ,
          t1.AT34_TOT_UTILZTN, 
          t1.GO11_PC_OF_TRDS_NEVER_DLQNT
      FROM  CB_flag t1
      WHERE t1.flag6m = 1
	  order by CUST_CID, mth_tm_id;
QUIT;


proc sql;
create table CB_VAR_6MOS_temp as select distinct
	CUST_CID, 
    mth_tm_id, 
    AT34_TOT_UTILZTN, 
    GO11_PC_OF_TRDS_NEVER_DLQNT
	,min(mth_tm_id) as min_tm_id		  
	,max(mth_tm_id) as max_tm_id
from CB_VAR_6MOS
group by CUST_CID
having (mth_tm_id=calculated min_tm_id or mth_tm_id=calculated max_tm_id)
order by CUST_CID, mth_tm_id;
quit;


data CB_VAR_6MOS_FINAL;
SET CB_VAR_6MOS_temp;
lag_cust_key=lag(CUST_BASE_KEY);
lag_utl=lag(AT34_TOT_UTILZTN);
lag_trd_delq=lag(GO11_PC_OF_TRDS_NEVER_DLQNT);

AT34slp6m=.;
GO11slp6m=.;


if CUST_BASE_KEY=lag_cust_key and min_tm_id ne max_tm_id and min_tm_id <= &mti_p06me_cb. then do;
	AT34slp6m  =(AT34_TOT_UTILZTN - lag_utl)/5;
end;

if CUST_BASE_KEY=lag_cust_key and min_tm_id ne max_tm_id and min_tm_id <= &mti_p06me_cb. then do;
	GO11slp6m =  (GO11_PC_OF_TRDS_NEVER_DLQNT - lag_trd_delq)/5;
end;


if mth_tm_id= max_tm_id;
run;


