PROC SQL;
   CREATE TABLE CUST_SAV_VAR AS SELECT DISTINCT 
		  t1.CUST_ID, 
          (case when t4.total_d2dbal eq . then 0 else t4.total_d2dbal end) as total_d2dbal, 
		  (case when t3.tot_num_dep  eq . then 0 else t3.tot_num_dep end) as tot_num_dep, 
          (case when t3.tot_amt_dep  eq . then 0 else t3.tot_amt_dep end) as tot_amt_dep, 
		  (case when t2.min_dep_3mos eq . then 0 else t2.min_dep_3mos end) as min_dep_3mos, 
		  (case when t6.tot_num_nsf eq . then 0 else t6.tot_num_nsf end) as tot_num_nsf, 
       	  (case when t6.tot_amt_nsf eq . then 0 else t6.tot_amt_nsf end) as tot_amt_nsf, 
   	      (case when t5.avg_nb_nsf_12mos eq . then 0 else t5.avg_nb_nsf_12mos end) as avg_nb_nsf_12mos
   FROM WORK.CUST_SAV_ACCT t1
   		   inner join sav_acct_bal t7 on (t1.ACCT_ID=t7.ACCT_ID)
           LEFT JOIN WORK.DEP_CUST_VAR t2 ON (t1.CUST_ID = t2.CUST_ID)
           LEFT JOIN WORK.DEP_CUST_VAR_DT_SS t3 ON (t1.CUST_ID = t3.CUST_ID)
           LEFT JOIN WORK.LOC_D2D t4 ON (t1.CUST_ID = t4.CUST_ID)
           LEFT JOIN WORK.NSF_CUST_VAR t5 ON (t1.CUST_ID = t5.CUST_ID)
           LEFT JOIN WORK.NSF_CUST_VAR_DT_SS t6 ON (t1.CUST_ID = t6.CUST_ID);
QUIT;


