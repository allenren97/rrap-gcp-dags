pROC SQL;
   CREATE TABLE CB_flag AS SELECT 
		  *,
          (case when mth_tm_id ge &mti_p03me_cb. then 1 else 0 end) AS flag3m, 
          (case when mth_tm_id ge &mti_p06me_cb. then 1 else 0 end) AS flag6m
