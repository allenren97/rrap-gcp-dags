		  (CASE WHEN GO04_NUM_OF_INQRS IS MISSING OR  GO22_NUM_OF_COLCTN_INQRS IS MISSING THEN . ELSE  GO04_NUM_OF_INQRS - GO22_NUM_OF_COLCTN_INQRS END) AS G4_G22,
          GO11_PC_OF_TRDS_NEVER_DLQNT
