proc sql;
	create table tm_id as select
		tm_id
		,tm_lvl
		,lowcase(substr(tm_lvl,1,1)) as init
		,tm_lvl_end_dt
		,b.dt_period
		,(case when dt_period contains "cb" then "cb"  when dt_period contains "mor" then "mo" else "ks" end) as table
	from crdm.tm_dim a
		inner join trns_dt b on tm_lvl_end_dt = dt_id1
			where tm_lvl in ("Month", "Day")
				and (calculated table eq "ks" and tm_lvl ne "Month" 
				or calculated table eq "cb" and tm_lvl ne "Day" 
				or calculated table eq "mo" and tm_lvl eq "Day")
	order by calculated table, tm_lvl, tm_id;
quit;


