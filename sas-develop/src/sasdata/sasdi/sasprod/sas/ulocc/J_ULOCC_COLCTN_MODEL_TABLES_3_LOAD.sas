proc sql noprint;
   CREATE TABLE dev.CUST_SPOT_VAR AS 
   SELECT t1.ks_acct_id, 
            (MAX(t1.worst_Dlqdays_ks)) AS MAX_of_worst_Dlqdays_ks, 
          t1.num_cur_accts_cust
      FROM dev.latest_loc_forsum t1
      GROUP BY t1.ks_acct_id,
               t1.num_cur_accts_cust;
QUIT;

proc sql noprint;
   CREATE TABLE to_score AS 
   SELECT DISTINCT t1.EFF_TM_ID, 
          t1.EFF_DT, 
          t1.ACCT_ID, 
          t1.ACCT_NUM, 
          t1.PRIM_CUST_ID, 
          t1.PRIM_CUST_CID, 
          t1.CR_LMT_AMT, 
          t1.TOT_NEW_BAL_AMT, 
          (t1.TOT_NEW_BAL_AMT / t1.CR_LMT_AMT) AS util, 
          t1.DLQNT_DAY, 
          t1.OVERLIMIT_F, 
          t1.PRD_CD, 
          t1.SUB_PRD_CD, 
          t1.BLOCK_CD, 
          t1.RECL_CD, 
          t1.STEP_IND, 
          t1.CLS_REASON_CD, 
          t1.ACCT_STAT_CD, 
          t2.AT36_MTH_SINCE_MOST_RECNT_DLQN, 
          t2.GO04_NUM_OF_INQRS, 
          t2.GO22_NUM_OF_COLCTN_INQRS, 
          t2.G4_G22, 
          t2.AT34slp6m, 
          t2.GO11slp6m, 
          t2.MIN_of_BC33_TOT_BAL_TP_BNKCARD, 
          t3.MAX_of_SUM_of_MAX_of_delq_count as MAX_of_num_delq_accts_cust, 
          t4.MAX_of_worst_Dlqdays_ks, 
          t4.num_cur_accts_cust, 
          t5.AVG_of_osbal as AVG_of_tot_osbal_cust, 
          t6.tot_mo_bal_custslp3m, 
          (case when t12.CUST_ID is not missing then 1 else 0 end) AS sav_acct_flag, 
		   /* total_d2dbal */     
		  (case when t12.total_d2dbal is not missing then t12.total_d2dbal
           when t12.total_d2dbal is missing and calculated sav_acct_flag eq 1 then 0 else t12.total_d2dbal end) AS total_d2dbal, 
          /* DEP_AMT */
          (case when t12.tot_amt_dep is not missing then t12.tot_amt_dep
           when t12.tot_amt_dep is missing and calculated sav_acct_flag eq 1 then 0 else t12.tot_amt_dep end) AS tot_amt_dep, 
          /* DEP_AMTmin3m */
          (case when t12.min_dep_3mos is not missing then t12.min_dep_3mos
           when t12.min_dep_3mos is missing and calculated sav_acct_flag eq 1 then 0 else t12.min_dep_3mos end) AS min_dep_3mos, 
          /* NSF_NUMavg12m */
          (case when t12.avg_nb_nsf_12mos is not missing then t12.avg_nb_nsf_12mos
           when t12.avg_nb_nsf_12mos is missing and calculated sav_acct_flag eq 1 then 0 else t12.avg_nb_nsf_12mos end) AS avg_nb_nsf_12mos 
          /*t12.total_d2dbal, 
          t12.tot_num_dep, 
          t12.tot_amt_dep, 
          t12.min_dep_3mos, 
          t12.tot_num_nsf, 
          t12.tot_amt_nsf, 
          t12.avg_nb_nsf_12mos*/
      FROM dev.KS_DELQ_PRI_CUST t1
           LEFT JOIN dev.CB_VAR_ALL t2 ON (t1.PRIM_CUST_CID = t2.CUST_CID)
           inner JOIN dev.LAST_6M_CUST_MAX_DELQ  t3 ON (t1.ACCT_ID = t3.ks_acct_id)
           inner JOIN dev.CUST_SPOT_VAR t4 ON (t1.ACCT_ID = t4.ks_acct_id)
           inner JOIN dev.LAST_3M_CUST_KS_OSBAL_AVG  t5 ON (t1.ACCT_ID = t5.ks_acct_id)
           left JOIN dev.LAST_3M_MOR_SLOPE t6 ON (t1.ACCT_ID = t6.ks_acct_id)
           LEFT JOIN dev.CUST_SAV_VAR t12 ON (t1.PRIM_CUST_ID = t12.CUST_ID);
QUIT;
