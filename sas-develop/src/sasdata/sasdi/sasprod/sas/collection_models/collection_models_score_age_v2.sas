/*Collections models score age report*/
/*create datasets one for each portfolio for the past 70 days*/

PROC SQL NOPRINT;
CONNECT USING DB2PROD AS DBCON;
CREATE TABLE SASCOLL.ULOCC_SCORE_AGE_V2 AS 
SELECT * FROM CONNECTION TO DBCON(
SELECT DISTINCT TM_ID, TM_LVL_END_DT AS DT_SCORED_FOR, DAY_OF_WK_DESC, 
CASE WHEN DAYOFWEEK(TM_LVL_END_DT)=6 THEN TM_LVL_END_DT+3 DAYS 
	 WHEN DAYOFWEEK(TM_LVL_END_DT) IN (1,7) THEN NULL 
	 ELSE TM_LVL_END_DT+1 DAY END AS EXPECTED_SCORING_DT,
DAYNAME(CASE WHEN DAYOFWEEK(TM_LVL_END_DT)=6 THEN TM_LVL_END_DT+3 DAYS 
	 		 WHEN DAYOFWEEK(TM_LVL_END_DT) IN (1,7) THEN NULL 
			 ELSE TM_LVL_END_DT+1 DAY END) AS EXPECTED_SCORING_DAY,
YEAR(CASE WHEN DAYOFWEEK(TM_LVL_END_DT)=6 THEN TM_LVL_END_DT+3 DAYS ELSE TM_LVL_END_DT+1 DAY END)||'W'||WEEK(CASE WHEN DAYOFWEEK(TM_LVL_END_DT)=6 
THEN TM_LVL_END_DT+3 DAYS ELSE TM_LVL_END_DT+1 DAY END) AS YEARWEEK, 
EFF_TM_iD, SCORING_DT AS SCORED_DT, PRIM.INSRT_PROCESS_TMSTMP,  
SCORING_DT-TM_LVL_END_DT AS SCORE_AGE_IN_DAYS
FROM EDRTLRT.TM_DIM 
LEFT OUTER JOIN EDRTLRT.ULOC_COLCTN_MODEL_OUTPUT PRIM ON EFF_TM_iD=TM_ID
WHERE DAYS(TM_LVL_END_DT) >= DAYS(CURRENT_DATE)-70 
AND TM_LVL='Day' AND TM_LVL_END_DT<(CURRENT_DATE)
ORDER BY TM_iD DESC);
DISCONNECT FROM DBCON;
QUIT;

PROC SQL NOPRINT;
CONNECT USING DB2PROD AS DBCON;
CREATE TABLE SASCOLL.ITLC_SCORE_AGE_V2 AS 
SELECT * FROM CONNECTION TO DBCON(
SELECT DISTINCT TM_ID, TM_LVL_END_DT AS DT_SCORED_FOR, DAY_OF_WK_DESC, 
CASE WHEN DAYOFWEEK(TM_LVL_END_DT)=7 THEN TM_LVL_END_DT+2 DAYS 
	 WHEN DAYOFWEEK(TM_LVL_END_DT)=1 THEN NULL
	 ELSE TM_LVL_END_DT+1 DAY END AS EXPECTED_SCORING_DT,
DAYNAME(CASE WHEN DAYOFWEEK(TM_LVL_END_DT)=7 THEN TM_LVL_END_DT+2 DAYS 
	 		 WHEN DAYOFWEEK(TM_LVL_END_DT)=1 THEN NULL 
			 ELSE TM_LVL_END_DT+1 DAY END) AS EXPECTED_SCORING_DAY,
YEAR(CASE WHEN DAYOFWEEK(TM_LVL_END_DT)=7 THEN TM_LVL_END_DT+2 DAYS ELSE TM_LVL_END_DT+1 DAY END)||'W'||WEEK(CASE WHEN DAYOFWEEK(TM_LVL_END_DT)=7 
THEN TM_LVL_END_DT+2 DAYS ELSE TM_LVL_END_DT+1 DAY END) AS YEARWEEK, 
EFF_TM_iD, DATE(SCORING_DT) AS SCORED_DT,
DATE(SCORING_DT)-TM_LVL_END_DT AS SCORE_AGE_IN_DAYS
FROM EDRTLRT.TM_DIM 
LEFT OUTER JOIN EDRTLR.COLCTN_PROBE_DLY_ACCT_OUTPUT ON EFF_TM_iD=TM_ID
WHERE DAYS(TM_LVL_END_DT) >= DAYS(CURRENT_DATE)-70 
AND TM_LVL='Day' AND TM_LVL_END_DT<(CURRENT_DATE)
ORDER BY TM_iD DESC);
DISCONNECT FROM DBCON;
QUIT;


