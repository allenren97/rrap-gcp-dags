/*CREATE THE PRIMARY DATASET WITH ALL CALCULATIONS EXCEPT THE 11 MONTH COUNT*/
PROC SQL;
CREATE TABLE &INPATH.._TEMP_RRAP_2_6_EXTRACT AS 
SELECT ASST_CL_NUM, BCAR_SCHED_NUM, 
SUM(
CASE WHEN PIT_STAT_CD IN ('CUR','DEF') THEN 1 ELSE 0 
END
) AS ACCT_CNT, 
SUM(
CASE WHEN SRC_SYS_CD='SPL' THEN (ADJUSTED_OS_BAL_AMT/*+UNADJUSTED_ADD_ON_BAL_AMT*/)
	 WHEN SRC_SYS_CD IN ('MOR','KS','TNG-MOR') THEN (ADJUSTED_OS_BAL_AMT) 
END 
) AS ADJ_BEFORE_ZERO_NET_OS_BAL_AMT FORMAT 20.8,
SUM(
CASE WHEN SRC_SYS_CD='SPL' THEN 
CASE WHEN ADJUSTED_OS_BAL_AMT/*+UNADJUSTED_ADD_ON_BAL_AMT*/ < 0 THEN 0 ELSE 
ADJUSTED_OS_BAL_AMT /*+UNADJUSTED_ADD_ON_BAL_AMT*/ END
	 WHEN SRC_SYS_CD IN ('MOR','KS','TNG-MOR') THEN 
	 	CASE WHEN ADJUSTED_OS_BAL_AMT < 0 THEN 0 ELSE ADJUSTED_OS_BAL_AMT END 
END
) AS ADJUSTED_AF_ZERO_NET_OS_BAL_AMT FORMAT 20.8,
SUM(
CASE WHEN PIT_STAT_CD = 'DEF' THEN 1 ELSE 0 
END
) AS DEFLTD_ACCT_CNT,
SUM(
CASE WHEN PIT_STAT_CD = 'DEF' THEN
CASE WHEN SRC_SYS_CD='SPL' THEN (ADJUSTED_OS_BAL_AMT /*+UNADJUSTED_ADD_ON_BAL_AMT*/)
	 		WHEN SRC_SYS_CD IN ('MOR','KS','TNG-MOR') THEN (ADJUSTED_OS_BAL_AMT) 
	END 
ELSE 0 END
) AS ADJ_BEFR_ZER_NET_DF_AC_OS_BL_AMT FORMAT 20.8,
SUM(
CASE WHEN PIT_STAT_CD = 'DEF' THEN
	CASE 	WHEN SRC_SYS_CD='SPL' THEN 
CASE WHEN ADJUSTED_OS_BAL_AMT /*+UNADJUSTED_ADD_ON_BAL_AMT*/ < 0 THEN 0 ELSE 
ADJUSTED_OS_BAL_AMT /*+UNADJUSTED_ADD_ON_BAL_AMT*/ END
	 		WHEN SRC_SYS_CD IN ('MOR','KS','TNG-MOR') THEN 
	 			CASE WHEN ADJUSTED_OS_BAL_AMT < 0 THEN 0 ELSE ADJUSTED_OS_BAL_AMT END 
	END
ELSE 0 END
) AS ADJ_AF_ZERO_NET_DF_AC_OS_BAL_AMT FORMAT 20.8
FROM INPATH.BASEL_ANALYTCL_BL_INSTRMNT_FACT 
WHERE SML_BUS_F = 'N' AND CONSM_PRD_TREATMNT_CD ='A' 
AND PIT_STAT_CD IN ('CUR' ,'DEF')
AND TRNST_EXCLSN_F = 'N'
AND MTH_TM_ID=&MTH_TM_ID
GROUP BY ASST_CL_NUM,BCAR_SCHED_NUM;
QUIT;
/*FETCH THE 11 MONTH COUNT USING A PASS THROUGH*/
/*THE PROCESSING MONTH SUBTRACTED BY 11 MONTHS GIVES THE MTH_TM_ID OF THE 
PERIOD 11 MOMTH OLDER THAT PROCESSING MONTH*/
PROC SQL;
CONNECT TO DB2 AS DBCON (DATABASE=&DBNAME authdomain=db2_auth);
CREATE TABLE &INPATH.._TEMP_RRAP_2_6_11MTH_COUNT AS
SELECT * FROM CONNECTION TO DBCON (
SELECT ASST_CL_NUM, BCAR_SCHED_NUM,
COUNT(DISTINCT BASEL_ACCT_ID) AS PREV_12_MTH_TOT_DEFLTD_ACCT_CNT
FROM EDRRAPT.BASEL_ANALYTCL_BL_INSTRMNT_FACT 
WHERE SML_BUS_F = 'N' AND CONSM_PRD_TREATMNT_CD ='A' 
AND PIT_STAT_CD IN ('DEF')
AND TRNST_EXCLSN_F = 'N'
AND MTH_TM_ID BETWEEN (
SELECT TM_ID AS MTH_TM_ID_11MTHS FROM EDRTLRT.TM_DIM WHERE TM_LVL_ST_DT = (
SELECT TM_LVL_ST_DT - 11 MONTHS AS MTH_END_DT_11MTHS FROM EDRTLRT.TM_DIM WHERE 
TM_ID=&MTH_TM_ID
) AND TM_LVL='Month') AND &MTH_TM_ID
GROUP BY ASST_CL_NUM,BCAR_SCHED_NUM;
);
QUIT;
/*SORT THE DATASET*/
PROC SORT DATA=&INPATH.._TEMP_RRAP_2_6_EXTRACT 
OUT=&INPATH.._TEMP_RRAP_2_6_EXTRACT;
BY ASST_CL_NUM BCAR_SCHED_NUM;
RUN;
/*SORT THE DATASET*/
PROC SORT DATA=&INPATH.._TEMP_RRAP_2_6_11MTH_COUNT 
OUT=&INPATH.._TEMP_RRAP_2_6_11MTH_COUNT;
BY ASST_CL_NUM BCAR_SCHED_NUM;
RUN;
/*MERGE THE DATASETS TO INLCUDE THE PRIMARY EXTRACT AND THE 11MTH COUNT */
DATA &INPATH.._TEMP_RRAP_2_6_EXTRACT_F;
MERGE &INPATH.._TEMP_RRAP_2_6_EXTRACT &INPATH.._TEMP_RRAP_2_6_11MTH_COUNT;
BY ASST_CL_NUM BCAR_SCHED_NUM;
RUN;
/*ADD TIMESTAMPS*/
DATA &INPATH.._TEMP_RRAP_2_6_EXTRACT_F;
format mth_tm_id 11.
ASST_CL_NUM 6.
BCAR_SCHED_NUM $3. 
ACCT_CNT 11.
ADJ_BEFORE_ZERO_NET_OS_BAL_AMT	22.8
ADJUSTED_AF_ZERO_NET_OS_BAL_AMT 22.8
DEFLTD_ACCT_CNT 11.
ADJ_BEFR_ZER_NET_DF_AC_OS_BL_AMT 22.8
ADJ_AF_ZERO_NET_DF_AC_OS_BAL_AMT 22.8
PREV_12_MTH_TOT_DEFLTD_ACCT_CNT 6.
INSRT_PROCESS_TMSTMP UPDT_PROCESS_TMSTMP datetime25.6;
SET &INPATH.._TEMP_RRAP_2_6_EXTRACT_F;
MTH_TM_ID=&MTH_TM_ID;
INSRT_PROCESS_TMSTMP = &SESSIONTIME;
UPDT_PROCESS_TMSTMP = &SESSIONTIME;
RUN;

data &INPATH.._TEMP_RRAP_2_6_EXTRACT_F2;
set &INPATH.._TEMP_RRAP_2_6_EXTRACT_F;
where asst_cl_num ne .;
run;
			

/*APPEND THE SAS DATASET TO DB2 TABLE*/
PROC APPEND BASE=EDRRAPT.BASEL_RPTG_SCHED_2_6_FACT 
DATA=INPATH._TEMP_RRAP_2_6_EXTRACT_F2 FORCE;
RUN;


%datalog;

%SAS_DATASET_CLEANUP(LIBREF=INPATH,DATASETS=_TEMP_RRAP_2_6_EXTRACT _TEMP_RRAP_2_6_11MTH_COUNT _TEMP_RRAP_2_6_EXTRACT_F);

