%macro loaddata(table,PD_VAR_P,PD_VAR_1,type,model_name,model_type,prd);
	%PUT &table;
	%PUT &PD_VAR_P;
	%PUT &&PD_VAR_1;

	%IF &model_name EQ "BNS MOR PD" %THEN
		%DO;

			proc sql;
				create table work.&prd._&type as 
					select 
						"BNS PD" as model_name length=20,
						&PD_VAR_P.
					from &table
						where CONSM_PRD_TREATMNT_CD ='A' and SML_BUS_F = 'N' and PIT_STAT_CD='CUR' 
							and TRNST_EXCLSN_F = 'N' and PD_MODEL_NM=&model_name
				;
			quit;

		%END;

	%IF &model_name EQ "BNS MOR LGD-ND" %THEN
		%DO;

			proc sql;
				create table work.&prd._&type as 
					select 
						"BNS LGD-ND" as model_name length=20,
						&PD_VAR_P.
					from &table
						where CONSM_PRD_TREATMNT_CD ='A' and SML_BUS_F = 'N' and PIT_STAT_CD='CUR' 
							and TRNST_EXCLSN_F = 'N' and LGD_MODEL_NM=&model_name and LGD_BASEL_SEG_NUM < 13
				;
			quit;

		%END;

	%IF &model_name EQ "BNS MOR LGD-D" %THEN
		%DO;

			proc sql;
				create table work.&prd._&type as
					select 
						"BNS LGD-D" as model_name length=20,
						&PD_VAR_P.
					from &table
						where CONSM_PRD_TREATMNT_CD ='A' and SML_BUS_F = 'N' and PIT_STAT_CD='DEF' 
							and TRNST_EXCLSN_F = 'N' and LGD_MODEL_NM=&model_name and LGD_BASEL_SEG_NUM < 13
				;
			quit;

		%END;

	DATA WORK.&prd._&type._1;
		LENGTH VAR_NM $40.;
		SET work.&prd._&type;
		&PD_VAR_1;
		call SYMPUT('COUNT',_N_);
	RUN;

	%put WORK.&prd._&type._1 Total is: &COUNT;

	PROC SQL;
		create table WORK.&prd._&type._&model_type as 
			select VAR_NM, &model_name as BASEL_SCORECRD_NM length=40, model_name,points_assigned,
				COUNT(*) AS &type._CNT
			from work.&prd._&type._1 
				group by VAR_NM,BASEL_SCORECRD_NM,model_name, points_assigned 
					order by VAR_NM,BASEL_SCORECRD_NM,model_name, points_assigned 
		;
	quit;

	DATA WORK.&prd._&type._&model_type;
		SET WORK.&prd._&type._&model_type;
		&type._TOTAL = %eval(&COUNT);
		&type._PCT=&type._CNT/&type._TOTAL;
	RUN;

%mend loaddata;

