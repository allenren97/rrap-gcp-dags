	ANTQ.SCORE_MONTH_DEF,
	ANTQ.SCORE_UNEMP_RATIO,
	INST.LGD_ACCT_SCORE,
	INST.CONSM_PRD_TREATMNT_CD,
	INST.SML_BUS_F ,
	INST.PIT_STAT_CD ,
	INST.TRNST_EXCLSN_F,
	INST.LGD_MODEL_NM,
	INST.LGD_BASEL_SEG_NUM
FROM (SELECT INST.*, TM.TM_LVL_END_DT FROM &EDRPLL..BASEL_ANALYTCL_BL_INSTRMNT_FACT INST
			LEFT JOIN
			&EDRTLRP1D..TM_DIM TM
			ON INST.MTH_TM_ID = TM.TM_ID) INST
LEFT JOIN &FRGPLL..BNS_LGD_D_SCORED_SEG_ACCTS_ANTQ ANTQ
      ON
	ANTQ.MORTGAGE_NO = CAST(INST.MORT_NUM AS INTEGER) AND ANTQ.TIME_KEY = INST.TM_LVL_END_DT
WHERE INST.MTH_TM_ID = &current_tm_id
	AND INST.SRC_SYS_CD = 'MOR'
	AND INST.PIT_STAT_CD = 'DEF'
	AND INST.LGD_BASEL_SEG_NUM < 13);
DISCONNECT FROM IIASCON;
QUIT;

