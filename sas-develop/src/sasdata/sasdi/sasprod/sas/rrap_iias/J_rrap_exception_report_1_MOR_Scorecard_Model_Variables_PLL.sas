%macro process(base_table,current_table,result_table);

	PROC SORT DATA=&base_table;
		BY BASEL_SCORECRD_NM VAR_NM model_name points_assigned;
	RUN;

	PROC SORT DATA=&current_table;
		BY BASEL_SCORECRD_NM VAR_NM model_name points_assigned;
	RUN;

	DATA work.MOR_PD_1;
		MERGE WORK.&base_table.(IN=A) work.&current_table.(IN=B);
		BY BASEL_SCORECRD_NM VAR_NM model_name points_assigned;

		IF A OR B THEN
			OUTPUT;

	RUN;

	DATA WORK.&result_table.;
		SET work.MOR_PD_1;
		retain total_si 0;
		BY VAR_NM;

		if first.VAR_NM then
			do;
				total_si=0;
			end;

		si = (CURRENT_pct - BASE_PCT) * log(CURRENT_pct/BASE_PCT);
		total_si = total_si +si;
	run;

	DATA work.a0;
		SET WORK.&result_table.;

		if total_si > &Threshold then
			do;
				output;
			end;
	run;

%mend process;

