PROC SQL;
CONNECT USING NZUSER AS NZCON;
EXECUTE(

CREATE OR REPLACE VIEW PSNL_STATUS_V AS 
SELECT A.BASEL_ACCT_ID, A.MTH_TM_ID, 
A.BASEL_CUST_ID, A.PIT_STATUS_V2 AS PIT_STATUS, A.PROCESS_DT AS PROCESS_DATE, 
A.LOAN_NUM AS LOAN_NO, A.CAB, A.SUB_PORTFL AS SUB_PORTFOLIO, A.COMM_F_V2 AS COMMERCIAL_FLAGV2, 
A.IND_BAL_EXCL, A.IND_HL_EXCL, A.IND_CAB_EXCL, A.IND_24MOS_EXCL, A.MODEL_EXCL_F AS MODEL_EXCL, 
A.TREATMNT_F AS TREATMENT_FLAG, A.CONS_DFT_MTH_CNT AS CONS_MTHS_DEFAULT, A.PRD_ID AS PRODUCT_ID, 
M.TOT_CRNT_BAL_AMT AS PRINCIPAL_BAL, M.ACCR_INTR AS ACCR_INT, M.ADD_ON_BAL_AMT AS ADDON_BAL, 
((M.TOT_CRNT_BAL_AMT + M.ADD_ON_BAL_AMT) + M.ACCR_INTR) AS OS_BAL_AMT, A.OS_BAL_AMT_V2 

FROM 
(&RRAP_DB...BASEL_PSNL_LOAN_ACCT_DRVD_VARS_2 A 
LEFT JOIN 
&RRAP_DB...BASEL_PSNL_LOAN_MTH_SNAPSHOT M 
ON (((A.BASEL_ACCT_ID = M.BASEL_ACCT_ID) AND (A.MTH_TM_ID = M.MTH_TM_ID))))

) BY NZCON; 
