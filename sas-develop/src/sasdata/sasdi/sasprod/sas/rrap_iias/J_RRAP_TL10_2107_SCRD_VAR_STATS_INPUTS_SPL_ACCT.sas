/* Initial Gather of RRAP data for Account Level Scorecard process
* Create numeric purpose code and security code fields for later lookups
* Default subv_flag and sub to 0 as a default.  These fields get updated at the end of this job
*/

proc sql noprint;
connect using nzuser as nzcon;
execute(

         create table  &FRG_DB..SCRD_VAR_STATS_INPUTS_&product._&datatype. as (
         select m.mth_tm_id, 
		          m.basel_acct_id,
				    m.prim_basel_cust_id  basel_cust_id,
                m.CRNT_BR_LOCTN_TRNST  cab,
                m.loan_num  loan_no,

                case when m.day_odue > 0 then 1 else 0 end  ind_delq,
                m.prps_cd  Purpose_Code,
				    to_number(m.prps_cd, '999999999')  Num_Purpose_Code,
				    m.scrty_cd,
				    to_number(m.scrty_cd, '999999999')  num_scrty_cd,

                m.day_odue  daysover,
                m.loan_term  amort,
 
                d.os_bal_amt  os_balance,

                CASE WHEN c.rel_cd_total > 0 THEN 1 ELSE 0 END  ind_joint,

                m.LOAN_TERM - months_between(t.TM_LVL_END_DT, last_day(note_dt))  amort_left,

                m.BOOKED_AMT / nullif((m.MOTOR_VEHCL_VAL + m.LOAN_VAL_OTH),0) LTV_VEH10,

                '0'  SUBV_FLAG,
				    '0'  SUBV,
                
                floor(months_between(t.tm_lvl_end_dt, m.LAST_PYMT_DT))  PE_NUM_OF_MONTHS_SINCE_LAST_PAYM,
                case when m.MOTOR_VEHCL_VAL = 0 then  (m.BOOKED_AMT / nullif(m.LOAN_VAL_OTH,0)) else ( m.BOOKED_AMT / nullif(m.MOTOR_VEHCL_VAL,0)) end  LTV_VEH5,
 
                m.step_pln_snapshot_id,
                NULL  prd,
                NULL  sub_product,
                NULL  prd_id,
                NULL  prd_tp, 
				NULL as product_id
   
         from &RRAP_DB..BASEL_PSNL_LOAN_MTH_SNAPSHOT as m 
         left join &RRAP_DB..BASEL_PSNL_LOAN_ACCT_DRVD_VARS as d
              on m.basel_acct_id=d.basel_acct_id and
                 m.mth_tm_id=d.mth_tm_id 

         left join ( select mth_tm_id, 
                     basel_acct_id, 
                     sum(case when rel_cd in ('COS','COB') then 1 else 0 end)  rel_cd_total
                     from &RRAP_DB..BASEL_CUST_ACCT_RLTNP_SNAPSHOT
                     where PRIM_CUST_F='N' and
                           mth_tm_id between &begin_dt_24_tm and &end_period_tm_key
                     group by mth_tm_id, basel_acct_id) as c
              on m.basel_acct_id=c.basel_acct_id and
                 m.mth_tm_id=c.mth_tm_id 

         left join &RRAP_DB..TM_DIM as t
              on m.MTH_TM_ID=t.tm_id


	     where m.mth_tm_id between &begin_dt_24_tm and &end_period_tm_key and
              m.RECD_STAT_CD in (4,5,6,7,8)
			  ) WITH DATA ORGANIZE BY ROW; 
         ) by nzcon;
 quit;


