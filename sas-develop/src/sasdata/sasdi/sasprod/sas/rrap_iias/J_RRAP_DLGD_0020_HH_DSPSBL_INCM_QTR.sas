%let mth_tm_id=;

proc sql noprint;
	select FNCL_MTH_KEY into :mth_tm_id
	from nzrrap.tm_dim
	where tm_lvl='Day' and tm_lvl_end_dt = "&sysdate9."d;
quit;
/*---- End of User Written Code  ----*/ 

/*---- Start of User Written Code  ----*/ 


proc sql noprint;
	select put(tm_lvl_end_dt,yymmn6.)  into :yyyymm
		from nzrrap.tm_dim
	where tm_lvl='Month' and tm_id = &mth_tm_id.;

	select 
		case when count(*) = 0 then 'Y'
		else 'N' end as initial_load into :initial_load_f
	from nzrrap.HH_DSPSBL_INCM_QTR;
quit;
%put &initial_load_f;

proc import datafile="&rrap_dir./flat_files/rrap/HouseholdDispIncome.csv"
     out=output_csv
     dbms=csv
     replace;
     getnames=yes;
run;

proc sql noprint;
	select min(datepart(ref_date)) as min_date, max(datepart(ref_date)) as max_date into :min_date, :max_date
	from output_csv;
quit;

data QTR_MONTH;
	format REF_DATE QTR_MONTH date9.;
	do REF_DATE =  &min_date. to &max_date.;
	QTR_MONTH=intnx('Month',intnx('QTR',REF_DATE,0,'b'),0,'e');
	y=intnx('Month',REF_DATE,0,'e');
	if y = ref_date then output;
	end;
	drop y;
	rename REF_DATE = RDATE;
run;

%put &min_date. &max_date;

data household_income(keep=REF_DATE HH_DSPSBL_INCM_MILLNTH_AMT MTH_TM_ID );
	if _n_=1 then do;
		declare hash h0(dataset: "NZRRAP.TM_DIM(keep=TM_LVL_END_DT TM_ID TM_LVL where=(TM_LVL='Month')"); 
		h0.defineKey("TM_LVL_END_DT");
		h0.defineData("TM_ID");
		h0.defineDone();

		call missing (TM_LVL_END_DT, TM_ID, QTR_MONTH, RDATE); 
	end;  

	set output_csv(keep=REF_DATE VALUE);
	format  REF_DATE date9. HH_DSPSBL_INCM_MILLNTH_AMT comma20.2;
	REF_DATE=intnx('QTR',datepart(REF_DATE),0,'e');

	rc=h0.find(key:REF_DATE); 
	
	rename TM_ID = MTH_TM_ID VALUE=HH_DSPSBL_INCM_MILLNTH_AMT;
run;
proc sort nodupkey; by mth_tm_id; run;

data existing;
set NZRRAP.HH_DSPSBL_INCM_QTR (drop=INSRT_PROCESS_TMSTMP UPDT_PROCESS_TMSTMP);
	where "&yyyymm." GE EFF_FROM_YR_MTH and  "&yyyymm." LT  EFF_TO_YR_MTH;
run;
proc sort data=existing; by MTH_TM_ID; run;


data newfile;
	set household_income;
	keep MTH_TM_ID HH_DSPSBL_INCM_MILLNTH_AMT;
run;

data keep;
	merge newfile(in=new) existing(in=exist);
	by MTH_TM_ID;
	if exist and not new;
	KEEP=1;
run;

data existing;
	merge existing keep;
	by mth_tm_id;
run;

%macro new_close_stay();

data new close stay;
	merge newfile(in=new) existing(in=exist);
	by MTH_TM_ID HH_DSPSBL_INCM_MILLNTH_AMT;
	if new and not exist then do;
		%if &initial_load_f EQ Y %then %do;
			EFF_FROM_YR_MTH = '200001';
		%end;
		%else %do;
			EFF_FROM_YR_MTH = "&yyyymm.";
		%end;
		EFF_TO_YR_MTH = '999912';
		INSRT_PROCESS_TMSTMP = "&SYSDATE9.:&SYSTIME"dt;
		UPDT_PROCESS_TMSTMP = "&SYSDATE9.:&SYSTIME"dt;
		CRNT_F = 'Y';
		output new;
	end;
 
	if exist and not new then do;
		if KEEP NE 1 then do;
			EFF_TO_YR_MTH = "&yyyymm.";
			CRNT_F = 'N';
			output close;
		end;
	end;

	if exist and new then output stay;
	if exist and not new and keep=1 then output stay;
run;
%mend new_close_stay;
%new_close_stay;



proc sql;
update NZRRAP.HH_DSPSBL_INCM_QTR AA

     set EFF_TO_YR_MTH = (
        select EFF_TO_YR_MTH
           from close
           where MTH_TM_ID =  AA.MTH_TM_ID
           and HH_DSPSBL_INCM_MILLNTH_AMT = AA.HH_DSPSBL_INCM_MILLNTH_AMT)
     where exists ( select 1
           from close
           where MTH_TM_ID =  AA.MTH_TM_ID
           and HH_DSPSBL_INCM_MILLNTH_AMT = AA.HH_DSPSBL_INCM_MILLNTH_AMT);

update NZRRAP.HH_DSPSBL_INCM_QTR AA
     set CRNT_F = 'N'
     where exists ( select 1
           from close
           where MTH_TM_ID =  AA.MTH_TM_ID
           and HH_DSPSBL_INCM_MILLNTH_AMT = AA.HH_DSPSBL_INCM_MILLNTH_AMT);

update NZRRAP.HH_DSPSBL_INCM_QTR AA
     set UPDT_PROCESS_TMSTMP = "&SYSDATE9.:&SYSTIME"dt
     where exists ( select 1
           from close
           where MTH_TM_ID =  AA.MTH_TM_ID
           and HH_DSPSBL_INCM_MILLNTH_AMT = AA.HH_DSPSBL_INCM_MILLNTH_AMT);
quit;  
  

