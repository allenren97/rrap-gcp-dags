data population(keep=REF_DATE CANDN_POPN_THSNDTH_VAL MTH_TM_ID);
	if _n_=1 then do;
		declare hash h0(dataset: "NZRRAP.TM_DIM(keep=TM_LVL_END_DT TM_ID TM_LVL where=(TM_LVL='Month')"); 
		h0.defineKey("TM_LVL_END_DT");
		h0.defineData("TM_ID");
		h0.defineDone();
		call missing (TM_LVL_END_DT, TM_ID); 
	end;  

	set output_csv(keep=REF_DATE VALUE);
	format REF_DATE date9. VALUE comma20.2;
	REF_DATE=intnx('Month',datepart(REF_DATE),0,'e');

	rc=h0.find(key:REF_DATE);
	rename TM_ID = MTH_TM_ID VALUE=CANDN_POPN_THSNDTH_VAL;
run;
