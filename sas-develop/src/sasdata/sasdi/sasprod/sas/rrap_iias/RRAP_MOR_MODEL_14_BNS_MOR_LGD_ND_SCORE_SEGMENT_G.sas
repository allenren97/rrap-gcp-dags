%MACRO ANTQ_FETCH_DATES;

/* Sudhir --> where TIME_KEY = '31MAY2019'D */

PROC SQL NOPRINT;
SELECT MAX(TIME_KEY) FORMAT 8. INTO :TGT_TIME_KEY FROM NZUSER.BNS_LGD_ND_SCORED_SEG_ACCTS_ANTQ; /*where TIME_KEY = '30APR2019'D*/
SELECT MAX(TIME_KEY) FORMAT 8. INTO :SRC_TIME_KEY FROM RESULTS.BNS_LGD_ND_SCORED_SEG_ACCTS;	/*where TIME_KEY = '31MAY2019'D*/
SELECT INTNX('MONTH',MAX(TIME_KEY),-36,'E') FORMAT YYMMDD10. INTO :TIME_KEY_36MTH FROM RESULTS.BNS_LGD_ND_SCORED_SEG_ACCTS;  /*where TIME_KEY = '31MAY2019'D*/
SELECT INTNX('MONTH',MAX(TIME_KEY),-36,'E') INTO :DEL_TIME_KEY FROM RESULTS.BNS_LGD_ND_SCORED_SEG_ACCTS;   /*where TIME_KEY = '31MAY2019'D*/
QUIT;

DATA NZFORMATS;
FORMAT NZSRC NZTGT YYMMDD10.;
NZFORMAT="'"||"&TIME_KEY_36MTH"||"'";
CALL SYMPUT('PRIOR36MTH',NZFORMAT);
NZSRC=&SRC_TIME_KEY;
NZTGT=&TGT_TIME_KEY;
CALL SYMPUT('SRC_TIME_NZ',"'"||PUT(&SRC_TIME_KEY,YYMMDD10.)||"'");
CALL SYMPUT('TGT_TIME_NZ',"'"||PUT(&TGT_TIME_KEY,YYMMDD10.)||"'");
RUN;

%PUT SRC_TIME_KEY=&SRC_TIME_KEY;
%PUT TGT_TIME_KEY=&TGT_TIME_KEY;
%PUT TIME_KEY_36MTH=&TIME_KEY_36MTH;
%PUT DEL_TIME_KEY=&DEL_TIME_KEY;
%PUT PRIOR36MTH=&PRIOR36MTH;
%PUT SRC_TIME_NZ=&SRC_TIME_NZ;
%PUT TGT_TIME_NZ=&TGT_TIME_NZ;

%MEND ANTQ_FETCH_DATES;


