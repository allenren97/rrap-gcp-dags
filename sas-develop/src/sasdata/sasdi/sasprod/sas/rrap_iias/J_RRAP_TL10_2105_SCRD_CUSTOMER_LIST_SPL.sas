/* Extract the distinct Mortgage customers */
proc sql noprint;
connect using NZRRAP as nzcon;
create table work.mortgage_customers as
select * from connection to nzcon (
   select distinct m.prim_basel_cust_id as basel_cust_id
   from &RRAP_DB..BASEL_MORT_MTH_SNAPSHOT as m,
        &RRAP_DB..BASEL_MORT_ACCT_DRVD_VARS as d
   where (m.mth_tm_id between &start_period_tm_key and &end_period_tm_key) and
         m.basel_acct_id=d.basel_acct_id and
         m.mth_tm_id=d.mth_tm_id and
         m.prim_basel_cust_id is not null and m.prim_basel_cust_id <> -1 and
	      m.CRNT_BAL_AMT <> 0 and
         m.PD_OFF_F ='N' and
         upper(d.COMM_TP_CD)='RESIDENTIAL');
quit;


 
/* Extract the distinct SPL customers */
proc sql noprint;
connect using NZRRAP as nzcon;
create table work.personal_loans_customers as
select * from connection to nzcon (
   select distinct m.prim_basel_cust_id as basel_cust_id
   from &RRAP_DB..BASEL_PSNL_LOAN_MTH_SNAPSHOT as m
   where (m.mth_tm_id between &start_period_tm_key and &end_period_tm_key) and 
          m.prim_basel_cust_id is not null and m.prim_basel_cust_id <> -1 and
	       m.RECD_STAT_CD in (4,5,6,7,8));
quit;


 
/* Extract the distinct Revolving Credit customers */
proc sql noprint;
connect using NZRRAP as nzcon;
create table work.revolving_credit_customers as
select * from connection to nzcon (
   select distinct m.prim_basel_cust_id as basel_cust_id
   from &RRAP_DB..BASEL_REVLVNG_CR_MTH_SNAPSHOT as m
   where (m.mth_tm_id between &start_period_tm_key and &end_period_tm_key) and
          m.prim_basel_cust_id is not null and m.prim_basel_cust_id <> -1 and
	      (m.TOT_NEW_BAL_AMT > 0 or m.CR_LMT_AMT > 0) and
          m.PRD_CD not in ('BLV') and
          m.SUB_PRD_CD not in ('CC') and 
          m.PRD_CD in ('VIC','SCL','VLR','VGD','VCL','LOC','SSL',''));
quit;


/* Gather all customers */
data all_customers;
set work.revolving_credit_customers work.mortgage_customers work.personal_loans_customers;
run;

/* Delete duplicate customer records */
proc sort data=all_customers nodupkey;
by basel_cust_id ;
run;



