);
set NZRRAP.temp1_c;
RETAIN 
MTH_TM_ID BASEL_ACCT_ID BASEL_PRIM_CUST_ID ACCT_NUM APRSD_VAL_TERANET_INDEXED_AMT CONS_DFT_MTH_CNT 
DLQNT_CYCL_CD DLQNT_PREV_12_MTH_CNT INACT_12_MTH_F LTV_TP_CD LOAN_TO_VAL_WITHOUT_INDEX_RTO 
LOAN_TO_VAL_WITH_TERANET_INDEX_R MTH_SINCE_LAST_PYMT_CNT OS_BAL_AMT OV_LMT_F PAST_12_MTH_MAX_UTLTN_RTO PREV_12_MTH_DLQNT_F
TERANET_HOUSE_APRSD_DT_INDEX TERANET_HOUSE_INDEX UTLTN_RTO TRNST_NUM HELOC_PRD_TP THPI_BYLBL_DFT_APSDT  
INSRT_PROCESS_TMSTMP UPDT_PROCESS_TMSTMP;

format
MTH_TM_ID 10. BASEL_ACCT_ID 19. BASEL_PRIM_CUST_ID 19. ACCT_NUM $50. THPI_BYLBL_DFT_APSDT 8.4
APRSD_VAL_TERANET_INDEXED_AMT 17.3 v_T_IDX_BY_TM_ID 8.4 v_T_IDX_BY_APRSD_TM_ID 8.4 v_APSD_VAL_TNT_IDX_AMT 17.3
TERANET_HOUSE_APRSD_DT_INDEX 8.4 OV_LMT_F $1. TRNST_NUM $5.
TERANET_HOUSE_INDEX 8.4 DLQNT_PREV_12_MTH_CNT 5. INACT_12_MTH_F $1. DLQNT_CYCL_CD $10. PREV_12_MTH_DLQNT_F $1.
CONS_DFT_MTH_CNT 5.  LTV_TP_CD $10. OS_BAL_AMT 17.3 PAST_12_MTH_MAX_UTLTN_RTO 11.4 LOAN_TO_VAL_WITH_TERANET_INDEX_R 11.4
LOAN_TO_VAL_WITHOUT_INDEX_RTO 11.4 UTLTN_RTO 11.4 HELOC_PRD_TP $10. MTH_SINCE_LAST_PYMT_CNT 10.
v_T_IDX_APRD_ID_chkd 8.4 v_TIDX_APRSD_TMID_PROV 11.4 HIR 11.4 THPI_BYDT_CURDT 8.4 LOCTN_LABEL_1 $20. 
LOCTN_LABEL_2 $20. THPI_LBL_CURDT_APSDT 8.4 v_T_IDX_BY_TM_ID_Chk 8.4 v_T_IDX_BY_TM_ID_PROV 11.4 THPI_DFT 8.4
v_LN_TO_VAL_WTH_TNET_IDX_RTO 17.4 
INSRT_PROCESS_TMSTMP datetime25.6 UPDT_PROCESS_TMSTMP datetime25.6
  
v_TOTAL_OS_AMT_MO_SPL_KS 17.3 APRSD_VAL 17.3 v_LOAN_TO_VAL_WITHOUT_INDEX_RTO 17.4
v_MORT_OS_BAL_AMT 17.3
v_SPL_OS_BAL_AMT 17.3
v_VISA_LOC_OS_BAL_AMT 17.3
TOT_NEW_BAL_AMT 17.3
v_RVLVNG_CR_OS_BAL_AMT 17.3
v_RVLVNG_CR_OS_BAL_AMT_src v
v_SPL_OS_BAL_AMT 17.3
v_SPL_OS_BAL_AMT_src 17.3
v_MORT_OS_BAL_AMT_src 17.3
v_MORT_OS_BAL_AMT 17.3;
INSRT_PROCESS_TMSTMP="&SYSDATE9.:&SYSTIME."dt;
UPDT_PROCESS_TMSTMP ="&SYSDATE9.:&SYSTIME."dt;

/*v_T_IDX_APRD_ID_chkd*/
if ((THPIBYDTAPRSD_IDX EQ . OR THPIBYDTAPRSD_IDX EQ '') AND NOT (APRSD_TM_ID eq . OR APRSD_TM_ID eq ''))then do ; 
	v_T_IDX_APRD_ID_chkd=THPI_CURDT_APSDT_IDX; end;
else if ((THPIBYDTAPRSD_IDX EQ . OR THPIBYDTAPRSD_IDX EQ '') AND (APRSD_TM_ID eq . OR APRSD_TM_ID eq '')) THEN do;  v_T_IDX_APRD_ID_chkd= .; end;
else do; v_T_IDX_APRD_ID_chkd=THPIBYDTAPRSD_IDX; end;

/*v_TIDX_APRSD_TMID_PROV*/
IF ((v_T_IDX_APRD_ID_chkd EQ . or v_T_IDX_APRD_ID_chkd EQ '')  AND NOT (APRSD_TM_ID eq . OR APRSD_TM_ID eq '')) THEN DO; 
	v_TIDX_APRSD_TMID_PROV=HIR;END;
ELSE IF (v_T_IDX_APRD_ID_chkd EQ . or v_T_IDX_APRD_ID_chkd EQ '') AND (APRSD_TM_ID eq . OR APRSD_TM_ID eq '') THEN DO;
	v_TIDX_APRSD_TMID_PROV=.;END;
ELSE DO;v_TIDX_APRSD_TMID_PROV=v_T_IDX_APRD_ID_chkd;END;

/*v_T_IDX_BY_APRSD_TM_ID*/
IF ((v_TIDX_APRSD_TMID_PROV EQ . OR v_TIDX_APRSD_TMID_PROV EQ '')  AND NOT (APRSD_TM_ID eq . OR APRSD_TM_ID eq '')) THEN DO;
	v_T_IDX_BY_APRSD_TM_ID=THPI_BYLBL_DFT_APSDT;END;
ELSE IF ((v_TIDX_APRSD_TMID_PROV EQ . OR v_TIDX_APRSD_TMID_PROV EQ '')  AND (APRSD_TM_ID eq . OR APRSD_TM_ID eq '')) THEN DO;
		v_T_IDX_BY_APRSD_TM_ID=.;END;
ELSE DO; v_T_IDX_BY_APRSD_TM_ID=v_TIDX_APRSD_TMID_PROV;END;

TERANET_HOUSE_APRSD_DT_INDEX=ROUND(v_T_IDX_BY_APRSD_TM_ID,.0001);

/*v_T_IDX_BY_TM_ID_Chk*/
IF ((THPI_BYDT_CURDT EQ . or THPI_BYDT_CURDT eq '') AND NOT (LOCTN_LABEL_1 eq '') AND NOT (LOCTN_LABEL_2 eq '') ) THEN DO;
	v_T_IDX_BY_TM_ID_Chk=THPI_LBL_CURDT_APSDT;END;
ELSE DO; v_T_IDX_BY_TM_ID_Chk=THPI_BYDT_CURDT;END;

/*v_T_IDX_BY_TM_ID_PROV*/
IF (v_T_IDX_BY_TM_ID_Chk EQ '' or v_T_IDX_BY_TM_ID_Chk EQ .) THEN DO; v_T_IDX_BY_TM_ID_PROV=HIR_PROV; END;
ELSE DO; v_T_IDX_BY_TM_ID_PROV=v_T_IDX_BY_TM_ID_Chk; END;

/*v_T_IDX_BY_TM_ID*/
IF (v_T_IDX_BY_TM_ID_PROV EQ '' OR v_T_IDX_BY_TM_ID_PROV EQ .) THEN DO; 
	v_T_IDX_BY_TM_ID=THPI_DFT;end;
ELSE DO; v_T_IDX_BY_TM_ID=v_T_IDX_BY_TM_ID_PROV; END;

TERANET_HOUSE_INDEX=v_T_IDX_BY_TM_ID;

/*v_APSD_VAL_TNT_IDX_AMT*/
IF( (APRSD_TM_ID eq . OR APRSD_TM_ID eq '') OR (APRSD_VAL eq . OR APRSD_VAL eq '') ) THEN DO;
 	v_APSD_VAL_TNT_IDX_AMT=.;END;
ELSE IF (v_T_IDX_BY_APRSD_TM_ID EQ '' OR v_T_IDX_BY_APRSD_TM_ID = . OR v_T_IDX_BY_APRSD_TM_ID=0) THEN DO;
	v_APSD_VAL_TNT_IDX_AMT=.;END;
ELSE DO; v_APSD_VAL_TNT_IDX_AMT=ROUND(((APRSD_VAL * v_T_IDX_BY_TM_ID) / v_T_IDX_BY_APRSD_TM_ID),.001) ; END;

APRSD_VAL_TERANET_INDEXED_AMT=v_APSD_VAL_TNT_IDX_AMT;
DLQNT_PREV_12_MTH_CNT=DLQNT_PREV_12_MTH_CNT1;

/*INACT_12_MTH_F*/
IF ( TRIM(PIT_STAT_VER_2_CD)='CUR' AND (i_MAX_TOT_NEW_BAL_AMT-i_MIN_TOT_NEW_BAL_AMT=0 AND i_CNT_TOT_NEW_BAL_AMT=12))
	THEN DO; INACT_12_MTH_F='Y'; END;
ELSE DO; INACT_12_MTH_F='N';END;

/*DLQNT_CYCL_CD */
IF ACCRL_STAT_F EQ 'N' THEN DO;
	DLQNT_CYCL_CD='E';END;
ELSE IF (ACCRL_STAT_F EQ '' OR ACCRL_STAT_F NE 'N') THEN DO;
	DLQNT_CYCL_CD=DLQNT_CYCL_CD1;END;
ELSE DO; DLQNT_CYCL_CD='';END;


/*PREV_12_MTH_DLQNT_F*/
IF  DLQNT_PREV_12_MTH_CNT1 EQ 0 THEN DO; PREV_12_MTH_DLQNT_F='N';END;
ELSE DO; PREV_12_MTH_DLQNT_F='Y';END;
	
OS_BAL_AMT=TOT_NEW_BAL_AMT;

/*v_MORT_OS_BAL_AMT*/
IF(v_MORT_OS_BAL_AMT_src EQ .) THEN DO;
	v_MORT_OS_BAL_AMT=0;END;
ELSE DO; v_MORT_OS_BAL_AMT=v_MORT_OS_BAL_AMT_src;END;

/*v_SPL_OS_BAL_AMT*/
IF(v_SPL_OS_BAL_AMT_src EQ '' OR v_SPL_OS_BAL_AMT_src EQ .) THEN DO;
	v_SPL_OS_BAL_AMT=0;END;
ELSE DO; v_SPL_OS_BAL_AMT=v_SPL_OS_BAL_AMT_src;END;

/*v_RVLVNG_CR_OS_BAL_AMT*/
IF(v_RVLVNG_CR_OS_BAL_AMT_src EQ '' OR v_RVLVNG_CR_OS_BAL_AMT_src EQ .) THEN DO;
	v_RVLVNG_CR_OS_BAL_AMT=0;END;
ELSE DO; v_RVLVNG_CR_OS_BAL_AMT=v_RVLVNG_CR_OS_BAL_AMT_src;END;

/*v_VISA_LOC_OS_BAL_AMT*/

IF TRIM(LTV_TP_CD) EQ 'LOC' THEN DO; v_VISA_LOC_OS_BAL_AMT=TOT_NEW_BAL_AMT; END;
ELSE IF TRIM(LTV_TP_CD) EQ 'VISA' THEN DO; v_VISA_LOC_OS_BAL_AMT=(TOT_NEW_BAL_AMT+v_RVLVNG_CR_OS_BAL_AMT);END;
ELSE DO;v_VISA_LOC_OS_BAL_AMT=0; END;

v_TOTAL_OS_AMT_MO_SPL_KS=v_MORT_OS_BAL_AMT+v_SPL_OS_BAL_AMT+v_VISA_LOC_OS_BAL_AMT;

/*v_LN_TO_VAL_WTH_TNET_IDX_RTO*/
IF (APRSD_VAL_TERANET_INDEXED_AMT EQ '' OR APRSD_VAL_TERANET_INDEXED_AMT EQ .) THEN DO;
	v_LN_TO_VAL_WTH_TNET_IDX_RTO=.; END; /* update 0 with . value by vk 18MAR2022*/

	/* newly added to address 0 value 18MAR2022*/
IF APRSD_VAL_TERANET_INDEXED_AMT = 0 then do;
v_LN_TO_VAL_WTH_TNET_IDX_RTO=0; END;
ELSE DO; v_LN_TO_VAL_WTH_TNET_IDX_RTO=ROUND((v_TOTAL_OS_AMT_MO_SPL_KS/APRSD_VAL_TERANET_INDEXED_AMT),.0001);END;

/*v_LOAN_TO_VAL_WITHOUT_INDEX_RTO*/
IF APRSD_VAL EQ '' OR APRSD_VAL EQ . THEN DO; v_LOAN_TO_VAL_WITHOUT_INDEX_RTO=.; /* updated 0 with . value by vk 18MAR2022 */ END;
IF APRSD_VAL = 0 then do; v_LOAN_TO_VAL_WITHOUT_INDEX_RTO = 0; end;/* newly added to address 0 value by vk on 18MAR2022*/
ELSE DO;v_LOAN_TO_VAL_WITHOUT_INDEX_RTO=ROUND((v_TOTAL_OS_AMT_MO_SPL_KS/APRSD_VAL),.0001); END;

/*LOAN_TO_VAL_WITH_TERANET_INDEX_R*/
IF (v_LN_TO_VAL_WTH_TNET_IDX_RTO EQ '' OR v_LN_TO_VAL_WTH_TNET_IDX_RTO EQ .) THEN DO; 
	LOAN_TO_VAL_WITH_TERANET_INDEX_R=.; END; /* update 0 with . value by vk 18MAR2022*/
ELSE DO; LOAN_TO_VAL_WITH_TERANET_INDEX_R=v_LN_TO_VAL_WTH_TNET_IDX_RTO; END;

/*LOAN_TO_VAL_WITHOUT_INDEX_RTO*/
IF (v_LOAN_TO_VAL_WITHOUT_INDEX_RTO EQ '' OR v_LOAN_TO_VAL_WITHOUT_INDEX_RTO EQ .) THEN DO; 
	LOAN_TO_VAL_WITHOUT_INDEX_RTO=.; END; /* updated 0 with . value by vk 18MAR2022*/
ELSE DO; LOAN_TO_VAL_WITHOUT_INDEX_RTO=v_LOAN_TO_VAL_WITHOUT_INDEX_RTO; END;


IF PRD_CD='VIC' THEN DO; HELOC_PRD_TP= 'CC';END;
ELSE DO; HELOC_PRD_TP= BASEL_PRD_CD; END;

/* added by vk for metric CONS_DFT_MTH_CNT */
/*v_CONS_DFT_MTH_CNT_CHEK_NULL*/
IF STRIP(PIT_STAT_VER_2_CD) NOT IN ('DEF','CHG') OR  PIT_STAT_VER_2_CD = '' /*OR PIT_STAT_VER_2_CD '' */
THEN v_CONS_DFT_MTH_CNT_CHEK_NULL = '';
ELSE v_CONS_DFT_MTH_CNT_CHEK_NULL = PIT_STAT_VER_2_CD;


/*v_CONS_DFT_MTH_CNT_lkp*/
IF(v_CONS_DFT_MTH_CNT_CHEK_NULL = '') 
THEN v_CONS_DFT_MTH_CNT_lkp = -999;
ELSE v_CONS_DFT_MTH_CNT_lkp = CONS_DFT_MTH_CNT;


/*CONS_DFT_MTH_CNT*/
IF v_CONS_DFT_MTH_CNT_lkp = -999 THEN DO CONS_DFT_MTH_CNT = .;END;
ELSE IF v_CONS_DFT_MTH_CNT_lkp = . AND MAX_NON_DFT_TM_ID NE . THEN DO CONS_DFT_MTH_CNT = 0;END;
ELSE IF (v_CONS_DFT_MTH_CNT_lkp = . OR v_CONS_DFT_MTH_CNT_lkp = 0)  AND MAX_NON_DFT_TM_ID = . THEN DO CONS_DFT_MTH_CNT = 24; END;
ELSE DO CONS_DFT_MTH_CNT = v_CONS_DFT_MTH_CNT_lkp; END;
/*MTH_SINCE_LAST_PYMT_CNT*/ /* removed from &net_db..temp1 and added here by VK 21MAR2022 */
MTH_SINCE_LAST_PYMT_CNT = intck("month",LAST_PYMT_DT,"&MTH_END_DT."d); 
run;






