LOAN_TO_VAL_WITH_TERANET_INDEX_R 
MTH_SINCE_LAST_PYMT_CNT OS_BAL_AMT OV_LMT_F PAST_12_MTH_MAX_UTLTN_RTO PREV_12_MTH_DLQNT_F
TERANET_HOUSE_APRSD_DT_INDEX TERANET_HOUSE_INDEX UTLTN_RTO TRNST_NUM HELOC_PRD_TP   
