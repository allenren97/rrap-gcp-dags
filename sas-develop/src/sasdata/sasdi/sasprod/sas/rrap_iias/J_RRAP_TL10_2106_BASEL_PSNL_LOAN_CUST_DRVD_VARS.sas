/**************** Start of Basic Derivations Section   **********************/
/******** Result of Two Step Derivations are included in this join **********/
/***** Target Table is stored in FRG User space.  RRAP Load is in the next node ********/

%delete_table(nzuser.BASEL_PSNL_LOAN_CUST_DRVD_VARS);

 
proc sql noprint;
connect using nzuser as nzcon;
execute(

         create table &FRG_DB..BASEL_PSNL_LOAN_CUST_DRVD_VARS as (
         select l.basel_cust_id, 
 		        
                b.MTH_TM_ID,
                (d.INQRY_CNT - d.COLCTN_INQR_CNT) as GO05,
               
                case when (
	                coalesce(d.BNKRPY_CNT, 0) +  
		             coalesce(d.COLCTN_CNT, 0) + 
		             coalesce(d.NOT_SUFFICENT_FUNDS_CHQ_CNT, 0)  + 
		             coalesce(d.DERGTRY_PUB_RECD_CNT, 0)  + 
		             coalesce(d.LEGAL_CNT, 0)
		             )
                   >= 1 THEN 1 ELSE 0 END as BAD_PAYER_IND,

                p.D2D_BAL_AMT as CUST25,

                t.TOT_DEP_AMT as CUST32,
               
                r.CUST24,

                b.CUST_19,
                b.CUST13,
                b.CUST16,
                b.CUST18,
                b.CUST21,
                b.CUST22
 
         
           from &FRG_DB..SCRD_CUSTOMER_LIST_&product as l inner join
                &FRG_DB..SCRD_DERIVED_INPUTS_SPL_CUST as b
		   on l.basel_cust_id=b.prim_basel_cust_id
             

		   left join &RRAP_DB..BASEL_TL_CUST_MTH_POSTN_SUM as p
		   on b.prim_basel_cust_id=p.basel_cust_id and
            b.mth_tm_id=p.mth_tm_id
		   
		   left join &RRAP_DB..BASEL_TL_CUST_MTH_DEP_TXN_SUM as t
		   on b.prim_basel_cust_id=t.basel_cust_id and
            b.mth_tm_id=t.mth_tm_id

         left join &RRAP_DB..CR_BUREAU_DELI_MTH_SNAPSHOT as d
		   on   b.prim_basel_cust_id=d.basel_cust_id and 
			     b.mth_tm_id=d.mth_tm_id and 
              d.basel_cust_id <> -1

         left join 
         (
            select mth_tm_id, 
                   basel_cust_id, 
                   trunc((sum_tot_new_bal_amt / sum_cr_lmt_amt), 4) as cust24
            from (
                    select a.mth_tm_id, 
                           a.basel_cust_id, 
                           sum(TOT_NEW_BAL_AMT) as sum_tot_new_bal_amt, 
                           sum(CR_LMT_AMT) as sum_cr_lmt_amt
                    from  &RRAP_DB..BASEL_CUST_ACCT_RLTNP_SNAPSHOT as a
                    inner join &RRAP_DB..BASEL_REVLVNG_CR_MTH_SNAPSHOT as b
                    on a.BASEL_ACCT_ID=b.basel_acct_id and 
	                    a.MTH_TM_ID=b.mth_tm_id
                    inner join &RRAP_DB..BASEL_REVLVNG_CR_BASE_DRVD_VARS c
                    on c.basel_acct_id=b.basel_acct_id and 
	                    c.mth_tm_id=b.mth_tm_id
                    where a.mth_tm_id between &begin_dt_24_tm and &end_period_tm_key and 
	                      (b.TOT_NEW_BAL_AMT > 0 or b.CR_LMT_AMT > 0) and 
		                    b.prd_cd <> 'BLV' and 
		                    b.SUB_PRD_CD not in ('CC') and 
		                    b.PRD_CD in ('VIC','SCL','VLR','VGD','VCL','LOC','SSL','')
                    group by a.mth_tm_id, a.basel_cust_id) as s
              where sum_cr_lmt_amt > 0
              order by mth_tm_id, basel_cust_id

         )   as r
         on b.prim_basel_cust_id=r.basel_cust_id and
            b.mth_tm_id=r.mth_tm_id

		   where b.mth_tm_id between &begin_dt_24_tm and &end_period_tm_key
             ) WITH DATA;  
 
         ) by nzcon;
 quit;


