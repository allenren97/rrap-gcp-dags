%macro delete_previously_loaded_data;
        /*---------------------------------------------
        * Checks to see if the date is in NZ table 
        *---------------------------------------------*/

       proc sql noprint;
          select count(*) 
          into :date_count trimmed
          from NZRRAP.&output_table
          where mth_tm_id between &start_period_tm_key and &end_period_tm_key;
                                  
       quit;


      /*---------------------------------------------
       * If data already exists for the month, the 
       * run delete from code.
       *---------------------------------------------*/

      %if %eval(&date_count) > 0 %then
      %do;
         proc sql;
            connect using NZRRAP as nzcon;
            execute (
               
               delete from %nrbquote(&RRAP_DB..&output_table)
               where mth_tm_id between &start_period_tm_key and &end_period_tm_key

            ) by nzcon;
            execute(CALL SYSPROC.ADMIN_CMD (%nrbquote('RUNSTATS 
						ON TABLE ) %nrbquote(&RRAP_DB..&output_table) 
							%nrbquote(ON KEY COLUMNS and INDEXES ALL'))) by nzcon;

            disconnect from nzcon;
         quit;
      %end;   

%mend delete_previously_loaded_data;
 

