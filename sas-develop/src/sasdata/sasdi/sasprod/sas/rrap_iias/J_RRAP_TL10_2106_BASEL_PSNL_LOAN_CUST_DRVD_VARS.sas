/* Calculate Two Step Customer Derivations */
/* Calculations are pulled from SPL, MOR,  */
/* Revolving Credit                        */

/* Scotia Personal Loans */
%delete_table(nzuser.SCRD_DERIVED_INPUTS_SPL_CUST_SP);


proc sql noprint;
connect using nzuser as nzcon;
execute(

         create table &FRG_DB..SCRD_DERIVED_INPUTS_SPL_CUST_SP as (
         select  
       max(CASE WHEN NB_CHG = 0
                THEN DAY_ODUE
	            ELSE NULL
           END)  CUST13,  
       
       sum(NB_DEF)  CUST16,   
        
       sum(CASE WHEN RECD_STAT_CD = 4 and DAY_ODUE = 0
                THEN 1
	            ELSE 0
           END)  CUST18, 
       
       max(CASE WHEN NB_CHG = 1
                THEN 4
           	    WHEN NB_DEF = 1
	            THEN 3
	            WHEN NB_DELQ = 1
	            THEN 2
	            ELSE 1
           END)  CUST19, 
        
		sum(CASE WHEN NB_CHG = 1
                 THEN 0
	             WHEN NB_DEF = 1
	             THEN BALANCE
	             WHEN NB_DELQ = 1
	             THEN 0
	             ELSE 0
            END)  CUST21,
		sum(CASE WHEN NB_CHG = 1
	             THEN 0
	             WHEN NB_DEF = 1
    	         THEN BALANCE
	             WHEN NB_DELQ = 1
	             THEN BALANCE
	             ELSE 0
           END)  CUST22, 
        prim_basel_cust_id,
        mth_tm_id
from 
(select  
       CASE WHEN RECD_STAT_CD in (6,7,8) 
            THEN 1
	        ELSE 0
       END  NB_CHG,
       CASE WHEN RECD_STAT_CD = 5 
            THEN 1 
			WHEN (RECD_STAT_CD = 4 and DAY_ODUE >= 90)
			THEN 1
	        ELSE 0
       END  NB_DEF ,
	   CASE WHEN RECD_STAT_CD not in (6,7,8)  and DAY_ODUE > 0
            THEN 1
	        ELSE 0
       END  NB_DELQ,
       v.OS_BAL_AMT  BALANCE,
	   DAY_ODUE, 
	   RECD_STAT_CD, 
	   
       a.basel_cust_id  prim_basel_cust_id,
       a.mth_tm_id
 from  &RRAP_DB..BASEL_CUST_ACCT_RLTNP_SNAPSHOT as a
       inner join &RRAP_DB..BASEL_PSNL_LOAN_MTH_SNAPSHOT S
       on a.basel_acct_id=s.basel_acct_id and
          a.mth_tm_id=s.mth_tm_id

       inner join &RRAP_DB..BASEL_PSNL_LOAN_ACCT_DRVD_VARS V
       on s.MTH_TM_ID = v.MTH_TM_ID and 
       s.BASEL_ACCT_ID = v.BASEL_ACCT_ID
 where s.mth_tm_id between &begin_dt_24_tm and &end_period_tm_key and 
       s.prim_basel_cust_id is not null and s.prim_basel_cust_id <> -1 and
	    s.RECD_STAT_CD in (4,5,6,7,8)
) as sv
group by prim_basel_cust_id,
         mth_tm_id  ) WITH DATA;
 
         ) by nzcon;
 quit;



 
/* Revolving Credit */		 
%delete_table(nzuser.SCRD_DERIVED_INPUTS_SPL_CUST_RC);

proc sql noprint;
connect using nzuser as nzcon;
execute(

         create table &FRG_DB..SCRD_DERIVED_INPUTS_SPL_CUST_RC as (
         select 	  
	   MAX(CASE WHEN NB_CHG =0  
            THEN MAX(0,BNS_DLQNT_DAY-30)
			ELSE NULL
		END)  CUST13,  
	 
       sum(NB_DEF)  CUST16,
	   
	   sum(CASE WHEN NB_CHG = 0 and NB_DELQ = 0 
	        THEN 1
			ELSE 0
		END)  CUST18,
	   
	   max(CASE WHEN NB_CHG = 1
                THEN 4
	            WHEN NB_DEF = 1
	            THEN 3
	            WHEN NB_DELQ = 1
	            THEN 2
	            ELSE 1
           END)  CUST19, 
        
		sum(CASE WHEN NB_CHG = 1
                 THEN 0
	             WHEN NB_DEF = 1
	             THEN BALANCE
	             WHEN NB_DELQ = 1
	             THEN 0
	             ELSE 0
        END)  CUST21,
        sum(CASE WHEN NB_CHG = 1
                 THEN 0
	             WHEN NB_DEF = 1
	   	         THEN BALANCE
	             WHEN NB_DELQ = 1
	             THEN BALANCE
	             ELSE 0
         END)  CUST22,
	 
        prim_basel_cust_id,
        mth_tm_id
from (select  
       CASE WHEN CHRG_OFF_CD='1'
	        THEN 1
			ELSE 0
	   END  NB_CHG,
       CASE WHEN CHRG_OFF_CD!='1' and ( BLOCK_RECL_CD='B5' or CHRG_OFF_CD in ('N','Q') or BNS_DLQNT_DAY >= 120)
	        THEN 1
			ELSE 0
	   END  NB_DEF,
       CASE WHEN CHRG_OFF_CD!='1' and (BNS_DLQNT_DAY >= 30 or (CHRG_OFF_CD!='1' and ( BLOCK_RECL_CD='B5' or CHRG_OFF_CD in ('N','Q') or BNS_DLQNT_DAY >= 120)))
	        THEN 1
			ELSE 0
	   END  NB_DELQ,

       BNS_DLQNT_DAY,
	   TOT_NEW_BAL_AMT  BALANCE,
       a.basel_cust_id  prim_basel_cust_id,
       a.mth_tm_id
from  &RRAP_DB..BASEL_CUST_ACCT_RLTNP_SNAPSHOT as a
inner join  &RRAP_DB..BASEL_REVLVNG_CR_MTH_SNAPSHOT as m
      on a.basel_acct_id=m.basel_acct_id and
         a.mth_tm_id=m.mth_tm_id

inner join &RRAP_DB..BASEL_REVLVNG_CR_BASE_DRVD_VARS as d
       on a.basel_acct_id=d.basel_acct_id and
          a.mth_tm_id=d.mth_tm_id

where  m.mth_tm_id between &begin_dt_24_tm and &end_period_tm_key and
       m.prim_basel_cust_id is not null and m.prim_basel_cust_id <> -1  and 
	    (m.TOT_NEW_BAL_AMT > 0 or m.CR_LMT_AMT > 0) and
        m.PRD_CD not in ('BLV') and
        m.SUB_PRD_CD not in ('CC') and 
        m.PRD_CD in ('VIC','SCL','VLR','VGD','VCL','LOC','SSL','')
      ) as sv
group by prim_basel_cust_id,
mth_tm_id) WITH DATA;          
 
         ) by nzcon;
 quit;		 
		 




/* Mortgage */
%delete_table(nzuser.SCRD_DERIVED_INPUTS_SPL_CUST_MO);

 
proc sql noprint;
connect using nzuser as nzcon;
execute(

         create table &FRG_DB..SCRD_DERIVED_INPUTS_SPL_CUST_MO as (
          
 select 	 
        max(DLQNT_DAY_CNT)  CUST13,  
	     
		sum(NB_DEF)  CUST16, 
	 
		sum(CASE WHEN DLQNT_DAY_CNT = 0
		     THEN 1
			 ELSE 0
		END)  CUST18, 
	 
        max(CASE WHEN NB_CHG = 1
                 THEN 4
	             WHEN NB_DEF = 1
	             THEN 3
	             WHEN NB_DELQ = 1
	             THEN 2
	             ELSE 1
         END)  CUST19, 		
	 
		sum(CASE WHEN NB_CHG = 1
                 THEN 0
	             WHEN NB_DEF = 1
	             THEN BALANCE
	             WHEN NB_DELQ = 1
	             THEN 0
	             ELSE 0
        END)  CUST21,
        sum(CASE WHEN NB_CHG = 1
                 THEN 0
	             WHEN NB_DEF = 1
	   	         THEN BALANCE
	             WHEN NB_DELQ = 1
	             THEN BALANCE
	             ELSE 0
         END)  CUST22,
        prim_basel_cust_id,
        mth_tm_id
from (
select  
       CASE WHEN ms.FRCLSR_F = 'Y' or dv.LAND_RGSTRN_ACT_STAT_F = 'Y'
	        THEN 1
			ELSE 0
		END  NB_CHG,
		CASE WHEN dv.DLQNT_DAY_CNT >= 90 and ((ms.FRCLSR_F <> 'Y' OR ms.FRCLSR_F IS NULL) AND  (dv.LAND_RGSTRN_ACT_STAT_F <> 'Y' OR dv.LAND_RGSTRN_ACT_STAT_F IS NULL))
		     THEN 1
			 ELSE 0
		END  NB_DEF,
		CASE WHEN (ms.FRCLSR_F != 'Y' or dv.LAND_RGSTRN_ACT_STAT_F != 'Y') and (dv.DLQNT_DAY_CNT > 0 and dv.DLQNT_DAY_CNT < 90)
		     THEN 1
			 ELSE 0
		END  NB_DELQ, 
		 
	  	dv.OS_BAL_AMT  BALANCE,
		dv.DLQNT_DAY_CNT,
        a.basel_cust_id  prim_basel_cust_id,
        a.mth_tm_id
from &RRAP_DB..BASEL_CUST_ACCT_RLTNP_SNAPSHOT as a
inner join &RRAP_DB..BASEL_MORT_MTH_SNAPSHOT ms
      on a.basel_acct_id=ms.basel_acct_id and
         a.mth_tm_id=ms.mth_tm_id

inner join &RRAP_DB..BASEL_MORT_ACCT_DRVD_VARS dv
      on a.basel_acct_id=dv.basel_acct_id and
         a.mth_tm_id=dv.mth_tm_id  

where ms.mth_tm_id between &begin_dt_24_tm and &end_period_tm_key and
      ms.prim_basel_cust_id is not null and ms.prim_basel_cust_id <> -1  and
	   ms.CRNT_BAL_AMT <> 0 and
      ms.PD_OFF_F ='N' and
      upper(dv.COMM_TP_CD)='RESIDENTIAL'
) as sv
group by prim_basel_cust_id,
mth_tm_id ) WITH DATA; 

         ) by nzcon;
 quit;		 
		 



  
