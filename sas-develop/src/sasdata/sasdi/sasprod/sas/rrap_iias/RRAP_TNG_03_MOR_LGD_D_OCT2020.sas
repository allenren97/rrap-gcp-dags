/*** identify the recovery period for each default event ***/
/*In the following proc sql, the dateparts on month_end_dt were removed by will.*/

proc sql noprint;
   create table work.recov_obs as 
   select pt1.*, 
          pt2.*
   from (select a.account_id,
                a.aggregate_key,
                a.final_defaultdate,
                a.final_defaultbal,
                a.final_defaultdate2,
                a.write_off_ind,
                a.write_off_month,
                a.write_off_amt
        from work.default_points as a) as pt1

   left join
     (select b.account_id as account, 
             b.month_end_dt,
             b.end_principal_balance,
             b.final_default_ind
      from work.all_default_obs2 as b) as pt2

      on pt1.account_id = pt2.account and 
         pt1.final_defaultdate <= pt2.month_end_dt < pt1.final_defaultdate2
   order by aggregate_key, pt2.month_end_dt;
quit;

data work.recov_obs;
   set work.recov_obs;
   by aggregate_key;
   format recovery_date default_start date9.;
   def_ind_lag = lag(final_default_ind);
   if first.aggregate_key then 
   do;
      last_known_default = .;
      def_ind_lag = .;
   end;
   if final_default_ind = 'N' and def_ind_lag = 'Y' then 
   do;
      recovery = 1;
      recovery_date = month_end_dt;
      default_start = final_defaultdate;
   end;
run;

