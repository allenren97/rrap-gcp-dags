                a.final_defaultbal,
                a.write_off_ind,
                a.write_off_month,
                a.write_off_amt
         from work.default_points as a) as pt1
   left join
        (select b.aggregate_key as aggreg_k,
                b.default_end,
                b.default_start,
                b.type,
                b.type2 
         from def_obs_with_recovery_period as b) as pt2
   on pt1.aggregate_key = pt2.aggreg_k;
quit;

