/* JD - 25SEP2015 - CR #47 - Adding field nondiscounted_recovery */
%macro loop_over_ind_costs1;
data work.different_acctsd_WL6;
   set work.different_acctsd_WL5;
   array bal_[96];
   array rec_time_[96];

   recovery = 0;
   nondiscounted_recovery=0;
   indirect_cost = 0;


   if indicator_bal >= work_out_period then recovery=0;
   else 
   do;
      do i=indicator_bal3 to work_out_period;
         if bal_(i) ne . and rec_time_(i)<25  then recovery = recovery + bal_(i)/((1.1)**((rec_time_(i) - months_in_default )/12));
         else recovery = recovery;

         /* CR 47 - Need non-discounted recoveries in final results table. Coping logic from above and removing  */
		   /*         discounting. */
		   if bal_(i) ne . and rec_time_(i)<25  then nondiscounted_recovery = nondiscounted_recovery + bal_(i);
         else nondiscounted_recovery = nondiscounted_recovery;

         if rec_time_(i-1) ne . and rec_time_(i-1) < 25 and intnx('month', default_start, rec_time_(i-1), 'end') < default_end
         then
         do;

            /* Loop over indirect cost variables - values and date */
            %do jj = 1 %to &num_indir_costs_years;
               if year(intnx('month', default_start, rec_time_(i-1)))= indir_costs_dt&jj 
               then indirect_cost = indirect_cost + (indir_costs_tot&jj/12)/((1.1)**((rec_time_(i-1) - months_in_default )/12));
            %end;
            else indirect_cost=indirect_cost;
         end;
      end;
   end;
run;
%mend loop_over_ind_costs1;
%loop_over_ind_costs1; 

