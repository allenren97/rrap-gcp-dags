%macro insert_recoveries;
 
   /*----------------------------------------------------
    * Checks to see if the data being loaded already 
    * exists in the recoveries NZ table
    *----------------------------------------------------*/ 

   proc sql noprint;
       select count(*) 
       into :date_count trimmed
       from &frg_lib..&master_output_rcvry_table
       where upcase(src_sys_cd)='TNG' and 
             upcase(model)='LGD-D' and
             process_date in (select distinct process_date from &frg_lib..&output_rcvry_table) ;
    quit;   

	%put Date_count is &date_count;
	  

    /*---------------------------------------------
    * If data already exists for the data being 
    * loaded, delete it from the target table
    *---------------------------------------------*/  

   %if %eval(&date_count) > 0 %then
   %do;
      proc sql noprint;
         connect using nzuser as nzcon;
         execute (
                  
            delete from %nrbquote(&frg_db..&master_output_rcvry_table)
            where upper(src_sys_cd)='TNG' and upper(model)='LGD-D' and
                  process_date in (select distinct process_date from %nrbquote(&frg_db..&output_rcvry_table))       

         ) by nzcon;
         *execute (generate statistics on %nrbquote(&frg_db..&master_output_rcvry_table)) by nzcon;
         disconnect from nzcon;
      quit;
   %end;   


   /* Insert data into NZ results table*/ 
   proc sql noprint;
   connect using nzuser as nzcon;
   execute(
           insert into %nrbquote(&frg_db..&master_output_rcvry_table) 
           select a.basel_acct_id,
                  a.mortgage_no,
                  a.mth_tm_id,
	               a.process_date,
                  a.crnt_os_bal_amt,
	               a.mth_rcvry_amt,
		            a.prev_mth_os_bal_amt,
		            a.src_sys_cd,
		            a.model,
					 
                  now() as insrt_process_tmstmp,
                  now() as updt_process_tmstmp,
				a.status 
           from %nrbquote(&frg_db..&output_rcvry_table) as a
            
           ) by nzcon;
   quit;
        

   proc sql noprint;
	connect using nzuser as nzcon;       
      *execute (generate statistics on %nrbquote(&frg_db..&master_output_rcvry_table)  ) by nzcon;
      disconnect from nzcon;
   quit;

%mend insert_recoveries;
%insert_recoveries;
