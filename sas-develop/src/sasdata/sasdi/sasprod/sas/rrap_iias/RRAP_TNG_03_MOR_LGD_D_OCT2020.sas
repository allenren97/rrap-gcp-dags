            %end;
           else indirect_cost=indirect_cost;
         end;

      end;
      if direct_cost_(work_out_period) ne . then final_cost=final_cost +direct_cost_(work_out_period)/((1.1)**((rec_time_(work_out_period) - months_in_default )/12));
