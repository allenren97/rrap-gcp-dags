data work.temp_write_off;
   set netcon.tng_acct_writeoff; 
   where month_end_dt le "&_rundate."d; 
   format account_id $80.;
   if substrn(mtg_num,1,1) ='F' or substrn(mtg_num,1,1) ='M' or substrn(mtg_num,1,1) ='R' then account_id=mtg_num;
   else if Provider="FNAL" then account_id=catt("FNAL~",mtg_num,"~1");
   else if  Provider="MCAP" then account_id=catt("MCAP~",mtg_num,"~1");
   else if  Provider="DIR" and substrn(mtg_num,1,1) ne '7' then account_id=catt("MCAP~",mtg_num,"~1");
   else account_id=catt("MBS~",mtg_num);
run;

