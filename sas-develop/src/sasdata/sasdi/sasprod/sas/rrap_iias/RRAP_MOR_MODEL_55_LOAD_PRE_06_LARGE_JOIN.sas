/*---------------------------------------------------
 * 1. Joins Status with a many NZ tables to grab
 *    as many variables as possible while in NZ
 *---------------------------------------------------*/

proc sql;
   connect USING NZUSER as nzcon ;
  
   execute (

   /* Pass through run */
   create table &target_lib3..base_bns_mor_rpt_tbl_temp as (
   SELECT
    CAST(a.mortgage_no AS INTEGER) AS mortgage_no,
    a.process_date,
    d.tm_id AS mth_tm_id,
    a.comm_type AS house_tp_nm,
    a.current_bal AS os_bal_amt,
    a.int_accr_amt AS intr_accr_amt,
    a.paid_off_date AS pd_off_dt,
    a.paid_off_ind AS pd_off_f,
    a.status AS pit_stat_cd,
    UPPER(TRIM(a.bulk_ind)) AS bulk_ind,
    a.insurance,
    a.foreclose_ind,
    a.total_suspense,
    a.current_bal,
    a.paid_off_ind,
    (CASE WHEN a.current_bal + a.int_accr_amt != 0
                THEN (a.current_bal + a.int_accr_amt)
            ELSE -a.total_suspense
            END) AS total_bal,
    UPPER(TRIM(g.insur_grp)) AS insur_grp,
    (CASE WHEN a.current_bal + a.int_accr_amt != 0
                THEN (a.current_bal + a.int_accr_amt)
            ELSE -a.total_suspense
            END) AS total_bal_for_ltv,
    e.lend_val2,
    'MOR' AS src_sys_cd,
    '0201' AS ncr_rt_sys_key_val,
    1 AS utltn_rto,
    0 AS cr_lmt_amt,
    0 AS unadjusted_add_on_bal_amt,
    CAST(NULL AS INTEGER) AS ead_acct_score,
    0 AS cust_behv_score,
    NULL AS acct_num,
    NULL AS loan_num,
    NULL AS prd_cd,
    NULL AS sub_prd_cd,
    CAST(NULL AS DATE) AS last_pymt_dt,
    NULL AS scrty_tp_cd,
    CAST(NULL AS DATE) AS last_acty_dt,
    CAST(NULL AS DATE) AS e_mat_dt,
    CAST(NULL AS DATE) AS note_dt,
    CAST(NULL AS DATE) AS last_rgl_pay_dt,
    'N' AS sml_bus_f,
    CAST(NULL AS INTEGER) AS basel_acct_id,
    '3.0' AS pd_model_ver,
    'BNS MOR PD' AS pd_model_nm,
    'BNS MOR PD Scorecard' AS pd_basel_scorecrd_nm,
    '3.0' AS pd_scorecrd_ver,
    '3.0' AS pd_seg_ver,
    CAST(NULL AS INTEGER) AS pd_basel_seg_id,
    -1 AS pd_basel_model_rel_id,
    c.segment_dr AS pd_model_rto,
    (CASE WHEN upper(a.paid_off_ind) = 'Y' OR upper(a.status) != 'CUR' OR a.current_bal <= 0
                THEN 99
            ELSE NULL
            END) AS base_def_seg,
    NULL AS ead_model_nm,
    NULL AS ead_model_ver,
    NULL AS ead_basel_scorecrd_nm,
    NULL AS ead_scorecrd_ver,
    CAST(NULL AS INTEGER) AS ead_basel_seg_num,
    NULL AS ead_seg_ver,
    CAST(NULL AS INTEGER) AS ead_basel_seg_id,
    -1 AS ead_basel_model_rel_id,
    1.0 AS ead_model_rto,
    1.0 AS ead_lr_rptg_rto,
    0 AS ead_lr_pv_rptg_rto,
    0 AS ead_lr_pv_ad_rptg_rto,
    0 AS ead_ld_pv_ad_sv_rptg_rto,
    0 AS ead_ld_pv_ad_sv_dt_rptg_rto,
    1.0 AS ead_final_rptg_rto,
    0 AS ead_unadjusted_rptg_rto,
    0 AS ead_lr_pv_ad_sv_dt_aa_rto,
    f.amort,
    f.at36,
    f.at94,
    f.cust_acct_cnt,
    f.dlqnt_day,
    f.dlqnt_mthmax24m,
    f.dlqnt_dayavg24m,
    f.bi33max3m,
    f.br147max6m,
    f.d2dbalmax12m,
    f.d2dbalpmin6m,
    f.go04max6m,
    f.nsf_nummax6m,
    f.payroll_amtmin3m,
    f.prepay_ytdmax24m,
    f.index_teranetv,
    f.index_teranetv AS indexed_prpty_val_amt,
    f.ltv,
    f.ltv AS indexed_loan_to_val_rto,
    f.ratio,
    f.urate,
    '3.0' AS lgd_model_ver,
    '3.0' AS lgd_scorecrd_ver,
    '3.0' AS lgd_seg_ver,
    -1 AS lgd_basel_model_rel_id,
    CAST(NULL AS INTEGER) AS lgd_basel_seg_id,
    (CASE WHEN upper(a.status) = 'CUR' THEN 'BNS MOR LGD-ND'
          WHEN upper(a.status) = 'DEF'
          THEN 'BNS MOR LGD-D'
          ELSE ''
     END) AS lgd_model_nm,
    (CASE WHEN upper(a.status) = 'CUR' THEN 'BNS MOR LGD-ND Scorecard'
          WHEN upper(a.status) = 'DEF'
          THEN 'BNS MOR LGD-D Scorecard'
          ELSE ''
     END) AS lgd_basel_scorecrd_nm,
    k.month_def,
    (CASE WHEN upper(a.status) = 'CUR'
                THEN 0
            WHEN upper(a.status) = 'DEF'
                THEN k.month_def
            ELSE 0
            END) AS cons_dft_mth_cnt ,
    j.bns_lgd_nd_segment,
    j.time_key j_time_key,
    k.bns_lgd_d_segment,
    k.time_key as k_time_key
FROM
    &frg_db..status_final AS a
    LEFT JOIN &frg_db..scored_segmented_accts AS b
        ON (CAST(a.mortgage_no AS INTEGER) = CAST(b.mortgage_no AS INTEGER)
        AND last_day(date_trunc('day', a.process_date)) = last_day(date_trunc('day',b.process_date)))
    LEFT JOIN &frg_db..bns_mor_realized_dr AS c
        ON (CAST(b.node AS INTEGER) = CAST(c.node AS INTEGER)
         AND last_day(date_trunc('day', a.process_date)) = last_day(date_trunc('day',c.process_date)))
    LEFT JOIN &frg_db..tm_dim AS d
        ON last_day(date_trunc('day', a.process_date)) = last_day(date_trunc('day', d.tm_lvl_end_dt))
        AND upper(d.tm_lvl) = 'MONTH'
    LEFT JOIN &frg_db..ltv_var_clus_ltv_final AS e
        ON CAST(a.mortgage_no AS INTEGER) = CAST(e.mortgage_no AS INTEGER)
           /*and e.yymth = %nrbquote('&_run_date_yymth')*/
           AND e.yymth = a.yymth
    LEFT JOIN &frg_db..scorecard_vars_final AS f
        ON (CAST(a.mortgage_no AS INTEGER) = CAST(f.mortgage_no AS INTEGER)
        AND last_day(date_trunc('day', a.process_date)) = last_day(date_trunc('day',f.process_date)))
    LEFT JOIN &frg_db..mortgage_hist AS g
        ON (CAST(a.mortgage_no AS INTEGER) = CAST(g.mortgage_no AS INTEGER)
        AND last_day(date_trunc('day', a.process_date)) = last_day(date_trunc('day',g.process_date)))
    LEFT JOIN &frg_db..bns_lgd_nd_scored_seg_accts AS j
        ON (CAST(a.mortgage_no AS INTEGER) = CAST(j.mortgage_no AS INTEGER)
        AND last_day(date_trunc('day', a.process_date)) = last_day(date_trunc('day',j.time_key)))
    LEFT JOIN &frg_db..bns_lgd_d_scored_seg_accts AS k
        ON (CAST(a.mortgage_no AS INTEGER) = CAST(k.mortgage_no AS INTEGER)
        AND last_day(date_trunc('day', a.process_date)) = last_day(date_trunc('day',K.TIME_KEY)))
) WITH DATA DISTRIBUTE BY HASH("MORTGAGE_NO") ORGANIZE BY COLUMN) by nzcon;
 
  * execute (generate statistics on &target_lib3..base_bns_mor_rpt_tbl) by nzcon;
	Execute (CALL SYSPROC.ADMIN_CMD (%nrbquote('RUNSTATS
								ON TABLE ) %nrbquote(&target_lib3..base_bns_mor_rpt_tbl_temp)
											%nrbquote(ON KEY COLUMNS and INDEXES ALL'))) by nzcon;
   disconnect from nzcon;
quit;


%delete_table(&target_lib..province_temp);
proc sql;
connect USING NZUSER as nzcon ;
execute (
		CREATE TABLE &target_lib3..province_temp AS (
         SELECT
             CAST(x.mortgage_no AS INTEGER) AS MORTGAGE_NO,
             process_date,
             p.province_cd
         FROM
             &frg_db..STATUS_FINAL x
             LEFT OUTER JOIN &frg_db..PROVINCE_REF p
                ON CAST(x.province AS INTEGER)= CAST (p.province_id AS INTEGER)
        WHERE  province <> ' '
	) WITH DATA DISTRIBUTE BY HASH("MORTGAGE_NO") ORGANIZE BY COLUMN) by nzcon;
	Execute (CALL SYSPROC.ADMIN_CMD (%nrbquote('RUNSTATS
								ON TABLE ) %nrbquote(&target_lib3..province_temp)
											%nrbquote(ON KEY COLUMNS and INDEXES ALL'))) by nzcon;
   disconnect from nzcon;
quit;


