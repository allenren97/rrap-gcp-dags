/* SQL step sorts data for next step and adds the start_date column - CV Nov18 2015*/

proc sql;
	create table work.lgdnd_raw_hist_sorted as
	select *,
			min(end_date) as start_date format=date9.
	from nzuser.bns_lgdnd_raw_historical
	order by bns_lgd_nd_segment, end_date;
quit;

/* Deletes existing BNS_MOR_HISTORICAL_LGD_ND - CV Nov18 2015*/

%delete_table(results.BNS_MOR_HISTORICAL_LGD_ND);

/* Recalculates the continued averages to include the new months that have been added to the raw data - CV Nov18 2015*/

data results.BNS_MOR_HISTORICAL_LGD_ND (keep= bns_lgd_nd_segment start_date end_date avg_lgd24d avg_lgdc24d avg_lgdc_cap_100 avg_lgdc_cap_150);
		set work.lgdnd_raw_hist_sorted;
		retain new_lgd24d new_lgdc24d new_lgdc_cap_100 new_lgdc_cap_150;
		by bns_lgd_nd_segment;
		if first.bns_lgd_nd_segment then do;
			counter = 0;	
			new_lgd24d = 0;
			new_lgdc24d = 0;
			new_lgdc_cap_100 = 0;
			new_lgdc_cap_150 = 0;
		end;
		counter + 1;		
		new_lgd24d = sum(new_lgd24d,qtr_lgd24d);
		new_lgdc24d = sum(new_lgdc24d,qtr_lgdc24d);
		new_lgdc_cap_100 = sum(new_lgdc_cap_100,qtr_lgdc_cap_100);
		new_lgdc_cap_150 = sum(new_lgdc_cap_150,qtr_lgdc_cap_150);
		
		avg_lgd24d = (new_lgd24d/counter);
		avg_lgdc24d = (new_lgdc24d/counter);
		avg_lgdc_cap_100 = (new_lgdc_cap_100/counter);
		avg_lgdc_cap_150 = (new_lgdc_cap_150/counter);

		format end_date date9. start_date date9.;
run;
