/*-----------------------------------------------
 * Calculates the default rates by segment
 *-----------------------------------------------*/ 
%macro create_bns_lgd_nd_lgd(_in_data =, _out_data=);

   proc summary data = &_in_data(where=(LGDC_CAP_150>0)) nway missing;

      var lgd24d lgdc24d lgdc_cap_100 lgdc_cap_150;

      /* Aggregate by observation start date and segment */
      class time_key bns_lgd_nd_segment;
      output out = work.lgd_components (drop = _TYPE_ rename = (_freq_ = current_count))
      sum = lgd24d lgdc24d lgdc_cap_100 lgdc_cap_150;
   run;

   proc sql noprint;
      create table &_out_data as
      select a.bns_lgd_nd_segment,
             a.time_key,
             a.current_count,
             a.lgd24d,
             (case
               when a.current_count NE . and a.lgd24d NE . then a.lgd24d/a.current_count
               when a.current_count NE . and a.lgd24d EQ . then .
               when a.current_count EQ . and a.lgd24d NE . then .
               else .
             end) as segment_lgd24d,
             a.lgdc24d,
             (case
               when a.current_count NE . and a.lgdc24d NE . then a.lgdc24d/a.current_count
               when a.current_count NE . and a.lgdc24d EQ . then .
               when a.current_count EQ . and a.lgdc24d NE . then .
               else .
             end) as segment_lgdc24d,
             a.lgdc_cap_100,
             (case
               when a.current_count NE . and a.lgdc_cap_100 NE . then a.lgdc_cap_100/a.current_count
               when a.current_count NE . and a.lgdc_cap_100 EQ . then .
               when a.current_count EQ . and a.lgdc_cap_100 NE . then .
               else .
             end) as segment_lgdc_cap_100,
             a.lgdc_cap_150,
             (case
               when a.current_count NE . and a.lgdc_cap_150 NE . then a.lgdc_cap_150/a.current_count
               when a.current_count NE . and a.lgdc_cap_150 EQ . then .
               when a.current_count EQ . and a.lgdc_cap_150 NE . then .
               else .
             end) as segment_lgdc_cap_150
      from work.lgd_components as a
      order by bns_lgd_nd_segment;
   quit;

%mend create_bns_lgd_nd_lgd;
%create_bns_lgd_nd_lgd(_in_data = NZUSER.BNS_LGD_ND_SCORED_SEG_ACCTS,
                            _out_data = results.bns_mor_lgd_nd_realized);

/*-----------------------------------------------
 * Takes average of quarter end DRs for a given
 * segment
 *-----------------------------------------------*/ 
									 
%macro create_avg_pds(_in_data=, _out_data=, _avg_start_qtr=, _avg_end_qtr=);

/* Added logic so only quarter ends are used and added time_key to class - CV Nov18 2015*/

   proc summary data = &_in_data nway missing;
      where time_key GE "&_avg_start_qtr"d and time_key LE "&_avg_end_qtr"d
				and month(time_key) in (1,4,7,10);
      class bns_lgd_nd_segment time_key;
      var current_count lgd24d lgdc24d lgdc_cap_100 lgdc_cap_150;
      output out = work.summarized_vals (drop = _type_ _freq_)
      sum = current_count lgd24d lgdc24d lgdc_cap_100 lgdc_cap_150;
   quit;


/* added end_date column
	added end_date to order by
	changed prefixs to qtr - CV Nov 18 2015*/

   proc sql noprint;
      create table &_out_data as
      select a.bns_lgd_nd_segment,
				time_key as end_date,
             (case
               when a.current_count NE . and a.lgd24d NE . then a.lgd24d/a.current_count
               when a.current_count NE . and a.lgd24d EQ . then .
               when a.current_count EQ . and a.lgd24d NE . then .
               else .
             end) as qtr_lgd24d,
             (case
               when a.current_count NE . and a.lgdc24d NE . then a.lgdc24d/a.current_count
               when a.current_count NE . and a.lgdc24d EQ . then .
               when a.current_count EQ . and a.lgdc24d NE . then .
               else .
             end) as qtr_lgdc24d,
             (case
               when a.current_count NE . and a.lgdc_cap_100 NE . then a.lgdc_cap_100/a.current_count
               when a.current_count NE . and a.lgdc_cap_100 EQ . then .
               when a.current_count EQ . and a.lgdc_cap_100 NE . then .
               else .
             end) as qtr_lgdc_cap_100,
             (case
               when a.current_count NE . and a.lgdc_cap_150 NE . then a.lgdc_cap_150/a.current_count
               when a.current_count NE . and a.lgdc_cap_150 EQ . then .
               when a.current_count EQ . and a.lgdc_cap_150 NE . then .
               else .
             end) as qtr_lgdc_cap_150
      from work.summarized_vals as a
      order by bns_lgd_nd_segment, end_date;
   quit;

%mend create_avg_pds;
%create_avg_pds(_in_data = results.bns_mor_lgd_nd_realized, 
                _out_data = work.qtr_averages,
                _avg_start_qtr = &_ave_start_qtr,
                _avg_end_qtr = &_ave_end_qtr;)





