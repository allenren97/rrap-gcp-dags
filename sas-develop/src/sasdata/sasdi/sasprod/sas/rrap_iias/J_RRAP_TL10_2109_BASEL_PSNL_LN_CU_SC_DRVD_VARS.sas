/* Get the tm_id for the start and end dates being processed */
/* Notice that for the load to the target table, we are only */
/* concerned with the exact start and end dates.  In the     */
/* initial scorecard vars extract, we changed the start date */
/* to pull data for the 24 month lookback.                   */
proc sql noprint;
select tm_key into :start_period_tm_key
from control.tm_id_lkp
where sas_date="&start_period_dt"d;
quit;

proc sql noprint;
select tm_key into :end_period_tm_key
from control.tm_id_lkp
where sas_date="&end_period_dt"d;
quit;


