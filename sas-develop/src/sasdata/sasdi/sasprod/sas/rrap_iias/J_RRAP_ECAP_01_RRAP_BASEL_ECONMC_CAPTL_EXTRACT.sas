proc sql NOPRINT;
create table &INPATH.._temp_rrap_eco_capt_extr as
select
("&MTH_END_DT"d) as MTH_END_DT length = 8
   format = date.
   informat = date.
   label = 'MTH_END_DT',
PRD_ID,
ASST_CL_NUM,
PD_BASEL_SEG_NUM,
LGD_BASEL_SEG_NUM,
EAD_BASEL_SEG_NUM,
RGNL_OFFC_CD,
EGL_DEPRTMNT,
TRNST_NUM,
(MIN(DLQNT_STG )) as DLQNT_STG length = 10
   format = $10.
   informat = $10.
   label = 'DLQNT_STG',
(SUM(
   CASE 
   WHEN SRC_SYS_CD in ('KS' ,'MOR','TNG-MOR') THEN ADJUSTED_OS_BAL_AMT
   WHEN SRC_SYS_CD='SPL' THEN (ADJUSTED_OS_BAL_AMT/*+UNADJUSTED_ADD_ON_BAL_AMT*/)
   END
   )) as ADJUSTED_OS_BAL_AMT length = 8
   format = 22.8
   informat = 22.8
   label = 'ADJUSTED_OS_BAL_AMT',

/*IF SRC_SYS_CD = 'KS' or 'MOR' or 'TNG-MOR'*/
/**/
/*Average of PD Unadjusted Reporting Ratio for the Product ID, Asset Class Number, PD Basel Segment Number, LGD Basel Segment Number, EAD Basel Segment Number, Regional Office Code, Enhanced General Ledger Department, TNIF Transit Number*/
/**/
/*ELSE*/
/**/
/*Average of PD_MODEL_RTO for the Product ID, Asset Class Number, PD Basel Segment Number, LGD Basel Segment Number, EAD Basel Segment Number, Regional Office Code, Enhanced General Ledger Department, TNIF Transit Number*/

(Mean(
   CASE 
   WHEN SRC_SYS_CD in ('KS' ,'MOR','TNG-MOR') THEN PD_UNADJUSTED_RPTG_RTO
   WHEN SRC_SYS_CD not in ('KS' ,'MOR','TNG-MOR')  THEN PD_UNADJUSTED_RPTG_RTO /*PD_MODEL_RTO*/
   END
   )) as PD_WITHOUT_RPTG_RTO length = 8
   format = 22.8
   informat = 22.8
   label = 'PD_WITHOUT_RPTG_RTO',


(MEAN(PD_MODEL_RTO)) as PD_MODEL_RTO length = 8
   format = 30.8
   informat = 30.8
   label = 'PD_MODEL_RTO',
(MEAN(PD_LR_RPTG_RTO)) as PD_LR_RPTG_RTO length = 8
   format = 30.8
   informat = 30.8
   label = 'PD_LR_RPTG_RTO',
(MEAN(PD_FINAL_RPTG_RTO )) as PD_FINAL_RPTG_RTO length = 8
   format = 30.8
   informat = 30.8
   label = 'PD_FINAL_RPTG_RTO',

/*IF SRC_SYS_CD = 'KS' or 'MOR' or 'TNG-MOR'*/
/*Average of LGD Unadjusted Reporting Ratio for the Product ID, Asset Class Number, PD Basel Segment Number, LGD Basel Segment Number, EAD Basel Segment Number, Regional Office Code, Enhanced General Ledger Department Name, TNIF Transit Number*/
/*ELSE*/
/*Average of LGD_MODEL_RTO for the Product ID, Asset Class Number, PD Basel Segment Number, LGD Basel Segment Number, EAD Basel Segment Number, Regional Office Code, Enhanced General Ledger Department, TNIF Transit Number*/

   (Mean(
   CASE 
   WHEN SRC_SYS_CD in ('KS' ,'MOR','TNG-MOR') THEN LGD_UNADJUSTED_RPTG_RTO
   WHEN SRC_SYS_CD not in ('KS' ,'MOR','TNG-MOR')  THEN LGD_UNADJUSTED_RPTG_RTO /*LGD_MODEL_RTO*/
   END
   )) as LGD_WITHOUT_RPTG_RTO length = 8
   format = 22.8
   informat = 22.8
   label = 'LGD_WITHOUT_RPTG_RTO',


(MEAN(LGD_MODEL_RTO )) as LGD_MODEL_RTO length = 8
   format = 30.8
   informat = 30.8
   label = 'LGD_MODEL_RTO',
(MEAN(LGD_LR_RPTG_RTO )) as LGD_LR_RPTG_RTO length = 8
   format = 30.8
   informat = 30.8
   label = 'LGD_LR_RPTG_RTO',
(MEAN(DLGD_RPTG_RTO)) as LGD_FINAL_RPTG_RTO length = 8
   format = 30.8
   informat = 30.8
   label = 'LGD_FINAL_RPTG_RTO',
/*hadi*/
/*IF SRC_SYS_CD = 'KS' or 'MOR' or 'TNG-MOR'*/
/*Average of EAD Unadjusted Reporting Ratio for the Product ID, Asset Class Number, PD Basel Segment Number, LGD Basel Segment Number, EAD Basel Segment Number, Regional Office Code, Enhanced General Ledger Department Name, TNIF Transit Number*/
/*ELSE*/
/*Average of EAD Ratio for the Product ID, Asset Class Number, PD Basel Segment Number, LGD Basel Segment Number, EAD Basel Segment Number, Regional Office Code, Enhanced General Ledger Department Name, TNIF Transit Number*/
 (Mean(
   CASE 
   WHEN SRC_SYS_CD in ('KS' ,'MOR','TNG-MOR') THEN EAD_UNADJUSTED_RPTG_RTO
   WHEN SRC_SYS_CD not in ('KS' ,'MOR','TNG-MOR')  THEN EAD_UNADJUSTED_RPTG_RTO /*EAD_MODEL_RTO*/
   END
   )) as EAD_WITHOUT_RPTG_RTO length = 8
   format = 22.8
   informat = 22.8
   label = 'EAD_WITHOUT_RPTG_RTO',

(MEAN(EAD_MODEL_RTO )) as EAD_MODEL_RTO length = 8
   format = 30.8
   informat = 30.8
   label = 'EAD_MODEL_RTO',
(MEAN(EAD_LR_RPTG_RTO )) as EAD_LR_RPTG_RTO length = 8
   format = 30.8
   informat = 30.8
   label = 'EAD_LR_RPTG_RTO',
(MEAN(EAD_FINAL_RPTG_RTO )) as EAD_FINAL_RPTG_RTO length = 8
   format = 30.8
   informat = 30.8
   label = 'EAD_FINAL_RPTG_RTO',
(SUM(
   CASE 
   WHEN SRC_SYS_CD in ('SPL' ,'MOR','TNG-MOR')  THEN OS_BAL_AMT
   WHEN SRC_SYS_CD='KS' THEN (OS_PRNCPL_BAL_AMT /*+ UNADJUSTED_ADD_ON_BAL_AMT*/ )
   END
   )) as UNADJUSTED_OS_BAL_AMT length = 8
   format = 19.3
   informat = 19.3
   label = 'UNADJUSTED_OS_BAL_AMT',
(SUM(AUTH_AMT )) as AUTH_AMT length = 8
   format = 30.8
   informat = 30.8
   label = 'AUTH_AMT',
(SUM(CR_LMT_AMT )) as CR_LMT_AMT length = 8
   format = 22.8
   informat = 22.8
   label = 'CR_LMT_AMT',
(COUNT(PRD_ID )) as ACCOUNT_COUNT length = 8
   label = 'ACCOUNT_COUNT'
from &INPATH..BASEL_ANALYTCL_BL_INSTRMNT_FACT
where SML_BUS_F='N' & CONSM_PRD_TREATMNT_CD='A' & PIT_STAT_CD in ('CUR','DEF') 
& TRNST_EXCLSN_F='N' & MTH_TM_ID=&MTH_TM_ID
group by
   MTH_END_DT,
   PRD_ID,
   ASST_CL_NUM,
   PD_BASEL_SEG_NUM,
   LGD_BASEL_SEG_NUM,
   EAD_BASEL_SEG_NUM,
   RGNL_OFFC_CD,
   EGL_DEPRTMNT,
   TRNST_NUM
order by
   PRD_ID
;
quit;

