proc sql noprint;
	select tm_id into :tm_id
	from nzrrap.tm_dim
	where tm_lvl='Day' and tm_lvl_end_dt = "&start_period_dt."d;
quit;


PROC SQL NOPRINT;
	create table NZ as
	select name
	from dictionary.columns
	where libname='NZ' and memname='BASEL_MORT'
	order by name;

	create table DB2 as
	select name
	from dictionary.columns
	where libname='EDRTLR' and memname='BASEL_MORT'
	order by name;
QUIT;

data columns;
	merge NZ (in=a) DB2 (in=b);
	by name;
	if a and b;
run;

proc sql noprint;
	select name into :columns separated by ' ,'
	from columns;

	
	CREATE TABLE BASEL_MORT AS
	SELECT -1 as DLQNT_CYCL_LKP_ID,
			-1 as DLQNT_STG_LKP_ID,
			-1 as PRD_LKP_ID,
			-1 as TNIF_RGN_LKP_ID,
			&columns FROM EDRTLR.BASEL_MORT
	where eff_tm_id = &tm_id.;
quit;

/*EDRTLR.BASEL_MORT is not using mth_tm_id, it uses the tm_id for the day*/

PROC SQL NOPRINT;
	CONNECT USING NZ AS NZCON; 
	execute(DELETE FROM BASEL_MORT WHERE EFF_TM_ID=&TM_ID) by nzcon;
	DISCONNECT FROM NZCON;
QUIT;
PROC APPEND BASE=NZ.BASEL_MORT DATA=BASEL_MORT FORCE; RUN;




