proc sql noprint;
	select tm_id into :tm_id
	from nzrrap.tm_dim
	where tm_lvl='Day' and tm_lvl_end_dt = "&start_period_dt."d;
quit;

proc sql;
create table myload as
select eff_tm_id, count(*) as count format=comma11., sum(CRNT_BAL) as BALANCE format=comma20.
from nz.BASEL_MORT
where eff_tm_id = &tm_id.
group by 1
order by 1 desc;
quit;

proc sql;
create table dms_load as
select eff_tm_id, count(*) as count_dms format=comma11., sum(CRNT_BAL) as BALANCE_DMS format=comma20.
from EDRTLR.BASEL_MORT
where eff_tm_id = &tm_id.
group by 1
order by 1 desc;
quit;



/*Rig the load :)*/
/*DATA DMS_LOAD; 	SET DMS_LOAD; balance_dms=30085518534; RUN;*/





proc sql noprint;
select max(audit_key) +1 as audit_key into :audit_key
from NZWRK.AUDIT_TABLE;
quit;


%let audit_status=PASS;
data compare;
	merge myload dms_load;
	
	FORMAT COUNT_DIFF BALANCE_DIFF PERCENT12.5;
	COUNT_DIFF=ABS(COUNT-COUNT_DMS)/COUNT_DMS;
	BALANCE_DIFF=ABS(BALANCE-BALANCE_DMS)/BALANCE_DMS;
		call symputx('COUNT_DIFF',COUNT_DIFF);
		call symputx('SRC_ROW_CNT',COUNT_DMS);
		call symputx('TARGET_ROW_CNT',COUNT);

		call symputx('BALANCE_DIFF',BALANCE_DIFF);
		call symputx('SRC_SUM1',BALANCE_DMS);
		call symputx('TARGET_SUM1',BALANCE);
	IF COUNT_DIFF GT 0 THEN DO;
		PUT ;
		PUT "  The count difference is greater than the threshold of &threshold.%.";
		PUT ;
		PUT "  		Rows Loaded: " COUNT ", Rows Expected: " COUNT_DMS;
		PUT ;
		PUT "  Please investigate prior to restarting this job. The process will now abort.";
		PUT ;
		CALL SYMPUTX('AUDIT_STATUS','FAIL');
	END;
	IF BALANCE_DIFF GT &threshold./100 THEN DO;
		PUT ;
		PUT "  The balance difference is greater than the threshold of &threshold.%.";
		PUT ;
		PUT "  		Balance Loaded: " BALANCE ", Balance Expected: " BALANCE_DMS;
		PUT ;
		PUT "  Please investigate prior to restarting this job. The process will now abort.";
		PUT ;
		CALL SYMPUTX('AUDIT_STATUS','FAIL');
	END;
run;

