                           process_date_adjusted  = '31Jul2009'd; 
                        
                        else if yymth in (201001, 201004, 201007) then 
                           process_date_adjusted  = '29Oct2010'd;
                        
                        run;

                        %put &=syserr;
                        %put &=sqlrc;
                        
                        /*----------------------------------------------------
                         * 6. Get Amort Value for the adjusted qtr and month    
                         *----------------------------------------------------*/
                        
                         /* Grab the AMORT value for the process date adjusted quarter end month */
                        proc sql;
                        create table work.mort_hist2_&pn._tmp as
                        select a.mortgage_no, a.process_date, a.yymth, a.current_bal, a.prepay_ytd, 
                               a.province, a.amort, a.process_date_adjusted, l.amort as amort_adjusted
                        from work.mortgage_data as a
                        left join
                             work.mort_hist2_&pn. as l
                        on    a.mortgage_no=l.mortgage_no and 
                              a.process_date_adjusted=datepart(l.process_date)
                        order by a.mortgage_no, a.process_date;
                        quit; 

                        %put &=syserr;
                        %put &=sqlrc;
                        
                        
                        /* New logic to address null values in PROVINCE variable*/
                        
                        
                        data work.mort_hist3_&pn._tmp;
                           set work.mort_hist2_&pn._tmp;
                        
                         format process_date2 date9.;
                           process_date2 = datepart(process_date);
                        
                           /*If Process_Date is in exceptions quarters, use nearest available date*/
                           if yymth = 200904 then process_date2 = '31Jul2009'd;
                           if yymth in (201001, 201004, 201007) then process_date2 = '29Oct2010'd;
                        run;

                        %put &=syserr;
                        %put &=sqlrc;
                        
                        proc sql;
                           create table work.mort_hist4_&pn._tmp as
                           select a.mortgage_no,
                                 a.process_date,
                                 a.YYMTH,
                                 a.CURRENT_BAL,
                                 a.Prepay_ytd,
                                 a.amort,
                                 a.Process_date_adjusted,
                                 a.amort_adjusted,
                                 b.province
                            from work.mort_hist3_&pn._tmp a
                                 left join 
                                 work.mort_hist2_&pn._tmp b  
                           on a.mortgage_no = b.mortgage_no
                              and 
                              datepart(b.process_date) = a.process_date2;
                        quit;

                        %put &=syserr;
                        %put &=sqlrc;
                        
                        
                        /*----------------------------------------------------
                         * 7. Copy Table to Netezza     
                         *----------------------------------------------------*/
                        
                        %delete_table(nzuser.mort_hist2_&pn._update);

                        %put &=syserr;
                        %put &=sqlrc;
                         
                        data nzuser.mort_hist2_&pn._update (BULKLOAD=YES BL_METHOD=CLILOAD);
                        set work.mort_hist4_&pn._tmp;
                        drop amort_adjusted process_date_adjusted;
                        
                        if yymth in (201001, 201004, 201007, 200904 ) then 
                           amort = amort_adjusted - intck('MONTH', process_date_adjusted, datepart(process_date));
                        
                        run;

                        %put &=syserr;
                        %put &=sqlrc;
                        
                        
                        /*----------------------------------------------------
                         * 8. Replace Amort and Prepay_tyd from Update table    
                         *----------------------------------------------------*/
                        
                        /* Replace AMORT and PREPAY_YTD from mort_hist2_&pn. with the value in mort_hist2_&pn._update */
                        
                        
                        %delete_table(nzuser.MORTGAGE_HIST_&pn.);
                        %put &=syserr;
                        %put &=sqlrc;
                        proc sql ;
                        	connect USING NZUSER as nzcon ;
                        	/* execute (drop table &target_lib3...MORTGAGE_HIST_&pn.) by nzcon; */
                        	execute(
                        	create table &target_lib3..MORTGAGE_HIST_&pn. as (
                        	select a.MORTGAGE_NO, a.COMM_TYPE, a.FLOAT_LKP_ID, a.GENL_LKP_ID, a.CURRENT_BAL, a.DELQ_DAYS, a.DELQ_MONTHS, a.FLOAT_IND, 
                                  a.FORECLOSE_IND, a.INT_ACCR_AMT, a.LRA_STATUS, a.PAID_OFF_DATE, a.PAID_OFF_IND, a.PROCESS_DATE, a.TOTAL_SUSPENSE, 
                                  a.UNPD_MTH_PAY_DATE, a.UNPD_WKL_PAY_DATE, a.MADE_DATE, a.TIME_KEY, a.INT_ADJ_DATE, a.YYMTH, a.INSURANCE, a.CLASS, 
                                  a.EFF_TMSTMP, a.PRPTY_DESC_1, a.PRPTY_DESC_2, a.PRPTY_DESC_3, a.LEND_VAL2, a.TRNST, 
                                  a.AUTH_AMT, a.MAT_DT, a.CAB, a.TOT_ADVNC_AMT, a.PRIM_CUST_ID, a.CIF_KEY, a.STEP_F, a.INSUR_GRP, a.BULK_IND, 
                                  b.AMORT, b.PREPAY_YTD, b.PROVINCE
                        	from &target_lib3..mort_hist2_&pn. a
                        	left join &target_lib3..mort_hist2_&pn._update b
                              on a.mortgage_no=b.mortgage_no and
                                 a.process_date=b.process_date 
								 ) WITH DATA;
                        	
                        ) by nzcon;
                        *	execute (generate statistics on &target_lib3..MORTGAGE_HIST_&pn.) by nzcon;
						Execute (CALL SYSPROC.ADMIN_CMD (%nrbquote('RUNSTATS
								ON TABLE ) %nrbquote(&target_lib3..MORTGAGE_HIST_&pn.)
