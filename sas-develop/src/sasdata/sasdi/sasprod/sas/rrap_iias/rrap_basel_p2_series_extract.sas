		, NCR_EXPSR_CL_KEY_VAL
		, NCR_LGD_SEG_KEY_VAL
		, SUM(RPTG_QTR_ACCT_CNT) AS RPTG_QTR_ACCT_CNT
		, SUM(LGD_REALZ_ACCT_CNT) AS LGD_REALZ_ACCT_CNT
		, CASE WHEN SUM(RPTG_QTR_ACCT_CNT) = 0 THEN 0 ELSE SUM(LGD_ESTD_RTO*RPTG_QTR_ACCT_CNT)/SUM(RPTG_QTR_ACCT_CNT) END AS LGD_ESTD_RTO
		, CASE WHEN SUM(LGD_REALZ_ACCT_CNT) = 0 THEN 0 ELSE SUM(LGD_REALZ_RTO*LGD_REALZ_ACCT_CNT)/SUM(LGD_REALZ_ACCT_CNT) END AS LGD_REALZ_RTO
		, SUM(LGD_REALZ_DEFLTD_OS_BAL_AMT) AS LGD_REALZ_DEFLTD_OS_BAL_AMT
		, SUM(LGD_REALZ_DEFLTD_ACCT_CNT) AS LGD_REALZ_DEFLTD_ACCT_CNT
	FROM EDRRAPT.BASEL_CANDN_RTL_NCR_BE_FACT BE
		INNER JOIN EDRRAPT.BASEL_NCR_RISK_RT_SYS_DIM RISK_RT ON
			RISK_RT.NCR_RISK_RT_SYS_ID = BE.NCR_RISK_RT_SYS_ID
		INNER JOIN EDRRAPT.BASEL_EXPSR_CL_DIM EXPSR_CL ON
			EXPSR_CL.EXPSR_CL_ID = BE.EXPSR_CL_ID
		INNER  JOIN EDRRAPT.BASEL_NCR_LGD_SEG_DIM LGD ON
			LGD.NCR_LGD_SEG_ID = BE.NCR_LGD_SEG_ID
	WHERE MTH_TM_ID = &mth_tm_id.
			AND ECONMC_CAPTL_AMT IS NULL
	GROUP BY NCR_RISK_RT_KEY_VAL, NCR_EXPSR_CL_KEY_VAL, NCR_LGD_SEG_KEY_VAL
	Order By NCR_RISK_RT_KEY_VAL, NCR_EXPSR_CL_KEY_VAL, NCR_LGD_SEG_KEY_VAL
);
DISCONNECT FROM DB3CON;
Quit;

PROC SQL;
CREATE TABLE SRC_ROLLUP AS 
SELECT	NCR_RISK_RT_KEY_VAL
		, NCR_PRNT_KEY_VAL AS NCR_EXPSR_CL_KEY_VAL
		, NCR_LGD_SEG_KEY_VAL
		, CASE WHEN SUM(RPTG_QTR_ACCT_CNT) = 0 THEN 0 ELSE SUM(LGD_ESTD_RTO*RPTG_QTR_ACCT_CNT)/SUM(RPTG_QTR_ACCT_CNT) END AS LGD_ESTD_RTO
		, CASE WHEN SUM(LGD_REALZ_ACCT_CNT) = 0 THEN 0 ELSE SUM(LGD_REALZ_RTO*LGD_REALZ_ACCT_CNT)/SUM(LGD_REALZ_ACCT_CNT) END AS LGD_REALZ_RTO
		, SUM(LGD_REALZ_DEFLTD_OS_BAL_AMT) AS LGD_REALZ_DEFLTD_OS_BAL_AMT
		, SUM(LGD_REALZ_DEFLTD_ACCT_CNT) AS LGD_REALZ_DEFLTD_ACCT_CNT
FROM SRC
		INNER JOIN OUTFILE.BASEL_NCR_HIERARCHY_LKP EXPSR_CL
			ON EXPSR_CL.NCR_KEY_VAL = SRC.NCR_EXPSR_CL_KEY_VAL
	GROUP BY NCR_RISK_RT_KEY_VAL, EXPSR_CL.NCR_PRNT_KEY_VAL, NCR_LGD_SEG_KEY_VAL
;
quit;

