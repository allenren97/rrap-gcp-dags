data outfile.BASEL_CANDN_RTL_NCR_BE_FACT;
set ldd.BASEL_CANDN_RTL_NCR_BE_FACT;
where MTH_TM_ID=&MTH_TM_ID;
run;
PROC DATASETS LIB=WORK KILL NOLIST ;
RUN;
QUIT;
PROC SQL;
CREATE TABLE BASEL_P2_015_TMP1 AS
SELECT distinct
"&tm_lvl_end_dt."d as MTH_END_DT FORMAT DATE9.,
"&dtime."dt AS EXTRACT_TMSTMP format datetime25.,
'015' AS NCR_RECD_TP format $3.,
B.NCR_EXPSR_CL_KEY_VAL AS NCR_EXPSR_CL Label='NCR_EXPSR_CL' format $4.,
'0299' AS NCR_RISK_RT_SYS format $4.,
'0999' AS NCR_PD_SEG format $4.,
'3299' AS NCR_LGD_SEG format $4.,
'3399' AS NCR_EAD_SEG format $4.,
(A.ECONMC_CAPTL_AMT
/*+C.ECONMC_CAPTL_AMT*/
)/1000 AS ECONMC_CAPTL,
"&dtime."dt AS INSRT_PROCESS_TMSTMP format datetime25.,
"&dtime."dt AS UPDT_PROCESS_TMSTMP format datetime25.
	FROM outfile.BASEL_CANDN_RTL_NCR_BE_FACT A

	LEFT JOIN outfile.BASEL_EXPSR_CL_DIM B ON A.EXPSR_CL_ID = b.EXPSR_CL_ID
	AND &YEARMONTH. between input(eff_from_yr_mth,6.) and input(eff_to_yr_mth,6.)


	WHERE B.NCR_EXPSR_CL_KEY_VAL in ('0502','0503','0505','0506','0507')
	AND A.ECONMC_CAPTL_AMT NE .

	AND A.MTH_TM_ID=&mth_tm_id.

	Order By B.NCR_EXPSR_CL_KEY_VAL
;
Quit;


/*     GROUPING THE DATA TO GET RID OF 0 VALUE RECORDS  */
PROC SQL;
CREATE TABLE BASEL_P2_015_TMP2 AS
SELECT MTH_END_DT,EXTRACT_TMSTMP,NCR_RECD_TP,NCR_EXPSR_CL,NCR_RISK_RT_SYS,NCR_PD_SEG,NCR_LGD_SEG,
NCR_EAD_SEG,round(Sum(econmc_captl)) AS ECONMC_CAPTL, INSRT_PROCESS_TMSTMP,UPDT_PROCESS_TMSTMP
From BASEL_P2_015_TMP1

Group By MTH_END_DT,EXTRACT_TMSTMP,NCR_RECD_TP,NCR_EXPSR_CL,NCR_RISK_RT_SYS,NCR_PD_SEG,NCR_LGD_SEG,
NCR_EAD_SEG,INSRT_PROCESS_TMSTMP,UPDT_PROCESS_TMSTMP

Order By MTH_END_DT,EXTRACT_TMSTMP,NCR_RECD_TP,NCR_EXPSR_CL,NCR_RISK_RT_SYS,NCR_PD_SEG,NCR_LGD_SEG,
NCR_EAD_SEG,INSRT_PROCESS_TMSTMP,UPDT_PROCESS_TMSTMP
;
