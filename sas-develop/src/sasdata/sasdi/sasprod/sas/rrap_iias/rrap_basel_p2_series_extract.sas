%global outfile;
%global mth_tm_id;
%global tm_lvl_st_dt;
%global tm_lvl_end_dt;
%global dtime;




proc sql noprint;
select tm_id as mth_tm_id, tm_lvl_st_dt, tm_lvl_end_dt , datetime() as dtime format datetime25.
into :mth_tm_id, :tm_lvl_st_dt, :tm_lvl_end_dt, :dtime
from  EDRTLRT.TM_DIM
where tm_id=&mth_tm_id.;
quit;

%PUT &mth_tm_id.;
%PUT &tm_lvl_st_dt.;
%PUT &tm_lvl_end_dt.;
%PUT &dtime.;



%global yearmonth;

/*Fetch the Year and Month from TM_DIM Output TO  MTH_TM_ID and YearMonth and creates Work._TempYearMonth Table*/
proc sql noprint ;
   connect USING EDRRAPT as dbcon;
                select compress(yrmo,"-") into :yearmonth
                  from connection to dbcon (
select substr(tm_lvl_st_dt,1,7) as yrmo from edrtlrt.tm_dim where tm_id=&MTH_TM_ID);
DISCONNECT FROM DBCON;
quit;



