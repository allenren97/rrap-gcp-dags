FROM &DB..BASEL_NCR_PD_SEG_DIM
WHERE NCR_PD_SEG_KEY_VAL not in ('0999','0998')
;
quit;

PROC SQL;
CREATE TABLE risk_rt20 AS 
SELECT DISTINCT NCR_RISK_RT_KEY_VAL
FROM &DB..BASEL_NCR_RISK_RT_SYS_DIM
WHERE   NCR_RISK_RT_KEY_VAL in ('0201','0207')
;
quit;


PROC SQL;
CREATE TABLE BASE_REC AS 
SELECT
		'020' AS NCR_RECD_TP
		,Exposure_Class.NCR_EXPSR_CL_KEY_VAL AS NCR_EXPSR_CL
		,risk_rt.NCR_RISK_RT_KEY_VAL
		,PD_SEG.NCR_PD_SEG_KEY_VAL AS NCR_PD_SEG
		,'3299' AS NCR_LGD_SEG
		,'3399' AS NCR_EAD_SEG
	FROM Exposure_Class20 as Exposure_Class
		CROSS JOIN PD_SEG20 as PD_SEG 
		CROSS JOIN risk_rt20 as risk_rt
;
quit;

PROC SQL;
CREATE TABLE BASEL_P2_020_TMP1 AS 
SELECT
	"&tm_lvl_end_dt."d as MTH_END_DT FORMAT DATE9.
	,"&dtime."dt AS EXTRACT_TMSTMP format datetime25.
	,BASE_REC.NCR_RECD_TP Length=3  FORMAT $3.
	,BASE_REC.NCR_EXPSR_CL format $4.
	,BASE_REC.NCR_RISK_RT_KEY_VAL as NCR_RISK_RT_SYS format $4.
	,BASE_REC.NCR_PD_SEG format $4.
	,BASE_REC.NCR_LGD_SEG format $4.
	,BASE_REC.NCR_EAD_SEG format $4.
	,COALESCE(SRC_ROLLUP.PD_ESTD_RTO, 0)*100 AS ESTD_PD format 5.2
	,CASE WHEN BASE_REC.NCR_PD_SEG = '0923' THEN 100.00
			ELSE COALESCE(SRC_ROLLUP.PD_REALZ_RTO, 0) * 100
			END AS REALZ_PD format 5.2
