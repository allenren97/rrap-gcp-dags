/**************************************************************************************
  BE_P2_020.sas     Revised 8th Sep 2014  at 2:59pm
**************************************************************************************/

PROC SQL;
CONNECT USING EDRRAPT AS DB3CON;
CREATE TABLE SRC AS 
SELECT * FROM CONNECTION TO DB3CON
(SELECT DISTINCT
		NCR_RISK_RT_KEY_VAL
		, NCR_EXPSR_CL_KEY_VAL
		, NCR_PD_SEG_KEY_VAL
		, SUM(RPTG_QTR_ACCT_CNT) AS RPTG_QTR_ACCT_CNT
		, SUM(PD_REALZ_ACCT_CNT) AS PD_REALZ_ACCT_CNT
		, CASE WHEN SUM(RPTG_QTR_ACCT_CNT) = 0 THEN 0 ELSE SUM(PD_ESTD_RTO*RPTG_QTR_ACCT_CNT)/SUM(RPTG_QTR_ACCT_CNT) END AS PD_ESTD_RTO
		, CASE WHEN SUM(PD_REALZ_ACCT_CNT) = 0 THEN 0 ELSE SUM(PD_REALZ_RTO*PD_REALZ_ACCT_CNT)/SUM(PD_REALZ_ACCT_CNT) END AS PD_REALZ_RTO
		, SUM(PD_REALZ_DEFLTD_OS_BAL_AMT) AS PD_REALZ_DEFLTD_OS_BAL_AMT
		, SUM(PD_REALZ_DEFLTD_ACCT_CNT) AS PD_REALZ_DEFLTD_ACCT_CNT
FROM EDRRAPT.BASEL_CANDN_RTL_NCR_BE_FACT BE
	INNER JOIN EDRRAPT.BASEL_NCR_RISK_RT_SYS_DIM RISK_RT ON
			RISK_RT.NCR_RISK_RT_SYS_ID = BE.NCR_RISK_RT_SYS_ID
	INNER JOIN EDRRAPT.BASEL_EXPSR_CL_DIM EXPSR_CL ON
			EXPSR_CL.EXPSR_CL_ID = BE.EXPSR_CL_ID
	INNER JOIN EDRRAPT.BASEL_NCR_PD_SEG_DIM PD ON
			PD.NCR_PD_SEG_ID = BE.NCR_PD_SEG_ID
	WHERE MTH_TM_ID = &mth_tm_id.
	AND ECONMC_CAPTL_AMT IS NULL
	GROUP BY NCR_RISK_RT_KEY_VAL, NCR_EXPSR_CL_KEY_VAL, NCR_PD_SEG_KEY_VAL
	Order By NCR_RISK_RT_KEY_VAL, NCR_EXPSR_CL_KEY_VAL, NCR_PD_SEG_KEY_VAL
);
DISCONNECT FROM DB3CON;
Quit;


PROC SQL;
CREATE TABLE SRC_ROLLUP AS 
SELECT 	NCR_RISK_RT_KEY_VAL
		, NCR_PRNT_KEY_VAL AS NCR_EXPSR_CL_KEY_VAL
		, NCR_PD_SEG_KEY_VAL
		, CASE WHEN SUM(RPTG_QTR_ACCT_CNT) = 0 THEN 0 ELSE SUM(PD_ESTD_RTO*RPTG_QTR_ACCT_CNT)/SUM(RPTG_QTR_ACCT_CNT) END AS PD_ESTD_RTO
		, CASE WHEN SUM(PD_REALZ_ACCT_CNT) = 0 THEN 0 ELSE SUM(PD_REALZ_RTO*PD_REALZ_ACCT_CNT)/SUM(PD_REALZ_ACCT_CNT) END AS PD_REALZ_RTO
		, SUM(PD_REALZ_DEFLTD_OS_BAL_AMT) AS PD_REALZ_DEFLTD_OS_BAL_AMT
		, SUM(PD_REALZ_DEFLTD_ACCT_CNT) AS PD_REALZ_DEFLTD_ACCT_CNT
FROM SRC
		INNER JOIN &DB..BASEL_NCR_HIERARCHY_LKP EXPSR_CL
			ON EXPSR_CL.NCR_KEY_VAL = SRC.NCR_EXPSR_CL_KEY_VAL
GROUP BY NCR_RISK_RT_KEY_VAL, EXPSR_CL.NCR_PRNT_KEY_VAL, NCR_PD_SEG_KEY_VAL
;
quit;

PROC SQL;
CREATE TABLE Exposure_Class20 AS 
SELECT DISTINCT NCR_EXPSR_CL_KEY_VAL
FROM &DB..BASEL_EXPSR_CL_DIM
WHERE NCR_EXPSR_CL_KEY_VAL IN ('0500', '0501', '0502', '0503', '0504','0505', '0506', '0507')
;
/*** NCR_EXPSR_CL_KEY_VAL = '0504' has been added to fi defect #551 from Sreeraj ***/
