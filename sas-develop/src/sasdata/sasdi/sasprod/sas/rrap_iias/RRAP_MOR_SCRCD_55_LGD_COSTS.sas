/*Hadi - Source the indirect cost data from DRVD_MTH_INDRCT_COST_SUM*/

proc sql;
create table source.lgd_indirect_cost as
      select 
	   DHMS(t.tm_lvl_end_dt,0,0,0) format = datetime22.3 as REPORTING_DATE 
      ,a.TOT_INDRCT_COST_AMT as TOTAL_INDIRECT_COSTS
      ,a.TOT_DFT_ACCT_CNT as DEFAULTS_COUNT
      ,a.UNIT_INDRCT_COST_AMT as INDIRECT_UNIT_COSTS
	   ,'Y' as Is_Approved

      from NZRRAP.DRVD_MTH_INDRCT_COST_SUM a , NZRRAP.tm_dim t
      where a.mth_tm_id=t.tm_id and t.tm_lvl='Month'
      order by 1;
quit;



%delete_table(nzuser.lgd_indirect_cost);
data nzuser.lgd_indirect_cost (BULKLOAD=YES BL_METHOD=CLILOAD);
       set source.lgd_indirect_cost;
run;




