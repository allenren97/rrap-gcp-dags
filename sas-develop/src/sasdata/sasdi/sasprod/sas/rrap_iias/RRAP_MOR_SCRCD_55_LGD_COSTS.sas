PROC SQL;
   CREATE TABLE WORK.NETEZZA_COSTS AS 
   SELECT t1.MTH_TM_ID, 
   BASEL_ACCT_ID,
		input(substr(t1.ACCT_NUM,13),21.) as MORTGAGE_NO,
		Compress(Catx(SRC_SYS_CD,PGM_TP_CD,put(calculated mortgage_no,13.),put(datepart(ASGNMN_DT),yymmddn8.))) as REC_ID,
          t1.TOT_COST_EXPNS_AMT, 
		  t1.ASGNMN_DT,	
		 t1.PGM_TP_CD,
		 
          t1.HGHWY_CD,
		  t1.SRC_SYS_CD
      FROM NZRRAP.ASST_DRC_COST_MTH_SNAPSHOT t1
	  where t1.SRC_SYS_CD in ('MOR','STEP') and t1.BASEL_ACCT_ID NE -1 
	  order by Calculated REC_ID,MTH_TM_ID;
QUIT;


data work.netezza_costs;
	set work.netezza_costs;
	by REC_ID mth_tm_id;
	lag_cost=lag(TOT_COST_EXPNS_AMT);
	if First.REC_ID then do;
		DATE_HGHWY_COST=TOT_COST_EXPNS_AMT;
	end;
	else DATE_HGHWY_COST=TOT_COST_EXPNS_AMT-lag_cost;
	drop lag_cost;
run;


proc sql;
	create table source.LGD_DIRECT_COSTS as
		select t1.MORTGAGE_NO, 
			t1.MTH_TM_ID, 
			dhms(t2.TM_LVL_END_DT,0,0,0) format=datetime25.  as REPORTING_DATE ,
			sum(t1.DATE_HGHWY_COST) as costs
		from work.netezza_costs t1
			left join NZRRAP.tm_DIM t2
				on t1.MTH_TM_ID=t2.TM_ID
	group by t1.MORTGAGE_NO, t1.MTH_TM_ID, t2.TM_LVL_END_DT;
quit;


%delete_table(nzuser.lgd_direct_costs);
data nzuser.lgd_direct_costs (BULKLOAD=YES BL_METHOD=CLILOAD);
       set source.lgd_direct_costs;
run;

