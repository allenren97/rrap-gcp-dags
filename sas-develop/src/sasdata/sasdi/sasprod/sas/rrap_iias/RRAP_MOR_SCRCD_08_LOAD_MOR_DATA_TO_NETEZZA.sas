*step 8;

proc sql;
connect USING NZUSER as nzcon ;
execute (create table &target_lib3..SCORECARD_VARS_MOR_COMB as (
         select * from FRG_USER_DATA.SCORECARD_VARS_MOR2 
         union
          select * from &target_lib3..SCORECARD_VARS_MOR_09_3
) WITH DATA
) by nzcon;
*execute (generate statistics on &target_lib3..SCORECARD_VARS_MOR_COMB) by nzcon;
	execute(CALL SYSPROC.ADMIN_CMD (%nrbquote('RUNSTATS
				ON TABLE ) %nrbquote(&target_lib3..SCORECARD_VARS_MOR_COMB)
					%nrbquote(ON KEY COLUMNS and INDEXES ALL'))) by nzcon; 
 
execute(	create table &target_lib3..LAST_CUSTOMER_KEY as (
	select svm.mortgage_no, cust_base_key as cust_base_key_last, cid as cid_last, product as product_last
	from &target_lib3..SCORECARD_VARS_MOR_COMB svm, 
	(select mortgage_no, max(time_key) as time_key, max(load_date_tm) as load_date_tm
	from &target_lib3..SCORECARD_VARS_MOR_COMB
	where product is not null
	group by mortgage_no) svm2
	where svm.MORTGAGE_NO = svm2.mortgage_no
	and svm.TIME_KEY = svm2.time_key 
   	/*and svm.load_date_tm = svm2.load_date_tm*/
	and date(svm.load_date_tm) = date(svm2.load_date_tm)
	and time(svm.load_date_tm) = time(svm2.load_date_tm)  ) WITH DATA ) by nzcon;

