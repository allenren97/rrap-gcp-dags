         PROC SQL NOPRINT;
         	CREATE TABLE ANL_SECOND AS 
         		SELECT 
         			A.*, 
         /*		CASE */
         /*			WHEN A.E_MAT_DT = . THEN INTCK('MONTH', "&MTH_END_DT"d, (INTNX('MONTH', A.NOTE_DT, A.AMORT, 'E')))*/
         /*			WHEN A.E_MAT_DT < "&MTH_END_DT"d THEN INTCK('MONTH', "&MTH_END_DT"d, A.LAST_RGL_PAY_DT)*/
         /*			ELSE INTCK('MONTH', "&MTH_END_DT"d, A.E_MAT_DT) */
         /*		END */
         /*				AS RESIDUAL_MAT,*/
         		CASE 
         			WHEN A.ADJUSTED_OS_BAL_AMT < 0 THEN 0 
         			ELSE A.ADJUSTED_OS_BAL_AMT 
         		END 
         				AS AF_SECRTZTN_BAL_AMT,
         		A.ADJUSTED_OS_BAL_AMT AS BEFORE_ZERO_NET_DRAWN_AMT,
         	CASE 
         		WHEN A.ADJUSTED_OS_BAL_AMT < 0 THEN 0 
         		ELSE A.ADJUSTED_OS_BAL_AMT 
         	END 
         			AS AF_ZERO_NET_DRAWN_AMT,
         	LKP_MODEL.BASEL_MODEL_ID,
         	LKP_MODEL.MODEL_NM AS PD_MODEL_NM, /*ADDED AS PART OF Q4*/
         	LKP_MODEL.MODEL_VER AS PD_MODEL_VER, /*ADDED AS PART OF Q4*/
         	HDR.SCORECRD_VER AS PD_SCORECRD_VER, 
         	HDR.BASEL_SCORECRD_NM AS PD_BASEL_SCORECRD_NM,
         	SPLPD.BASEL_SEG_ID AS PD_BASEL_SEG_ID, /*MODIFIED AS PART OF Q4*/
         	LKP_SEG.SEG_NUM AS PD_BASEL_SEG_NUM, /*MODIFIED AS PART OF Q4*/
         	LKP_SEG.SEG_VER AS PD_SEG_VER, /*ADDED AS PART OF Q4*/
         	LKP_PARM.LR_RTO AS PD_LR_RPTG_RTO,
         	LKP_PARM.LR_PV_RTO AS PD_LR_PV_RPTG_RTO,
         	LKP_PARM.LR_PV_AD_RTO AS PD_LR_PV_AD_RPTG_RTO,
