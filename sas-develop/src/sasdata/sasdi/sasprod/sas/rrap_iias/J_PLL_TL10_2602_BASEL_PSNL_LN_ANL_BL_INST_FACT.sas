         	LKP_PARM.LR_PV_AD_SV_DT_AA_RTO AS PD_LR_PV_AD_SV_DT_AA_RTO,
         	SPLLGD.BASEL_SEG_ID AS LGD_BASEL_SEG_ID, /*MODIFIED AS PART OF Q4*/
         	LKP_MODEL1.MODEL_NM AS LGD_MODEL_NM, /*ADDED AS PART OF Q4*/
         	LKP_MODEL1.MODEL_VER AS LGD_MODEL_VER, /*ADDED AS PART OF Q4*/
         	HDR1.BASEL_SCORECRD_NM AS LGD_BASEL_SCORECRD_NM, /*ADDED AS PART OF Q4*/
         	HDR1.SCORECRD_VER AS LGD_SCORECRD_VER, /*ADDED AS PART OF Q4*/
         	LKP_SEG1.SEG_NUM AS LGD_BASEL_SEG_NUM, /*MODIFIED AS PART OF Q4*/
         	LKP_SEG1.SEG_VER AS LGD_SEG_VER, /*ADDED AS PART OF Q4*/
         	SPLPD.BASEL_MODEL_REL_ID AS PD_BASEL_MODEL_REL_ID, /*ADDED AS PART OF Q4*/
         	SPLLGD.BASEL_MODEL_REL_ID AS LGD_BASEL_MODEL_REL_ID, /*ADDED AS PART OF Q4*/
         	PD_VAL.PD_SEGEMENT_RTO AS PD_MODEL_RTO, /*MODIFIED AS PART OF Q4*/
         	LGD_VAL.LGD_SEG_RTO AS LGD_MODEL_RTO, /*MODIFIED AS PART OF Q4*/
         	LKP_PARM1.LR_RTO AS LGD_LR_RPTG_RTO,
         	LKP_PARM1.LR_PV_RTO AS LGD_LR_PV_RPTG_RTO,
         	LKP_PARM1.LR_PV_AD_RTO AS LGD_LR_PV_AD_RPTG_RTO,
         	LKP_PARM1.LR_PV_AD_SV_RTO AS LGD_LD_PV_AD_SV_RPTG_RTO,
         	LKP_PARM1.LR_PV_AD_SV_DT_RTO AS LGD_LD_PV_AD_SV_DT_RPTG_RTO,
         	LKP_PARM1.FINAL_RTO AS LGD_FINAL_RPTG_RTO,
         	LKP_PARM1.UNADJUSTED_RPTG_RTO AS LGD_UNADJUSTED_RPTG_RTO,
         	LKP_PARM1.LR_PV_AD_SV_DT_AA_RTO AS LGD_LR_PV_AD_SV_DT_AA_RTO,
         	SCORE.CALC_SCORE AS PD_ACCT_SCORE, 
         	SCORE1.CALC_SCORE AS LGD_ACCT_SCORE, 
         	TRIM(A.CCAR_BASEL_PRD_TP_NM_A) || '_' || PUT(COALESCE(LKP_SEG.SEG_NUM,.,0), z2.) || '_01_' || PUT(COALESCE(LKP_SEG1.SEG_NUM,.,0), z2.) AS CCAR_BASEL_PRD_TP_NM,
         	CASE WHEN SEC.BASEL_ACCT_ID_CCAR_MATCHED IS NOT NULL THEN ADJUSTED_OS_BAL_AMT*(1-&OS_ADJ_FACTR)
			ELSE A.ADJUSTED_OS_BAL_AMT END AS UPDATED_OS_BAL_AMT

         	FROM NZUSER.ANL_FIRST A 
         
         	LEFT OUTER JOIN NZUSER.PD_SEG_ACCT_XREF_SPL SPLPD 
         			ON A.BASEL_ACCT_ID = SPLPD.BASEL_ACCT_ID AND A.MTH_TM_ID = SPLPD.MTH_TM_ID 
         /*			AND SPLPD.BASEL_MODEL_REL_ID IN (SELECT BASEL_MODEL_REL_ID FROM NZRRAP.BASEL_MODEL_REL WHERE RPTG_USAGE_F = 'Y')*/
         	LEFT OUTER JOIN NZRRAP.BASEL_MODEL_REL REL 
         			ON SPLPD.BASEL_MODEL_REL_ID = REL.BASEL_MODEL_REL_ID AND REL.RPTG_USAGE_F = 'Y'
         	LEFT OUTER JOIN NZRRAP.BASEL_MODEL_SCORECRD_HDR HDR 
         			ON SPLPD.BASEL_MODEL_ID = HDR.BASEL_MODEL_ID AND HDR.BASEL_MODEL_SCORECRD_HDR_ID = REL.BASEL_MODEL_SCORECRD_HDR_ID
         	LEFT OUTER JOIN NZRRAP.BASEL_MODEL LKP_MODEL 
         			ON SPLPD.BASEL_MODEL_ID = LKP_MODEL.BASEL_MODEL_ID AND "&MTH_END_DT"d BETWEEN LKP_MODEL.MODEL_ST_DT AND LKP_MODEL.MODEL_END_DT
         	LEFT OUTER JOIN NZRRAP.BASEL_SEG LKP_SEG 
         			ON SPLPD.BASEL_SEG_ID = LKP_SEG.BASEL_SEG_ID AND (LKP_SEG.SEG_END_DT IS NULL OR LKP_SEG.SEG_END_DT >= "&MTH_END_DT"d) AND LKP_SEG.SEG_ST_DT <= "&MTH_END_DT"d 
         	LEFT OUTER JOIN NZUSER.LGD_SEG_ACCT_XREF_SPL SPLLGD 
         			ON A.BASEL_ACCT_ID = SPLLGD.BASEL_ACCT_ID AND A.MTH_TM_ID = SPLLGD.MTH_TM_ID
         /*			AND SPLLGD.BASEL_MODEL_REL_ID IN (SELECT BASEL_MODEL_REL_ID FROM NZRRAP.BASEL_MODEL_REL WHERE RPTG_USAGE_F = 'Y')*/
         	LEFT OUTER JOIN NZRRAP.BASEL_MODEL_REL REL1 
         			ON SPLLGD.BASEL_MODEL_REL_ID = REL1.BASEL_MODEL_REL_ID AND REL1.RPTG_USAGE_F = 'Y'
         	LEFT OUTER JOIN NZRRAP.BASEL_MODEL_SCORECRD_HDR HDR1 
         			ON SPLLGD.BASEL_MODEL_ID = HDR1.BASEL_MODEL_ID AND HDR1.BASEL_MODEL_SCORECRD_HDR_ID = REL1.BASEL_MODEL_SCORECRD_HDR_ID
         	LEFT OUTER JOIN NZRRAP.BASEL_MODEL LKP_MODEL1 
         			ON SPLLGD.BASEL_MODEL_ID = LKP_MODEL1.BASEL_MODEL_ID AND "&MTH_END_DT"d BETWEEN LKP_MODEL1.MODEL_ST_DT AND LKP_MODEL1.MODEL_END_DT 
         	LEFT OUTER JOIN NZRRAP.BASEL_SEG LKP_SEG1 
         			ON SPLLGD.BASEL_SEG_ID = LKP_SEG1.BASEL_SEG_ID AND (LKP_SEG1.SEG_END_DT IS NULL OR LKP_SEG1.SEG_END_DT >= "&MTH_END_DT"d) AND LKP_SEG1.SEG_ST_DT <= "&MTH_END_DT"d 
         	LEFT OUTER JOIN NZUSER.PD_SEG_MTH_REALZ_VAL_SPL PD_VAL 
         			ON SPLPD.BASEL_SEG_ID = PD_VAL.BASEL_SEG_ID AND SPLPD.BASEL_MODEL_REL_ID = PD_VAL.BASEL_MODEL_REL_ID
         	LEFT OUTER JOIN NZUSER.LGD_SEG_MTH_REALZ_VAL_SPL LGD_VAL 
         			ON SPLLGD.BASEL_SEG_ID = LGD_VAL.BASEL_SEG_ID AND SPLLGD.BASEL_MODEL_REL_ID = LGD_VAL.BASEL_MODEL_REL_ID
         	LEFT OUTER JOIN NZRRAP.BASEL_SEG_RPTG_PARM LKP_PARM 
         			ON SPLPD.BASEL_SEG_ID = LKP_PARM.BASEL_SEG_ID AND "&MTH_ST_DT"d BETWEEN LKP_PARM.EFF_FROM_DT AND LKP_PARM.EFF_TO_DT
         	LEFT OUTER JOIN NZRRAP.BASEL_SEG_RPTG_PARM LKP_PARM1 
         			ON SPLLGD.BASEL_SEG_ID = LKP_PARM1.BASEL_SEG_ID AND "&MTH_ST_DT"d BETWEEN LKP_PARM1.EFF_FROM_DT AND LKP_PARM1.EFF_TO_DT
         	LEFT OUTER JOIN NZRRAP.BASEL_PNL_LN_SCORE_SNAPSHOT SCORE 
         			ON SPLPD.BASEL_ACCT_ID = SCORE.BASEL_ACCT_ID AND SPLPD.BASEL_MODEL_ID = SCORE.BASEL_MODEL_ID 
         			AND SPLPD.MTH_TM_ID = SCORE.MTH_TM_ID AND SCORE.BASEL_MODEL_SCORECRD_HDR_ID = HDR.BASEL_MODEL_SCORECRD_HDR_ID
         	LEFT OUTER JOIN NZRRAP.BASEL_PNL_LN_SCORE_SNAPSHOT SCORE1 
         			ON SPLLGD.BASEL_ACCT_ID = SCORE1.BASEL_ACCT_ID AND SPLLGD.BASEL_MODEL_ID = SCORE1.BASEL_MODEL_ID 
         			AND SPLLGD.MTH_TM_ID = SCORE1.MTH_TM_ID AND SCORE1.BASEL_MODEL_SCORECRD_HDR_ID = HDR1.BASEL_MODEL_SCORECRD_HDR_ID
         	LEFT OUTER JOIN WORK.SPL_SEC_ACCTS SEC 
         			ON SPLPD.BASEL_ACCT_ID = SEC.BASEL_ACCT_ID_CCAR_MATCHED AND SPLPD.MTH_TM_ID = SEC.MTH_TM_ID 

         /*	WHERE REL.RPTG_USAGE_F = 'Y' and REL1.RPTG_USAGE_F = 'Y'*/
         	;
         QUIT;
         
         /*********** SECURITIZATION CHANGES ***************/
		 data ANL_SECOND_INT;
			set ANL_SECOND;
			ADJUSTED_OS_BAL_AMT=UPDATED_OS_BAL_AMT;
			drop UPDATED_OS_BAL_AMT;
		run;


         proc sql;
          create table ANL_THIRD as
          select distinct a.*,
         		CASE 
         			WHEN A.E_MAT_DT = . THEN INTCK('MONTH', "&MTH_END_DT"d, (INTNX('MONTH', A.NOTE_DT, A.AMORT, 'E')))
         			WHEN A.E_MAT_DT < "&MTH_END_DT"d THEN INTCK('MONTH', "&MTH_END_DT"d, A.LAST_RGL_PAY_DT)
         			ELSE INTCK('MONTH', "&MTH_END_DT"d, A.E_MAT_DT) 
         		END 
         				AS RESIDUAL_MAT
         FROM ANL_SECOND_INT A
         /*where clause added to exclude invalid product type*/
         /*where a.CCAR_BASEL_PRD_TP_NM not in  ('DTL_UNSEC_99_01_00','DTL_OTHER_07_01_00')*/
         ;
         QUIT;
         
         
         proc sort data=ANL_THIRD(drop=CCAR_BASEL_PRD_TP_NM_A) nodupkey; by mth_tm_id basel_acct_id src_sys_cd; run;
         
         
         %delete_table(nzuser.qtr_month);
         
         data nzuser.QTR_MONTH;
         	format REF_DATE QTR_MONTH date9.;
         	do REF_DATE = intnx('YEAR',"&sysdate9."d,-2,'b') to intnx('YEAR',"&sysdate9."d,2,'e');
         		QTR_MONTH=intnx('Month',intnx('QTR.2',REF_DATE,0,'e'),0,'e');
         		y=intnx('Month',REF_DATE,0,'e');
         		if y = ref_date then output;
         	end;
         	drop y;
         run;
         
         %macro translate(dset);
         	STRIP(COMPBL(compress((translate(lowcase(&dset),"aaaceeeeiiouuuy    ","àâäçèéêëîïôùûüÿ,-'/")),,'kadt')))
         %mend translate;
         
         PROC SQL NOPRINT;
         	CREATE TABLE DLGD AS
         	SELECT 
         	a.MTH_TM_ID, a.basel_acct_id, a.STEP_PLN_SNAPSHOT_ID 
         	,B.PRD_ID, a.NOTE_DT, COALESCE(d.METRPL_BREACH_F, d2.METRPL_BREACH_F) AS METRPL_BREACH_F, c.LOCTN_LABEL_2, COALESCE(d.METRPL_AREA_NM, d2.METRPL_AREA_NM) as METRPL_AREA_NM_compare, t.tm_lvl_end_dt , 
         	q.QTR_MONTH, d.mth_tm_id as D_mth_tm_id, t.tm_id, h.final_rto, g.basel_seg_id
         
         	,'Y' AS DLGD_F
			,CASE 
				WHEN c.LOCTN_LABEL_2 = 'N/A' then '11'
				ELSE COALESCE(c.LOCTN_LABEL_2,'11') 
			END as METRPL_AREA_NM
         	,CASE 
         		WHEN COALESCE(d.METRPL_BREACH_F, d2.METRPL_BREACH_F) = 'Y' and e.CRNT_PRPTY_VAL_AMT ne 0 then max(1-(e.PREV_12_QTR_PRPTY_VAL_AMT/e.CRNT_PRPTY_VAL_AMT),0.25)
         		WHEN (COALESCE(d.METRPL_BREACH_F, d2.METRPL_BREACH_F) = 'N' or COALESCE(d.METRPL_BREACH_F, d2.METRPL_BREACH_F) IS NULL) and e.CRNT_PRPTY_VAL_AMT ne 0 then max(1-(e.PREV_12_QTR_PRPTY_VAL_AMT/e.CRNT_PRPTY_VAL_AMT),0)
         		ELSE .
         	END AS PRPTY_VAL_CORR_PCTG
         	,f.CRNT_LTV_RTO
         /*	,f.INDEXED_CCLTV_RTO*/
         	,CASE 
         		WHEN f.CRNT_LTV_RTO ne . and f.CRNT_LTV_RTO ne 0 and calculated PRPTY_VAL_CORR_PCTG ne . then 
         			CASE WHEN f.INDEXED_CCLTV_RTO ne . then MAX((MIN(f.CRNT_LTV_RTO,MAX(f.INDEXED_CCLTV_RTO-0.8*(1-calculated PRPTY_VAL_CORR_PCTG),0))-MAX(f.INDEXED_CCLTV_RTO-0.8,0))/f.CRNT_LTV_RTO,0)
         				 ELSE (MAX(f.CRNT_LTV_RTO-0.8*(1-calculated PRPTY_VAL_CORR_PCTG),0)-MAX(f.CRNT_LTV_RTO-0.8,0))/f.CRNT_LTV_RTO
         			END
         		ELSE . 
         	END as LNG_RUN_LGD_ADD_ON_RTO
         
         	,CASE 
         		WHEN calculated LNG_RUN_LGD_ADD_ON_RTO ne . then 
         			MAX(0.1,h.final_rto, MIN(1,(COALESCE(h.UNADJUSTED_RPTG_RTO,0) + calculated LNG_RUN_LGD_ADD_ON_RTO)))
         		ELSE h.final_rto
         	END as DLGD_RPTG_RTO_OLD format=32.20
	
         	,e.PREV_12_QTR_PRPTY_VAL_AMT
         
         	FROM 	  
            NZRRAP.BASEL_PSNL_LOAN_MTH_SNAPSHOT a 
         
         	LEFT JOIN NZRRAP.TM_DIM tt
         				ON a.MTH_TM_ID = tt.TM_ID AND tT.TM_LVL = 'Month'
         
         	LEFT JOIN nzuser.QTR_MONTH q
         				ON tt.tm_lvl_end_dt = q.REF_DATE
         
         	LEFT JOIN NZRRAP.TM_DIM t
         				ON t.tm_lvl_end_dt = q.QTR_MONTH and T.TM_LVL='Month'
         
         	inner JOIN NZRRAP.BASEL_PSNL_LOAN_ACCT_DRVD_VARS_2 b 
         				ON a.BASEL_ACCT_ID = b.BASEL_ACCT_ID 
         				AND a.MTH_TM_ID = b.MTH_TM_ID
         
         	LEFT JOIN NZRRAP.BASEL_STEP_PLN_BASE_DRVD_VAR_CMA c 
         				ON a.STEP_PLN_SNAPSHOT_ID = c.BASEL_STEP_PLN_SNAPSHOT_ID 
         				AND a.MTH_TM_ID = c.MTH_TM_ID
         
         	LEFT JOIN NZRRAP.DLGD_SCRI_QTR_DRVD_VARS d 
         				ON d.mth_tm_id = t.tm_id  
         /*				and t.tm_lvl_end_dt = q.REF_DATE*/
         				AND %translate(c.LOCTN_LABEL_2) = %translate(d.METRPL_AREA_NM) 

			/* RRMSS-1557 map new CMAs as '11' for breach flag  */
			LEFT JOIN NZRRAP.DLGD_SCRI_QTR_DRVD_VARS d2 ON d.METRPL_AREA_NM IS NULL AND TRIM(d2.METRPL_AREA_NM)='11' AND d2.MTH_TM_ID=t.tm_id 
         
         	LEFT JOIN NZRRAP.BASEL_STEP_LTV_DRVD_VARS_CMA e on a.mth_tm_id = e.mth_tm_id 
         				and a.STEP_PLN_SNAPSHOT_ID = e.STEP_PLN_SNAPSHOT_ID
         				and e.STEP_PLN_SNAPSHOT_ID ne -1
         
         	LEFT JOIN NZRRAP.BASEL_ACCT_LTV_DRVD_VARS_CMA f
         				ON a.mth_tm_id = f.mth_tm_id
         				and a.basel_acct_id = f.basel_acct_id and f.acct_senrty_cd=3
         
         	LEFT JOIN NZUSER.LGD_SEG_ACCT_XREF_SPL g
         				ON a.mth_tm_id = g.mth_tm_id and a.basel_acct_id = g.basel_acct_id
         
         	LEFT JOIN NZRRAP.BASEL_SEG_RPTG_PARM h
         				ON g.basel_seg_id = h.basel_seg_id and t.tm_lvl_end_dt between h.EFF_FROM_DT and h.EFF_TO_DT
         	
         	LEFT JOIN NZRRAP.BASEL_PSNL_LOAN_ACCT_DRVD_VARS_2 i
         				ON i.basel_Acct_id = a.basel_acct_id and i.mth_tm_id = a.mth_tm_id
         
         	WHERE a.MTH_TM_ID = &MTH_TM_ID. 
         			and UPCASE(b.PRD_ID) IN ('S05','S08') AND a.NOTE_DT GE "&dlgd_date."d
                     and g.basel_seg_id not in (.,16136,16135,16162,16155,16128,16156,16163,16164,16134) 
         				and i.PIT_STATUS_V2  in ('CUR')						
         	order by mth_tm_id, basel_Acct_id
         ;
         QUIT;
         
/* Jira 1646 Changes start here 
   Added columns LTV_BUCKET & RNTL_PRPTY_F
