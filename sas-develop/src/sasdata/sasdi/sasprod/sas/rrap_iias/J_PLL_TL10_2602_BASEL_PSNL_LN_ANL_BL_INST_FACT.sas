     PROC SQL NOPRINT;
         	CONNECT USING NZRRAP AS NZCON;
         	CREATE TABLE ACCT_PRFM AS
         		SELECT * FROM CONNECTION TO NZCON (     		 
				 SELECT mth_tm_id,
						'CA0201'||LPAD(a.ACCT_NUM,23,'0') AS uq_acct_id, 
						a.basel_Acct_id,
						a.CURRENCY_MISMATCH_F,
						a.TOT_EXPSR_ABOVE_1500K_LMT_F,
						a.LTV_BCKT_CD AS LTV_BUCKET,
						a.RNTL_INCM_DPNDCY_F AS RNTL_PRPTY_F,
						a.CLP_FLAG as CLP_FLAG   /*RRMSS-1907*/
				FROM &RRAP_DB..BASEL_ACCT_PRFM_FACT a 
				WHERE mth_tm_id=&MTH_TM_ID. AND src_sys_cd='SL' 
			);
         QUIT;

 %delete_table(nzuser.qtr_month);
         
 proc sql;
         create table final as
          select distinct a.*
         		,coalesce(b.DLGD_F,'N') as DLGD_F
         		,b.METRPL_AREA_NM
         		,b.PRPTY_VAL_CORR_PCTG
         		,b.CRNT_LTV_RTO
         		,b.LNG_RUN_LGD_ADD_ON_RTO
         		,COALESCE(b.DLGD_RPTG_RTO_OLD,a.LGD_FINAL_RPTG_RTO) as DLGD_RPTG_RTO_OLD
/*				,COALESCE(b.DLGD_RPTG_RTO,a.LGD_FINAL_RPTG_RTO) as UNINSURED_DLGD_RTO*/
         		,b.PREV_12_QTR_PRPTY_VAL_AMT
				,ap.CURRENCY_MISMATCH_F
				,ap.TOT_EXPSR_ABOVE_1500K_LMT_F
				,LGD_BASEL_SEG_NUM as UNINSURED_LGD_SEG_NUM
				,LGD_FINAL_RPTG_RTO as UNINSURED_LGD_RTO				  
				, ap.LTV_BUCKET
				, ap.RNTL_PRPTY_F
				, '' as Transactor_F
				, . as ORIG_AMT_LOAN
         		,"&SYSDATE9.:&SYSTIME"dt as INSRT_PROCESS_TMSTMP
         		,"&SYSDATE9.:&SYSTIME"dt as UPDT_PROCESS_TMSTMP
				,(case when CONSM_PRD_TREATMNT_CD = 'A' and pd_final_rptg_rto >= 1 then 'True'
						when CONSM_PRD_TREATMNT_CD = 'A' and pd_final_rptg_rto < 1 then 'False'
						else '' end) as PD_90_day_F
				,'' AS TRANSACTOR_FLAG_QRR /*Added as part of 1590 Basel 3*/
				,ap.CLP_FLAG /*RRMSS-1907*/
				, '' as BCAR_SCHED_NM  /*RRMSS-1907*/
				, '' as BCAR_SCHED_NUM_50  /*RRMSS-1907*/
         from anl_third a left join dlgd b
         on a.mth_tm_id = b.mth_tm_id and a.basel_acct_id = b.basel_acct_id
		left join ACCT_PRFM AP on a.mth_tm_id = ap.mth_tm_id and a.BASEL_ACCT_ID = ap.BASEL_ACCT_ID;
         quit;



