         	NVL(SUM(LGD_REALZ_RTO*LGD_REALZ_ACCT_CNT)/NULLIF(SUM(LGD_REALZ_ACCT_CNT),0),0) 
         	AS LGD_REALZ_RTO,/*HANDLING DIVIDE BY ZERO*/
         	NVL(SUM(EAD_REALZ_RTO*EAD_REALZ_ACCT_CNT)/NULLIF(SUM(EAD_REALZ_ACCT_CNT),0),0) 
         	AS EAD_REALZ_RTO,/*HANDLING DIVIDE BY ZERO*/
         	SUM(PD_REALZ_DEFLTD_ACCT_CNT) AS PD_DEFLTD_PREV_12_MTH_ACCT_CNT,
         	SUM(LGD_REALZ_DEFLTD_ACCT_CNT) AS LGD_DEFLTD_PREV_36_MTH_ACCT_CNT,
         	SUM(EAD_REALZ_DEFLTD_ACCT_CNT) AS EAD_EVER_DF_PREV_12_MTH_ACCT_CNT,
         	SUM(PD_REALZ_DEFLTD_OS_BAL_AMT) AS PD_REALZ_OS_BAL_AMT,
         	SUM(LGD_REALZ_DEFLTD_OS_BAL_AMT) AS LGD_REALZ_OS_BAL_AMT,
         	SUM(EAD_REALZ_DEFLTD_OS_BAL_AMT) AS EAD_REALZ_OS_BAL_AMT
         	FROM &DBSCHEMA..BASEL_CANDN_RTL_NCR_BE_FACT
         	WHERE MTH_TM_ID = &MTH_TM_ID. AND ECONMC_CAPTL_AMT IS NULL /* &MTH_TM_ID USED FOR 
         	TESTING */
         	GROUP BY CUBE ( /*GROUP BY CUBE USED HERE */
         	NCR_RISK_RT_SYS_ID,
         	EXPSR_CL_ID,
         	NCR_PD_SEG_ID,
         	NCR_LGD_SEG_ID,
         	NCR_EAD_SEG_ID);
         	);
         QUIT;
         
         ***
         GROUP BY
         NCR_RISK_RT_SYS_ID,
         EXPSR_CL_ID,
         NCR_PD_SEG_ID,
         NCR_LGD_SEG_ID,
         NCR_EAD_SEG_ID
         );
         QUIT;
         
         /*STEP 2 OF BSTM*/
         /*UPDATE MASTER TABLE CREATED IN STEP 1 WITH VALID VALUES EXTRACTED AT THE 
         BEGINNING OF THE MACRO THUS REPLACING NULL VALUES*/
         DATA _temp_backtest_first;
         	SET _temp_backtest_first;
         	IF NCR_RISK_RT_SYS_ID=. THEN DO; NCR_RISK_RT_SYS_ID=&V_NCR_RISK_RT_SYS_ID; END;
         	IF EXPSR_CL_ID=. THEN DO; EXPSR_CL_ID=&V_EXPSR_CL_ID; END;
         	IF NCR_PD_SEG_ID=. THEN DO; NCR_PD_SEG_ID=&V_NCR_PD_SEG_ID; END;
         	IF NCR_LGD_SEG_ID=. THEN DO; NCR_LGD_SEG_ID=&V_NCR_LGD_SEG_ID; END;
         	IF NCR_EAD_SEG_ID=. THEN DO; NCR_EAD_SEG_ID=&V_NCR_EAD_SEG_ID; END;
         RUN;
         
         /*STEP 3 OF BSTM*/
         /*CREATE A TABLE WITH DISTINCT EXPOSURE CLASS ID AND LGD SEGMENT ID WITH LEAST 
         LGD AVERAGE RATIO FROM MASTER TABLE CREATED IN STEP 1*/
         PROC SQL NOPRINT;
         	CREATE TABLE _temp_backtest_second AS 
         	SELECT EXPSR_CL_ID, NCR_LGD_SEG_ID, MIN(LGD_ESTD_AVG_RTO) AS 
         	UPD_LGD_ESTD_AVG_RTO FROM _temp_backtest_first
         	WHERE EXPSR_CL_ID<>&V_EXPSR_CL_ID AND NCR_LGD_SEG_ID<>&V_NCR_LGD_SEG_ID AND 
         	ACCT_CNT>0
         	GROUP BY EXPSR_CL_ID, NCR_LGD_SEG_ID;
         QUIT;
         /*UPDATE THE MASTER TABLE WITH DATA IN TABLE CREATED ABOVE USING MATCHED 
         MERGING BUT ONLY FOR THOSE RECORDS WHERE ACCT_CNT = 0*/
         PROC SQL NOPRINT;
         	UPDATE _temp_backtest_first AS A SET LGD_ESTD_AVG_RTO=(SELECT 
         	UPD_LGD_ESTD_AVG_RTO FROM _temp_backtest_second AS B
         	WHERE A.EXPSR_CL_ID=B.EXPSR_CL_ID AND A.NCR_LGD_SEG_ID=B.NCR_LGD_SEG_ID AND 
         	A.ACCT_CNT=0)
         	WHERE A.EXPSR_CL_ID IN (SELECT EXPSR_CL_ID FROM 
         	_temp_backtest_second) AND 
         	A.NCR_LGD_SEG_ID IN (SELECT NCR_LGD_SEG_ID FROM 
         	_temp_backtest_second)
         	AND A.ACCT_CNT=0;
         QUIT;
         
         /*STEP 4 OF BSTM*/
         /*CREATE A TABLE WITH DISTINCT EXPOSURE CLASS ID AND EAD SEGMENT ID WITH LEAST 
         EAD AVERAGE RATIO FROM MASTER TABLE CREATED IN STEP 1*/
         PROC SQL NOPRINT;
         	CREATE TABLE _temp_backtest_third AS 
         	SELECT EXPSR_CL_ID, NCR_EAD_SEG_ID, MIN(EAD_ESTD_AVG_RTO) AS 
         	UPD_EAD_ESTD_AVG_RTO FROM _temp_backtest_first
         	WHERE EXPSR_CL_ID<>&V_EXPSR_CL_ID AND NCR_EAD_SEG_ID<>&V_NCR_EAD_SEG_ID AND 
         	ACCT_CNT>0
         	GROUP BY EXPSR_CL_ID, NCR_EAD_SEG_ID;
         QUIT;
         /*UPDATE THE MASTER TABLE WITH DATA IN TABLE CREATED ABOVE USING MATCHED 
         MERGING BUT ONLY FOR THOSE RECORDS WHERE ACCT_CNT = 0*/
         PROC SQL NOPRINT;
         	UPDATE _temp_backtest_first AS A SET EAD_ESTD_AVG_RTO=(SELECT 
         	UPD_EAD_ESTD_AVG_RTO FROM _temp_backtest_third AS B
         	WHERE A.EXPSR_CL_ID=B.EXPSR_CL_ID AND A.NCR_EAD_SEG_ID=B.NCR_EAD_SEG_ID AND 
         	A.ACCT_CNT=0)
         	WHERE A.EXPSR_CL_ID IN (SELECT EXPSR_CL_ID FROM _temp_backtest_third) 
         	AND 
         	A.NCR_EAD_SEG_ID IN (SELECT NCR_EAD_SEG_ID FROM _temp_backtest_third)
         	AND A.ACCT_CNT=0;
         QUIT;
         /*ADD MONTH_TM_ID TO THE FINAL RESULT. THIS PREVENTS USE OF MACRO VARIABLES IN 
         INSERT STATEMENT BELOW THUS PREVENTING DB2 LOAD ERRORS*/
         DATA _temp_backtest_first;
         	SET _temp_backtest_first;
         	MTH_TM_ID=&MTH_TM_ID;
         	FORMAT MTH_TM_ID 8.;
         RUN;
         /*INSERT FINAL RESULT INTO THE DB2 TARGET TABLE*/
         PROC SQL NOPRINT;
         INSERT INTO BTT.BASEL_NCR_BACK_TESTNG_FACT
         SELECT 
         	MTH_TM_ID, 
         	NCR_RISK_RT_SYS_ID,
         	EXPSR_CL_ID,
         	NCR_PD_SEG_ID,
         	NCR_LGD_SEG_ID,
         	NCR_EAD_SEG_ID,
         	ACCT_CNT,
         	PD_ESTD_AVG_RTO,
         	LGD_ESTD_AVG_RTO,
         	EAD_ESTD_AVG_RTO,
         	NON_DEFLTD_PREV_12_MTH_ACCT_CNT,
         	LGD_CALC_PREV_36_MTH_ACCT_CNT,
         	EVER_DEFLTD_PREV_12_MTH_ACCT_CNT,
         	PD_REALZ_RTO,
         	LGD_REALZ_RTO,
         	EAD_REALZ_RTO,
         	PD_DEFLTD_PREV_12_MTH_ACCT_CNT,
         	LGD_DEFLTD_PREV_36_MTH_ACCT_CNT,
         	EAD_EVER_DF_PREV_12_MTH_ACCT_CNT,
         	PD_REALZ_OS_BAL_AMT,
         	LGD_REALZ_OS_BAL_AMT,
         	EAD_REALZ_OS_BAL_AMT,
         	"&SYSDATE9.:&SYSTIME."dt AS INSRT_PROCESS_TMSTMP,
         	"&SYSDATE9.:&SYSTIME."dt AS UPDT_PROCESS_TMSTMP
         FROM _temp_backtest_first;
         QUIT;
         /*END OF MACRO*/
         %MEND;
         /*EXECUTE THE MACRO*/
         %basel_ncr_back_testing_fact;
         
         
         %datalog;
         %PUT 
         PROCESSING MONTH IS &MTH_TM_ID 
         YEARMONTH IS &YEARMONTH 
         PRELOAD DATA COUNT IN TARGET FOR &MTH_TM_ID IS &PRELOAD_DATA_COUNT 
         &INPUT00. COUNT IS &SRCCOUNT00 
         &TGT00. COUNT IS &TGTCOUNT00 ;
         
         /*%SAS_DATASET_CLEANUP(LIBREF=INPATH,DATASETS=_temp_backtest_first _temp_backtest_second _temp_backtest_third);*/
         
         %exitetls_conditionW36PM3VD:
         %mend etls_conditionW36PM3VD;
         
         %etls_conditionW36PM3VD;
         
         %PUT etls_endTime = %sysfunc(datetime(),datetime.);
         
         /*---- End of User Written Code  ----*/ 
         
      %mend etls_jobW2IY1Q9; 
      
      %etls_jobW2IY1Q9; 
      
      %let handleName = %etls_getHandle(statusTable=&etls_statusTable,
         handleVariable=etls_handleName, row=&&&etls_controlName);
         
      %let job_rc&handleName. = &job_rc; 
      
      %etls_freeHandle(statusTable=&etls_statusTable, statusVariable=etls_status, 
         handleVariable=etls_handleName, handleName="&handleName", 
         startTimeVariable=etls_startTime, endTimeVariable=etls_endTime, signoff=0, 
         returnCodeVariable=etls_jobRC, returnCodeMacroVariable=job_rc&handleName., setMainJobRc=1); 
         
   %mend etls_processToLoopW2IY1PZ;
   
   %local etls_controlTable etls_statusTable etls_controlName 
      etls_processesRunning etls_maxProcesses etls_parameterTable 
      etls_additionalSignonOptions etls_signonRetries;
   %let etls_controlName = L65_; 
   %let etls_statusTable = work.WUSRQW9; 
   %let etls_parameterTable = work.W2IY1PV; 
   %let &etls_controlName = 0;
   %let etls_controlTable = work.LOOP_DATES_R;
   
   %put %str(NOTE: Creating status table...);
   data &etls_statusTable 
      (keep = etls_handleName etls_machineId etls_startTime etls_endTime etls_status 
              etls_jobRC mth_tm_id
      );
      attrib etls_handleName length = $32
         label = 'Name of handle to remote session'; 
      attrib etls_machineId length = $32
         label = 'Name of machine executing the task'; 
      attrib etls_startTime length = 8
         format = nldatmap.
         label = 'Start time of task'; 
      attrib etls_endTime length = 8
         format = nldatmap.
         label = 'End time of task'; 
      attrib etls_status length = $32
         label = 'Current status of task'; 
      attrib etls_jobRC length = 8
         label = 'Return code of task'; 
      attrib mth_tm_id length = 8
         format = 20.
         informat = 20.
         label = 'TM_ID'; 
      set &etls_controlTable;
   run;
   
   %rcSet(&syserr); 
   
   %put %str(NOTE: Creating parameter table...);
   proc sql; 
      create table &etls_parameterTable as 
         select mth_tm_id as mth_tm_id 
         from &etls_controlTable; 
   quit; 
   
   %rcSet(&sqlrc); 
   
   /* Get the number of times to iterate from the number of rows in the source  */ 
   /*  table                                                                    */ 
   proc sql noprint; 
      select count(*) into :&etls_controlName._max from &etls_statusTable;
      %let &etls_controlName._max = &&&etls_controlName._max;
   quit;
   
   %rcSet(&sqlrc); 
   
   %let etls_maxProcesses = 1; 
   
   %if (&etls_maxProcesses > 0) %then 
   %do; 
      %do %until (&&&etls_controlName ge &&&etls_controlName._max); 
      
         %let etls_lastLoopPtr = &&&etls_controlName;
         
         %let etls_processesRunning = 0; 
         
         %do %while(&etls_processesRunning lt &&&etls_controlName._max 
            and &etls_processesRunning lt &etls_maxProcesses 
            and &&&etls_controlName lt &&&etls_controlName._max);
            
            %let &etls_controlName = %eval(&&&etls_controlName+1);
            
            %let job_rcLast=&job_rc; 
            
            %etls_createHandle(statusTable=&etls_statusTable,
                               statusVariable=etls_status,
                               handleVariable=etls_handleName,
                               handlePrefix=&etls_controlName,
                               statusSetting="Running",
                               row=&&&etls_controlName,
                               machineVariable=etls_machineId,
                               startTimeVariable=etls_startTime,
                               signon=0,
                               useGrid=0);
            
         %let etls_processesRunning = 1; 
         %etls_processToLoopW2IY1PZ(parameterTable=&etls_parameterTable, row=&&&etls_controlName,
            handleName=%etls_getHandle(statusTable=&etls_statusTable,
            handleVariable=etls_handleName, row=&&&etls_controlName)); 
         
         /* Reset main Job_RC and Trans_RC to max return code of all iterations */ 
         %let job_rcThisIter=&job_rc; 
         %let job_rc=&job_rcLast; 
         %let trans_rc=&job_rcLast; 
         %rcSet(&job_rcThisIter); 
      %end; 
      
   %end; 
   
%end;

