/*REPROCESSING LOGIC*/
%MACRO TO_DELETE();

%LET START_MT=&MTH_TM_ID;
%LET END_MT=&MTH_TM_ID;

%DO i = &START_MT %TO &END_MT %BY 1;
	%LET MTH_LEFT = %EVAL(((&END_MT-&i.))/40);
	%LET PARTITIONS=10;
        %DO p=0 %TO %EVAL(&PARTITIONS -1);

        PROC SQL NOPRINT;
			CONNECT USING EDRRAPT AS DBCON;
			EXECUTE(DELETE FROM EDRRAPT.BASEL_CC_SEC_ACCT_MTH_SNAP WHERE 
                MOD(BASEL_ACCT_ID_CCAR_MATCHED,&PARTITIONS.) = &p. AND BASEL_ACCT_ID_CCAR_MATCHED IS NOT NULL 
				AND MTH_TM_ID=&i.
				AND SECRTZTN_TP_CD='AUTO') BY DBCON;
			DISCONNECT FROM DBCON;
        QUIT;
		%PUT Partition &p. for mth_tm_id &i. for AUTO deleted.;
		%END;

		PROC SQL NOPRINT;
			CONNECT USING EDRRAPT AS DBCON;
			EXECUTE(DELETE FROM EDRRAPT.BASEL_CC_SEC_ACCT_MTH_SNAP WHERE MTH_TM_ID=&i. AND SECRTZTN_TP_CD='AUTO') BY DBCON;
		DISCONNECT FROM DBCON;
        QUIT;

	%PUT Delete of mth_tm_id=&i. complete.;
%END;

%MEND TO_DELETE;

%TO_DELETE;

proc sql;
	connect using nzuser as nzcon;
	create table DRAPT.SPL_ACCOUNTS_FROM_INSTR_FACT as 
			select MTH_TM_ID, PRD_CD, OS_BAL_AMT, BASEL_ACCT_ID, ADJUSTED_OS_BAL_AMT, OS_PRNCPL_BAL_AMT, 
				INPUT(strip(CRNT_BR_LOCTN_TRNST)||strip(LOAN_NUM),12.) AS UNIQUE_ACCOUNTS FORMAT=12. 
		from connection to nzcon
		(
			select src_sys_cd, 
			 ss.MTH_TM_ID, 
			 bdv.prd_id as	PRD_CD, 
             ss.tot_crnt_bal_amt as OS_BAL_AMT, 
			 ss.BASEL_ACCT_ID,         
			 CASE 
         			WHEN BDV.PIT_STATUS_V2 = 'CUR' AND BDV.TREATMNT_F = 'A' AND BD.TRNST_EXCLSN_F = 'N' AND BDV.PRD_ID IN ('S09', 'S10') THEN IJ.AF_ADJ_OS_BAL_AMT 
         			ELSE BDV.OS_BAL_AMT_V2 
         		END 
         			AS ADJUSTED_OS_BAL_AMT, 

             bdv.OS_BAL_AMT_V2 as OS_PRNCPL_BAL_AMT, 
             ss.CRNT_BR_LOCTN_TRNST,
			 ss.LOAN_NUM
		from &net_db..BASEL_PSNL_LOAN_MTH_SNAPSHOT ss
		
		LEFT OUTER JOIN &net_db..BASEL_PSNL_LOAN_ACCT_DRVD_VARS BD
			ON SS.BASEL_ACCT_ID=BD.BASEL_ACCT_ID and ss.MTH_TM_ID=bd.mth_tm_id and ss.mth_tm_id=&mth_tm_id.

		LEFT OUTER JOIN &net_db..BASEL_PSNL_LOAN_ACCT_DRVD_VARS_2 BDV
			ON SS.BASEL_ACCT_ID=BDV.BASEL_ACCT_ID and ss.MTH_TM_ID=bdv.mth_tm_id and ss.mth_tm_id=&mth_tm_id.

		left outer join &net_db..PSNL_LOAN_RPTG_PRD_LKP lkp
		 	on BDV.PRD_ID = lkp.PRD_ID
		
		left outer join &net_db..BASEL_PSNL_LOAN_INSTRMNT_ADJ IJ
			on ss.BASEL_ACCT_ID=IJ.basel_acct_id and ss.mth_tm_id=ij.mth_tm_id and ss.mth_tm_id=&mth_tm_id.

		where ss.mth_tm_id=&mth_tm_id. 
			and ss.tot_crnt_bal_amt>=0 
			AND bdv.TREATMNT_F = 'A' AND bdv.PIT_STATUS_V2 IN ('CUR','DEF')
			AND bd.TRNST_EXCLSN_F = 'N' 
			AND lkp.PRD_ID IN ('S09', 'S10')
		);	
quit;

/*FETCHING ACCOUNTS FROM BASEL_REVLVNG_CR_MTH_SNAPSHOT*/

PROC SQL NOPRINT;
CREATE TABLE DRAPT.SPL_ACCOUNTS_FROM_ACCT_DIM AS 
SELECT MTH_TM_ID,  
INPUT(strip(CRNT_BR_LOCTN_TRNST)||strip(LOAN_NUM),12.) AS UNIQUE_ACCOUNTS FORMAT=12.,
BASEL_ACCT_ID
FROM 
NZRRAP.BASEL_PSNL_LOAN_MTH_SNAPSHOT
WHERE 
MTH_TM_ID=&MTH_TM_ID;
QUIT;

/*CREATING THE ACCOUNT SNAPSHOT*/
PROC SQL NOPRINT;
CREATE TABLE DRAPT.SPL_SECUR_ACCT_SNAPSHOT AS 
SELECT 
	&MTH_TM_ID AS MTH_TM_ID,
	STRIP(PUT(T1.ACCOUNT_NUMBER,12.)) AS ACCT_NUM_RECVD,
	T1.OUTSTANDING_BALANCE,
	CASE WHEN T2.UNIQUE_ACCOUNTS=. THEN '' 
		ELSE STRIP(PUT(T2.UNIQUE_ACCOUNTS,12.)) 
	END AS ACCT_NUM_RRAP_DONT,
	T2.BASEL_ACCT_ID AS BASEL_ACCT_ID_DONT,
	T3.BASEL_ACCT_ID AS BASEL_ACCT_ID_CCAR_MATCHED,
	T3.PRD_CD,
	T3.OS_BAL_AMT,
	T3.ADJUSTED_OS_BAL_AMT,
	T3.OS_PRNCPL_BAL_AMT,
	&SESSIONTIME AS INSRT_PROCESS_TMSTMP,
	&SESSIONTIME AS UPDT_PROCESS_TMSTMP,
	'AUTO' AS SECRTZTN_TP_CD,
	T1.SECURITIZATION_DATE
FROM DRAPT.SPL_SOURCE_FILE_ACCOUNTS T1
LEFT OUTER JOIN DRAPT.SPL_ACCOUNTS_FROM_ACCT_DIM T2 ON T1.ACCOUNT_NUMBER=T2.UNIQUE_ACCOUNTS
LEFT OUTER JOIN DRAPT.SPL_ACCOUNTS_FROM_INSTR_FACT T3 ON T1.ACCOUNT_NUMBER=T3.UNIQUE_ACCOUNTS;
QUIT;

/*LOADING THE DB2 TABLES*/
PROC APPEND BASE=EDRRAPT.BASEL_CC_SEC_ACCT_MTH_SNAP 
	(BULKLOAD=YES BL_METHOD=CLILOAD UPDATE_LOCK_TYPE=TABLE BL_LOAD_REPLACE=NO) 
	DATA=DRAPT.SPL_SECUR_ACCT_SNAPSHOT FORCE;
RUN;


