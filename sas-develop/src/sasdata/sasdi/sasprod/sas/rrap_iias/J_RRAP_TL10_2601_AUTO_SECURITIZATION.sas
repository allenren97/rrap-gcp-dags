%MACRO SECURI;
/*READING THE ACCOUNTS FILE*/
PROC IMPORT DATAFILE="&OUTPATH/securitization/cc/incoming/autoloan_securitization_acct_mthly_&YEARMONTH..csv"

OUT=DRAPT.SPL_SOURCE_FILE_ACCOUNTS
DBMS=CSV
REPLACE;
GETNAMES=YES;
RUN;

/*FORMATTING AND REMOVING NULLS DURING LOAD*/
DATA DRAPT.SPL_SOURCE_FILE_ACCOUNTS;
SET DRAPT.SPL_SOURCE_FILE_ACCOUNTS;
WHERE ACCOUNT_NUMBER^=.;
FORMAT ACCOUNT_NUMBER 32.;
RUN;

/*DUPLICATE CHECK*/
PROC SQL NOPRINT;
CREATE TABLE DUPLICATES AS
SELECT * FROM (
SELECT account_number, COUNT(*) AS COUNT
FROM DRAPT.SPL_SOURCE_FILE_ACCOUNTS GROUP BY account_number
) WHERE COUNT > 1
;
QUIT;

PROC SQL NOPRINT;
SELECT sum(count) INTO :DUPE_COUNT FROM DUPLICATES;
QUIT;

data _null_;
  set DUPLICATES;
  if &DUPE_COUNT > 1 then do;
    put "ERROR: There are &DUPE_COUNT. duplicates in the source csv file, please delete duplicates and run this process again.";
    abort cancel;
  end;
run;

/*SAVING THE CSV STATS INTO VARIABLES*/
PROC SQL NOPRINT;
SELECT COUNT(ACCOUNT_NUMBER) FORMAT 15., SUM(OUTSTANDING_BALANCE) FORMAT=15.2 
INTO :SOURCE_ACCT_COUNT, :SOURCE_TOT_OS_BAL
FROM DRAPT.SPL_SOURCE_FILE_ACCOUNTS;
QUIT;

/*READING THE BCR FILE FOR ACCOUNTS*/
PROC IMPORT DATAFILE="&OUTPATH/securitization/cc/incoming/autoloan_securitization_acct_mthly_&YEARMONTH..bcr"

OUT=DRAPT.SPL_SOURCE_FILE_AMOUNT
DBMS=CSV
REPLACE;
GETNAMES=YES;
RUN;

/*STORING THE BCR DATA INTO VARIABLES*/
PROC SQL NOPRINT;
SELECT NUM_ACCT FORMAT 10., OUTSTANDING_BAL FORMAT=15.2, SUBSTR(PUT(MAX(EFFECTIVE_DATE),8.),1,6) FORMAT=$6., REDUCTION_RATE FORMAT=4.2
INTO :TOTAL_ACCOUNTS, :OUTSTANDING_BALANCE, :BCR_DATE, :REDUCTION_RATE
FROM DRAPT.SPL_SOURCE_FILE_AMOUNT;
QUIT;


