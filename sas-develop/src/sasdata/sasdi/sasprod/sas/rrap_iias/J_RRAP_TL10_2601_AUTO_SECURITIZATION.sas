PROC SQL NOPRINT;
DELETE FROM EDRRAPT.BASEL_SEC_ADJ_FACTR_MTH_SNAP WHERE MTH_TM_ID=&MTH_TM_ID AND SECRTZTN_TP_CD='AUTO';
QUIT;

/*CREATING THE MATCH RATE RESULTS*/

PROC SQL NOPRINT;
CREATE TABLE DRAPT.SPL_SEC_ADJ_FACTOR AS 
SELECT 
	'AUTO' AS SECRTZTN_TP_CD,
	t6.MTH_TM_ID,
	'AUTO' AS SECRTZTN_TP_DESC,
	SUM(T6.ADJUSTED_OS_BAL_AMT)*&REDUCTION_RATE FORMAT 15.2 AS TOT_SECRTZTN_AMT_TO_ADJUST,
	SUM(T6.ADJUSTED_OS_BAL_AMT) FORMAT=20.8 AS TOT_ADJUSTED_OS_BAL_IN_CCAR,
	/*min(((&SECURI_AMT)*&RETAIL_PERCENTAGE)/SUM(T6.ADJUSTED_OS_BAL_AMT),1) AS SECRTZTN_OS_ADJ_FACTR,*/
	&REDUCTION_RATE AS SECRTZTN_OS_ADJ_FACTR,
	&SESSIONTIME AS INSRT_PROCESS_TMSTMP,
	&SESSIONTIME AS UPDT_PROCESS_TMSTMP
FROM DRAPT.SPL_SOURCE_FILE_ACCOUNTS T5
INNER JOIN DRAPT.SPL_ACCOUNTS_FROM_INSTR_FACT T6 ON T5.ACCOUNT_NUMBER=T6.UNIQUE_ACCOUNTS
GROUP BY T6.MTH_TM_ID;
QUIT;

/*LOADING THE DB2 TABLES*/
PROC APPEND BASE=EDRRAPT.BASEL_SEC_ADJ_FACTR_MTH_SNAP 
	DATA=DRAPT.SPL_SEC_ADJ_FACTOR FORCE;
RUN;

/*DECLARATION*/
%GLOBAL QTRTIMEKEY;
%GLOBAL TOTAL_ACCOUNTS;
%GLOBAL OUTSTANDING_BALANCE;
%GLOBAL SECURI_AMT;
%GLOBAL SOURCE_ACCT_COUNT;
%GLOBAL SOURCE_TOT_OS_BAL;
%GLOBAL TGT_TOT_OS_BAL;
%GLOBAL TGT_TOT_OS_BAL_MATCH_RT;
%GLOBAL TGT_SECURI_ADJ_RT;
%GLOBAL TGT_THRESHOLD;
%GLOBAL RETAIL_PERCENTAGE;
%GLOBAL SECURI_AMT;
%GLOBAL TM_DESC;
%GLOBAL TGT_TOT_SECRTZTN_AMT_TO_ADJUST;

/*DISPLAY IN LOG*/
%PUT MTH_TM_ID IS : &MTH_TM_ID;
%PUT &YEARMONTH;

%PUT QTRTIMEKEY IS &QTRTIMEKEY;

/*REPROCESSING LOGIC*/
PROC SQL NOPRINT;
DELETE FROM EDRRAPT.BASEL_SEC_MATCH_RT_MTH_SNAP WHERE MTH_TM_ID=&MTH_TM_ID AND SECRTZTN_TP_CD='AUTO';
QUIT;

/*CREATING THE MATCH RATE RESULTS*/

PROC SQL NOPRINT;
CREATE TABLE DRAPT.SPL_ACCOUNT_MATCH_RESULTS AS 
SELECT 
	'AUTO' AS SECRTZTN_TP_CD,
	t6.MTH_TM_ID,
	'AUTO' AS SECRTZTN_TP_DESC, 
	&TOTAL_ACCOUNTS FORMAT=19.3 AS TOT_ACCT_CNT_RECVD,
	&OUTSTANDING_BALANCE FORMAT=19.3 AS TOT_OS_BAL_RECVD,
	COUNT(t6.UNIQUE_ACCOUNTS) AS TOT_ACCT_CNT_MATCHED,
	SUM(t6.OS_BAL_AMT) FORMAT=19.3 AS TOT_OS_BAL_MATCHED,
	(COUNT(t6.UNIQUE_ACCOUNTS)/&TOTAL_ACCOUNTS)*100 AS ACCT_MATCHED_PCTG,
	SUM(t6.OS_BAL_AMT)/&OUTSTANDING_BALANCE*100 AS OS_BAL_AMT_MATCHED_PCTG,
	/*&SECURI_AMT*&RETAIL_PERCENTAGE FORMAT 15.2 AS TOT_SECRTZTN_AMT_TO_ADJUST,*/
	SUM(T6.ADJUSTED_OS_BAL_AMT)*&REDUCTION_RATE FORMAT 15.2 AS TOT_SECRTZTN_AMT_TO_ADJUST,
	SUM(T6.ADJUSTED_OS_BAL_AMT) FORMAT=20.8 AS TOT_ADJUSTED_OS_BAL_IN_CCAR,
	/*MIN((&SECURI_AMT*&RETAIL_PERCENTAGE)/SUM(T6.ADJUSTED_OS_BAL_AMT),1) AS SECRTZTN_OS_ADJ_FACTR,*/
	&REDUCTION_RATE AS SECRTZTN_OS_ADJ_FACTR,
	&SESSIONTIME AS INSRT_PROCESS_TMSTMP,
	&SESSIONTIME AS UPDT_PROCESS_TMSTMP
FROM DRAPT.SPL_SOURCE_FILE_ACCOUNTS T5
INNER JOIN DRAPT.SPL_ACCOUNTS_FROM_INSTR_FACT T6 ON T5.ACCOUNT_NUMBER=T6.UNIQUE_ACCOUNTS
GROUP BY T6.MTH_TM_ID;
QUIT;

/*LOADING THE DB2 TABLES*/

PROC APPEND BASE=EDRRAPT.BASEL_SEC_MATCH_RT_MTH_SNAP 
	DATA=DRAPT.SPL_ACCOUNT_MATCH_RESULTS FORCE;
RUN;

/*SAVING THE CRITICAL VALUES INTO VARIABLES*/
PROC SQL NOPRINT;
SELECT TOT_OS_BAL_MATCHED FORMAT=15.2, OS_BAL_AMT_MATCHED_PCTG FORMAT=8.3, TOT_SECRTZTN_AMT_TO_ADJUST FORMAT=15.2, SECRTZTN_OS_ADJ_FACTR FORMAT=15.2, TOT_ADJUSTED_OS_BAL_IN_CCAR FORMAT=15.2,
CASE WHEN OS_BAL_AMT_MATCHED_PCTG>=95 THEN '  YES' ELSE '  NO, AUTHORIZATION REQUIRED' END AS THRESHOLD
INTO :TGT_TOT_OS_BAL, :TGT_TOT_OS_BAL_MATCH_RT, :TGT_TOT_SECRTZTN_AMT_TO_ADJUST, :TGT_SECURI_ADJ_RT, :CCAR_ADJUSTED_AMT, :TGT_THRESHOLD
FROM DRAPT.SPL_ACCOUNT_MATCH_RESULTS WHERE MTH_TM_ID=&MTH_TM_ID;
QUIT;

/*EXTRACT TIME DESCRIPTION FOR THE TIME ID*/
PROC SQL NOPRINT;
SELECT TM_DESC FORMAT=$18. INTO :TM_DESC FROM NZRRAP.TM_DIM WHERE TM_ID=&MTH_TM_ID;
QUIT;


