PROC SQL;
SELECT DATECHECK FORMAT=1., ACCOUNTCHECK FORMAT=1., AMOUNTCHECK FORMAT=1. INTO :FLAG1, :FLAG2, :FLAG3 FROM DRAPT.SPL_VALIDATIONS;
QUIT;

%IF (&FLAG1=1 OR &FLAG2=1 OR &FLAG3=1) %THEN %DO;
