/*REPROCESSING LOGIC*/
PROC SQL NOPRINT;
DELETE FROM EDRRAPT.BASEL_SEC_MATCH_RT_MTH_SNAP WHERE MTH_TM_ID=&MTH_TM_ID AND SECRTZTN_TP_CD='CC';
QUIT;

/*FETCHING DATA FROM THE DATASETS WHICH STORES THE DATA FROM FILES*/
PROC SQL NOPRINT;
SELECT RETAIL_PERCENTAGE FORMAT=15.10 INTO :RETAIL_PERCENTAGE
FROM DRAPT.CC_SOURCE_FILE_AMOUNT;
QUIT;

PROC SQL NOPRINT;
SELECT SECURITIZEDAMOUNT FORMAT=15. INTO :SECURI_AMT 
FROM DRAPT.CC_SOURCE_FILE_SECURITIZATION;
QUIT;

/*CREATING THE MATCH RATE RESULTS*/

PROC SQL NOPRINT;
CREATE TABLE DRAPT.CC_ACCOUNT_MATCH_RESULTS AS 
SELECT 'CC' AS SECRTZTN_TP_CD,
t6.MTH_TM_ID,
'CREDIT CARD' AS SECRTZTN_TP_DESC,
&TOTAL_ACCOUNTS AS TOT_ACCT_CNT_RECVD,
&OUTSTANDING_BALANCE AS TOT_OS_BAL_RECVD,
COUNT(t6.UNIQUE_ACCOUNTS) AS TOT_ACCT_CNT_MATCHED,
SUM(t6.OS_BAL_AMT) FORMAT=19.3 AS TOT_OS_BAL_MATCHED,
(COUNT(t5.VISA_ACCT_NUM)/&TOTAL_ACCOUNTS)*100 AS ACCT_MATCHED_PCTG,
SUM(t6.OS_BAL_AMT)/&OUTSTANDING_BALANCE*100 AS OS_BAL_AMT_MATCHED_PCTG,
&SECURI_AMT*&RETAIL_PERCENTAGE AS TOT_SECRTZTN_AMT_TO_ADJUST,
SUM(T6.ADJUSTED_OS_BAL_AMT) FORMAT=20.8 AS TOT_ADJUSTED_OS_BAL_IN_CCAR,
(&SECURI_AMT*&RETAIL_PERCENTAGE)/SUM(T6.ADJUSTED_OS_BAL_AMT) AS SECRTZTN_OS_ADJ_FACTR,
&SESSIONTIME AS INSRT_PROCESS_TMSTMP,
&SESSIONTIME AS UPDT_PROCESS_TMSTMP
FROM DRAPT.CC_SOURCE_FILE_ACCOUNTS T5
INNER JOIN DRAPT.CC_ACCOUNTS_FROM_INSTR_FACT T6 ON T5.VISA_ACCT_NUM=T6.UNIQUE_ACCOUNTS
GROUP BY T6.MTH_TM_ID;
QUIT;

/*LOADING THE DB2 TABLES*/

PROC APPEND BASE=EDRRAPT.BASEL_SEC_MATCH_RT_MTH_SNAP (BULKLOAD=YES BL_METHOD=CLILOAD)
	DATA=DRAPT.CC_ACCOUNT_MATCH_RESULTS FORCE;
RUN;

/*SAVING THE CRITICAL VALUES INTO VARIABLES*/
PROC SQL NOPRINT;
SELECT TOT_OS_BAL_MATCHED, OS_BAL_AMT_MATCHED_PCTG, TOT_SECRTZTN_AMT_TO_ADJUST FORMAT=15., SECRTZTN_OS_ADJ_FACTR FORMAT=15.10,
CASE WHEN OS_BAL_AMT_MATCHED_PCTG>=95 THEN 'YES' ELSE 'NO, AUTHORIZATION REQUIRED' END AS THRESHOLD
INTO :TGT_TOT_OS_BAL, :TGT_TOT_OS_BAL_MATCH_RT, :TGT_TOT_SECRTZTN_AMT_TO_ADJUST, :TGT_SECURI_ADJ_RT, :TGT_THRESHOLD
FROM DRAPT.CC_ACCOUNT_MATCH_RESULTS WHERE MTH_TM_ID=&MTH_TM_ID;
QUIT;

/*EXTRACT TIME DESCRIPTION FOR THE TIME ID*/
PROC SQL NOPRINT;
SELECT TM_DESC FORMAT=$18. INTO :TM_DESC FROM NZRRAP.TM_DIM WHERE TM_ID=&MTH_TM_ID;
QUIT;


