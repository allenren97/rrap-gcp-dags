proc sql;
	connect using nzuser as nzcon;
	create table DRAPT.CC_ACCOUNTS_FROM_INSTR_FACT as select MTH_TM_ID, PRD_CD, OS_BAL_AMT, BASEL_ACCT_ID, ADJUSTED_OS_BAL_AMT, OS_PRNCPL_BAL_AMT, 
							INPUT(SUBSTR(CATS('CA','0201',ACCT_NUM),17,13),15.) AS UNIQUE_ACCOUNTS FORMAT=15. 
		from connection to nzcon
		(
		select src_sys_cd, ss.MTH_TM_ID, ss.PRD_CD, ss.TOT_NEW_BAL_AMT as OS_BAL_AMT, 
				ss.BASEL_ACCT_ID, IJ.AF_ADJ_OS_BAL_AMT as ADJUSTED_OS_BAL_AMT,  ss.TOT_NEW_BAL_AMT as OS_PRNCPL_BAL_AMT, ss.ACCT_NUM

		from &net_db..BASEL_REVLVNG_CR_MTH_SNAPSHOT ss
		LEFT OUTER JOIN &net_db..BASEL_REVLVNG_CR_BASE_DRVD_VARS BDV
			ON SS.BASEL_ACCT_ID=BDV.BASEL_ACCT_ID and ss.MTH_TM_ID=bdv.mth_tm_id and ss.mth_tm_id=&mth_tm_id.
		left outer join &net_wrk..ks_RPTG_DRVD_VAR RDV
			on RDV.basel_acct_id = ss.BASEL_ACCT_ID and ss.mth_tm_id=rdv.mth_tm_id and ss.mth_tm_id=&mth_tm_id.
		left outer join &net_wrk..ks_BASEL_RPTG_PRD_LKP lkp
			on ss.PRD_CD=lkp.PRD_CD and ss.SUB_PRD_CD=lkp.SUB_PRD_CD and bdv.HELOC_F=lkp.HELOC_F and bdv.HELOC_F=lkp.HELOC_F and bdv.BASEL_PRD_CD=lkp.BASEL_PRD_CD and lkp.REVISED_EXPSR_OV_125K_F=rdv.REVISED_EXPSR_OV_125K_F
		left outer join &net_wrk..ks_instr_adj IJ
			on ss.BASEL_ACCT_ID=IJ.basel_acct_id and ss.mth_tm_id=ij.mth_tm_id and ss.mth_tm_id=&mth_tm_id.
		where ss.mth_tm_id=&mth_tm_id. 
			and ss.TOT_NEW_BAL_AMT>=0 AND bdv.CONSM_PRD_TREATMNT_CD='A' AND bdv.SML_BUS_F='N' AND bdv.PIT_STAT_ver_2_CD IN ('CUR','DEF') 
			AND bdv.TRNST_EXCLSN_F='N' AND lkp.BASEL_PRD_TP_CD='CARD'
		);
quit;

/*FETCHING ACCOUNTS FROM BASEL_REVLVNG_CR_MTH_SNAPSHOT*/

PROC SQL NOPRINT;
CREATE TABLE DRAPT.CC_ACCOUNTS_FROM_ACCT_DIM AS 
SELECT MTH_TM_ID, PRD_CD, 
INPUT(SUBSTR(ACCT_NUM,11,13),15.) AS UNIQUE_ACCOUNTS FORMAT=15.,
BASEL_ACCT_ID
FROM NZRRAP.BASEL_REVLVNG_CR_MTH_SNAPSHOT
WHERE 
MTH_TM_ID=&MTH_TM_ID;
QUIT;

/*CREATING THE ACCOUNT SNAPSHOT*/

PROC SQL NOPRINT;
CREATE TABLE DRAPT.CC_SECUR_ACCT_SNAPSHOT AS 
SELECT 
	&MTH_TM_ID AS MTH_TM_ID,
	STRIP(PUT(T1.VISA_ACCT_NUM,15.)) AS ACCT_NUM_RECVD,
	T1.OUTSTANDING_BAL,
	CASE WHEN T2.UNIQUE_ACCOUNTS=. THEN '' 
		ELSE STRIP(PUT(T2.UNIQUE_ACCOUNTS,15.)) 
	END AS ACCT_NUM_RRAP_DONT,
	T2.BASEL_ACCT_ID AS BASEL_ACCT_ID_DONT,
	T3.BASEL_ACCT_ID AS BASEL_ACCT_ID_CCAR_MATCHED,
	T3.PRD_CD,
	T3.OS_BAL_AMT,
	T3.ADJUSTED_OS_BAL_AMT,
	T3.OS_PRNCPL_BAL_AMT,
	&SESSIONTIME AS INSRT_PROCESS_TMSTMP,
	&SESSIONTIME AS UPDT_PROCESS_TMSTMP,
	'CC' AS SECRTZTN_TP_CD
FROM DRAPT.CC_SOURCE_FILE_ACCOUNTS T1
LEFT OUTER JOIN DRAPT.CC_ACCOUNTS_FROM_ACCT_DIM T2 ON T1.VISA_ACCT_NUM=T2.UNIQUE_ACCOUNTS
LEFT OUTER JOIN DRAPT.CC_ACCOUNTS_FROM_INSTR_FACT T3 ON T1.VISA_ACCT_NUM=T3.UNIQUE_ACCOUNTS;
QUIT;

/*LOADING THE DB2 TABLES*/

PROC APPEND BASE=EDRRAPT.BASEL_CC_SEC_ACCT_MTH_SNAP 
	(BULKLOAD=YES BL_METHOD=CLILOAD UPDATE_LOCK_TYPE=TABLE BL_LOAD_REPLACE=NO) 
	DATA=DRAPT.CC_SECUR_ACCT_SNAPSHOT FORCE;
RUN;


