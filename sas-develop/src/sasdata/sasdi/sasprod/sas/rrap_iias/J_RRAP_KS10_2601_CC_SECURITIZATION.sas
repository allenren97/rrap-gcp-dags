%MACRO SECURI;
/*READING THE ACCOUNTS FILE*/

PROC IMPORT DATAFILE="&OUTPATH/securitization/cc/incoming/cc_edwext_securitization_acct_mthly_&YEARMONTH..csv"
OUT=DRAPT.CC_SOURCE_FILE_ACCOUNTS
DBMS=CSV
REPLACE;
GETNAMES=YES;
RUN;

/*FORMATTING AND REMOVING NULLS DURING LOAD*/

DATA DRAPT.CC_SOURCE_FILE_ACCOUNTS;
SET DRAPT.CC_SOURCE_FILE_ACCOUNTS;
WHERE VISA_ACCT_NUM^=.;
FORMAT VISA_ACCT_NUM 32.;
RUN;

/*SAVING THE CSV STATS INTO VARIABLES*/

PROC SQL NOPRINT;
SELECT COUNT(VISA_ACCT_NUM) FORMAT 15., SUM(OUTSTANDING_BAL) FORMAT=15.1, SUBSTR(PUT(MAX(Effective_date),8.),1,6) FORMAT=$6. 
INTO :SOURCE_ACCT_COUNT, :SOURCE_TOT_OS_BAL, :ACCT_DATE
FROM DRAPT.CC_SOURCE_FILE_ACCOUNTS;
QUIT;

/*READING THE BCR FILE FOR ACCOUNTS*/
PROC IMPORT DATAFILE="&OUTPATH/securitization/cc/incoming/cc_edwext_securitization_acct_mthly_&YEARMONTH..bcr"
OUT=DRAPT.CC_SOURCE_FILE_AMOUNT
DBMS=CSV
REPLACE;
GETNAMES=YES;
RUN;

/*STORING THE BCR DATA INTO VARIABLES*/

PROC SQL NOPRINT;
SELECT NUM_ACCT FORMAT 10., OUTSTANDING_BAL FORMAT=15.1, SUBSTR(PUT(MAX(EFFECTIVE_DATE),8.),1,6) FORMAT=$6., RETAIL_PERCENTAGE FORMAT=15.10
INTO :TOTAL_ACCOUNTS, :OUTSTANDING_BALANCE, :BCR_DATE, :RETAIL_PERCENTAGE
FROM DRAPT.CC_SOURCE_FILE_AMOUNT;
QUIT;


/*READING THE CSV FILE FOR SECURITIZATION AMOUNT*/
PROC IMPORT DATAFILE="&OUTPATH/securitization/sf/incoming/cc_edwext_securitization_gl_summary_mthly_&YEARMONTH..csv"
OUT=DRAPT.CC_SOURCE_FILE_SECURITIZATION
DBMS=CSV
REPLACE;
GETNAMES=YES;
RUN;

/*STORING THE SECURITIZATION AMOUNT INTO VARIABLES*/
PROC SQL NOPRINT;
SELECT SECURITIZEDAMOUNT FORMAT=15., SUBSTR(PUT(MAX(EFFECTIVEDATE),8.),1,6) FORMAT=$6.
INTO :SECURI_AMT, :SECURI_DATE
FROM DRAPT.CC_SOURCE_FILE_SECURITIZATION;
QUIT;


/*SOURCE VALIDATIONS*/
%PUT CSV COUNT = &SOURCE_ACCT_COUNT;
%PUT BCR COUNT = &TOTAL_ACCOUNTS;
%PUT CSV AMOUNT = &SOURCE_TOT_OS_BAL;
%PUT BCR AMOUNT = &OUTSTANDING_BALANCE;

DATA DRAPT.CC_VALIDATIONS;
YEARMONTH=&YEARMONTH;
ACCT_DATE=&ACCT_DATE;
BCR_DATE=&BCR_DATE;
SECURI_DATE=&SECURI_DATE;
SOURCE_ACCT_COUNT=&SOURCE_ACCT_COUNT;
BCR_ACCOUNTS=&TOTAL_ACCOUNTS;
SOURCE_TOT_OS_BAL=&SOURCE_TOT_OS_BAL;
BCR_OS_AMT=&OUTSTANDING_BALANCE;
IF YEARMONTH^=ACCT_DATE OR YEARMONTH^=BCR_DATE OR YEARMONTH^=SECURI_DATE THEN DATECHECK=1;ELSE DATECHECK=0;
IF SOURCE_ACCT_COUNT^=BCR_ACCOUNTS THEN ACCOUNTCHECK=1; ELSE ACCOUNTCHECK=0;
IF SOURCE_TOT_OS_BAL^=BCR_OS_AMT THEN AMOUNTCHECK=1; ELSE AMOUNTCHECK=0;
RUN;

PROC SQL NOPRINT;
SELECT DATECHECK FORMAT=1., ACCOUNTCHECK FORMAT=1., AMOUNTCHECK FORMAT=1. INTO :FLAG1, :FLAG2, :FLAG3 FROM DRAPT.CC_VALIDATIONS;
QUIT;

%IF (&FLAG1=1 OR &FLAG2=1 OR &FLAG3=1) %THEN %DO;
%PUT SOURCE FILE VALIDATIONS FAILED. ;
%PUT FLAG1=&FLAG1 AND FLAG2=&FLAG2 AND FLAG3=&FLAG3;
%ABORT ABEND; 
%END;

%MEND;
%SECURI;

