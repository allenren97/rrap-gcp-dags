/*CREATING THE MATCH RATE RESULTS*/

PROC SQL NOPRINT;
CREATE TABLE DRAPT.CC_SEC_ADJ_FACTOR AS 
SELECT 'CC' AS SECRTZTN_TP_CD,
t6.MTH_TM_ID,
'CREDIT CARD' AS SECRTZTN_TP_DESC,
&SECURI_AMT*&RETAIL_PERCENTAGE AS TOT_SECRTZTN_AMT_TO_ADJUST,
SUM(T6.ADJUSTED_OS_BAL_AMT) FORMAT=20.8 AS TOT_ADJUSTED_OS_BAL_IN_CCAR,
(&SECURI_AMT*&RETAIL_PERCENTAGE)/SUM(T6.ADJUSTED_OS_BAL_AMT) AS SECRTZTN_OS_ADJ_FACTR,
&SESSIONTIME AS INSRT_PROCESS_TMSTMP,
&SESSIONTIME AS UPDT_PROCESS_TMSTMP
FROM DRAPT.CC_SOURCE_FILE_ACCOUNTS T5
INNER JOIN DRAPT.CC_ACCOUNTS_FROM_INSTR_FACT T6 ON T5.VISA_ACCT_NUM=T6.UNIQUE_ACCOUNTS
GROUP BY T6.MTH_TM_ID;
QUIT;

/*LOADING THE DB2 TABLES*/

PROC APPEND BASE=EDRRAPT.BASEL_SEC_ADJ_FACTR_MTH_SNAP (BULKLOAD=YES BL_METHOD=CLILOAD)
	DATA=DRAPT.CC_SEC_ADJ_FACTOR FORCE;
RUN;

