data cc_time_keys;
	MONTHTIMEID=&MTH_TM_ID; 
	format yearmonth YEARQTR date9.;
	yearmonth=input(cats("&yearmonth.","01"),yymmdd8.);
	YEARQTR=intnx('QTR.1',yearmonth,0,'b');
	call symputx('QTRTIMEKEY',put(yearqtr,yymmn6.));
