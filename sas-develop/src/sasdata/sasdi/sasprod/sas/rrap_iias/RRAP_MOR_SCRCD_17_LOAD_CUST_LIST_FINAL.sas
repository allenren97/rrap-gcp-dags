%delete_table(&target_lib..SCORECARD_VARS_CUST_LIST);
%delete_table(&target_lib..SCORECARD_VARS_CUST_LIST_TMP2);


proc sql; 
	connect USING NZUSER AS NZCON;
 execute (	
	CREATE TABLE &target_lib3..SCORECARD_VARS_CUST_LIST(
		&acct_key.  INTEGER,
		&time_key.  DATE,
        CIS_TM_ID   CHARACTER(4),
		&cust_key.  CHARACTER(16),
		CID_NUM     BIGINT,
		&cust_key2. INTEGER,
		FROM_DT     DATE,
		TO_DT       DATE,
		RDM_FROM_DT INTEGER,
		RDM_TO_DT   INTEGER) 
  ) by NZCON;
quit;



proc sql;
	connect USING NZUSER AS NZCON;
execute (	
   create table &target_lib3..SCORECARD_VARS_CUST_LIST_TMP2 as (
       select
			a.*, 
			b.time_key as rdm_from_dt,
			c.time_key as rdm_to_dt
		from &target_lib3..SCORECARD_VARS_CUST_LIST_TMP as a
			left join &target_lib3..iwd_time as b on b.TIME_LVL='Month' and a.FROM_DT=b.TIME_LVL_END_DT
			left join &target_lib3..iwd_time as c on c.TIME_LVL='Month' and a.TO_DT=c.TIME_LVL_END_DT
				 ) WITH DATA   ) by NZCON;
quit;

proc sql;
	connect USING NZUSER AS NZCON;
execute (
 INSERT INTO &target_lib3..SCORECARD_VARS_CUST_LIST
		SELECT 
			&acct_key., 
			&TIME_KEY.,
         CIS_TM_ID,
			&cust_key., 
			to_number(&cust_key., '9999999999999999') as CID_NUM,
			&cust_key2., 
			FROM_DT, 
			TO_DT, 
			RDM_FROM_DT, 
			RDM_TO_DT 
		from &target_lib3..SCORECARD_VARS_CUST_LIST_TMP2

) by NZCON;
disconnect from NZCON;
quit;

