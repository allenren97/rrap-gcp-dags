/* There 2nd extract from the Deli file for AT34 needs the extra join 
   criteria because this field feeds into an Average calculation.  This 
   extra filtering is only needed for fields which come from the Deli file
   that become averages. */

/* Join to monthly snapshot table to ensure we have a customer record for every month.  
   Deli file filers were causing nulls */

/* The basel_cust_id check in the where clause ensures that we are only loading customers that are valid for the observation point */ 

/* 06Jul2015 - CR41 - AT34 no longer needs the relationship table.  Pulling straight from Deli file. 
                   The AT34_NULL_FLAG is used in the Create Var Stats code to override AT34avg6m.  If TOT_UTLTN_AMT
                   is null and HIT_NOHIT_EDIT_REJCT_CD is H for the same month in a six month period, set AT34avg6m to null  */

proc sql noprint;
connect using nzuser as nzcon;
execute(

         create table &FRG_DB..SCRD_VAR_STATS_INPUTS_&product._&datatype. as (

         select coalesce(b.basel_cust_id, d.basel_cust_id)  basel_cust_id,
		          coalesce(b.mth_tm_id, d.mth_tm_id)  mth_tm_id, 
				
                b.GO05,
                b.CUST25, 
                b.CUST32, 
                b.CUST24, 
                b.CUST13, 
                b.CUST22, 
                b.CUST21, 
                b.CUST16, 
                b.CUST18, 
                b.CUST_19,
 		        
                d.ACTV_INSTLMNT_TRDS_BAL_GT_ZERO_CNT  AT29_NUM_OF_ACTV_INSTLMNT_TRDS,
                d.TOT_UTLTN_BNK_REVLVNG_CRD_AMT  BR34_TOT_UTIL_BNK_REVLVNG_CRDS,
                d.TRADE_NEVER_DLQNT_PC  GO11_PC_OF_TRDS_NEVER_DLQNT,
                d.TOT_BAL_REVLVNG_AMT  RE33_TOT_BAL_REVLVNG,
                d.TM_OV_90_DAY_PD_LAST_12_MTH_CNT  AT43_NUM_TM_90_DY_PAST_IN_12,
                d.TOT_PD_AMT  AT84_TOT_AMT_PAST_DUE,
                d.MTH_SINCE_LAST_30_DAY_DLQNT_CNT  AT85_NUM_MTH_SINCE_LAST_30_DY,
                d.MAX_REVLVNG_CR_CRNT_UTLTN_AMT  BR147_MAX_CRNT_UTILZTN_BNK_REV,
                d.BNKRPY_CNT  PR01_NUM_OF_BNKRPC,
                d.TRADE_90_DPD_LAST_24_MTH_CNT  AT83_NUM_ACTV_TRDS_90_PDY_PAST,
                d.OCC_60_DAY_PD_WITHIN_PAST_12_MTH_CNT  AT19_NUM_OF_OCCS_60_DY_PAST,
                d.MTH_SINCE_MOST_RECNT_DLQNT_CNT  AT36_MTH_SINCE_MOST_RECNT_DLQN,
                d.TOT_UTLTN_BNK_REVLVNG_LINE_AMT  BY34_TOT_UTIL_BNK_REVLVNG_LINE,
                d.INQRY_CNT  GO04,
                d.COLCTN_INQR_CNT  GO22,
                
                d.TOT_UTLTN_AMT  AT34_TOT_UTILZTN, 
                case when d.TOT_UTLTN_AMT is null and d.HIT_NOHIT_EDIT_REJCT_CD='H' then 1 else 0 end  AT34_NULL_FLAG
                
          
        from ( select * from &RRAP_DB..BASEL_PSNL_LOAN_CUST_DRVD_VARS
               where mth_tm_id between &begin_dt_24_tm and &end_period_tm_key) as b
		  full outer join
             ( select * from &RRAP_DB..CR_BUREAU_DELI_MTH_SNAPSHOT
               where mth_tm_id between &begin_dt_24_tm and &end_period_tm_key) as d
             on b.basel_cust_id=d.basel_cust_id and
                b.mth_tm_id=d.mth_tm_id and
		          d.basel_cust_id <> -1          

		   where b.basel_cust_id in ( select basel_cust_id from &&RRAP_DB..BASEL_PSNL_LOAN_CUST_DRVD_VARS
                                    where mth_tm_id between &start_period_tm_key and &end_period_tm_key)
		   order by b.MTH_TM_ID
 			) WITH DATA ORGANIZE BY ROW;
         ) by nzcon;
 quit;
 
 %etl_job_end;
