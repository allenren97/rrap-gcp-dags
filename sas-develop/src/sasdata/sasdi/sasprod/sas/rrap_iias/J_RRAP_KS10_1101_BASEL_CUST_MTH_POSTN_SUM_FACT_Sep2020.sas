         quit;
         
         proc sql;
         create table myload as
         select a.TIME_KEY, count(*) as count format=comma11., sum(a.d2dbal) as BALANCE format=comma20.
         		FROM rrap_lib.cust_products_agg a, rrap_lib.cust_id_base_key b, rrap_lib.basel_cust_id_cid c
         		WHERE a.CUST_BASE_KEY = b.CUST_BASE_KEY
         		and b.CUST_ID = c.CUST_CID
         		group by 1
         		order by 1;
         quit;
         
         proc sql;
         create table dms_load as
         select mth_tm_id, count(*) as count_dms format=comma11., sum(D2D_BAL_AMT) as BALANCE_DMS format=comma20.
         from NETCON.BASEL_CUST_MTH_POSTN_SUM_FACT
         where mth_tm_id = &mth_tm_id.
         group by 1
         order by 1;
         quit;
         
         
         
         /*Rig the load :)*/
