                * 3. Defines observation period values for PD
                *---------------------------------------------------*/
               proc sql noprint;
                  create table work._pd_obs_counts as       
         
                  select a.ncr_expsr_cl_key_val,
                         a.ncr_rt_sys_key_val,
                         a.ncr_pd_seg_key_val,
                         a.ncr_lgd_seg_key_val,
                         a.ncr_ead_seg_key_val,
                         a.src_sys_cd,      
         
                         /* For 12 month realized PD */
                         a.pit_stat_cd,
                         count(*) as count,
                         sum(a.default_ind) as def_ind_cnt,      
         
                         sum(
                           (case 
                              when upcase(a.pit_stat_cd) = 'CUR' and a.default_ind = 1 and a.default_bal >= 0 then a.default_bal
                              when upcase(a.pit_stat_cd) = 'CUR' and a.default_ind = 1 and a.default_bal < 0 then 0
                              when upcase(a.pit_stat_cd) = 'CUR' and a.default_ind = 0 then 0
                              when upcase(a.pit_stat_cd) = 'DEF' and a.os_bal_amt NE . and a.intr_accr_amt NE . then a.os_bal_amt + a.intr_accr_amt
                              when upcase(a.pit_stat_cd) = 'DEF' and a.os_bal_amt NE . and a.intr_accr_amt EQ . then a.os_bal_amt 
                              else .
                              end)
                           ) as pr_12_m_rlz_def_ln_os_pd_bal_am 
                       
                  from &input_history_tbl_db..&_int_tbl_for_be as a
                  where intnx('month', datepart(a.process_date), 0, 'e') = "&pd_obs_dt"d
                  group by a.ncr_expsr_cl_key_val, 
                           a.ncr_rt_sys_key_val,
                           a.ncr_pd_seg_key_val,
                           a.ncr_lgd_seg_key_val, 
                           a.ncr_ead_seg_key_val, 
                           a.src_sys_cd,
                           a.pit_stat_cd;
               quit;      
         
               data work._pd_obs_metrics (drop = pit_stat_cd count def_ind_cnt);
                  set work._pd_obs_counts;      
         
                  if upcase(pit_stat_cd) = 'CUR' then 
                  do;
                     prior_12_mth_realz_pd_acct_cnt = count;
                     pr_12_m_realz_pd_def_acct_cnt = def_ind_cnt;
                     prior_12_mth_realz_pd_rto = pr_12_m_realz_pd_def_acct_cnt/prior_12_mth_realz_pd_acct_cnt;
                  end;      
         
                  else if upcase(pit_stat_cd) = 'DEF' then 
                  do;
                     prior_12_mth_realz_pd_acct_cnt = 0;
                     pr_12_m_realz_pd_def_acct_cnt = count;
                     prior_12_mth_realz_pd_rto = 1;
                  end;      
         
               run;      
               
         
               /*---------------------------------------------------
                * 4. Defines observation period values for LGD
                *---------------------------------------------------*/
               proc sql noprint;
                  create table work._lgd_obs_counts_bals as       
         
                  select a.ncr_expsr_cl_key_val,
                         a.ncr_rt_sys_key_val,
                         a.ncr_pd_seg_key_val,
                         a.ncr_lgd_seg_key_val,
                         a.ncr_ead_seg_key_val,
                         a.src_sys_cd,      
         
                         /* For 36 month realized LGD - per workbook, same logic*/
                         count(*) as prior_36_mth_realz_lgd_acct_cnt format 17.3,
                         count(*) as pr_36_m_realz_lgd_def_acct_cnt format 17.3,      
         
                         a.pit_stat_cd,
                         sum(
                           (case 
                              when upcase(a.pit_stat_cd) = 'CUR' and a.default_ind = 1 and a.default_bal >= 0 then a.default_bal
                              when upcase(a.pit_stat_cd) = 'CUR' and a.default_ind = 1 and a.default_bal < 0 then 0
                              when upcase(a.pit_stat_cd) = 'CUR' and a.default_ind = 0 then 0
                              when upcase(a.pit_stat_cd) = 'DEF' and a.os_bal_amt NE . and a.intr_accr_amt NE . then a.os_bal_amt + a.intr_accr_amt
                              when upcase(a.pit_stat_cd) = 'DEF' and a.os_bal_amt NE . and a.intr_accr_amt EQ . then a.os_bal_amt 
                              else .
                              end)
                           ) as pr_36_m_rlz_def_ln_os_lgd_bal_am format = 17.3      
         
                       
                  from &input_history_tbl_db..&_int_tbl_for_be as a
                  where intnx('month', datepart(a.process_date), 0, 'e') = "&lgd_obs_dt"d and
                        (a.default_ind=1 or upcase(a.pit_stat_cd)='DEF') and a.lgd_model_rto not in (.,0)
                  group by a.ncr_expsr_cl_key_val, 
                           a.ncr_rt_sys_key_val,
                           a.ncr_pd_seg_key_val,
                           a.ncr_lgd_seg_key_val, 
                           a.ncr_ead_seg_key_val, 
                           a.src_sys_cd,
                           a.pit_stat_cd;
               quit;      
         
               /*----------------------------------------------------
                * Needs to be separate query because average of ratio
                * is over all accounts in a segment
                *----------------------------------------------------*/
               proc sql noprint;
                  create table work._lgd_obs_realized as       
         
                  select a.ncr_expsr_cl_key_val,
                         a.ncr_rt_sys_key_val,
                         a.ncr_pd_seg_key_val,
                         a.ncr_lgd_seg_key_val,
                         a.ncr_ead_seg_key_val,
                         a.src_sys_cd,
                         avg(a.lgd_model_rto) as prior_36_mth_realz_lgd_rto format 28.8
                       
                  from &input_history_tbl_db..&_int_tbl_for_be as a
                  where intnx('month', datepart(a.process_date), 0, 'e') = "&lgd_obs_dt"d
                  group by a.ncr_expsr_cl_key_val, 
                           a.ncr_rt_sys_key_val,
                           a.ncr_pd_seg_key_val,
                           a.ncr_lgd_seg_key_val, 
                           a.ncr_ead_seg_key_val, 
                           a.src_sys_cd;
               quit;      
               
         
               /*---------------------------------------------------
                * 5. Defines observation period values for EAD
                *---------------------------------------------------*/
               proc sql noprint;
                  create table work._ead_obs_counts as       
         
                  select a.ncr_expsr_cl_key_val,
                         a.ncr_rt_sys_key_val,
                         a.ncr_pd_seg_key_val,
                         a.ncr_lgd_seg_key_val,
                         a.ncr_ead_seg_key_val,
                         a.src_sys_cd,      
         
                         /* For 12 month realized EAD */
                         sum(
                           (case 
                              when upcase(a.pit_stat_cd) = 'DEF' then 0
                              when upcase(a.pit_stat_cd) = 'CUR' and default_ind = 1 then 1
                              else .
                              end)
                         ) as prior_12_mth_realz_ead_acct_cnt
                       
                  from &input_history_tbl_db..&_int_tbl_for_be as a
                  where intnx('month', datepart(a.process_date), 0, 'e') = "&ead_obs_dt"d   
                  group by a.ncr_expsr_cl_key_val, 
                           a.ncr_rt_sys_key_val,
                           a.ncr_pd_seg_key_val,
                           a.ncr_lgd_seg_key_val, 
                           a.ncr_ead_seg_key_val, 
                           a.src_sys_cd;
               quit;      
         
               /*---------------------------------------------------
                * 5. Join results together - for ONE month only
                *---------------------------------------------------*/
               proc sql noprint;
                  create table work.base_with_process as
                  select a.mth_tm_id,
                         a.ncr_expsr_cl_key_val,
                         a.ncr_rt_sys_key_val,
                         a.ncr_pd_seg_key_val,
                         a.ncr_lgd_seg_key_val,
                         a.ncr_ead_seg_key_val,
                         a.src_sys_cd,      
         
                         /* Process date values */
                         b.rptg_qtr_acct_cnt,
                         b.pd_final_rptg_rto, 
                         b.lgd_final_rptg_rto,      
         
                         c.prior_12_mth_realz_ead_acct_cnt,
                         (case 
                           when b.rptg_qtr_acct_cnt > 0 then 1
                           else 0
                           end) as ead_final_rptg_rto format=28.8,
                         
                         0 as pr_12_m_realz_ead_def_acct_cnt,
                          
         
                          /* Replacing May 31 code change with original logic */
                          (case
                           when a.ncr_ead_seg_key_val = '3308' then 1
                           when c.prior_12_mth_realz_ead_acct_cnt > 0 then 1
                           else 0
                           end) as prior_12_mth_realz_ead_rto format=28.8,
         
                          0 as pr_12_m_rlz_def_ln_os_ead_bal_am format=17.3      
         
                  from work.distinct_groupings1 as a
                       left join      
         
                        /* Adds Process date metrics */
                       work._processing_dt_vals as b
                       on (a.ncr_expsr_cl_key_val = b.ncr_expsr_cl_key_val and
                           a.ncr_rt_sys_key_val = b.ncr_rt_sys_key_val and
                           a.ncr_pd_seg_key_val = b.ncr_pd_seg_key_val and
                           a.ncr_lgd_seg_key_val = b.ncr_lgd_seg_key_val and
                           a.ncr_ead_seg_key_val = b.ncr_ead_seg_key_val and
                           a.src_sys_cd = b.src_sys_cd)      
         
                       left join      
         
                       /* Adds EAD observation metrics */
                       work._ead_obs_counts as c
                       on (a.ncr_expsr_cl_key_val = c.ncr_expsr_cl_key_val and
                           a.ncr_rt_sys_key_val = c.ncr_rt_sys_key_val and
                           a.ncr_pd_seg_key_val = c.ncr_pd_seg_key_val and
                           a.ncr_lgd_seg_key_val = c.ncr_lgd_seg_key_val and
                           a.ncr_ead_seg_key_val = c.ncr_ead_seg_key_val and
                           a.src_sys_cd = c.src_sys_cd);
               quit;      
         
               proc sql noprint;
                  create table work.base_with_pd as
                  select a.*,      
         
                         /* PD at obs*/
                         b.pr_12_m_realz_pd_def_acct_cnt,
                         b.prior_12_mth_realz_pd_acct_cnt,
                         b.prior_12_mth_realz_pd_rto format = 28.8,
                         b.pr_12_m_rlz_def_ln_os_pd_bal_am format = 17.3      
         
                  from work.base_with_process as a
                       left join      
         
                       /* Adds PD observation metrics */
                       work._pd_obs_metrics as b
                       on (a.ncr_expsr_cl_key_val = b.ncr_expsr_cl_key_val and
                           a.ncr_rt_sys_key_val = b.ncr_rt_sys_key_val and
                           a.ncr_pd_seg_key_val = b.ncr_pd_seg_key_val and
                           a.ncr_lgd_seg_key_val = b.ncr_lgd_seg_key_val and
                           a.ncr_ead_seg_key_val = b.ncr_ead_seg_key_val and
                           a.src_sys_cd = b.src_sys_cd);
               quit;
                   
               proc sql noprint;
                  create table work.base_with_lgd as
                  select a.*,      
         
                         /* LGD at obs */
                         b.prior_36_mth_realz_lgd_acct_cnt,
                         b.pr_36_m_realz_lgd_def_acct_cnt,
                         c.prior_36_mth_realz_lgd_rto format = 28.8,
                         b.pr_36_m_rlz_def_ln_os_lgd_bal_am       
         
                  from work.base_with_pd as a
                       left join      
         
                       /* Adds LGD observation counts */
                       work._lgd_obs_counts_bals as b
                       on (a.ncr_expsr_cl_key_val = b.ncr_expsr_cl_key_val and
                           a.ncr_rt_sys_key_val = b.ncr_rt_sys_key_val and
                           a.ncr_pd_seg_key_val = b.ncr_pd_seg_key_val and
                           a.ncr_lgd_seg_key_val = b.ncr_lgd_seg_key_val and
                           a.ncr_ead_seg_key_val = b.ncr_ead_seg_key_val and
                           a.src_sys_cd = b.src_sys_cd)      
         
                       left join      
         
                       /* Adds LGD observation realized value */
                       work._lgd_obs_realized as c
                       on (a.ncr_expsr_cl_key_val = c.ncr_expsr_cl_key_val and
                           a.ncr_rt_sys_key_val = c.ncr_rt_sys_key_val and
                           a.ncr_pd_seg_key_val = c.ncr_pd_seg_key_val and
                           a.ncr_lgd_seg_key_val = c.ncr_lgd_seg_key_val and
                           a.ncr_ead_seg_key_val = c.ncr_ead_seg_key_val and
                           a.src_sys_cd = c.src_sys_cd);
               quit;       
         
               /*----------------------------------------------------
                * 6. Load to final table
                *----------------------------------------------------*/ 
         
         
         
                  proc sql noprint;
                     connect using NZWRKBT as nzcon;
                     execute (delete from &bttdb..&spl_be_fact_table where mth_tm_id = &mth_tm_id) by nzcon;
                  quit;
               
         
               proc sql noprint;
                  insert into NZWRKBT.&spl_be_fact_table (bulkload=yes)
                  select a.mth_tm_id,
                        a.ncr_expsr_cl_key_val,
                        a.ncr_rt_sys_key_val,
                        a.ncr_pd_seg_key_val,
                        a.src_sys_cd,
                        a.ncr_lgd_seg_key_val,
                        a.prior_12_mth_realz_pd_acct_cnt,
                        a.ncr_ead_seg_key_val,
                        a.prior_36_mth_realz_lgd_acct_cnt,
                        a.prior_12_mth_realz_ead_acct_cnt,
                        a.rptg_qtr_acct_cnt,
                        a.pd_final_rptg_rto,
                        a.lgd_final_rptg_rto,
                        a.ead_final_rptg_rto,
                        a.prior_12_mth_realz_pd_rto,
                        a.prior_36_mth_realz_lgd_rto,
                        a.prior_12_mth_realz_ead_rto,
                        a.pr_12_m_realz_pd_def_acct_cnt,
                        a.pr_36_m_realz_lgd_def_acct_cnt,
                        a.pr_12_m_realz_ead_def_acct_cnt,
                        a.pr_12_m_rlz_def_ln_os_pd_bal_am,
                        a.pr_36_m_rlz_def_ln_os_lgd_bal_am,
                        a.pr_12_m_rlz_def_ln_os_ead_bal_am,
                        datetime() as insrt_process_tmstmp format = datetime21.,
                        datetime() as updt_process_tmstmp format = datetime21.
                  from work.base_with_lgd as a;
               quit;      
         
         
         /*---- End of User Written Code  ----*/ 
         
      %mend etls_jobW2IURCA; 
      
      %etls_jobW2IURCA; 
      
      %let handleName = %etls_getHandle(statusTable=&etls_statusTable,
         handleVariable=etls_handleName, row=&&&etls_controlName);
         
      %let job_rc&handleName. = &job_rc; 
      
      %etls_freeHandle(statusTable=&etls_statusTable, statusVariable=etls_status, 
         handleVariable=etls_handleName, handleName="&handleName", 
         startTimeVariable=etls_startTime, endTimeVariable=etls_endTime, signoff=0, 
         returnCodeVariable=etls_jobRC, returnCodeMacroVariable=job_rc&handleName., setMainJobRc=1); 
         
   %mend etls_processToLoopW2IURC0;
   
   %local etls_controlTable etls_statusTable etls_controlName 
      etls_processesRunning etls_maxProcesses etls_parameterTable 
      etls_additionalSignonOptions etls_signonRetries;
   %let etls_controlName = ifct; 
   %let etls_statusTable = work.W3LPAWL; 
   %let etls_parameterTable = work.W2IURBW; 
   %let &etls_controlName = 0;
   %let etls_controlTable = work.W3LPA4T;
   
   %put %str(NOTE: Creating status table..);
   data &etls_statusTable 
      (keep = etls_handleName etls_machineId etls_startTime etls_endTime etls_status 
              etls_jobRC TM_ID MTH_END_DT mth_tm_id
      );
      attrib etls_handleName length = $32
         label = 'Name of handle to remote session'; 
      attrib etls_machineId length = $32
         label = 'Name of machine executing the task'; 
      attrib etls_startTime length = 8
         format = nldatmap.
         label = 'Start time of task'; 
      attrib etls_endTime length = 8
         format = nldatmap.
         label = 'End time of task'; 
      attrib etls_status length = $32
         label = 'Current status of task'; 
      attrib etls_jobRC length = 8
         label = 'Return code of task'; 
      attrib TM_ID length = 8; 
      attrib MTH_END_DT length = $9; 
      attrib mth_tm_id length = 8
         format = 20.
         informat = 20.
         label = 'TM_ID'; 
      set &etls_controlTable;
   run;
   
   %rcSet(&syserr); 
   
   %put %str(NOTE: Creating parameter table..);
   proc sql; 
      create table &etls_parameterTable as 
         select mth_tm_id as mth_tm_id, 
                LOOP_DATE as loop_date 
         from &etls_controlTable; 
   quit; 
   
   %rcSet(&sqlrc); 
   
   /* Get the number of times to iterate from the number of rows in the source  */ 
   /*  table                                                                    */ 
   proc sql noprint; 
      select count(*) into :&etls_controlName._max from &etls_statusTable;
      %let &etls_controlName._max = &&&etls_controlName._max;
   quit;
   
   %rcSet(&sqlrc); 
   
   /* Initialize checks for status handling per iteration  */ 
   %do i=1 %to &&&etls_controlName._max; 
      %local etls_statusReported&i; 
      %let etls_statusReported&i = 0; 
   %end; 
   
   %let etls_maxProcesses = 1; 
   
   %if (&etls_maxProcesses > 0) %then 
   %do; 
      %do %until (&&&etls_controlName ge &&&etls_controlName._max); 
      
         %let etls_lastLoopPtr = &&&etls_controlName;
         
         %let etls_processesRunning = 0; 
         
         %do %while(&etls_processesRunning lt &&&etls_controlName._max 
            and &etls_processesRunning lt &etls_maxProcesses 
            and &&&etls_controlName lt &&&etls_controlName._max);
            
            %let &etls_controlName = %eval(&&&etls_controlName+1);
            
            %let job_rcLast=&job_rc; 
            
            %etls_createHandle(statusTable=&etls_statusTable,
                               statusVariable=etls_status,
                               handleVariable=etls_handleName,
                               handlePrefix=&etls_controlName,
                               statusSetting="Running",
                               row=&&&etls_controlName,
                               machineVariable=etls_machineId,
                               startTimeVariable=etls_startTime,
                               signon=0,
                               useGrid=0);
            
         %let etls_processesRunning = 1; 
         %etls_processToLoopW2IURC0(parameterTable=&etls_parameterTable, row=&&&etls_controlName,
            handleName=%etls_getHandle(statusTable=&etls_statusTable,
            handleVariable=etls_handleName, row=&&&etls_controlName)); 
         
         /* Reset main Job_RC and Trans_RC to max return code of all iterations */ 
         %let job_rcThisIter=&job_rc; 
         %let job_rc=&job_rcLast; 
         %let trans_rc=&job_rcLast; 
         %rcSet(&job_rcThisIter); 
         
         %etls_loopRCCheck(statusTable=&etls_statusTable, returnCodeVariable=etls_jobRC, 
            start=&&&etls_controlName,end=&&&etls_controlName); 
      %end; 
      
   %end; 
   
%end;

proc datasets lib = work nolist nowarn memtype = (data view);
   delete W2IURBW;
quit;

%mend etls_loopW2IURBQ; 

