         								A.NCR_PD_SEG_ID,
         								A.NCR_LGD_SEG_ID,
         								A.NCR_EAD_SEG_ID,
         								SUM
         							(CASE 
         								WHEN B.LAST_NEW_DFT_BAL_AMT < 0 THEN 0 
