         /*FINAL MASTER TABLE AFTER ALL CHILD TABLES JOINED*/
         PROC SQL;
         	CREATE TABLE FINAL_BE_FACT AS 
         		SELECT
         			&MTH_TM_ID AS MTH_TM_ID,
         			I.NCR_EXPSR_CL_KEY_VAL,
         			'0201' AS NCR_RT_SYS_KEY_VAL,
         			I.NCR_PD_SEG_KEY_VAL,
         			I.NCR_LGD_SEG_KEY_VAL,
         			I.NCR_EAD_SEG_KEY_VAL,
         			'SPL' AS SRC_SYS_CD,
         			I.RPTG_QTR_ACCT_CNT,
         			II.PD_FINAL_RPTG_RTO,
         			II.LGD_FINAL_RPTG_RTO,
         		CASE 
         			WHEN I.RPTG_QTR_ACCT_CNT > 0 THEN 1 
         			ELSE 0 
         		END 
         	AS EAD_FINAL_RPTG_RTO,
         		COALESCE(III.PRIOR_12_MTH_REALZ_PD_ACCT_CNT,0) AS PRIOR_12_MTH_REALZ_PD_ACCT_CNT, 
         		COALESCE(III.PRIOR_12_MTH_REALZ_EAD_ACCT_CNT,0) AS PRIOR_12_MTH_REALZ_EAD_ACCT_CNT,
         		COALESCE(IV.ACCT_COUNT,0) AS PRIOR_36_MTH_REALZ_LGD_ACCT_CNT,
         		COALESCE(V.PR_12_M_REALZ_PD_DEF_ACCT_CNT,0) AS PR_12_M_REALZ_PD_DEF_ACCT_CNT, 
         		COALESCE(V.PR_12_M_REALZ_EAD_DEF_ACCT_CNT,0) AS PR_12_M_REALZ_EAD_DEF_ACCT_CNT,
         		COALESCE(VI.ACCT_COUNT,0) AS PR_36_M_REALZ_LGD_DEF_ACCT_CNT,
         		COALESCE(VII.PR_12_M_RLZ_DEF_LN_OS_PD_BAL_AM,0) AS PR_12_M_RLZ_DEF_LN_OS_PD_BAL_AM,
         		COALESCE(VII.PR_12_M_RLZ_DEF_LN_OS_EAD_BAL_AM,0) AS PR_12_M_RLZ_DEF_LN_OS_EAD_BAL_AM,
         		COALESCE(VIII.PR_36_M_RLZ_DEF_LN_OS_LGD_BAL_AM,0) AS PR_36_M_RLZ_DEF_LN_OS_LGD_BAL_AM,
         		COALESCE
         	(CASE 
         		WHEN V.PR_12_M_REALZ_PD_DEF_ACCT_CNT = 0 THEN 0 
         		WHEN III.PRIOR_12_MTH_REALZ_PD_ACCT_CNT <> 0 THEN V.PR_12_M_REALZ_PD_DEF_ACCT_CNT/PRIOR_12_MTH_REALZ_PD_ACCT_CNT
         		ELSE 1 END,0) AS PRIOR_12_MTH_REALZ_PD_RTO,
         		COALESCE(IX.PRIOR_36_MTH_REALZ_LGD_RTO,0) AS PRIOR_36_MTH_REALZ_LGD_RTO,
         		COALESCE
         	(CASE 
         		WHEN V.PR_12_M_REALZ_EAD_DEF_ACCT_CNT > 0 THEN 1 
         		ELSE 0 END,0) AS PRIOR_12_MTH_REALZ_EAD_RTO
         	FROM
