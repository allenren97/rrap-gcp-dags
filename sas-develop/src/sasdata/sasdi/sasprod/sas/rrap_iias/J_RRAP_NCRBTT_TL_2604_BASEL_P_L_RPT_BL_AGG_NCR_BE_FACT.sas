         									AS AMOUNT_SUM2  /*CR 27 ADDED*/
         										FROM &bttdb..BASEL_PSNL_LOAN_RPTG_DRVD_VARS A, &RRAP_DB..BASEL_PSNL_LOAN_ACCT_DRVD_VARS_2 B     /*CR 27 ADDED*/
         											WHERE A.BASEL_ACCT_ID = B.BASEL_ACCT_ID AND A.MTH_TM_ID = &MTH_TM_ID_12 AND B.MTH_TM_ID = &MTH_TM_ID_12
         												GROUP BY 
         													A.EXPSR_CL_ID, 
         													A.NCR_PD_SEG_ID,
         													A.NCR_LGD_SEG_ID,
         													A.NCR_EAD_SEG_ID) QUERY3 
         													ON QUERY1.EXPSR_CL_ID = QUERY3.EXPSR_CL_ID AND  
         													QUERY1.NCR_PD_SEG_ID = QUERY3.NCR_PD_SEG_ID AND 
         													QUERY1.NCR_LGD_SEG_ID = QUERY3.NCR_LGD_SEG_ID AND
         													QUERY1.NCR_EAD_SEG_ID = QUERY3.NCR_EAD_SEG_ID);
         
         	/*PR_36_M_RLZ_DEF_LN_OS_LGD_BAL_AM*/
         	CREATE TABLE BE_FACT_P_36_M_R_D_LN_OS_LGD_AM AS 
