         			A.NCR_PD_SEG_ID,
         			A.NCR_LGD_SEG_ID,
         			A.NCR_EAD_SEG_ID,
         			NVL(AVG(B.LGD_NPV_ALL_COST_FLR_CAP_150_RTO),0) AS PRIOR_36_MTH_REALZ_LGD_RTO
         		FROM &bttdb..BASEL_PSNL_LOAN_RPTG_DRVD_VARS A, &RRAP_DB..PSNL_LN_LGD_OBSVT_PT_RELZ_VAL B
         			WHERE A.BASEL_ACCT_ID = B.BASEL_ACCT_ID AND A.MTH_TM_ID = &MTH_TM_ID_36 AND B.OBSVTN_MTH_TM_ID = &MTH_TM_ID_36
         				GROUP BY 
         					A.EXPSR_CL_ID, 
