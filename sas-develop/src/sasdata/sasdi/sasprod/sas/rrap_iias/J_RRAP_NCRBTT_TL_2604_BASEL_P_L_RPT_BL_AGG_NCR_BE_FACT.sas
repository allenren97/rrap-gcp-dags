         										QUERY1.NCR_PD_SEG_ID = QUERY2.NCR_PD_SEG_ID AND 
         										QUERY1.NCR_LGD_SEG_ID = QUERY2.NCR_LGD_SEG_ID AND
         										QUERY1.NCR_EAD_SEG_ID = QUERY2.NCR_EAD_SEG_ID);
         
         	/*PR_36_M_REALZ_LGD_DEF_ACCT_CNT*/
         	CREATE TABLE BE_FACT_P_36_M_R_LGD_DEF_ACNT AS 
         		SELECT * FROM CONNECTION TO NZCON (
         		SELECT 
         			A.EXPSR_CL_ID, 
         			A.NCR_PD_SEG_ID,
         			A.NCR_LGD_SEG_ID,
         			A.NCR_EAD_SEG_ID,
