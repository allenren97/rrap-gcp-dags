         								WHERE B.MODEL_DFT_F = 'Y' AND A.BASEL_ACCT_ID = B.BASEL_ACCT_ID AND A.MTH_TM_ID = &MTH_TM_ID_36 AND B.OBSVTN_MTH_TM_ID = &MTH_TM_ID_36
         									GROUP BY 
         										A.EXPSR_CL_ID, 
         										A.NCR_PD_SEG_ID,
         										A.NCR_LGD_SEG_ID,
         										A.NCR_EAD_SEG_ID) QUERY2 
         										ON QUERY1.EXPSR_CL_ID = QUERY2.EXPSR_CL_ID AND  
         										QUERY1.NCR_PD_SEG_ID = QUERY2.NCR_PD_SEG_ID AND 
         										QUERY1.NCR_LGD_SEG_ID = QUERY2.NCR_LGD_SEG_ID AND
         										QUERY1.NCR_EAD_SEG_ID = QUERY2.NCR_EAD_SEG_ID
         									LEFT OUTER JOIN 
         										(SELECT 
         											A.EXPSR_CL_ID, 
         											A.NCR_PD_SEG_ID,
         											A.NCR_LGD_SEG_ID,
         											A.NCR_EAD_SEG_ID,
         											SUM
         										(CASE 
         											WHEN B.OS_BAL_AMT_V2 < 0 THEN 0 
