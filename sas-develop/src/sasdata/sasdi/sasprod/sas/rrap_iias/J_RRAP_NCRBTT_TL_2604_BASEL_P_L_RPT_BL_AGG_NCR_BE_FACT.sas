         PROC SQL;
         	CONNECT USING NZWRKBT AS NZCON;
         	CREATE TABLE BE_FACT_P_12_M_R_D_LN_OS_AM AS 
         		SELECT * FROM CONNECTION TO NZCON (
         
         		SELECT QUERY1.*, 
         			CASE 
         				WHEN QUERY1.PIT_STATUS_V2 = 'DEF' THEN NVL(QUERY3.AMOUNT_SUM2,0) 
         				WHEN QUERY1.PIT_STATUS_V2 = 'CUR' THEN NVL(QUERY2.AMOUNT_SUM1,0) 
