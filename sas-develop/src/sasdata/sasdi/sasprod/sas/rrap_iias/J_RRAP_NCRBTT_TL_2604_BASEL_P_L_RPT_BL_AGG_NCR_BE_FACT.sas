         					WHERE A.BASEL_ACCT_ID = B.BASEL_ACCT_ID AND A.MTH_TM_ID = &MTH_TM_ID_12 AND B.MTH_TM_ID = &MTH_TM_ID_12
         						GROUP BY 
         							A.EXPSR_CL_ID, 
         							A.NCR_PD_SEG_ID,
         							A.NCR_LGD_SEG_ID,
         							A.NCR_EAD_SEG_ID) QUERY1 
         						LEFT OUTER JOIN 
         							(SELECT 
         								A.EXPSR_CL_ID, 
         								A.NCR_PD_SEG_ID,
         								A.NCR_LGD_SEG_ID,
         								A.NCR_EAD_SEG_ID,
         								SUM
         							(CASE 
         								WHEN B.LAST_NEW_DFT_BAL_AMT < 0 THEN 0 
