proc sql;
	create table time_key as
	select TM_ID, put(tm_lvl_end_dt,date9.) as tm_lvl_end_dt from 
	nzrrap.TM_DIM
	where tm_lvl='Month' and tm_lvl_end_dt between "&start_period_dt"d and "&end_period_dt"d
	order by 1;
quit;
  
         /*---- Start of User Written Code  ----*/ 
         
         /* ENTER KS CODE BELOW -- REMOVE CALL TO AUTOEXEC!! OTHERWISE THE MTH_TM_ID SETTING WILL BE OVERWRITTEN!!!*/
         
         %put MTH_TM_ID=&mth_tm_id;
         %let time_key=&mth_tm_id;
         
         %put TIME_KEY=&time_key;
         
         proc sql;
         connect using netcon as nzcon1;
         execute (delete from &net_db..BASEL_CUST_MTH_DEP_TXN_SUM where mth_tm_id = &time_key) by nzcon1;
         quit;
         
         proc sql;
         	connect using OWSTAR as dbcon;
         	create table rrap_lib.cust_acct_trxn as 
             select * from connection to dbcon (
         		Select 	
         			b.TIME_KEY,
         			b.CUST_BASE_KEY,
         			b.PRIM_CUST_F,
         			d.DLVY_KEY,
         			SUM(d.ACTY_CNT) as acty_cnt,
         			SUM(d.ACTY_TOT_AMT) as acty_tot_amt,
         			'' as TXN_GRP_KEY_RM
         		from owstar.iwf_cust_acct b,
         		     owstar.iwf_cust_acty_rlp d
         		where   b.TIME_KEY = &time_key
         		  and   b.ACCT_LCST in ('A', 'I', 'D')
         		  and	b.CUST_BASE_KEY = d.CUST_BASE_KEY
         		  and	b.PRIM_CUST_F = 'P'
         		  and  	b.TIME_KEY = d.TIME_KEY
         		  and   b.ACCT_KEY = d.ACCT_KEY
         		group by  b.TIME_KEY, b.CUST_BASE_KEY, b.PRIM_CUST_F, d.DLVY_KEY
              );
         	quit;
         
         	/* Assume the IWD_CHNL_RM.xlsx already uploaded INTO NETCON.DLVY_KEY_TO_TXN_GRP_MAPPNG_LKP*/
         
         	PROC sql;
         	update rrap_lib.cust_acct_trxn b
         	set TXN_GRP_KEY_RM = (select a.TXN_GRP_KEY from NETCON.DLVY_KEY_TO_TXN_GRP_MAPPNG_LKP a where a.DLVY_key  = b.DLVY_KEY);
         	quit;
         
         	
         	PROC SORT data=rrap_lib.cust_acct_trxn;
         		by TIME_KEY CUST_BASE_KEY;
         	run;
         
         	data rrap_lib.Owstar_cust_acct_trxn_aggr;
         	set rrap_lib.cust_acct_trxn;
         	by TIME_KEY CUST_BASE_KEY;
         	retain Deposit_Count NSF_Count OverDraft_Count Payroll_Count Total_Deposit_Amount Total_NSF_Amount Total_Payroll_Amount Total_Withdrawal_Amount Withdrawal_Count 0;
         
         	if first.CUST_BASE_KEY then
         	do;
         		Deposit_Count = 0;
         		NSF_Count = 0;
         		OverDraft_Count = 0; 
         		Payroll_Count = 0;
         		Total_Deposit_Amount = 0; 
         		Total_NSF_Amount = 0;
         		Total_Payroll_Amount = 0; 
         		Total_Withdrawal_Amount = 0; 
         		Withdrawal_Count = 0;
         	end;
         
         	if TXN_GRP_KEY_RM = 'W' then
         	do;
         		Withdrawal_Count = Withdrawal_Count + 1;
         		Total_Withdrawal_Amount = sum(Total_Withdrawal_Amount, ACTY_TOT_AMT, 0);
         	end;
         	
         	if TXN_GRP_KEY_RM = 'D' then
         	do;
         		Deposit_Count = Deposit_Count + 1;
         		Total_Deposit_Amount = sum(Total_Deposit_Amount, ACTY_TOT_AMT, 0);
         	end;
         
         	if TXN_GRP_KEY_RM = 'P' then
         	do;
         		Payroll_Count = Payroll_Count + 1;
         		Total_Payroll_Amount = sum(Total_Payroll_Amount, ACTY_TOT_AMT, 0);
         	end;
         
         	if TXN_GRP_KEY_RM = 'O' then
         	do;
         		OverDraft_Count = OverDraft_Count + 1;
         	end;
         
         	if TXN_GRP_KEY_RM = 'N' then
         	do;
         		NSF_Count = NSF_Count + 1;
         		Total_NSF_Amount = sum(Total_NSF_Amount, ACTY_TOT_AMT, 0);
         	end;
         
         	if last.CUST_BASE_KEY then
           	output;
         
         	Keep TIME_KEY CUST_BASE_KEY Deposit_Count NSF_Count OverDraft_Count Payroll_Count Total_Deposit_Amount Total_NSF_Amount Total_Payroll_Amount Total_Withdrawal_Amount Withdrawal_Count;
         run;
         
         
         proc sql;
         	connect using OWSTAR as dbcon;
         	create table rrap_lib.CUST_ID_BASE_KEY as 
             select * from connection to dbcon (
         		select cust_base_key, CUST_ID from owtact.cust_xref group by cust_base_key, CUST_ID
         		);
         quit;
         
         proc sql;
         	connect using NZRRAP as nzcon;
         	
         	create table rrap_lib.basel_cust_id_cid as
         	select * from connection to nzcon (
         		SELECT basel_cust_id, cust_cid FROM &net_db..basel_cust_dim
         		);
         quit;
         
         
         Proc sql;
         
         %let dt = %SYSFUNC(datetime(),best18.);
         
         	insert into NETCON.BASEL_CUST_MTH_DEP_TXN_SUM (
         			MTH_TM_ID
         		   , BASEL_CUST_ID
         	       , DEP_CNT
         	       , NSF_CNT
         	       , OVDR_CNT
         	       , PAYRL_CNT
         	       , TOT_DEP_AMT
         	       , TOT_NSF_AMT
         	       , TOT_PAYRL_AMT
         	       , TOT_WTHDRWL_AMT
         	       , WTHDRWL_CNT
         	       , INSRT_PROCESS_TMSTMP
         	)
         		select  a.TIME_KEY,
         				c.BASEL_CUST_ID,
         				Deposit_Count,
         				NSF_Count,
         				OverDraft_Count, 
         				Payroll_Count,
         				Total_Deposit_Amount, 
         				Total_NSF_Amount,
         				Total_Payroll_Amount, 
         				Total_Withdrawal_Amount, 
         				Withdrawal_Count,
         				&dt
         		FROM rrap_lib.Owstar_cust_acct_trxn_aggr a, rrap_lib.cust_id_base_key b, rrap_lib.basel_cust_id_cid c
         		WHERE a.CUST_BASE_KEY = b.CUST_BASE_KEY
         		and b.CUST_ID = c.CUST_CID
         		;
         quit;	
         
         proc datasets library=rrap_lib;
            delete cust_acct_trxn;
         run;
         
         
         proc datasets library=rrap_lib;
            delete Owstar_cust_acct_trxn_aggr;
         run;
         
         
         
         
         
         
         
