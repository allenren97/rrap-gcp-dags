                  /*MAX(0.1, MIN(1, FINAL3.LGD_FINAL_RPTG_RTO+ADDON)) */
                  /*Changed Feb10, 2017*/
                  MAX(0.1, MIN(1, MAX(FINAL3.lgd_unadjusted_rptg_rto + ADDON , FINAL3.LGD_FINAL_RPTG_RTO))) 
				 
				   ELSE FINAL3.LGD_FINAL_RPTG_RTO 
			   END AS DLGD_FINAL_RPTG_RTO
         FROM
         (
	         SELECT FINAL2.*,
	         		/*STEP.INDEXED_CCLTV_RTO,*/
			         CASE 
			         	WHEN FINAL2.DLGD_F='Y' AND FINAL2.CRNT_LTV_RTO IS NOT NULL AND DELTA_P IS NOT NULL 
			         		AND FINAL2.INDEXED_CCLTV_RTO IS NOT NULL THEN MAX((MIN(FINAL2.CRNT_LTV_RTO, MAX(FINAL2.INDEXED_CCLTV_RTO-0.8*(1-DELTA_P),0))-MAX(FINAL2.INDEXED_CCLTV_RTO-0.8,0))/NULLIF(FINAL2.CRNT_LTV_RTO,0),0) 
			         	WHEN FINAL2.DLGD_F='Y' AND FINAL2.CRNT_LTV_RTO IS NOT NULL AND DELTA_P IS NOT NULL 
			         		AND FINAL2.INDEXED_CCLTV_RTO IS NULL THEN (MAX(FINAL2.CRNT_LTV_RTO-0.8*(1-DELTA_P),0)-MAX(FINAL2.CRNT_LTV_RTO-0.8,0))/NULLIF(FINAL2.CRNT_LTV_RTO,0)
			         	ELSE NULL 
		         	END AS ADDON
	         FROM
	         (
		         SELECT FINAL1.*, 
		         		CASE 
							WHEN FINAL1.DLGD_F='N' THEN NULL 
							WHEN FINAL1.DLGD_F<>'N' AND FINAL1.METRPL_BREACH_F='Y' THEN MAX(1-(HPV_12_QTR_AGO/NULLIF(FINAL1.INDEX_TERANETV,0)),0.25) 
							WHEN FINAL1.DLGD_F<>'N' AND FINAL1.METRPL_BREACH_F<>'Y' THEN MAX(1-(HPV_12_QTR_AGO/NULLIF(FINAL1.INDEX_TERANETV,0)),0) 
						END AS DELTA_P
		         FROM
		         (
                  SELECT SUBQ2.*, INDX.INDEX, INDX12.INDEX AS INDEX_12_QTR_AGO, (SUBQ2.INDEX_TERANETV/INDX.INDEX)*INDX12.INDEX AS HPV_12_QTR_AGO, SCRI.METRPL_BREACH_F
                  FROM (
                  SELECT SUBQ1.*, FIR.PROP_CITY, FIR.INDEX_TERANETV, LTVVAR.CRNT_LTV_RTO, LTVVAR.INDEXED_CCLTV_RTO,
                  CASE WHEN SUBQ1.DLGD_F='N' THEN NULL  
                     WHEN SUBQ1.DLGD_F<>'N' AND (FIR.PROP_CITY IS NULL OR UPPER(FIR.PROP_CITY) LIKE '%OTHER%') THEN '11'
                     WHEN SUBQ1.DLGD_F<>'N' AND TRIM(FIR.PROP_CITY)='Ottawa - Gatineau' THEN 'OTTAWA_GATINEAU' ELSE FIR.PROP_CITY END AS METROPOLITAN
                  FROM (
                  SELECT A.*, B.BASEL_MORT_MTH_SNAPSHOT_ID, B.INTR_ADJ_DT, B.LAST_RNEW_DT,
                  CASE WHEN A.LGD_BASEL_SEG_NUM NOT IN (13,14) AND A.PIT_STAT_CD = 'CUR' AND A.SCRTY_TP_DESC='Uninsured' AND (B.INTR_ADJ_DT>='11-01-2016' OR B.LAST_RNEW_DT>='11-01-2016') THEN 'Y' ELSE 'N' END AS DLGD_F 
                  FROM 
                  &bttdb..BASEL_ANALYTCL_BL_INST_FCT_BNS A,&RRAP_DB..BASEL_MORT_MTH_SNAPSHOT B 
                  WHERE 
                  TRIM(A.MORT_NUM)=TRIM(B.MORT_NUM) AND A.MTH_TM_ID=&MTH_TM_ID AND B.MTH_TM_ID=&MTH_TM_ID) SUBQ1
                  LEFT OUTER JOIN &FRG_DB..LTV_VAR_CLUS_LTV_FINAL FIR ON SUBQ1.MORT_NUM=CAST(FIR.MORTGAGE_NO AS VARCHAR(30)) AND FIR.YYMTH=&YEARMONTH
                  LEFT OUTER JOIN &RRAP_DB..BASEL_ACCT_LTV_DRVD_VARS LTVVAR ON TRIM(SUBQ1.MORT_NUM)=TRIM(LTVVAR.ACCT_NUM) AND LTVVAR.ACCT_SENRTY_CD=1 AND LTVVAR.MTH_TM_ID=&MTH_TM_ID) SUBQ2
                  LEFT OUTER JOIN (SELECT DISTINCT MTH_TM_ID, LABEL_2, INDEX FROM &RRAP_DB..TERANET_HOUSE_PRC_INDEX WHERE MTH_TM_ID=(SELECT MAX(MTH_TM_ID) FROM &RRAP_DB..TERANET_HOUSE_PRC_INDEX)) INDX 
                     ON UPPER(TRIM(INDX.LABEL_2)) =UPPER(TRIM(SUBQ2.METROPOLITAN))
                  LEFT OUTER JOIN (SELECT DISTINCT MTH_TM_ID, LABEL_2, INDEX FROM &RRAP_DB..TERANET_HOUSE_PRC_INDEX WHERE MTH_TM_ID=(SELECT MAX(MTH_TM_ID)-1440 FROM &RRAP_DB..TERANET_HOUSE_PRC_INDEX)) INDX12 
                     ON UPPER(TRIM(INDX12.LABEL_2)) =UPPER(TRIM(SUBQ2.METROPOLITAN)) 
                  LEFT OUTER JOIN &RRAP_DB..DLGD_SCRI_QTR_DRVD_VARS SCRI ON UPPER(TRIM(SCRI.METRPL_AREA_NM))=UPPER(TRIM(SUBQ2.METROPOLITAN)) AND SCRI.MTH_TM_ID=&CURR_QTR_MTH_TM_ID
               ) FINAL1
            ) FINAL2
         ) FINAL3
         ) FINAL
         ) BY NZCON;
         DISCONNECT FROM NZCON;
         QUIT;
         
         /*---- End of User Written Code  ----*/ 
         
      %mend etls_jobW3YJ4UX; 
      
      %etls_jobW3YJ4UX; 
      
      %let handleName = %etls_getHandle(statusTable=&etls_statusTable,
         handleVariable=etls_handleName, row=&&&etls_controlName);
         
      %let job_rc&handleName. = &job_rc; 
      
      %etls_freeHandle(statusTable=&etls_statusTable, statusVariable=etls_status, 
         handleVariable=etls_handleName, handleName="&handleName", 
         startTimeVariable=etls_startTime, endTimeVariable=etls_endTime, signoff=0, 
         returnCodeVariable=etls_jobRC, returnCodeMacroVariable=job_rc&handleName., setMainJobRc=1); 
         
   %mend etls_processToLoopW3YJ4UN;
   
   %local etls_controlTable etls_statusTable etls_controlName 
      etls_processesRunning etls_maxProcesses etls_parameterTable 
      etls_additionalSignonOptions etls_signonRetries;
   %let etls_controlName = ifct; 
   %let etls_statusTable = work.W3LPAWL; 
   %let etls_parameterTable = work.W3YJ4UU; 
   %let &etls_controlName = 0;
   %let etls_controlTable = work.W3LP9D0;
   
   %put %str(NOTE: Creating status table...);
   data &etls_statusTable 
      (keep = etls_handleName etls_machineId etls_startTime etls_endTime etls_status 
              etls_jobRC TM_ID MTH_END_DT MTH_TM_ID LOOP_DATE
      );
      attrib etls_handleName length = $32
         label = 'Name of handle to remote session'; 
      attrib etls_machineId length = $32
         label = 'Name of machine executing the task'; 
      attrib etls_startTime length = 8
         format = nldatmap.
         label = 'Start time of task'; 
      attrib etls_endTime length = 8
         format = nldatmap.
         label = 'End time of task'; 
      attrib etls_status length = $32
         label = 'Current status of task'; 
      attrib etls_jobRC length = 8
         label = 'Return code of task'; 
      attrib TM_ID length = 8; 
      attrib MTH_END_DT length = $9; 
      attrib MTH_TM_ID length = 8
         format = 20.
         informat = 20.
         label = 'TM_ID'; 
      attrib LOOP_DATE length = 8
         format = DATE9.
         informat = DATE9.
         label = 'TM_LVL_END_DT'; 
      set &etls_controlTable;
   run;
   
   %rcSet(&syserr); 
   
   %put %str(NOTE: Creating parameter table...);
   proc sql; 
      create table &etls_parameterTable as 
         select MTH_TM_ID as mth_tm_id, 
                LOOP_DATE as loop_date 
         from &etls_controlTable; 
   quit; 
   
   %rcSet(&sqlrc); 
   
   /* Get the number of times to iterate from the number of rows in the source  */ 
   /*  table                                                                    */ 
   proc sql noprint; 
      select count(*) into :&etls_controlName._max from &etls_statusTable;
      %let &etls_controlName._max = &&&etls_controlName._max;
   quit;
   
   %rcSet(&sqlrc); 
   
   /* Initialize checks for status handling per iteration  */ 
   %do i=1 %to &&&etls_controlName._max; 
      %local etls_statusReported&i; 
      %let etls_statusReported&i = 0; 
   %end; 
   
   %let etls_maxProcesses = 1; 
   
   %if (&etls_maxProcesses > 0) %then 
   %do; 
      %do %until (&&&etls_controlName ge &&&etls_controlName._max); 
      
         %let etls_lastLoopPtr = &&&etls_controlName;
         
         %let etls_processesRunning = 0; 
         
         %do %while(&etls_processesRunning lt &&&etls_controlName._max 
            and &etls_processesRunning lt &etls_maxProcesses 
            and &&&etls_controlName lt &&&etls_controlName._max);
            
            %let &etls_controlName = %eval(&&&etls_controlName+1);
            
            %let job_rcLast=&job_rc; 
            
            %etls_createHandle(statusTable=&etls_statusTable,
                               statusVariable=etls_status,
                               handleVariable=etls_handleName,
                               handlePrefix=&etls_controlName,
                               statusSetting="Running",
                               row=&&&etls_controlName,
                               machineVariable=etls_machineId,
                               startTimeVariable=etls_startTime,
                               signon=0,
                               useGrid=0);
            
         %let etls_processesRunning = 1; 
         %etls_processToLoopW3YJ4UN(parameterTable=&etls_parameterTable, row=&&&etls_controlName,
            handleName=%etls_getHandle(statusTable=&etls_statusTable,
            handleVariable=etls_handleName, row=&&&etls_controlName)); 
         
         /* Reset main Job_RC and Trans_RC to max return code of all iterations */ 
         %let job_rcThisIter=&job_rc; 
         %let job_rc=&job_rcLast; 
         %let trans_rc=&job_rcLast; 
         %rcSet(&job_rcThisIter); 
         
         %etls_loopRCCheck(statusTable=&etls_statusTable, returnCodeVariable=etls_jobRC, 
            start=&&&etls_controlName,end=&&&etls_controlName); 
      %end; 
      
   %end; 
   
%end;

