/* EXTRACT RUN DATE FROM CONTROL TABLE */

%get_model_period_dates(product=mor);
/*%let start_period_dt=31JAN2010;*/
/*%let end_period_dt=31MAY2015;*/
%put Start and End Dates for Mortgage Models:;
%put start_period_dt: &start_period_dt ;
%put end_period_dt: &end_period_dt;
 
%let _avg_start_qtr = 31DEC2004;
/*%let _avg_end_qtr = 31JUL2015;*/
%let _avg_end_qtr = &end_period_dt;
%let _input_base_pd_tbl = nz_frg.tng_12mth_default;
%let _input_base_seg_tbl = nz_frg.tng_pd_segmentation_final;
%let _output_dr_tbl = results.tng_pd_realized_dr;
%let _output_dr_avg_tbl = results.tng_pd_historical_dr;

%let _qtr_cntrl_tbl=control.qtr_end_dates;



proc sql;
   create table intmed.realized_dr_input as
   select a.*, 
          b.segment
   from &_input_base_pd_tbl as a,
        &_input_base_seg_tbl as b
   where a.account_id=b.account_id and a.month_end_dt=b.month_end_dt;
quit;

proc summary data = intmed.realized_dr_input nway missing;

   /* BRD (pg 17): only CURRENT at obs period */
   where upcase(final_default_ind) = 'N';
   var def_ind;

   /* Aggregate by observation start date and segment */
   class month_end_date segment;
   output out = work.dr_components (drop = _TYPE_ rename = (_freq_ = current_count))
   sum = def_ind;
run;

proc sql noprint;
   create table &_output_dr_tbl as
   select a.segment,
          a.month_end_date format=date9.,
          a.current_count,
          a.def_ind,
          (case
            when a.current_count NE . and a.def_ind NE . then a.def_ind/a.current_count
            when a.current_count NE . and a.def_ind EQ . then .
            when a.current_count EQ . and a.def_ind NE . then .
            else .
          end) as segment_dr
   from work.dr_components as a;
quit;


/*Added Start_date and seg_end_date variables and order by clause 
  changed logic on how quarter ends are choosen - CV 2DEC2015*/

proc sql noprint;
   create table intmed.realized_dr_quarter_end as
   select a.*,
	min(a.month_end_date) format=date9. as start_date,
			max(a.month_end_date) format=date9. as seg_end_date
   from &_output_dr_tbl as a
   where month(a.month_end_date) in (1,4,7,10)
	order by segment, month_end_date;
quit;

/* Added data step to create a complete timespan for each segment, The segments now have a data point
	 for each quarter inbetween their min dates and the most recent date - CV 2DEC2015*/

data work.fill_in_dates_pd (keep=segment end_date);
	retain end_date;
	set intmed.realized_dr_quarter_end (keep=segment seg_end_date month_end_date);
	by segment;
	end_date= month_end_date;
	if first.segment then 
		do until (end_date gt seg_end_date);
				if month(end_date) in (1,4,7,10) then output;
				end_date= intnx('MONTH',end_date,1,'e');
		end;
	format end_date date9.;
run;

/* added to calculate averages - CV 2DEC2015*/
	data work.quarter_averages_pd (keep= segment start_date end_date avg_segment_dr);
	set intmed.realized_dr_quarter_end (rename= (month_end_date = end_date));
	retain new_segment_dr;
	by segment;
	if first.segment then do;
		counter = 0;	
		new_segment_dr = 0;
	end;
	counter + 1;		
	new_segment_dr=sum(new_segment_dr,segment_dr);
	avg_segment_dr=(new_segment_dr/counter);
	format start_date date9.;
run;

/* Joins the complete list of dates with the averages for the quarter - CV 2DEC2015*/

proc sql;
	create table work.hist_with_missing_pd as
	select a.*,
			b.start_date,
			b.avg_segment_dr
	from work.fill_in_dates_pd as a
			left join
	   	work.quarter_averages_pd as b
	on a.segment = b.segment and
		a.end_date = b.end_date;
quit;

/*Fills in the data points that do not have averages associated with them by retaining the previous
values - CV 2DEC2015*/

data &_output_dr_avg_tbl (keep= end_date start_date segment avg_segment_dr);
	set work.hist_with_missing_pd;
	retain ret_start_date ret_avg_segment_dr;
	if start_date = . then start_date = ret_start_date;
	if avg_segment_dr = . then avg_segment_dr = ret_avg_segment_dr;
	
	ret_start_date = start_date;
	ret_avg_segment_dr = avg_segment_dr ;
	
run; 


