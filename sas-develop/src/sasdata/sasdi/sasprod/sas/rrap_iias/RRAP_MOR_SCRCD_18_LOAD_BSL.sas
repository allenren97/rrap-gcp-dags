%delete_table(NZUSER.SCORECARD_VARS_BSL); 

proc sql;
	connect USING NZUSER as nzcon ;
	/*execute(drop table &target_lib3..SCORECARD_VARS_BSL) by nzcon; */
	execute(
	create table &target_lib3..SCORECARD_VARS_BSL as (
		select
		a.cid,
		a.cust_base_key,
		a.time_key,
		coalesce(date_trunc('day',b.EFF_TMSTMP),b.time_key) as  EFF_TMSTAMP,
      b.mortgage_no,
      b.eff_tmstmp,
      b.DELQ_DAYS as dlqnt_day,
      b.DELQ_MONTHS as DLQNT_MTH,
      b.amort,
      b.prepay_ytd,
      b.process_date,
      b.province
		from    
		&target_lib3..SCORECARD_VARS_ACCT_LIST as a   
		left join &target_lib3..MORTGAGE_HIST as b on
		to_number(a.&acct_key.,'999999999999999')=to_number(b.mortgage_no,'999999999999999') and 
		date_trunc('day',b.EFF_TMSTMP)>=a.from_dt and
		date_trunc('day',b.EFF_TMSTMP)<=a.to_dt ) WITH DATA ;
			) by nzcon;
	 *execute (generate statistics on &target_lib3..SCORECARD_VARS_BSL) by nzcon;
	   execute(CALL SYSPROC.ADMIN_CMD (%nrbquote('RUNSTATS 
						ON TABLE ) %nrbquote(&target_lib3..SCORECARD_VARS_BSL) 
							%nrbquote(ON KEY COLUMNS and INDEXES ALL'))) by nzcon;
	 disconnect from nzcon;
quit;




