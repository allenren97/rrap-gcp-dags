proc sql;
create table WORK.AUDIT_CHECK_OUTPUT_LOG( bufsize=106496 )
  (
   LOG_ID num format=11. informat=11. label='LOG_ID',
   LOG_TP char(80) format=$80. informat=$80. label='LOG_TP',
   LOG_TBL_NM char(80) format=$80. informat=$80. label='LOG_TBL_NM',
   LOG_AUDIT_NM char(200) format=$200. informat=$200. label='LOG_AUDIT_NM',
   LOG_SQL_TEXT char(2000) format=$2000. informat=$2000. label='LOG_SQL_TXT',
   LOG_TM_ID num format=11. informat=11. label='LOG_TM_ID',
   INSRT_PROCESS_TMSTMP num format=DATETIME25.6 informat=DATETIME25.6 label='INSRT_PROCESS_TMSTMP',
   LOG_NM char(200) format=$200. informat=$200. label='LOG_NM',
   LOG_CRNT_VAL num label='LOG_CRNT_VAL',
   LOG_BASLN_VAL num label='LOG_BASLN_VAL',
   LOG_VARNC_VAL num label='LOG_VARNC_VAL',
   LOG_CMB_RSLT char(2000) format=$2000. informat=$2000. label='LOG_CMB_RSLT'
  );
quit;

data _null_;
set AUDIT_CHECK_CNFGRTN;
call execute('

		proc sql;
		connect using ' || TRIM(dbcon) || 'rrap as dbcon;
				insert into WORK.AUDIT_CHECK_OUTPUT_LOG select * from connection to dbcon 
		(

		select 
			' || trim(AUDIT_CNFGRTN_ID) || ' as LOG_ID, 
			' || "'" || TRIM(AUDIT_SUB_CLASS_CD) || "'" || ' as LOG_TP, 
			' || "'" || TRIM(ETL_NM) || "'" || ' as LOG_TBL_NM, 
			' || "'" || TRIM(AUDIT_NM) || "'" || ' as LOG_AUDIT_NM, 
			' || "'" || TRIM(SQL_TEXT_INPUT) || "'" || ' as LOG_SQL_TEXT, 
			&mth_tm_id as LOG_TM_ID,
			' ||  TRIM(TMSTMP) || ' as INSRT_PROCESS_TMSTMP
			, aa.* 
		FROM 
			('  || TRIM(SQL_TEXT)  || ') Aa

		);
		quit;


'); 
run;


