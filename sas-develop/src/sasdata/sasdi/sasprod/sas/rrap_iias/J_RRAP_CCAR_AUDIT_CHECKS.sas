data AUDIT_CHECK_CNFGRTN;
	set NZRRAP.AUDIT_CHECK_CNFGRTN;
	where ACTV_F = 'Y';
	if upcase(db_tp) not in ('NETEZZA','DB2') then do;
		put "THIS PROCESS HAS ABORTED!";
		put " ";
		put "Cannot process unless DB2 or Netezza is specified in the db_tp field. Please update the AUDIT_CHECK_CNFGRTN table.";
		put " ";
		put "THIS PROCESS HAS ABORTED!";
		put " ";
		abort;
	end;
	length sql_text_input $2000. dbcon $3. TMSTMP $20.;
	if upcase(db_tp)='NETEZZA' then do;
		sql_text_input=tranwrd(sql_text,"'","''");
		dbcon='NZ';
		TMSTMP='NOW()';
	end;
	else if upcase(db_tp)='DB2' then do;
	sql_text_input=tranwrd(sql_text,"'","''");
	dbcon='DB2';
	TMSTMP='CURRENT_TIMESTAMP';
	end;
/*	where AUDIT_CNFGRTN_ID=22120;*/
run;
proc sort; by AUDIT_CNFGRTN_ID; run;


