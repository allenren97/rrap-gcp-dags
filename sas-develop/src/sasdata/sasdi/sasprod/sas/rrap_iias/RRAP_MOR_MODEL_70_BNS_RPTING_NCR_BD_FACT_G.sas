%macro etls_loopRCCheck(statusTable=, returnCodeVariable=,start=,end=); 
   %macro etls_loopRCError(_iteration); 
      /* Abort with a return code of  99  */ 
      %abort return  99; 
   %mend etls_loopRCError; 
   
   %local etls_rows etls_dsid rc etls_varnum;
   
   %let etls_rows = 0; 
   proc sql noprint; 
      select count(*) into :etls_rows from &statusTable; 
   quit; 
   
   %if &start le &etls_rows %then 
   %do; 
      %let etls_dsid = %sysfunc(open(&statusTable)); 
      %if (&etls_dsid = 0) %then 
         %put %sysfunc(sysmsg()); 
      %else 
      %do; 
         %do i=&start %to &end; 
            %let rc = %sysfunc(fetchobs(&etls_dsid, &i)); 
            %if (&rc ne 0) %then 
               %put %sysfunc(sysmsg()); 
            %else 
            %do; 
               %let etls_varnum = %sysfunc(varnum(&etls_dsid,&returnCodeVariable)); 
               %if (&etls_varnum > 0) %then 
               %do; 
                  %if ((%sysfunc(getvarn(&etls_dsid,&etls_varnum)) ge 5) and 
                       (&&etls_statusReported&i eq 0)) %then 
                  %do; 
                     %etls_loopRCError(&i); 
                     %let etls_statusReported&i = 1; 
                  %end; 
               %end; 
               %else 
                  %put %sysfunc(sysmsg()); 
            %end; 
         %end; 
         %let rc = %sysfunc(close(&etls_dsid)); 
      %end; 
   %end; 
%mend etls_loopRCCheck; 

