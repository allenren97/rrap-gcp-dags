         /*---- Start of User Written Code  ----*/ 
         
         /*---------------------------------------------------------------------
          * NAME:       07_bns_rpting_ncr_bd_fact.sas
          *
          * PURPOSE:    Pulls together the data needed to feed into the reporting
          *             table BASEL_RPTG_BL_AGGRTD_NCR_BD_FACT
          *             
          * NOTES:    
          *             1. This needs to be run on a monthly basis because the 
          *                1 year and 3 year historical months will change each
          *                month. 
          * 
          * MODIFIED:
          *    20JAN2015 - JL - Created
          *    24JAN2015 - JL - Change to macro vars
          *    01FEB2015 - JL - Updated join logic
          *
          * Copyright (c) 2014 by The Financial Risk Group, Cary, NC, USA.
          *---------------------------------------------------------------------*/
         
         %let _in_tbl_for_bd_fact = nzuser.history_tbl_for_bd_be_fact_bns;
         /*%let _ncr_bd_fact_process_dt = 31OCT2014; */
         
         
         
         /* These dates are used to query history from tables */
         data _null_;
             call symput('yymth',cats(put(intnx('month', "&_ncr_bd_fact_process_dt"d, 0, 'e'), yymmn.)));
         	 call symput('_ncr_bd_fact_process_dt2', cats(put(intnx('month', "&_ncr_bd_fact_process_dt"d, 0, 'e'), yymmdd10.)));
             call symput('three_months_ago', cats(put(intnx('month', "&_ncr_bd_fact_process_dt"d, -3, 'e'), yymmdd10.)));
         run;
         %put three_months_ago = &three_months_ago;
         %put _ncr_bd_fact_process_dt2 = &_ncr_bd_fact_process_dt2;
         %put yymth = &yymth;
         
         /*---------------------------------------------------
          * 1. Gets a table of distinct values. This will
          *    define the aggregations available
          *---------------------------------------------------*/
         proc sql noprint;
            create table work.bd_distinct_groupings1 as 
            select distinct a.process_date,
                            a.mth_tm_id,
                            a.ncr_expsr_cl_key_val,
                            a.ncr_geo_key_val,
                            a.ncr_pd_band_key_val,
                            a.src_sys_cd
            from &_in_tbl_for_bd_fact as a
            where intnx('month', datepart(a.process_date), 0, 'e') = "&_ncr_bd_fact_process_dt"d;
         quit;
         
         /*---------------------------------------------------
          * 2. Count of realized defaults - 3 months ago
          *---------------------------------------------------*/
         /**** 5/10/15 FF moved the Delete_table out of the Netezza process causing errrors when table isn't there ****/
         %delete_table(nzuser.bns_period_accts_&yymth);
         proc sql noprint;
            connect USING NZUSER as nzcon ;
         /*    execute (drop table &target_lib3...bns_period_accts_&yymth) by nzcon; */
            execute (
         
               create table &target_lib3..bns_period_accts_&yymth as (
                  select a.process_date,
                         a.mortgage_no
         
               from &target_lib3..history_tbl_for_bd_be_fact_bns as a
         
               /* Subset on date */     
               where last_day(date_trunc('day', a.process_date)) = %nrbquote('&_ncr_bd_fact_process_dt2') 
         
                 /* For speed at creating table */
				) WITH DATA
                /*distribute on (mortgage_no)) by nzcon; */
				distribute BY (mortgage_no) ) by nzcon;
            *execute (generate statistics on &target_lib3..bns_period_accts_&yymth) by nzcon;
			  Execute (CALL SYSPROC.ADMIN_CMD (%nrbquote('RUNSTATS
								ON TABLE ) %nrbquote(&target_lib3..bns_period_accts_&yymth)
											%nrbquote(ON KEY COLUMNS and INDEXES ALL'))) by nzcon;
            disconnect from nzcon;
         quit;    
         
         
         /**** 5/10/15 FF moved the Delete_table out of the Netezza process causing errrors when table isn't there ****/
         %delete_table(nzuser.bns_period_def_cnt_&yymth.);
         
         proc sql noprint;
            connect USING NZUSER as nzcon ;
         /*   execute (drop table &target_lib3...bns_period_def_cnt_&yymth.) by nzcon;*/
            execute (
         
               create table &target_lib3..bns_period_def_cnt_&yymth. as (
                  select a.process_date,
                         a.mortgage_no,
                         a.ncr_expsr_cl_key_val,
                         a.ncr_geo_key_val,
                         a.ncr_pd_band_key_val,
                         a.src_sys_cd,
                         a.pit_stat_cd
         
               from &target_lib3..history_tbl_for_bd_be_fact_bns as a
                    inner join
                    &target_lib3..bns_period_accts_&yymth as b
                    on a.mortgage_no = b.mortgage_no
         
               /* Subset on date */     
               where last_day(date_trunc('day', a.process_date)) >= %nrbquote('&three_months_ago') and
                     last_day(date_trunc('day', a.process_date)) <= %nrbquote('&_ncr_bd_fact_process_dt2') 
         
               order by a.mortgage_no,
                        a.process_date desc
             ) WITH DATA
                 /* For speed at creating table */
             /*   distribute on (mortgage_no)) by nzcon; */
				distribute BY (mortgage_no)) by nzcon;
            *execute (generate statistics on &target_lib3..bns_period_def_cnt_&yymth.) by nzcon;
  			  Execute (CALL SYSPROC.ADMIN_CMD (%nrbquote('RUNSTATS
								ON TABLE ) %nrbquote(&target_lib3..bns_period_def_cnt_&yymth.)
											%nrbquote(ON KEY COLUMNS and INDEXES ALL'))) by nzcon;
            disconnect from nzcon;
         quit;
          
         
         /* Counts those accounts that go into default in a three month period */
         data work.period_def_cnt1;
            set nzuser.bns_period_def_cnt_&yymth.;
         
            retain def_in_period 0 already_defaulted 0;
         
            by mortgage_no process_date;
         
            /* First period - if in DEF then count as default */
            if first.mortgage_no = 1 and first.process_date = 1 then
            do;
               def_in_period = 0;
               already_defaulted = 0;
               if upcase(pit_stat_cd) = 'DEF' then 
               do;
                  def_in_period = 1;
                  already_defaulted = 1;
               end;
            end;
         
            /* All other periods - if in DEF then count as default */
            else if first.mortgage_no = 0 and already_defaulted = 0 then
            do;
               if upcase(pit_stat_cd) = 'DEF' then 
               do;
                  def_in_period = 1;
                  already_defaulted = 1;
               end;
            end;
         
            if last.mortgage_no = 1 then output;
         run;
         
         proc summary data=work.period_def_cnt1 nway missing;
            class ncr_expsr_cl_key_val
                  ncr_geo_key_val
                  ncr_pd_band_key_val
                  src_sys_cd;
         
            var def_in_period;
         
            output out = work._3mos_ago_def_cnt (drop = _freq_ _type_)
            sum = prior_3_mth_realz_defltd_cnt;
         run;
                
         
         /*---------------------------------------------------
          * 3. Estimated defaulted loan count process
          *---------------------------------------------------*/
         proc sql noprint;
            create table work._est_def_metrics as 
            select a.ncr_expsr_cl_key_val,
                   a.ncr_geo_key_val,
                   a.ncr_pd_band_key_val,
                   a.src_sys_cd,
         
                   /* Count and average PD */
                   count(*) as count_by_segment,
                   avg(a.pd_final_rptg_rto) as avg_by_segment
                 
            from &_in_tbl_for_bd_fact as a
            where intnx('month', datepart(a.process_date), 0, 'e') = "&_ncr_bd_fact_process_dt"d 
            group by a.ncr_expsr_cl_key_val, 
                     a.ncr_geo_key_val,
                     a.ncr_pd_band_key_val,
                     a.src_sys_cd;
         quit;
         
         /*---------------------------------------------------
          * 4. Join results together 
          *---------------------------------------------------*/
         proc sql noprint;
            create table work.ncr_bd_fact as
            select a.process_date,
                   a.mth_tm_id,
                   a.ncr_expsr_cl_key_val,
                   a.ncr_geo_key_val,
                   a.ncr_pd_band_key_val,
                   a.src_sys_cd,
         
                   /* Prior three months realized defaulted loan count */
                   (case 
                     when b.prior_3_mth_realz_defltd_cnt EQ . then 0
                     else b.prior_3_mth_realz_defltd_cnt
                     end) as prior_3_mth_realz_defltd_cnt,
         
                   /* Estimated defaulted loan count */
                   (case
                     when c.count_by_segment NE . and c.avg_by_segment NE . then round(c.count_by_segment*c.avg_by_segment, 1)
                     else .
                     end) as estd_defltd_loan_cnt
         
            from work.bd_distinct_groupings1 as a
                 left join 
                 work._3mos_ago_def_cnt as b
                 on (a.ncr_expsr_cl_key_val = b.ncr_expsr_cl_key_val and
                     a.ncr_geo_key_val = b.ncr_geo_key_val and
                     a.ncr_pd_band_key_val = b.ncr_pd_band_key_val and
                     a.src_sys_cd = b.src_sys_cd)
         
                 left join
                 work._est_def_metrics as c
                 on (a.ncr_expsr_cl_key_val = c.ncr_expsr_cl_key_val and
                     a.ncr_geo_key_val = c.ncr_geo_key_val and
                     a.ncr_pd_band_key_val = c.ncr_pd_band_key_val and
                     a.src_sys_cd = c.src_sys_cd);
         quit;
         
         /*----------------------------------------------------
          * 5. Load to final table
          *----------------------------------------------------*/
         proc sql noprint;
            insert into nzuser.basel_rpt_bl_agg_ncr_bd_fact_bns (bulkload=yes BL_METHOD=CLILOAD)
            select a.mth_tm_id,
                   a.ncr_expsr_cl_key_val,
                   a.ncr_pd_band_key_val,
         			 a.ncr_geo_key_val,
                   a.src_sys_cd,
                   a.prior_3_mth_realz_defltd_cnt,
                   a.estd_defltd_loan_cnt,
                  datetime() as insrt_process_tmstmp format = datetime21.,
                  datetime() as updt_process_tmstmp format = datetime21.
            from work.ncr_bd_fact as a;
         quit;

         /* Load to BD fact table for MOR/TNG */
		 proc sql;
            connect using NZUSER as nzcon;
            execute (delete from &target_lib3..BASEL_RPTG_BL_AGGRTD_NCR_BD_FACT where SRC_SYS_CD = 'MOR') by nzcon; 
            disconnect from nzcon;

			insert into NZUSER.BASEL_RPTG_BL_AGGRTD_NCR_BD_FACT (bulkload=yes bl_method=cliload) 
		    select * from NZUSER.BASEL_RPT_BL_AGG_NCR_BD_FACT_BNS;
         quit;

		 /*---- End of User Written Code  ----*/ 
         
         %rcSet(&syserr); 
         %rcSet(&sqlrc); 
         %rcSet(&syscc); 
         
         
         
         /**  Step end User Written **/
         
         %let etls_endTime = %sysfunc(datetime(),datetime.);
         
         
         
         /**  Job end RRAP_MOR_MODEL_70_BNS_RPTING_NCR_BD_FACT **/
         
         /* Reset jobid and name */
         %let jobID = %quote(A57SWEI7.BH0009KD);
         %let etls_jobName = %nrquote(RRAP_MOR_MODEL_70_BNS_RPTING_NCR_BD_FACT_G);
         
      %mend etls_jobW2HII3L; 
      
      %etls_jobW2HII3L; 
      
      %let handleName = %etls_getHandle(statusTable=&etls_statusTable,
         handleVariable=etls_handleName, row=&&&etls_controlName);
         
      %let job_rc&handleName. = &job_rc; 
      
      %etls_freeHandle(statusTable=&etls_statusTable, statusVariable=etls_status, 
