/*Job name :- RRAP_SAS_SERVER_CLEANUP*/
/*THE JOB DELETES THE INTERMEDIATE TABLES BEFORE EVERY MONTH'S RUN, REMOVING THE NEED FOR MANUL SAS SERVER CLEANUP*/

%macro Server_Cleanup(table_name);
proc sql;
	drop table &table_name;
QUIT;
%mend;
options Mprint;

%RRAP_MOR_TNG_AUTOEXEC

/*Below STEP deletes all the files in the "/sasdata/sasdi/sasprod/data/rrap_iias/mortgage/source" and "/sasdata/sasdi/sasprod/data/rrap_iias/mortgage/results" folders from the prod server*/

DATA _NULL_;
	CALL SYSTEM('rm /sasdata/sasdi/sasprod/data/rrap_iias/mortgage/source/*');
	CALL SYSTEM('rm /sasdata/sasdi/sasprod/data/rrap_iias/mortgage/results/*');
run;

