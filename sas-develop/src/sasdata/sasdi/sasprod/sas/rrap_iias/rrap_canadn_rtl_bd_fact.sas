PROC SQL THREADS;
CREATE TABLE AGGR AS 
select MTH_TM_ID,
		NCR_EXPSR_CL_KEY_VAL,
		NCR_GEO_KEY_VAL      ,
		NCR_PD_BAND_KEY_VAL  ,
        coalesce(SUM(TOT_ACT_CNT), 0) AS TOT_ACT_CNT,
        coalesce(SUM(ESTD_DEFLTD_ACCT_CNT), 0) AS ESTD_DEFLTD_ACCT_CNT,
        coalesce(SUM(REALZ_DEFLTD_ACCT_CNT),0) as REALZ_DEFLTD_ACCT_CNT,

		/* changed by Khalid Mahmood according to latest Sreraj email dated November 21, 2014 09:33 AM*/
		CASE WHEN coalesce(SUM(REALZ_DEFLTD_ACCT_CNT),0) >  coalesce(SUM(TOT_ACT_CNT), 0)
             THEN  coalesce(SUM(TOT_ACT_CNT), 0) ELSE coalesce(SUM(REALZ_DEFLTD_ACCT_CNT),0) END
			 as REALZ_DEFLTD_ACCT_CNT2
from
 ( SELECT       STEP1.MTH_TM_ID, 
                STEP1.NCR_PD_BAND_KEY_VAL, 
                STEP1.NCR_GEO_KEY_VAL, 
                STEP1.NCR_EXPSR_CL_KEY_VAL, 
                STEP1.TOT_ACT_CNT,
                STEP2.ESTD_DEFLTD_ACCT_CNT,
                STEP2.REALZ_DEFLTD_ACCT_CNT
         FROM 
                (SELECT F.MTH_TM_ID, 
						F.NCR_PD_BAND_KEY_VAL, 
						F.NCR_GEO_KEY_VAL, 
						F.NCR_EXPSR_CL_KEY_VAL, 
           				COUNT(DISTINCT f.BASEL_ACCT_ID) as TOT_ACT_CNT  
				FROM &LIB..Basel_analytcl_bl_instrmnt_fact  f
		        WHERE f.CCAR_F=1    
		          AND f.MTH_TM_ID = &Processing_Month_Time_ID. 
		        group BY F.MTH_TM_ID, 
						F.NCR_PD_BAND_KEY_VAL, 
						F.NCR_GEO_KEY_VAL, 
						F.NCR_EXPSR_CL_KEY_VAL ) STEP1
        LEFT OUTER JOIN (SELECT MTH_TM_ID, 
                                NCR_PD_BAND_KEY_VAL,
                                NCR_GEO_KEY_VAL, 
                                NCR_EXPSR_CL_KEY_VAL, 
                                SUM(ESTD_DEFLTD_LOAN_CNT) as ESTD_DEFLTD_ACCT_CNT, 
                                SUM(PRIOR_3_MTH_REALZ_DEFLTD_LOAN_CN) as REALZ_DEFLTD_ACCT_CNT
          FROM &LIB..BASEL_RPTG_BL_AGGRTD_NCR_BD_FACT A 
          WHERE MTH_TM_ID = &Processing_Month_Time_ID. 
          GROUP BY  MTH_TM_ID, 
                                NCR_PD_BAND_KEY_VAL,
                                NCR_GEO_KEY_VAL, 
                                NCR_EXPSR_CL_KEY_VAL
          ) STEP2

          ON  STEP2.MTH_TM_ID            = STEP1.MTH_TM_ID AND 
              STEP2.NCR_EXPSR_CL_KEY_VAL = STEP1.NCR_EXPSR_CL_KEY_VAL AND 
              STEP2.NCR_PD_BAND_KEY_VAL  = STEP1.NCR_PD_BAND_KEY_VAL  AND 
              STEP2.NCR_GEO_KEY_VAL      = STEP1.NCR_GEO_KEY_VAL
			  )
group by  MTH_TM_ID,
		NCR_EXPSR_CL_KEY_VAL,
		NCR_GEO_KEY_VAL,
		NCR_PD_BAND_KEY_VAL ;
run;

proc sql;

* third Summ;
CREATE TABLE
STG1_ROOLUP70 AS 
SELECT MTH_TM_ID
	,EXPSR_CL.NCR_PRNT_KEY_VAL AS NCR_EXPSR_CL_KEY_VAL
	, GEO.NCR_PRNT_KEY_VAL AS NCR_GEO_KEY_VAL
	, PD_BAND.NCR_PRNT_KEY_VAL AS NCR_PD_BAND_KEY_VAL
	,sum(TOT_ACT_CNT) AS ACCT_CNT
	,sum(ESTD_DEFLTD_ACCT_CNT) AS ESTD_DEFLTD_LOAN_CNT
	,coalesce(SUM(REALZ_DEFLTD_ACCT_CNT), 0) as REALZ_DEFLTD_ACCT_CNTO
	,  (CASE WHEN coalesce(SUM(REALZ_DEFLTD_ACCT_CNT), 0) > coalesce(SUM(TOT_ACT_CNT), 0)
             THEN coalesce(SUM(TOT_ACT_CNT), 0) ELSE coalesce(SUM(REALZ_DEFLTD_ACCT_CNT), 0) END
         ) as  PRIOR_3_MTH_REALZ_DEFLTD_LOAN_CN
	,  (CASE WHEN coalesce(SUM(REALZ_DEFLTD_ACCT_CNT2), 0) > coalesce(SUM(TOT_ACT_CNT), 0)
             THEN coalesce(SUM(TOT_ACT_CNT), 0) ELSE coalesce(SUM(REALZ_DEFLTD_ACCT_CNT2), 0) END
         ) as  PRIOR_3_MTH_REALZ_DEFLTD_LOAN_C2
FROM AGGR as stg1
	INNER JOIN &LIB..BASEL_NCR_HIERARCHY_LKP EXPSR_CL ON
		EXPSR_CL.NCR_KEY_VAL = STG1.NCR_EXPSR_CL_KEY_VAL
		and EXPSR_CL.NCR_PRNT_KEY_VAL in ('0502', '0503', '0505', '0506', '0507', '0510', '0511', '0512')
	INNER JOIN &LIB..BASEL_NCR_HIERARCHY_LKP GEO ON
		GEO.NCR_KEY_VAL = STG1.NCR_GEO_KEY_VAL
		and GEO.NCR_PRNT_KEY_VAL in ('0300', '0301', '0315', '0316', '0317', '0318', '0319')
	INNER JOIN &LIB..BASEL_NCR_HIERARCHY_LKP PD_BAND ON
		PD_BAND.NCR_KEY_VAL = STG1.NCR_PD_BAND_KEY_VAL
		/* changes for RRMSS2126- changed the where clause from 1400 to 1426, previously it was 1440-1414 or 1426 */
		and (INPUT(NCR_PD_BAND_KEY_VAL ,8.) BETWEEN 1400 AND 1426 )
group by MTH_TM_ID
	,EXPSR_CL.NCR_PRNT_KEY_VAL
	, GEO.NCR_PRNT_KEY_VAL 
, PD_BAND.NCR_PRNT_KEY_VAL
;
QUIT;


proc sql noprint;
select NCR_BD_RECD_TP_ID into :NCR_BD_RECD_TP_ID 
from &LIB..BASEL_NCR_BD_RECD_TP_DIM where NCR_RECD_TP_CD='070' 
AND put(&DAY_DTT,z6.) BETWEEN EFF_FROM_YR_MTH AND EFF_TO_YR_MTH;
CREATE VIEW
Exposure_Class AS 
       SELECT DISTINCT NCR_EXPSR_CL_KEY_VAL, EXPSR_CL_ID FROM &LIB..BASEL_EXPSR_CL_DIM 
WHERE NCR_EXPSR_CL_KEY_VAL IN ('0502', '0503', '0505', '0506', '0507', '0510', '0511', '0512')
AND 
"&mth_tm_id_yrmth." BETWEEN EFF_FROM_YR_MTH AND EFF_TO_YR_MTH
;
CREATE VIEW PD_Band AS
       SELECT DISTINCT NCR_PD_BAND_KEY_VAL FROM &LIB..PD_BAND_DIM 
	   /* changes for RRMSS2126- changed the where clause from 1400 to 1426, previously it was 1440-1414 or 1426 */
WHERE (INPUT(NCR_PD_BAND_KEY_VAL ,8.) BETWEEN 1400 AND 1426) AND 
"&mth_tm_id_yrmth." BETWEEN EFF_FROM_YR_MTH AND EFF_TO_YR_MTH
;
CREATE VIEW Geo AS
       SELECT DISTINCT NCR_GEO_ID FROM &LIB..BASEL_NCR_GEO_DIM 
WHERE NCR_GEO_KEY_VAL IN ('0300', '0301', '0315', '0316', '0317', '0318', '0319')
AND 
"&mth_tm_id_yrmth." BETWEEN EFF_FROM_YR_MTH AND EFF_TO_YR_MTH
;
CREATE TABLE TEMPL_070 AS 
SELECT DISTINCT
70 LENGTH=8 AS SRC
,&Processing_Month_Time_ID. LENGTH=8 AS MTH_TM_ID
       ,&NCR_BD_RECD_TP_ID. AS NCR_BD_RECD_TP_ID
/*       ,PD_Band.NCR_PD_BAND_KEY_VAL AS NCR_PD_BAND_KEY_VAL*/
	   ,D2.NCR_PD_BAND_ID
       ,&NCR_EXPSR_SIZE_ID. LENGTH=8 FORMAT=5.  AS NCR_EXPSR_SIZE_ID
       ,Geo.NCR_GEO_ID
       ,&NCR_LTV_ID. AS  NCR_LTV_ID
/*       ,Exposure_Class.EXPSR_CL_KEY_VAL AS NCR_EXPSR_CL*/
	   ,EXPOSURE_CLASS.EXPSR_CL_ID
	   ,&NCR_SECRTZTN_ID. LENGTH= 8 FORMAT = 5. AS NCR_SECRTZTN_ID
	   ,&NCR_RT_ID. LENGTH=8 FORMAT = 5.        AS NCR_RT_ID
       ,&DLQNT_ID. LENGTH=8 FORMAT= 5.          AS DLQNT_ID

FROM Exposure_Class 
       CROSS JOIN PD_Band 
       CROSS JOIN Geo
	   LEFT JOIN
       &LIB..PD_BAND_DIM D2
	   ON D2.NCR_PD_BAND_KEY_VAL = PD_Band.NCR_PD_BAND_KEY_VAL
	   AND D2.NCR_EXPSR_CL_KEY_VAL = Exposure_Class.NCR_EXPSR_CL_KEY_VAL
	   AND put(&DAY_DTT,z6.) BETWEEN D2.EFF_FROM_YR_MTH AND D2.EFF_TO_YR_MTH;
quit;

PROC SQL THREADS;
CREATE TABLE CNDN_RTL_BD_P1_070 AS
SELECT  
70 LENGTH=8 AS SRC,
MTH_TM_ID,
&NCR_BD_RECD_TP_ID. LENGTH=8 FORMAT= 5. AS NCR_BD_RECD_TP_ID,
E.NCR_PD_BAND_ID LENGTH =8 FORMAT = 5. AS NCR_PD_BAND_ID,
&NCR_EXPSR_SIZE_ID. LENGTH=8 FORMAT=5.  AS NCR_EXPSR_SIZE_ID,
NCR_GEO_ID LENGTH=8 FORMAT =5.   AS NCR_GEO_ID,
&NCR_LTV_ID. LENGTH=8 FORMAT =5.   AS NCR_LTV_ID,
C.EXPSR_CL_ID LENGTH = 8 FORMAT = 5. AS EXPSR_CL_ID,
&NCR_SECRTZTN_ID. LENGTH= 8 FORMAT = 5. AS NCR_SECRTZTN_ID,
&NCR_RT_ID. LENGTH=8 FORMAT = 5.        AS NCR_RT_ID,
&DLQNT_ID. LENGTH=8 FORMAT= 5.          AS DLQNT_ID,
'' LENGTH=255 FORMAT = $255.AS PD_BAND_NM,
. LENGTH= 8  FORMAT= 28.8 AS PD_BAND_RTO,
. LABEL="Outstanding Balance Amount"	FORMAT=	17.3 AS	OS_BAL_AMT,
. LABEL="Over Limit Account Ratio"	FORMAT=	28.8	 AS OV_LMT_ACCT_RTO,
. LABEL="Authorized Amount"	FORMAT=	17.3 AS	AUTH_AMT,
. LABEL="Fraud Loss Amount"	FORMAT=	17.3 AS	FRAUD_LOSS_AMT,
. LABEL="Estimated EAD Amount"	FORMAT= 17.3 AS	ESTD_EAD_AMT,
. LABEL="Write Off Account Count"	FORMAT=	24.	AS WRITE_OFF_ACCT_CNT,
. LABEL="Write Off Total Amount	"	FORMAT=	17.3 AS	WRITE_OFF_TOT_AMT,
. LABEL="IRB Expected Loss Amount"	FORMAT= 17.3 AS	IRB_EXPCTD_LOSS_AMT,
. LABEL="Recovery Amount"	FORMAT=	17.3	AS RCVRY_AMT,
. LABEL="Economic Loss Amount"	FORMAT=	17.3	AS ECONMC_LOSS_AMT,
. LABEL="IRB Capital Amount"	FORMAT=	17.3	AS IRB_CAPTL_AMT,
COALESCE(ACCT_CNT,0) LABEL="Account Count" LENGTH=8 FORMAT 12.  AS ACCT_CNT,
. LABEL="Realized Defaulted Account Count"	FORMAT=	28.8	AS AVG_UTLTN_RTO,
COALESCE(ESTD_DEFLTD_LOAN_CNT,0) LABEL="Average Utilization Ratio"	FORMAT=	12. AS	ESTD_DEFLTD_ACCT_CNT,
/*COALESCE(PRIOR_3_MTH_REALZ_DEFLTD_LOAN_CN,0) LABEL="Estimated Defaulted Account Count"	FORMAT=	12. AS 	REALZ_DEFLTD_ACCT_CNT,*/
COALESCE(PRIOR_3_MTH_REALZ_DEFLTD_LOAN_C2,0) LABEL="Estimated Defaulted Account Count"	FORMAT=	12. AS 	REALZ_DEFLTD_ACCT_CNT,
. LABEL="Gross Impaired Loan and Acceptance Amount"	FORMAT=	17.3	AS GRS_IMPRD_LN_AND_ACPT_AMT,
. LABEL="Gross Impaired Loan and Acceptance Addition Amount"	FORMAT=	17.3 AS	GRS_IMPRD_LN_ACPT_ADDTN_AMT,
. LABEL="Gross Impaired Loan and Acceptance Returned to Accrual Status Amount"	FORMAT=	17.3 
AS	GRS_IMPRD_LN_ACPT_RT_ACRL_ST_AMT,
. LABEL="Credit Loss Total Allowance Amount"	FORMAT=	17.3 AS	CR_LOSS_TOT_ALWNC_AMT,
. LABEL="Credit Loss Total Provision Amount"	FORMAT=	17.3 AS	CR_LOSS_TOT_PVSN_AMT,
. LABEL="Credit Loss General Provision Amount"	FORMAT=	17.3 AS ASCR_LOSS_GENL_PVSN_AMT,
. LABEL="Credit Loss Specific Provision Amount"	FORMAT=	17.3 AS	CR_LOSS_SPECIFIC_PVSN_AMT,
. LABEL="Gross Impaired Loan and Acceptance Other Change Amount"	FORMAT=	17.3 
AS	GRS_IMPRD_LN_ACPT_OTH_CHNG_AMT,
. LABEL="Credit Loss Allowance Other Change Amount"	FORMAT=	17.3	AS CR_LOSS_ALWNC_OTH_CHNG_AMT
FROM
STG1_ROOLUP70 as A
inner JOIN 
&LIB..TM_DIM T
ON A.MTH_TM_ID = T.TM_ID
inner JOIN
&LIB..BASEL_NCR_GEO_DIM B
ON A.NCR_GEO_KEY_VAL = B.NCR_GEO_KEY_VAL
AND put(&DAY_DTT,z6.) BETWEEN B.EFF_FROM_YR_MTH AND B.EFF_TO_YR_MTH
inner JOIN
&LIB..BASEL_EXPSR_CL_DIM C
ON A.NCR_EXPSR_CL_KEY_VAL = C.NCR_EXPSR_CL_KEY_VAL
AND put(&DAY_DTT,z6.) BETWEEN C.EFF_FROM_YR_MTH AND C.EFF_TO_YR_MTH
inner JOIN &LIB..PD_BAND_DIM E
ON 
INPUT(A.NCR_PD_BAND_KEY_VAL,8.)  = INPUT(E.NCR_PD_BAND_KEY_VAL,8.) AND
/* changes for RRMSS2126- changed the where clause from 1400 to 1426, previously it was 1440-1414 or 1426 */
(INPUT(e.NCR_PD_BAND_KEY_VAL ,8.) BETWEEN 1400 AND 1426) and
INPUT(A.NCR_EXPSR_CL_KEY_VAL,8.) = INPUT(E.NCR_EXPSR_CL_KEY_VAL,8.) 
AND put(&DAY_DTT,z6.) BETWEEN E.EFF_FROM_YR_MTH AND E.EFF_TO_YR_MTH ;

CREATE TABLE CNDN_RTL_BD_P1_070 AS
SELECT distinct *
FROM
TEMPL_070 GG
LEFT JOIN
CNDN_RTL_BD_P1_070 A
ON
GG.NCR_PD_BAND_ID = A.NCR_PD_BAND_ID AND
GG.NCR_GEO_ID = A.NCR_GEO_ID AND
GG.EXPSR_CL_ID = A.EXPSR_CL_ID 
