FROM (
select MTH_TM_ID, 
		B.NCR_PRNT_KEY_VAL AS NCR_EXPSR_CL_KEY_VAL ,
		C.NCR_PRNT_KEY_VAL AS NCR_GEO_KEY_VAL,
