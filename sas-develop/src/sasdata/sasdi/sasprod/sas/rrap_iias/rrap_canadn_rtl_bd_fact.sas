PROC SQL THREADS NOPRINT;

CREATE VIEW
Exposure_Class AS 
       SELECT DISTINCT NCR_EXPSR_CL_KEY_VAL, EXPSR_CL_ID FROM &LIB..BASEL_EXPSR_CL_DIM 
WHERE NCR_EXPSR_CL_KEY_VAL IN 
 ('0500', '0501', '0502', '0503', '0504', '0505', '0506', '0507', '0510', '0511', '0512')
 AND 
"&mth_tm_id_yrmth." BETWEEN EFF_FROM_YR_MTH AND EFF_TO_YR_MTH
	   ;
CREATE TABLE Securitization AS
	SELECT DISTINCT NCR_SECRTZTN_KEY_VAL,NCR_SECRTZTN_ID FROM &LIB..BASEL_NCR_SECRTZTN_DIM 
WHERE INPUT(NCR_SECRTZTN_KEY_VAL,8.) BETWEEN 600 AND 601
AND 
"&mth_tm_id_yrmth." BETWEEN EFF_FROM_YR_MTH AND EFF_TO_YR_MTH 
;
CREATE VIEW PD_Band AS
       SELECT DISTINCT NCR_PD_BAND_KEY_VAL,ncr_pd_band_id FROM &LIB..PD_BAND_DIM 
WHERE INPUT(NCR_PD_BAND_KEY_VAL ,8.) =1499 AND 
"&mth_tm_id_yrmth." BETWEEN EFF_FROM_YR_MTH AND EFF_TO_YR_MTH 
;
CREATE TABLE TEMPL_010 AS 
SELECT DISTINCT
10 LENGTH=8 AS SRC
,&Processing_Month_Time_ID. LENGTH=8 AS MTH_TM_ID
       ,&NCR_BD_RECD_TP_ID. AS NCR_BD_RECD_TP_ID
	   ,d2.NCR_PD_BAND_ID length=8  AS NCR_PD_BAND_ID
       ,&NCR_EXPSR_SIZE_ID. LENGTH=8 FORMAT=5.  AS NCR_EXPSR_SIZE_ID
       ,&NCR_GEO_ID. LENGTH =8 AS NCR_GEO_ID
       ,&NCR_LTV_ID. LENGTH=8  AS  NCR_LTV_ID
	   ,EXPOSURE_CLASS.EXPSR_CL_ID 
	   ,Securitization.NCR_SECRTZTN_ID LENGTH= 8 FORMAT = 5. AS NCR_SECRTZTN_ID
	   ,&NCR_RT_ID. LENGTH=8 FORMAT = 5.        AS NCR_RT_ID
       ,&DLQNT_ID. LENGTH=8 FORMAT= 5.          AS DLQNT_ID
	 
FROM Exposure_Class 
       CROSS JOIN Securitization
	    CROSS JOIN PD_Band 
	      LEFT JOIN
       &LIB..PD_BAND_DIM D2
	   ON D2.NCR_PD_BAND_KEY_VAL = PD_Band.NCR_PD_BAND_KEY_VAL
	   AND D2.NCR_EXPSR_CL_KEY_VAL = Exposure_Class.NCR_EXPSR_CL_KEY_VAL
	   AND put(&DAY_DTT,z6.) BETWEEN D2.EFF_FROM_YR_MTH AND D2.EFF_TO_YR_MTH
;
QUIT;

PROC SQL THREADS;
CREATE TABLE CNDN_RTL_BD_P1_0101 AS
SELECT
10 LENGTH=8 AS SRC,
MTH_TM_ID,
&NCR_BD_RECD_TP_ID. LENGTH=8 FORMAT= 5. AS NCR_BD_RECD_TP_ID,
D.NCR_PD_BAND_ID LENGTH =8 FORMAT = 5. AS NCR_PD_BAND_ID,
