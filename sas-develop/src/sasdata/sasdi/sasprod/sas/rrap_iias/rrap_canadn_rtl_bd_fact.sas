&LIB..Basel_ncr_hierarchy_lkp D
ON A.NCR_PD_BAND_KEY_VAL = D.NCR_KEY_VAL
/* changes for RRMSS2126- changed the where clause from 1400 to 1426, previously it was 1440-1414 or 1426 */
