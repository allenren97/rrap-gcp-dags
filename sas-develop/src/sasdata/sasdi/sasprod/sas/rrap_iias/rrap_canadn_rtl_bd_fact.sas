/* prepare and lookup parent of child exposure class in order to patch ratios */
PROC SQL;
CREATE TABLE CNDN_RTL_BD_P1_005_WITH_PRE_FIX AS 
SELECT A.*,
B.NCR_EXPSR_CL_KEY_VAL AS DIM_NCR_EXPSR_CL_KEY_VAL,
CASE WHEN B.NCR_EXPSR_CL_KEY_VAL IN ('0502','0503') THEN B.NCR_EXPSR_CL_KEY_VAL ELSE C.NCR_PRNT_KEY_VAL END AS NCR_PRNT_KEY_VAL
FROM &LIB..CNDN_RTL_BD_P1_005 A
LEFT OUTER JOIN &LIB..PD_BAND_DIM B ON A.NCR_PD_BAND_ID = B.NCR_PD_BAND_ID 
AND put(&DAY_DTT,z6.) BETWEEN B.EFF_FROM_YR_MTH AND B.EFF_TO_YR_MTH
LEFT OUTER JOIN DDB2CON.BASEL_NCR_HIERARCHY_LKP C ON B.NCR_EXPSR_CL_KEY_VAL = C.NCR_KEY_VAL AND C.NCR_PRNT_KEY_VAL IN ('0502', '0503', '0504', '0507');
QUIT;

/* patch ratios that are null, 0 or out of defined range from NCR dim table; overide formula from above */
PROC SQL ;
CREATE TABLE CNDN_RTL_BD_P1_005_WITH_FIX AS 
SELECT A.*, 
B.PD_MIN_VAL, B.PD_MAX_VAL, 
CASE WHEN A.PD_BAND_RTO_OLD = 0 THEN B.PD_MAX_VAL
     WHEN A.PD_BAND_RTO < B.PD_MIN_VAL THEN B.PD_MIN_VAL
     WHEN A.PD_BAND_RTO > B.PD_MAX_VAL THEN B.PD_MAX_VAL
     END AS PD_BAND_RTO_FIXD FORMAT=28.8
FROM CNDN_RTL_BD_P1_005_WITH_PRE_FIX A, &LIB..PD_BAND_DIM B
WHERE A.NCR_PRNT_KEY_VAL = B.NCR_EXPSR_CL_KEY_VAL AND A.NCR_PD_BAND_KEY_VAL = B.NCR_PD_BAND_KEY_VAL
AND put(&DAY_DTT,z6.) BETWEEN B.EFF_FROM_YR_MTH AND B.EFF_TO_YR_MTH
AND B.PD_MAX_VAL IS NOT NULL AND B.PD_MIN_VAL IS NOT NULL
AND A.PD_BAND_RTO_OLD NOT BETWEEN B.PD_MIN_VAL AND B.PD_MAX_VAL;
QUIT;


PROC SQL;
CREATE TABLE CNDN_RTL_BD_P1_005_MERGE AS
SELECT A.*, B.PD_BAND_RTO_FIXD, b.NCR_PRNT_KEY_VAL FROM &LIB..CNDN_RTL_BD_P1_005 A
LEFT OUTER JOIN CNDN_RTL_BD_P1_005_WITH_FIX B ON 
A.MTH_TM_ID = B.MTH_TM_ID AND 
A.NCR_BD_RECD_TP_ID = B.NCR_BD_RECD_TP_ID AND 
A.NCR_PD_BAND_ID = B.NCR_PD_BAND_ID AND 
A.NCR_EXPSR_SIZE_ID = B.NCR_EXPSR_SIZE_ID AND 
A.NCR_GEO_ID = B.NCR_GEO_ID AND
A.NCR_LTV_ID = B.NCR_LTV_ID AND 
A.EXPSR_CL_ID = B.EXPSR_CL_ID AND 
A.NCR_SECRTZTN_ID = B.NCR_SECRTZTN_ID AND 
A.NCR_RT_ID = B.NCR_RT_ID AND 
A.DLQNT_ID = B.DLQNT_ID;
QUIT;


/* apply patched ratios */
PROC SQL noprint;
UPDATE CNDN_RTL_BD_P1_005_MERGE SET PD_BAND_RTO = PD_BAND_RTO_FIXD WHERE PD_BAND_RTO_FIXD IS NOT NULL;
QUIT;

