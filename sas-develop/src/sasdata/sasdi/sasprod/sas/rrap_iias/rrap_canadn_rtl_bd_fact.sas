/* extract all exposure class and their PD bands for 005 and calculate average of final PD ratio and account count */
PROC SQL THREADS;
CREATE TABLE CNDN_RTL_BD_P1_005_TMP1 as
Select 
MTH_TM_ID,
B.NCR_PRNT_KEY_VAL AS EXPSR_PRNT_CL_KEY_VAL,
C.NCR_PRNT_KEY_VAL AS PD_BAND_PRNT_KEY_VAL,
round(avg(PD_FINAL_RPTG_RTO),0.00000001) as PD_FINAL_RPTG_RTO,
count(BASEL_ACCT_ID) as BASEL_ACCT_ID
FROM 
&LIB..Basel_analytcl_bl_instrmnt_fact A
inner JOIN
&LIB..Basel_ncr_hierarchy_lkp B
ON A.NCR_EXPSR_CL_KEY_VAL = B.NCR_KEY_VAL
and B.NCR_PRNT_KEY_VAL IN ('0502', '0503', '0505', '0506', '0507', '0510', '0511', '0512')
inner JOIN
&LIB..Basel_ncr_hierarchy_lkp C
ON A.NCR_PD_BAND_KEY_VAL = C.NCR_KEY_VAL
and INPUT(C.NCR_PRNT_KEY_VAL, 8.)  BETWEEN 1401 AND 1425
WHERE
CCAR_F=1 AND
MTH_TM_ID = &Processing_Month_Time_ID. 
group by
MTH_TM_ID,
B.NCR_PRNT_KEY_VAL,
C.NCR_PRNT_KEY_VAL;
QUIT;


PROC SQL THREADS NOPRINT;
SELECT DISTINCT NCR_BD_RECD_TP_ID INTO: NCR_BD_RECD_TP_ID FROM &LIB..BASEL_NCR_BD_RECD_TP_DIM
WHERE "&mth_tm_id_yrmth." BETWEEN EFF_FROM_YR_MTH AND EFF_TO_YR_MTH AND NCR_RECD_TP_CD = '005'
;
%PUT >> NCR_BD_RECD_TP_ID = &NCR_BD_RECD_TP_ID
;
SELECT DISTINCT NCR_EXPSR_SIZE_ID INTO: NCR_EXPSR_SIZE_ID FROM &LIB..BASEL_NCR_EXPSR_SIZE_DIM
WHERE "&mth_tm_id_yrmth." BETWEEN EFF_FROM_YR_MTH AND EFF_TO_YR_MTH AND NCR_KEY_VAL = '1599'
;
%LET NCR_GEO_ID = 0;
SELECT DISTINCT COALESCE(NCR_GEO_ID,0) INTO: NCR_GEO_ID FROM &LIB..BASEL_NCR_GEO_DIM
WHERE "&mth_tm_id_yrmth." BETWEEN EFF_FROM_YR_MTH AND EFF_TO_YR_MTH AND NCR_GEO_KEY_VAL = '0399'
;
SELECT MAX(NCR_LTV_ID) INTO: NCR_LTV_ID FROM &LIB..BASEL_NCR_LTV_DIM
WHERE "&mth_tm_id_yrmth." BETWEEN EFF_FROM_YR_MTH AND EFF_TO_YR_MTH AND NCR_LTV_KEY_VAL = '0499'
;
SELECT MAX(NCR_SECRTZTN_ID) INTO: NCR_SECRTZTN_ID FROM &LIB..BASEL_NCR_SECRTZTN_DIM
WHERE "&mth_tm_id_yrmth." BETWEEN EFF_FROM_YR_MTH AND EFF_TO_YR_MTH AND NCR_SECRTZTN_KEY_VAL = '0699'
;
SELECT MAX(NCR_RT_ID) INTO: NCR_RT_ID FROM &LIB..BASEL_NCR_RT_DIM
WHERE "&mth_tm_id_yrmth." BETWEEN EFF_FROM_YR_MTH AND EFF_TO_YR_MTH AND NCR_RT_KEY_VAL = '0799'
;
SELECT MAX(DLQNT_ID) INTO: DLQNT_ID FROM &LIB..DLQNT_DIM
WHERE &tdy. BETWEEN EFF_FROM_dt AND EFF_TO_dt AND NCR_DLQNT_CD = '0899'
;
CREATE VIEW
Exposure_Class AS 
       SELECT DISTINCT NCR_EXPSR_CL_KEY_VAL, EXPSR_CL_ID FROM &LIB..BASEL_EXPSR_CL_DIM 
WHERE NCR_EXPSR_CL_KEY_VAL IN ('0502', '0503', '0505', '0506', '0507', '0510', '0511', '0512') AND 
"&mth_tm_id_yrmth." BETWEEN EFF_FROM_YR_MTH AND EFF_TO_YR_MTH 
	   ;
CREATE VIEW PD_Band AS
       SELECT DISTINCT NCR_PD_BAND_KEY_VAL FROM &LIB..PD_BAND_DIM 
WHERE INPUT(NCR_PD_BAND_KEY_VAL ,8.) BETWEEN 1401 AND 1425 AND 
"&mth_tm_id_yrmth." BETWEEN EFF_FROM_YR_MTH AND EFF_TO_YR_MTH 
;

/* create all possible combinations of exposure class and PD band with other attributes */
CREATE TABLE TEMPL_005 AS 
SELECT DISTINCT
5 LENGTH=8 AS SRC
,&Processing_Month_Time_ID. LENGTH=8 AS MTH_TM_ID
       ,&NCR_BD_RECD_TP_ID. AS NCR_BD_RECD_TP_ID
       ,PD_Band.NCR_PD_BAND_KEY_VAL AS NCR_PD_BAND_KEY_VAL
	   ,D2.NCR_PD_BAND_ID
	   ,d2.ncr_pd_band_desc as PD_BAND_NM
       ,&NCR_EXPSR_SIZE_ID. LENGTH=8 FORMAT=5.  AS NCR_EXPSR_SIZE_ID
       ,&NCR_GEO_ID. LENGTH = 8 AS NCR_GEO_ID
       ,&NCR_LTV_ID. AS  NCR_LTV_ID
       ,Exposure_Class.NCR_EXPSR_CL_KEY_VAL AS NCR_EXPSR_CL
	   ,EXPOSURE_CLASS.EXPSR_CL_ID
	   ,&NCR_SECRTZTN_ID. LENGTH= 8 FORMAT = 5. AS NCR_SECRTZTN_ID
	   ,&NCR_RT_ID. LENGTH=8 FORMAT = 5.        AS NCR_RT_ID
       ,&DLQNT_ID. LENGTH=8 FORMAT= 5.          AS DLQNT_ID
FROM Exposure_Class 
       CROSS JOIN PD_Band 
	   LEFT JOIN
       &LIB..PD_BAND_DIM D2
	   ON D2.NCR_PD_BAND_KEY_VAL = PD_Band.NCR_PD_BAND_KEY_VAL
	   AND D2.NCR_EXPSR_CL_KEY_VAL = Exposure_Class.NCR_EXPSR_CL_KEY_VAL
		AND put(&DAY_DTT,z6.) BETWEEN D2.EFF_FROM_YR_MTH AND D2.EFF_TO_YR_MTH
	   ;
QUIT;


/* lookup by parent exposure class key and PD band key to get PD Band ID and exposure class ID*/
/* build table layout with other measures*/
PROC SQL THREADS;
CREATE TABLE CNDN_RTL_BD_P1_005 AS
SELECT
5 LENGTH=8 AS SRC,
b.NCR_EXPSR_CL_KEY_VAL,
NCR_PD_BAND_KEY_VAL,
MTH_TM_ID,
&NCR_BD_RECD_TP_ID. LENGTH=8 FORMAT= 5. AS NCR_BD_RECD_TP_ID,
B.NCR_PD_BAND_ID LENGTH =8 FORMAT = 5. AS NCR_PD_BAND_ID,
&NCR_EXPSR_SIZE_ID. LENGTH=8 FORMAT=5.  AS NCR_EXPSR_SIZE_ID,
&NCR_GEO_ID. LENGTH=8 FORMAT =5.   AS NCR_GEO_ID,
&NCR_LTV_ID. LENGTH=8 FORMAT =5.   AS NCR_LTV_ID,
EXPSR_CL_ID LENGTH = 8 FORMAT = 5. AS EXPSR_CL_ID,
&NCR_SECRTZTN_ID. LENGTH= 8 FORMAT = 5. AS NCR_SECRTZTN_ID,
&NCR_RT_ID. LENGTH=8 FORMAT = 5.        AS NCR_RT_ID,
&DLQNT_ID. LENGTH=8 FORMAT= 5.          AS DLQNT_ID,
B.NCR_PD_BAND_DESC LENGTH=255 FORMAT = $255.AS PD_BAND_NM,
COALESCE(PD_FINAL_RPTG_RTO,0) FORMAT=28.8 AS PD_BAND_RTO,
. LABEL="Outstanding Balance Amount"	FORMAT=	17.3 AS	OS_BAL_AMT,
. LABEL="Over Limit Account Ratio"	FORMAT=	28.8	 AS OV_LMT_ACCT_RTO,
. LABEL="Authorized Amount"	FORMAT=	17.3 AS	AUTH_AMT,
. LABEL="Fraud Loss Amount"	FORMAT=	17.3 AS	FRAUD_LOSS_AMT,
. LABEL="Estimated EAD Amount"	FORMAT= 17.3 AS	ESTD_EAD_AMT,
. LABEL="Write Off Account Count"	FORMAT=	24.	AS WRITE_OFF_ACCT_CNT,
. LABEL="Write Off Total Amount	"	FORMAT=	17.3 AS	WRITE_OFF_TOT_AMT,
. LABEL="IRB Expected Loss Amount"	FORMAT= 17.3 AS	IRB_EXPCTD_LOSS_AMT,
. LABEL="Recovery Amount"	FORMAT=	17.3	AS RCVRY_AMT,
. LABEL="Economic Loss Amount"	FORMAT=	17.3	AS ECONMC_LOSS_AMT,
. LABEL="IRB Capital Amount"	FORMAT=	17.3	AS IRB_CAPTL_AMT,
COALESCE(BASEL_ACCT_ID,0) AS ACCT_CNT,
. LABEL="Average Utilization Ratio"	FORMAT=	12. AS	ESTD_DEFLTD_ACCT_CNT,
. LABEL="Estimated Defaulted Account Count"	FORMAT=	12. AS 	REALZ_DEFLTD_ACCT_CNT,
. LABEL="Realized Defaulted Account Count"	FORMAT=	28.8	AS AVG_UTLTN_RTO,
. LABEL="Gross Impaired Loan and Acceptance Amount"	FORMAT=	17.3	AS GRS_IMPRD_LN_AND_ACPT_AMT,
. LABEL="Gross Impaired Loan and Acceptance Addition Amount"	FORMAT=	17.3 AS	GRS_IMPRD_LN_ACPT_ADDTN_AMT,
. LABEL="Gross Impaired Loan and Acceptance Returned to Accrual Status Amount"	FORMAT=	17.3 
AS	GRS_IMPRD_LN_ACPT_RT_ACRL_ST_AMT,
. LABEL="Credit Loss Total Allowance Amount"	FORMAT=	17.3 AS	CR_LOSS_TOT_ALWNC_AMT,
. LABEL="Credit Loss Total Provision Amount"	FORMAT=	17.3 AS	CR_LOSS_TOT_PVSN_AMT,
. LABEL="Credit Loss General Provision Amount"	FORMAT=	17.3 AS ASCR_LOSS_GENL_PVSN_AMT,
. LABEL="Credit Loss Specific Provision Amount"	FORMAT=	17.3 AS	CR_LOSS_SPECIFIC_PVSN_AMT,
. LABEL="Gross Impaired Loan and Acceptance Other Change Amount"	FORMAT=	17.3 
AS	GRS_IMPRD_LN_ACPT_OTH_CHNG_AMT,
. LABEL="Credit Loss Allowance Other Change Amount"	FORMAT=	17.3	AS CR_LOSS_ALWNC_OTH_CHNG_AMT
FROM
CNDN_RTL_BD_P1_005_TMP1 A
LEFT JOIN 
&LIB..TM_DIM T
ON A.MTH_TM_ID = T.TM_ID
LEFT JOIN
&LIB..PD_BAND_DIM B
ON 
A.PD_BAND_PRNT_KEY_VAL  = B.NCR_PD_BAND_KEY_VAL 
AND A.EXPSR_PRNT_CL_KEY_VAL  = B.NCR_EXPSR_CL_KEY_VAL
AND put(&DAY_DTT,z6.) BETWEEN B.EFF_FROM_YR_MTH AND
				B.EFF_TO_YR_MTH
LEFT JOIN
&LIB..BASEL_EXPSR_CL_DIM C
ON 
C.CRNT_F = 'Y' AND
A.EXPSR_PRNT_CL_KEY_VAL = C.NCR_EXPSR_CL_KEY_VAL
AND put(&DAY_DTT,z6.) BETWEEN C.EFF_FROM_YR_MTH AND
				C.EFF_TO_YR_MTH
;
QUIT;

