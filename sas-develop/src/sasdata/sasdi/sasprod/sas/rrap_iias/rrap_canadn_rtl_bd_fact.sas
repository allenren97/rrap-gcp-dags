	   ,&NCR_RT_ID. LENGTH=8 FORMAT = 5.        AS NCR_RT_ID
       ,DELQ.DLQNT_ID LENGTH=8 FORMAT= 5.          AS DLQNT_ID

FROM Exposure_Class 
       CROSS JOIN DELQ 
       CROSS JOIN Geo
	       LEFT JOIN
       &LIB..PD_BAND_DIM D2
