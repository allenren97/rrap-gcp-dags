/* check 1401 and default to start at 0.03% if ratio is blank; round the ratios to 8 decimals */
data tmp_005;
format PD_BAND_RTO_OLD 28.8;
set CNDN_RTL_BD_P1_005B(keep =MTH_TM_ID NCR_EXPSR_CL NCR_PD_BAND_KEY_VAL PD_BAND_RTO);
PD_BAND_RTO_OLD=PD_BAND_RTO;
if NCR_PD_BAND_KEY_VAL='1401' and PD_BAND_RTO=. then PD_BAND_RTO=0.0003;
PD=round(PD_BAND_RTO,0.00000001);
run;
/* Deduped for JIRA 2126
proc sort data= tmp_005 nodupkey  out=tmp_005a; by pd_band_rto pd_band_rto_old mth_tm_id NCR_EXPSR_CL NCR_PD_BAND_KEY_VAL pd; quit;*/
proc sort data= tmp_005 out=tmp_005a; by NCR_EXPSR_CL NCR_PD_BAND_KEY_VAL; run;
/*Added Distinct Clause RRMSS-1597*/

/* check for missing ratios inbetween list of PD band keys under each exposure class then identify the previous & next band with a ratio */
proc sql;
create table tmp_0052 as 
select  a.*,
( case when pd eq . then
(select distinct pd from tmp_005a where NCR_PD_BAND_KEY_VAL= 
(select max(NCR_PD_BAND_KEY_VAL) from tmp_005a where NCR_PD_BAND_KEY_VAL<a.NCR_PD_BAND_KEY_VAL and pd ne . and NCR_EXPSR_CL=a.NCR_EXPSR_CL)
and NCR_EXPSR_CL=a.NCR_EXPSR_CL)
else pd end) as prev_PD,
( case when pd eq . then
(select distinct pd from tmp_005a where NCR_PD_BAND_KEY_VAL=
(select min(NCR_PD_BAND_KEY_VAL) from tmp_005a where NCR_PD_BAND_KEY_VAL>a.NCR_PD_BAND_KEY_VAL and pd ne . and NCR_EXPSR_CL=a.NCR_EXPSR_CL)
and NCR_EXPSR_CL=a.NCR_EXPSR_CL)
else pd end) as next_PD,
( case when pd eq . then
(select max(NCR_PD_BAND_KEY_VAL) from tmp_005a where NCR_PD_BAND_KEY_VAL<a.NCR_PD_BAND_KEY_VAL and pd ne . and NCR_EXPSR_CL=a.NCR_EXPSR_CL)
else NCR_PD_BAND_KEY_VAL end) as prev_band,
( case when pd eq . then
(select min(NCR_PD_BAND_KEY_VAL) from tmp_005a where NCR_PD_BAND_KEY_VAL>a.NCR_PD_BAND_KEY_VAL and pd ne . and NCR_EXPSR_CL=a.NCR_EXPSR_CL)
else NCR_PD_BAND_KEY_VAL end) as next_band
from tmp_005a as a;
quit;


/* attempt to derive missing ratios inbetween PD band keys using a formula */
data tmp_00521
(drop = pd_k prev_pd next_pd prev_pd next_band next_band PD  PD_DIFF DIFF INTVL_NUM prev_band) 
;
set tmp_0052;
if pd eq . then do;
PD_DIFF=next_pd-prev_pd;
DIFF=input(next_band,8.)-input(prev_band,8.);
INTVL_NUM=input(NCR_PD_BAND_KEY_VAL,8.)-input(prev_band,8.);
PD_K=round(prev_pd+(PD_DIFF/DIFF)*INTVL_NUM,0.00000001);
end;
else do;pd_k=pd;
end;
PD_BAND_RTO=pd_k;
run;

proc sort data= tmp_00521; by NCR_EXPSR_CL NCR_PD_BAND_KEY_VAL; quit;


proc sort data= CNDN_RTL_BD_P1_005B; by NCR_EXPSR_CL NCR_PD_BAND_KEY_VAL; quit;

/* merge all exposure class & PD band combo with the list of actual & patched ratios */
DATA &LIB..CNDN_RTL_BD_P1_005;
MERGE CNDN_RTL_BD_P1_005B (in=a drop=PD_BAND_RTO)
		tmp_00521(in=b);
by NCR_EXPSR_CL NCR_PD_BAND_KEY_VAL;
if a=b;
IF ACCT_CNT = . THEN ACCT_CNT = 0;
if PD_BAND_RTO = . then PD_BAND_RTO = 0;
DROP PD_RTO _name_;
RUN;

