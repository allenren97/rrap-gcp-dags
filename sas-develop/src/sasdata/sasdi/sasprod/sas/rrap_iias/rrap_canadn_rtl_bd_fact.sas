PROC SQL THREADS;
CREATE TABLE PP_090 AS
	   SELECT BUS.MTH_TM_ID,
       bus.NCR_EXPSR_CL_KEY_VAL AS NCR_EXPSR_CL_KEY_VAL,
	GRS_IMPAIRED_LOAN_AND_ACPTNC_OTH as GRS_IMPRD_LN_ACPT_OTH_CHNG_AMT,
	CR_LOSS_OTH_CHNG_ALWNC_AMT as CR_LOSS_OTH_CHNG_ALWNC_AMT
