proc sql noprint ;

		    CREATE table  BD_P1_090_step1 as 
			select 
			DISTINCT
				mth_tm_id,
				&NCR_BD_RECD_TP_ID. as NCR_BD_RECD_TP_ID,
				d2.NCR_PD_BAND_ID as NCR_PD_BAND_ID,
				&NCR_EXPSR_SIZE_ID. as NCR_EXPSR_SIZE_ID,
				&NCR_GEO_ID. as NCR_GEO_ID,
				&NCR_LTV_ID. as NCR_LTV_ID,
				D3.EXPSR_CL_ID,
				&NCR_SECRTZTN_ID. as NCR_SECRTZTN_ID,
				&NCR_RT_ID. as NCR_RT_ID,
				&DLQNT_ID. as DLQNT_ID,
				GRS_IMPRD_LN_ACPT_OTH_CHNG_AMT,
				CR_LOSS_OTH_CHNG_ALWNC_AMT AS CR_LOSS_ALWNC_OTH_CHNG_AMT
				from PP_090 F1
				LEFT JOIN
				&LIB..TM_DIM T1
				ON F1.MTH_TM_ID = T1.TM_ID
				LEFT JOIN
				&LIB..PD_BAND_DIM D2
                ON 
				D2.NCR_PD_BAND_KEY_VAL='1499'  
				AND D2.NCR_EXPSR_CL_KEY_VAL = F1.NCR_EXPSR_CL_KEY_VAL
				AND put(&DAY_DTT,z6.) BETWEEN D2.EFF_FROM_YR_MTH AND
				D2.EFF_TO_YR_MTH
				LEFT JOIN
				&LIB..BASEL_EXPSR_CL_DIM D3
                ON 
				D3.NCR_EXPSR_CL_KEY_VAL = F1.NCR_EXPSR_CL_KEY_VAL
				AND put(&DAY_DTT,z6.) BETWEEN D3.EFF_FROM_YR_MTH AND
				D3.EFF_TO_YR_MTH

				where 
				F1.NCR_EXPSR_CL_KEY_VAL in ('0500') 
				and mth_tm_id = &Processing_Month_Time_ID.;

quit;


