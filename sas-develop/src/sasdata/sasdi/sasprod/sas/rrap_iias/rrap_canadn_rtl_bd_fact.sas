/**Program to create Canadian Retail Fact BD_P1_055 Extract Table on 10 Aug2014 **/

PROC SQL THREADS;
CREATE TABLE CNDN_RTL_BD_P1_055_TMP1 as
Select MTH_TM_ID,
B.NCR_PRNT_KEY_VAL AS EXPSR_PRNT_CL_KEY_VAL,
C.NCR_PRNT_KEY_VAL AS GEO_PRNT_KEY_VAL,
D.NCR_PRNT_KEY_VAL AS DLQNT_PRNT_KEY_VAL,
count(BASEL_ACCT_ID) AS BASEL_ACCT_ID,
coalesce(SUM(CASE WHEN coalesce(ADJUSTED_OS_BAL_AMT, 0) /*+ coalesce(UNADJUSTED_ADD_ON_BAL_AMT, 0)*/ <0 THEN 0 	
             ELSE coalesce(ADJUSTED_OS_BAL_AMT, 0) /*+ coalesce(UNADJUSTED_ADD_ON_BAL_AMT, 0)*/ END), 0)  AS ADJUSTED_OS_BAL_AMT

FROM 
&LIB..BASEL_ANALYTCL_BL_INSTRMNT_FACT A
LEFT JOIN &LIB..Basel_ncr_hierarchy_lkp B
ON A.NCR_EXPSR_CL_KEY_VAL = B.NCR_KEY_VAL
and b.NCR_PRNT_KEY_VAL IN ('0500', '0501', '0502', '0503', '0504', '0505', '0506', '0507', '0510', '0511', '0512') 
LEFT JOIN &LIB..Basel_ncr_hierarchy_lkp C
ON A.NCR_GEO_KEY_VAL = C.NCR_KEY_VAL 
and  c.NCR_PRNT_KEY_VAL IN ('0300', '0301', '0315', '0316', '0317', '0318', '0319')
LEFT JOIN &LIB..Basel_ncr_hierarchy_lkp D
ON A.NCR_DLQNT_BCKT_KEY_VAL = D.NCR_KEY_VAL 
and (INPUT(d.NCR_PRNT_KEY_VAL,8.) BETWEEN 800 AND 805)
WHERE CCAR_F=1 AND
MTH_TM_ID = &Processing_Month_Time_ID. 
group by MTH_TM_ID,B.NCR_PRNT_KEY_VAL, C.NCR_PRNT_KEY_VAL , D.NCR_PRNT_KEY_VAL ;
quit;



