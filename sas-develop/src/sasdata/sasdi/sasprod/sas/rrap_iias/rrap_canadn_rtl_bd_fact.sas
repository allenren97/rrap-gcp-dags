'' LENGTH=255 FORMAT = $255.AS PD_BAND_NM,
. LENGTH= 8  FORMAT= 28.8 AS PD_BAND_RTO,
COALESCE(a.ADJUSTED_OS_BAL_AMT,0) LABEL="Outstanding Balance Amount"	FORMAT=	17.3 AS	OS_BAL_AMT,
. LABEL="Over Limit Account Ratio"	FORMAT=	28.8	 AS OV_LMT_ACCT_RTO,
. LABEL="Authorized Amount"	FORMAT=	17.3 AS	AUTH_AMT,
. LABEL="Fraud Loss Amount"	FORMAT=	17.3 AS	FRAUD_LOSS_AMT,
. LABEL="Estimated EAD Amount"	FORMAT= 17.3 AS	ESTD_EAD_AMT,
. LABEL="Write Off Account Count"	FORMAT=	24.	AS WRITE_OFF_ACCT_CNT,
. LABEL="Write Off Total Amount	"	FORMAT=	17.3 AS	WRITE_OFF_TOT_AMT,
. LABEL="IRB Expected Loss Amount"	FORMAT= 17.3 AS	IRB_EXPCTD_LOSS_AMT,
. LABEL="Recovery Amount"	FORMAT=	17.3	AS RCVRY_AMT,
. LABEL="Economic Loss Amount"	FORMAT=	17.3	AS ECONMC_LOSS_AMT,
. LABEL="IRB Capital Amount"	FORMAT=	17.3	AS IRB_CAPTL_AMT,
. LABEL="ACCOUNT COUNT" LENGTH=8 FORMAT 12.  AS ACCT_CNT,
. LABEL="Average Utilization Ratio"	FORMAT=	12. AS	ESTD_DEFLTD_ACCT_CNT,
. LABEL="Estimated Defaulted Account Count"	FORMAT=	12. AS 	REALZ_DEFLTD_ACCT_CNT,
