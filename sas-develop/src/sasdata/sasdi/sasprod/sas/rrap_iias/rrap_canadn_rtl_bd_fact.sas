ON A.MTH_TM_ID = T.TM_ID
LEFT JOIN
&LIB..BASEL_NCR_GEO_DIM B
ON A.GEO_PRNT_KEY_VAL = B.NCR_GEO_KEY_VAL
AND B.CRNT_F = 'Y'
AND put(&DAY_DTT,z6.) BETWEEN B.EFF_FROM_YR_MTH AND
				B.EFF_TO_YR_MTH
LEFT JOIN
&LIB..BASEL_EXPSR_CL_DIM C
ON A.EXPSR_PRNT_CL_KEY_VAL = C.NCR_EXPSR_CL_KEY_VAL
AND C.CRNT_F = 'Y'
AND put(&DAY_DTT,z6.) BETWEEN C.EFF_FROM_YR_MTH AND
				C.EFF_TO_YR_MTH
LEFT JOIN
&LIB..DLQNT_DIM D
ON INPUT(A.DLQNT_PRNT_KEY_VAL,8.) = INPUT(D.NCR_DLQNT_CD, 8.)
AND "&mth_tm_id_st_dt."d between D.EFF_FROM_DT and D.EFF_TO_DT 
AND &tdy.  BETWEEN D.EFF_FROM_DT AND D.EFF_TO_DT
LEFT JOIN
&LIB..PD_BAND_DIM E
ON 
 E.NCR_PD_BAND_KEY_VAL = '1499'
AND INPUT(A.EXPSR_PRNT_CL_KEY_VAL,8.) = INPUT(E.NCR_EXPSR_CL_KEY_VAL,8.) 
AND put(&DAY_DTT,z6.) BETWEEN E.EFF_FROM_YR_MTH AND
				E.EFF_TO_YR_MTH

;
