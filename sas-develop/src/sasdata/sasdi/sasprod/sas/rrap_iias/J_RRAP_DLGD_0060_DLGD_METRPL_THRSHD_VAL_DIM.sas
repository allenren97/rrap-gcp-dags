%let file=rrm_edwext_DLGD_threshold_values_lookup_f_adhoc;


proc sql noprint;
	select put(tm_lvl_end_dt,yymmn6.)  into :yyyymm
		from nzrrap.tm_dim
	where tm_lvl='Month' and tm_id = &mth_tm_id.;

	select 
		case when count(*) = 0 then 'Y'
		else 'N' end as initial_load into :initial_load_f
	from nzrrap.DLGD_METRPL_THRSHD_VAL_DIM;
quit;
%put &initial_load_f;

DATA THRESHOLD_VALUES_LKP;
    LENGTH
        METRPL_AREA_NM         $ 32
        THRSHD_VAL             8 ;

    INFILE "&outpath./rrm/&file..csv"
        LRECL=50
        ENCODING="LATIN1"
/*        TERMSTR=CRLF*/
        DLM=','
        MISSOVER
		FIRSTOBS=2
        DSD ;
    INPUT
        METRPL_AREA_NM          : $CHAR32.
        THRSHD_VAL             : COMMA12. ;

	format INSRT_PROCESS_TMSTMP UPDT_PROCESS_TMSTMP  datetime25.6;
	CRNT_F = 'Y';
	if missing(METRPL_AREA_NM) then delete;
RUN;
proc sort nodupkey; by METRPL_AREA_NM THRSHD_VAL; run;




data existing;
	set NZRRAP.DLGD_METRPL_THRSHD_VAL_DIM (drop=INSRT_PROCESS_TMSTMP UPDT_PROCESS_TMSTMP);
	where "&yyyymm." GE EFF_FROM_YR_MTH and  "&yyyymm." LT  EFF_TO_YR_MTH;
run;
proc sort data=existing; by  METRPL_AREA_NM THRSHD_VAL; run;


data newfile;
	set THRESHOLD_VALUES_LKP;
	keep METRPL_AREA_NM THRSHD_VAL DIGEST;
	DIGEST = THRSHD_VAL;
run;

%macro new_close_stay();

data new close stay;
	merge newfile(in=new) existing(in=exist);
	by METRPL_AREA_NM;
	if new and not exist then do;
		%if &initial_load_f EQ Y %then %do;
			EFF_FROM_YR_MTH = '200001';
		%end;
		%else %do;
			EFF_FROM_YR_MTH = "&yyyymm.";
		%end;
		EFF_TO_YR_MTH = '999912';
		INSRT_PROCESS_TMSTMP = "&SYSDATE9.:&SYSTIME"dt;
		UPDT_PROCESS_TMSTMP = "&SYSDATE9.:&SYSTIME"dt;
		CRNT_F = 'Y';
		output new;
	end;
/**/
	if exist and not new then do;
		EFF_TO_YR_MTH = "&yyyymm.";
		CRNT_F = 'N';
		output close;
	end;

	if exist and new then do;
		IF THRSHD_VAL NE DIGEST then do;

			EFF_TO_YR_MTH = "&yyyymm.";
			CRNT_F = 'N';
			output close;

			THRSHD_VAL = DIGEST;
			EFF_FROM_YR_MTH = "&yyyymm.";
			EFF_TO_YR_MTH = '999912';
			INSRT_PROCESS_TMSTMP = "&SYSDATE9.:&SYSTIME"dt;
			UPDT_PROCESS_TMSTMP = "&SYSDATE9.:&SYSTIME"dt;
			CRNT_F = 'Y';
			output new;

		end;
		IF THRSHD_VAL = DIGEST then do;
			output stay;
		end;
	end;
	drop DIGEST;
run;

%mend new_close_stay;
%new_close_stay;


proc sql;
update nzrrap.DLGD_METRPL_THRSHD_VAL_DIM AA

     set EFF_TO_YR_MTH = (
        select EFF_TO_YR_MTH
           from close
           where METRPL_AREA_NM =  AA.METRPL_AREA_NM)
     where exists ( select 1
           from close
           where METRPL_AREA_NM =  AA.METRPL_AREA_NM);

update nzrrap.DLGD_METRPL_THRSHD_VAL_DIM AA
     set CRNT_F = 'N'
     where exists ( select 1
           from close
           where METRPL_AREA_NM =  AA.METRPL_AREA_NM);

update nzrrap.DLGD_METRPL_THRSHD_VAL_DIM AA
     set UPDT_PROCESS_TMSTMP = "&SYSDATE9.:&SYSTIME"dt
     where exists ( select 1
           from close
           where METRPL_AREA_NM =  AA.METRPL_AREA_NM);
quit;  
      
proc append base=NZRRAP.DLGD_METRPL_THRSHD_VAL_DIM data=new force; run;

