%get_model_period_dates(product=mor);
%put Start and End Dates for Mortgage Models:;
%put start_period_dt: &start_period_dt ;
%put end_period_dt: &end_period_dt;


proc sql noprint;
select tm_id into :tm_key
from nzrrap.tm_dim
where tm_lvl_end_dt = "&end_period_dt."d and tm_lvl='Month';
quit;

%put &tm_key;


proc sql ;
   create table work.brdm_data as
   select a.uniqueaccountidentifier as unq_acct_id,
          a.ncr_exposure_size as ncr_expsr_size_key_val,
          a.ncr_geography as ncr_geo_key_val,
          a.ncr_rate as ncr_rt_key_val,
          a.ncr_delinquency_bucket as ncr_dlqnt_bckt_key_val,
          a.gl_balancing_adjustment as genl_ledger_balcng_adj_amt format = 17.3,
          a.delinq_stage as dlqnt_stg,
          a.legal_entity as legal_entity,
          a.ccar_exposure_class as ccar_expsr_cl_nm length = 20,
          a.tnif_region_code as rgnl_offc_cd length = 5,

          a.treatment_flag as consm_prd_treatmnt_cd length = 1,

          /* Part of MO_NEW */
          a.transit as trnst_num, /*yes - in mo_new - transit*/
          a.authorizedamount as auth_amt, /*yes - in mo_new - auth_amount*/
          a.maturity_date as mat_dt, /*yes - in mo_new - maturity_date*/
          a.cab as cab_trnst_num, /*yes* - in mo_new - cab*/
          a.advancedamount as advnc_amt, /*yes - in mo_new - tot_adv_amt*/
          a.accountopendate as acct_odt, /* yes? - in mo_new - made_date?? */

          /* Part of BASEL_MORT */
          a.primary_customer_cid as prim_cust_cid length = 20, /* in basel_mort - prim_cust_id */
          a.basel_cif_key as basel_cif_key length = 17, /* in basel_mort - cif_key */
          a.Step_Flag as step_f length = 1, /* in basel_mort - step_f */
          a.DaysDelinquent as dlqnt_day_cnt, /* basel_mort - dlqnt_day */

          a.residual_maturity as residual_mat,
          a.transit_exclusion_flag as trnst_exclsn_f length = 1, /* in basel_mort? trnst & trnst_org_unit_id */
          a.originalpropertyvalue as orig_prpty_val_amt, /* Basel mort*/

          a.af_zero_net_drawn_amt as af_zero_net_drawn_amt format = 17.3,
          a.af_zero_net_undrawn_amt as af_zero_net_undrawn_amt format = 17.3,
          a.bf_zero_net_drawn_amt as before_zero_net_drawn_amt format = 17.3,
          a.bf_zero_net_undrawn_amt as before_zero_net_undrawn_amt format = 17.3,

          put(a.mort_num,7.) as mort_num,
          &tm_key as tm_id
 
   from nzuser.BASELAYER_MOR as a
   where a.mth_end_dt = "&end_period_dt."d;
quit;

/*DO NOT CLEANOUT DATA PRIOR TO MAY2017 as this is not coming in from EDL.*/
proc sql noprint;
   connect using nzuser as nzcon;
   execute (
      
      delete from &target_lib3..brdm_baselayer_mor
      where tm_id=&tm_key. and tm_id >=16916

   ) by nzcon;
quit;


