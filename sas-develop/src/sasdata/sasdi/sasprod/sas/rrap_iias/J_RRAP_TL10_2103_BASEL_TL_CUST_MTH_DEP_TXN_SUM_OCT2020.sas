                     endTimeMacroVariable=etls_endTime_&&etlsHandles&i. ); 
                  %put NOTE: Process &&etlsHandles&i. has completed.;
               %end; 
               %else %if (&SYSRC ne -1) %then /* process status unknown  */ 
               %do; 
                  %etls_freeHandle(statusTable=&statusTable, statusVariable=&statusVariable,
                     handleVariable=&handleVariable, handleName="&&etlsHandles&i", 
