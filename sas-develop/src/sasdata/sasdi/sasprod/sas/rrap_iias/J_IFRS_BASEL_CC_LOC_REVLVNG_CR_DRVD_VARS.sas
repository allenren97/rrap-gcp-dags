PROC SQL ;
		CONNECT USING NZRRAP AS NZCON;
             create table S_BASEL_REVLVNG_CR_MTH_SNAPSHOT as
            select *              
            from connection to NZCON
			(
		WITH

		S3m AS 
			(SELECT
			COUNT(1) AS  BASEL_CUSTACCT_Age_3mths,
			BASEL_CUST_ID as BASEL_CUST_ID 
			FROM (
				SELECT  DISTINCT  MTH_TM_ID,  BASEL_CUST_ID 
				FROM  &net_db..BASEL_CUST_ACCT_RLTNP_SNAPSHOT
				WHERE MTH_TM_ID>=&MTH_TM_ID.  - 80 
				AND   MTH_TM_ID<=&MTH_TM_ID. 
			)  A
			GROUP BY  BASEL_CUST_ID
			),

		S6M AS 
			(SELECT
			COUNT(1) AS  BASEL_CUSTACCT_Age_6mths,
			BASEL_CUST_ID as BASEL_CUST_ID 
			FROM (
				SELECT  DISTINCT  MTH_TM_ID,  BASEL_CUST_ID 
				FROM  &net_db..BASEL_CUST_ACCT_RLTNP_SNAPSHOT
				WHERE MTH_TM_ID>=&MTH_TM_ID.  - 200    
				AND   MTH_TM_ID<=&MTH_TM_ID. 
			)  A
			GROUP BY  BASEL_CUST_ID),


		S12M AS 
			(SELECT
			COUNT(1) AS  BASEL_CUSTACCT_Age_12mths,
			BASEL_CUST_ID as BASEL_CUST_ID 
			FROM (
				SELECT  DISTINCT  MTH_TM_ID,  BASEL_CUST_ID 
				FROM  &net_db..BASEL_CUST_ACCT_RLTNP_SNAPSHOT
				WHERE MTH_TM_ID>=&MTH_TM_ID. -440
				AND   MTH_TM_ID<=&MTH_TM_ID. 
			)  A
			GROUP BY  BASEL_CUST_ID),

		SM as
		(SELECT 
		
		(CASE WHEN MAX(LAST_PRCH_DT) IS NULL AND MAX(LAST_PYMT_DT) IS NOT NULL THEN date(TO_DATE('1800-01-01', 'YYYY-MM-DD')) 
		ELSE first_day(MAX(LAST_PRCH_DT)) END ) 		LLAST_PRCH_DT,

		(CASE WHEN MAX(LAST_PYMT_DT) IS NULL AND MAX(LAST_PRCH_DT) IS NOT NULL THEN date(TO_DATE('1800-01-01', 'YYYY-MM-DD')) 
			ELSE first_day(MAX(LAST_PYMT_DT)) END ) 		LLAST_PYMT_DT	,
		COUNT(BASEL_ACCT_ID) as CNT_BASEL_ACCT_ID ,
		MAX(LAST_PRCH_DT) as MAX_LAST_PRCH_DT, 
		MAX(LAST_PYMT_DT) as MAX_LAST_PYMT_DT,
		BASEL_ACCT_ID as BASEL_ACCT_ID 
		FROM &net_db..BASEL_REVLVNG_CR_MTH_SNAPSHOT
		WHERE
		MTH_TM_ID >&MTH_TM_ID.  - 240 AND
		MTH_TM_ID <=&MTH_TM_ID. 
		GROUP BY
		BASEL_ACCT_ID
		ORDER BY  BASEL_ACCT_ID
		),


		S5 AS 
		(SELECT 
			SS.BASEL_ACCT_ID,
			SUM(CASE
			     WHEN SS.CR_LMT_AMT=0 AND SS.TOT_NEW_BAL_AMT>0 THEN 1
			     WHEN SS.CR_LMT_AMT=0 AND SS.TOT_NEW_BAL_AMT<=0 THEN 0
			    ELSE SS.TOT_NEW_BAL_AMT/SS.CR_LMT_AMT END) AS LAST_3_MTH_AVG_UTLTN_RT,
			     
			 MAX(CASE
			     WHEN SS.CR_LMT_AMT=0 AND SS.TOT_NEW_BAL_AMT>0 THEN 1
			     WHEN SS.CR_LMT_AMT=0 AND SS.TOT_NEW_BAL_AMT<=0 THEN 0
			     ELSE SS.TOT_NEW_BAL_AMT/SS.CR_LMT_AMT END) AS LAST_3_MTH_MAX_CRD_UTLTN_RT
			         
			FROM &net_db..BASEL_REVLVNG_CR_MTH_SNAPSHOT SS
			WHERE
			SS.MTH_TM_ID BETWEEN &MTH_TM_ID.  - 80 AND &MTH_TM_ID. 
			GROUP BY SS.BASEL_ACCT_ID) ,
		S1 AS
		(SELECT 
			SS.BASEL_ACCT_ID, 
			MAX((CASE WHEN (SS.BNS_DLQNT_DAY-30)<0 THEN 0 ELSE (SS.BNS_DLQNT_DAY-30) end)) AS LAST24MtMxDlqDCnt,
			SUM((CASE WHEN (SS.BNS_DLQNT_DAY-30)<0 THEN 0 ELSE (SS.BNS_DLQNT_DAY-30) end)) AS LAST24MtToTdDlqCNT
			FROM &net_db..BASEL_REVLVNG_CR_MTH_SNAPSHOT SS
			WHERE
			SS.MTH_TM_ID BETWEEN &MTH_TM_ID.  - 920 AND &MTH_TM_ID. 
			GROUP BY SS.BASEL_ACCT_ID) ,
			
		s2 AS 
		(SELECT 
			SS.BASEL_ACCT_ID, 
			SUM(SS.CSH_ADVNC_1_CYCL_AGO_BAL_AMT)  AS LAST12MTotCAd1cBaA,
			SUM(SS.CSH_ADVNC_2_CYCL_AGO_BAL_AMT)  AS LAST2MAvCAdv2CbAmt,
			SUM(SS.MTH_DLQNT_CNT) AS LAST12MDlqAvMtCnt
			FROM &net_db..BASEL_REVLVNG_CR_MTH_SNAPSHOT SS
			WHERE
			SS.MTH_TM_ID BETWEEN &MTH_TM_ID.  - 440 AND &MTH_TM_ID. 
			GROUP BY SS.BASEL_ACCT_ID),
		S3 AS 

		(SELECT 
			SS.BASEL_ACCT_ID, 
			SUM(SS.CSH_ADVNC_2_CYCL_AGO_BAL_AMT)  AS Last6M_AvCshADV2cbAMT
			FROM &net_db..BASEL_REVLVNG_CR_MTH_SNAPSHOT SS
			WHERE
			SS.MTH_TM_ID BETWEEN &MTH_TM_ID.  - 200  AND &MTH_TM_ID. 
			GROUP BY SS.BASEL_ACCT_ID)	,
		S4 AS 
		(SELECT 
			SS.BASEL_ACCT_ID, SS.TOT_NEW_BAL_AMT  as TOT_NEW_BAL_AMT
			FROM &net_db..BASEL_REVLVNG_CR_MTH_SNAPSHOT SS
			WHERE
			SS.MTH_TM_ID = &MTH_TM_ID. -80)
			
			SELECT 
				SS.MTH_TM_ID AS MTH_TM_ID,
				SS.BASEL_ACCT_ID AS BASEL_ACCT_ID,
				SS.PRIM_BASEL_CUST_ID AS BASEL_CUST_ID,
				SS.LAST_PRCH_DT, 
				SS.ACCT_OPND_DT,
				months_between (tm_lvl_end_dt,SS.ACCT_OPND_DT) as ACCT_OPND_MTH_CNT,
				SS.LAST_PYMT_DT,
				DV.PIT_STAT_VER_2_CD AS DV_PIT_STAT_VER_2_CD,
				SS.TOT_NEW_BAL_AMT AS SS_TOT_NEW_BAL_AMT,
				S4.TOT_NEW_BAL_AMT AS S4TOT_NEW_BAL_AMT,
				S3.Last6M_AvCshADV2cbAMT AS Last6M_AvCshADV2cbAMT,
				S2.LAST2MAvCAdv2CbAmt AS LAST2MAvCAdv2CbAmt, 
				S2.LAST12MDlqAvMtCnt AS LAST12MDlqAvMtCnt, 
				S2.LAST12MTotCAd1cBaA AS LAST12MTotCAd1cBaA,
				S1.LAST24MtMxDlqDCnt AS LAST_24_MTH_MAX_DLQNT_DAY_CNT, 
				S1.LAST24MtToTdDlqCNT AS LAST_24_MTH_TOT_DAY_DLQNT_CNT,
				BASEL_CUSTACCT_Age_3mths,
				BASEL_CUSTACCT_Age_6mths,
				BASEL_CUSTACCT_Age_12mths,
				CNT_BASEL_ACCT_ID ,
				MAX_LAST_PRCH_DT, 
				MAX_LAST_PYMT_DT,
/*				round(S5.LAST_3_MTH_AVG_UTLTN_RT,4) AS LAST_3_MTH_AVG_UTLTN_RT0,*/
				round(S5.LAST_3_MTH_MAX_CRD_UTLTN_RT,4) AS LAST_3_MTH_MAX_CRD_UTLTN_RT,
				round((CASE WHEN COALESCE(BASEL_CUSTACCT_Age_3mths,0) <> 0 THEN S5.LAST_3_MTH_AVG_UTLTN_RT/BASEL_CUSTACCT_Age_3mths ELSE NULL end),4) AS LAST_3_MTH_AVG_UTLTN_RT , /* updated TRUNCATE function to ROUND function by VK */
				round((CASE WHEN COALESCE(SS.TOT_NEW_BAL_AMT-S4.TOT_NEW_BAL_AMT,0) <> 0 THEN ((SS.TOT_NEW_BAL_AMT-S4.TOT_NEW_BAL_AMT)/2) ELSE 0 end),3) AS LAST_3_MTH_SLOPE_TOT_NEW_BAL_AMT,
				round((CASE WHEN COALESCE(BASEL_CUSTACCT_Age_6mths,0) <> 0 THEN (Last6M_AvCshADV2cbAMT/BASEL_CUSTACCT_Age_6mths) ELSE null end),3) AS LAST_6_MTH_AVG_CSH_ADVNC_TWO_CYC, /* updated TRUNCATE function to ROUND function by VK */
				round((CASE WHEN COALESCE(BASEL_CUSTACCT_Age_12mths,0) <> 0 THEN (LAST2MAvCAdv2CbAmt/BASEL_CUSTACCT_Age_12mths) ELSE null end),3) AS LAST_12_MTH_AVG_CSH_ADVNC_TWO_CY, /* updated TRUNCATE function to ROUND function by VK */
				LAST12MTotCAd1cBaA AS LAST_12_MTH_TOT_CSH_ADVNC_ONE_CY,
				round((CASE WHEN COALESCE(BASEL_CUSTACCT_Age_12mths,0) <> 0 THEN (LAST12MDlqAvMtCnt/BASEL_CUSTACCT_Age_12mths) ELSE null end),4) AS 		LAST_12_MTH_DLQNT_AVG_MTH_CNT,

/*				S5.LAST_3_MTH_AVG_UTLTN_RT AS LAST_3_MTH_AVG_UTLTN_RT0,*/
/*				S5.LAST_3_MTH_MAX_CRD_UTLTN_RT AS LAST_3_MTH_MAX_CRD_UTLTN_RT,*/
/*				(CASE WHEN COALESCE(BASEL_CUSTACCT_Age_3mths,0) <> 0 THEN S5.LAST_3_MTH_AVG_UTLTN_RT/BASEL_CUSTACCT_Age_3mths ELSE NULL end) AS LAST_3_MTH_AVG_UTLTN_RT ,*/
/*				(CASE WHEN COALESCE(SS.TOT_NEW_BAL_AMT-S4.TOT_NEW_BAL_AMT,0) <> 0 THEN ((SS.TOT_NEW_BAL_AMT-S4.TOT_NEW_BAL_AMT)/2) ELSE 0 end) AS LAST_3_MTH_SLOPE_TOT_NEW_BAL_AMT,*/
/*				(CASE WHEN COALESCE(BASEL_CUSTACCT_Age_6mths,0) <> 0 THEN (Last6M_AvCshADV2cbAMT/BASEL_CUSTACCT_Age_6mths) ELSE 0 end) AS LAST_6_MTH_AVG_CSH_ADVNC_TWO_CYC,*/
/*				(CASE WHEN COALESCE(BASEL_CUSTACCT_Age_12mths,0) <> 0 THEN (LAST2MAvCAdv2CbAmt/BASEL_CUSTACCT_Age_12mths) ELSE 0 end) AS LAST_12_MTH_AVG_CSH_ADVNC_TWO_CY,*/
/*				LAST12MTotCAd1cBaA AS LAST_12_MTH_TOT_CSH_ADVNC_ONE_CY,*/
/*				(CASE WHEN COALESCE(BASEL_CUSTACCT_Age_12mths,0) <> 0 THEN (LAST12MDlqAvMtCnt/BASEL_CUSTACCT_Age_12mths) ELSE 0 end) AS 		LAST_12_MTH_DLQNT_AVG_MTH_CNT,*/
/*				DATE_COMPARE(v_LAST_PRCH_DT,v_LAST_PYMT_DT)*/

				LLAST_PRCH_DT , LLAST_PYMT_DT,
				Months_between(tm_lvl_st_dt, (case when LLAST_PRCH_DT < LLAST_PYMT_DT	then LLAST_PYMT_DT
					when LLAST_PRCH_DT = LLAST_PYMT_DT	then LLAST_PYMT_DT
					when LLAST_PRCH_DT > LLAST_PYMT_DT	then LLAST_PRCH_DT
					else null end
				)) v_ZERO_BAL_6_CONS_MTH_F_DIFF,tm_lvl_st_dt,tm_lvl_end_dt,
				round((CASE WHEN COALESCE(SS.TOT_NEW_BAL_AMT-S4.TOT_NEW_BAL_AMT,0) = 0 
				OR COALESCE(S4.TOT_NEW_BAL_AMT,0)=0 THEN 0 ELSE ((SS.TOT_NEW_BAL_AMT-S4.TOT_NEW_BAL_AMT)/S4.TOT_NEW_BAL_AMT) end),3) AS LAST_3_MTH_CHNG_TOT_NEW_BAL_AMT
		    	FROM
			(SELECT * FROM &net_db..BASEL_REVLVNG_CR_MTH_SNAPSHOT SS WHERE SS.MTH_TM_ID=&MTH_TM_ID. 
				)SS
			
			JOIN (	select 	TM_ID, tm_lvl_st_dt,tm_lvl_end_dt 
					from 	&net_db..TM_DIM
					where tm_id = &MTH_TM_ID. 
				) tm ON SS.MTH_TM_ID=tm.TM_ID

		JOIN &net_db..BASEL_REVLVNG_CR_BASE_DRVD_VARS DV
			ON
			SS.BASEL_ACCT_ID=DV.BASEL_ACCT_ID
			AND SS.MTH_TM_ID=DV.MTH_TM_ID
			LEFT OUTER JOIN 
			S1 	ON SS.BASEL_ACCT_ID = S1.BASEL_ACCT_ID

			LEFT OUTER JOIN 
			 S2 	ON SS.BASEL_ACCT_ID = S2.BASEL_ACCT_ID

			LEFT OUTER JOIN 
			 S3 	ON SS.BASEL_ACCT_ID = S3.BASEL_ACCT_ID

			LEFT OUTER JOIN 
			 S4 	ON SS.BASEL_ACCT_ID = S4.BASEL_ACCT_ID

			LEFT OUTER JOIN 
			S5 	ON SS.BASEL_ACCT_ID = S5.BASEL_ACCT_ID

			LEFT OUTER JOIN 
			S3m 	ON SS.prim_BASEL_CUST_ID = S3m.BASEL_CUST_ID
			
			LEFT OUTER JOIN 
			S6m 	ON SS.prim_BASEL_CUST_ID = S6m.BASEL_CUST_ID
			
			LEFT OUTER JOIN 
			S12m 	ON SS.prim_BASEL_CUST_ID = S12m.BASEL_CUST_ID
			
			LEFT OUTER JOIN 
			Sm 	ON SS.BASEL_ACCT_ID = Sm.BASEL_ACCT_ID
			
			ORDER BY SS.BASEL_ACCT_ID
		 );
            disconnect from NZCON; 
quit;


data 
ld_BASEL_REVLVNG_CC_DRVD_VARS (keep=MTH_TM_ID
BASEL_ACCT_ID	ACCT_OPND_MTH_CNT	BASEL_CUST_ID	LAST_3_MTH_AVG_UTLTN_RT	LAST_3_MTH_MAX_CRD_UTLTN_RT	LAST_3_MTH_SLOPE_TOT_NEW_BAL_AMT
LAST_6_MTH_AVG_CSH_ADVNC_TWO_CYC	LAST_12_MTH_AVG_CSH_ADVNC_TWO_CY	LAST_12_MTH_DLQNT_AVG_MTH_CNT	LAST_12_MTH_TOT_CSH_ADVNC_ONE_CY
LAST_24_MTH_MAX_DLQNT_DAY_CNT	LAST_24_MTH_TOT_DAY_DLQNT_CNT	INACT_6_CONS_MTH_F	LAST_3_MTH_CHNG_TOT_NEW_BAL_AMT	INSRT_PROCESS_TMSTMP
UPDT_PROCESS_TMSTMP
);
