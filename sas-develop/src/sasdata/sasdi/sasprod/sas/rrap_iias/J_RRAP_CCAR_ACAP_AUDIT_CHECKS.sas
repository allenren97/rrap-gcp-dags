	SELECT DISTINCT SRC_SYS_CD,MTH_TM_ID,SUM(EAD_TOT_AF_CRM_AMT) AS PREV
	FROM DB2RRAP.BASEL_RISK_WGHTD_AVG_FACT A
	WHERE MTH_TM_ID = &PREV_MTH_TM_ID
