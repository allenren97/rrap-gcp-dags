	SELECT 'Weighted Avg fact - EAD_TOT_AF_CRM_AMT' as AUDIT_NAME,A.*,B.PREV,(CURR-PREV)/CURR AS DIFFERENCE FORMAT PERCENT10.2
	FROM TEMP10310_A AS A
