PROC SQL;
	SELECT CLNDR_YR INTO:CURR_CAL_YR FROM NZRRAP.TM_DIM WHERE TM_LVL = 'Month' AND TM_ID = &MTH_TM_ID;
	SELECT CLNDR_YR INTO:PREV_CAL_YR FROM NZRRAP.TM_DIM WHERE TM_LVL = 'Month' AND TM_ID = &PREV_MTH_TM_ID;
	SELECT MTH_CLNDR_CD INTO:CURR_MONTH FROM NZRRAP.TM_DIM WHERE TM_LVL = 'Month' AND TM_ID = &MTH_TM_ID;
	SELECT MTH_CLNDR_CD INTO:PREV_MONTH FROM NZRRAP.TM_DIM WHERE TM_LVL = 'Month' AND TM_ID = &PREV_MTH_TM_ID;
	SELECT TM_LVL_END_DT INTO:CURR_MTH_END_DT FROM NZRRAP.TM_DIM WHERE TM_LVL = 'Month' AND TM_ID = &MTH_TM_ID;
	SELECT TM_LVL_END_DT INTO:PREV_MTH_END_DT FROM NZRRAP.TM_DIM WHERE TM_LVL = 'Month' AND TM_ID = &PREV_MTH_TM_ID;
QUIT;

DATA _NULL_;
	CALL SYMPUT('CURR',CATX("-","&CURR_MONTH","&CURR_CAL_YR"));
	CALL SYMPUT('PREV',CATX("-","&PREV_MONTH","&PREV_CAL_YR"));
	CALL SYMPUT('MonthYear',CATX(' ',"&CURR_MONTH","&CURR_CAL_YR"));
RUN;

%PUT &=MTH_TM_ID;
%PUT &=PREV_MTH_TM_ID;
%PUT &=CURR;
%PUT &=PREV;
%PUT &=CURR_MTH_END_DT;
%PUT &=PREV_MTH_END_DT;

PROC FORMAT;
	VALUE GTEQ5LTEQ
		LOW - -0.05 = 'YELLOW'
		0.05 - HIGH = 'YELLOW'
		OTHER = 'WHITE';
	VALUE GTEQ10LTEQ
		LOW - -0.1 = 'YELLOW'
		0.1 - HIGH = 'YELLOW'
		OTHER = 'WHITE';
	VALUE BKG_PD_CURVE
		0 = 'WHITE'
		OTHER = 'YELLOW';
	VALUE $BKG_PD_CURVE_TF
		'TRUE' = 'WHITE'
		'FALSE' = 'YELLOW';
	VALUE $DLGD
		'Downturn_LGD<Loss_Given_Default' = 'YELLOW'
		OTHER = 'WHITE';
	VALUE $UNINSURED_DLGD
		'Uninsured_DLGD<Uninsured_LGD' = 'YELLOW'
		OTHER = 'WHITE';
      VALUE F_INSURANCE
		LOW - -0.05 = 'YELLOW'
		0.05 - HIGH = 'YELLOW'
		OTHER = 'WHITE';
RUN;

/*IMPORT AND PROCESS CCAR DATA*/

Data CCAR;
	set NZRRAP.RRAP_CCAR_ACAP_FILES;
	WHERE MTH_TM_ID IN (&MTH_TM_ID,&PREV_MTH_TM_ID);
run;

DATA TEMP;
	SET CCAR;
	BASEL_PRODUCT_NAME2=SUBSTR(BASEL_PRODUCT_NAME,1,LENGTH(BASEL_PRODUCT_NAME)-9);
	PD_SEG = SUBSTR(BASEL_PRODUCT_NAME,LENGTH(BASEL_PRODUCT_NAME)-7,2);
	EAD_SEG = SUBSTR(BASEL_PRODUCT_NAME,LENGTH(BASEL_PRODUCT_NAME)-4,2);
	LGD_SEG = SUBSTR(BASEL_PRODUCT_NAME,LENGTH(BASEL_PRODUCT_NAME)-1,2);
RUN;

PROC SQL;
	CREATE TABLE CCAR_FINAL AS
	SELECT *,case when BASEL_PRODUCT_NAME2 like '%BNS%' then 'BNS'
        when BASEL_PRODUCT_NAME2 like '%TNG%' then 'TNG'
        when BASEL_PRODUCT_NAME2 like '%DTL%' then 'DTL'
        when BASEL_PRODUCT_NAME2 like '%ITL%' then 'ITL'
        when BASEL_PRODUCT_NAME2 like '%CC%' then 'CC'                   
        when BASEL_PRODUCT_NAME2 like '%CL%' then 'LOC'
        when BASEL_PRODUCT_NAME2 like '%HELOC%' then 'HELOC'
        when BASEL_PRODUCT_NAME2 like '%SLR%' then 'SLR'                
        when BASEL_PRODUCT_NAME2 like '%SLT%' then 'SLT'
end as PORTFOLIO,
(input(LOSS_GIVEN_DEFAULT,percent15.6)) as NUMERIC_LGD,
(input(EXPECTED_LOSS,percent15.6)) as EXPECTED_LOSS_NUM,
(input(EAD_FACTOR,percent15.6)) as EAD_FACTOR_NUM,
(input(DOWNTURN_LGD,percent15.6)) as DOWNTURN_LGD_NUM,
(input(UNINSURED_LGD,percent15.6)) as UNINSURED_LGD_NUM,
(input(UNINSURED_DLGD,percent15.6)) as UNINSURED_DLGD_NUM,
		CASE 
			WHEN (input(DOWNTURN_LGD,percent15.6)) = (input(LOSS_GIVEN_DEFAULT,percent15.6)) THEN 'Downturn_LGD=Loss_Given_Default'
			WHEN (input(DOWNTURN_LGD,percent15.6)) >= (input(LOSS_GIVEN_DEFAULT,percent15.6)) THEN 'Downturn_LGD>=Loss_Given_Default'
			WHEN (input(DOWNTURN_LGD,percent15.6)) < (input(LOSS_GIVEN_DEFAULT,percent15.6)) THEN 'Downturn_LGD<Loss_Given_Default'
			WHEN (input(DOWNTURN_LGD,percent15.6)) IS NULL THEN 'Downturn_LGD IS NULL'
		END AS DLGD_LGD_BUCKETS,
		CASE 
			WHEN (input(UNINSURED_DLGD,percent15.6)) = (input(UNINSURED_LGD,percent15.6)) THEN 'Uninsured_DLGD=Uninsured_LGD'
			WHEN (input(UNINSURED_DLGD,percent15.6)) >= (input(UNINSURED_LGD,percent15.6)) THEN 'Uninsured_DLGD>=Uninsured_LGD'
			WHEN (input(UNINSURED_DLGD,percent15.6)) < (input(UNINSURED_LGD,percent15.6)) THEN 'Uninsured_DLGD<Uninsured_LGD'
			WHEN (input(UNINSURED_DLGD,percent15.6)) IS NULL THEN 'Uninsured_DLGD IS NULL'
		END AS UNINSURED_DLGD_LGD_BUCKETS,
		CASE 
			WHEN MTH_TM_ID = &MTH_TM_ID THEN "&CURR"
			WHEN MTH_TM_ID = &PREV_MTH_TM_ID THEN "&PREV"
		END AS MONTH_CHAR
	FROM TEMP;
QUIT;

PROC SQL;
	CREATE TABLE ECL_TRANSPOSE AS
	SELECT DISTINCT 'ECL_DRAWN1' AS ECL_COL, SUM(ECL_DRAWN1) AS TOTAL, MONTH_CHAR FROM CCAR_FINAL GROUP BY MONTH_CHAR
	UNION
	SELECT DISTINCT 'ECL_DRAWN2' AS ECL_COL, SUM(ECL_DRAWN2) AS TOTAL, MONTH_CHAR FROM CCAR_FINAL GROUP BY MONTH_CHAR
	UNION
	SELECT DISTINCT 'ECL_DRAWN3' AS ECL_COL, SUM(ECL_Drawn3) AS TOTAL, MONTH_CHAR FROM CCAR_FINAL GROUP BY MONTH_CHAR
	UNION
	SELECT DISTINCT 'ECL_Undrawn1' AS ECL_COL, SUM(ECL_Undrawn1) AS TOTAL, MONTH_CHAR FROM CCAR_FINAL GROUP BY MONTH_CHAR
	UNION
	SELECT DISTINCT 'ECL_Undrawn2' AS ECL_COL, SUM(ECL_Undrawn2) AS TOTAL, MONTH_CHAR FROM CCAR_FINAL GROUP BY MONTH_CHAR
	UNION
	SELECT DISTINCT 'ECL_Undrawn3' AS ECL_COL, SUM(ECL_Undrawn3) AS TOTAL, MONTH_CHAR FROM CCAR_FINAL GROUP BY MONTH_CHAR
	UNION
	SELECT DISTINCT 'ECL_Drawn_PostSec1' AS ECL_COL, SUM(ECL_Drawn_PostSec1) AS TOTAL, MONTH_CHAR FROM CCAR_FINAL GROUP BY MONTH_CHAR
	UNION
	SELECT DISTINCT 'ECL_Drawn_PostSec2' AS ECL_COL, SUM(ECL_Drawn_PostSec2) AS TOTAL, MONTH_CHAR FROM CCAR_FINAL GROUP BY MONTH_CHAR
	UNION
	SELECT DISTINCT 'ECL_Drawn_PostSec3' AS ECL_COL, SUM(ECL_Drawn_PostSec3) AS TOTAL, MONTH_CHAR FROM CCAR_FINAL GROUP BY MONTH_CHAR
	UNION
	SELECT DISTINCT 'ECL_Post_Adj_Drawn1' AS ECL_COL, SUM(ECL_Post_Adj_Drawn1) AS TOTAL, MONTH_CHAR FROM CCAR_FINAL GROUP BY MONTH_CHAR
	UNION
	SELECT DISTINCT 'ECL_Post_Adj_Drawn2' AS ECL_COL, SUM(ECL_Post_Adj_Drawn2) AS TOTAL, MONTH_CHAR FROM CCAR_FINAL GROUP BY MONTH_CHAR
	UNION
	SELECT DISTINCT 'ECL_Post_Adj_Drawn3' AS ECL_COL, SUM(ECL_Post_Adj_Drawn3) AS TOTAL, MONTH_CHAR FROM CCAR_FINAL GROUP BY MONTH_CHAR
	UNION
	SELECT DISTINCT 'ECL_Post_Adj_Undrawn1' AS ECL_COL, SUM(ECL_Post_Adj_Undrawn1) AS TOTAL, MONTH_CHAR FROM CCAR_FINAL GROUP BY MONTH_CHAR
	UNION
	SELECT DISTINCT 'ECL_Post_Adj_Undrawn2' AS ECL_COL, SUM(ECL_Post_Adj_Undrawn2) AS TOTAL, MONTH_CHAR FROM CCAR_FINAL GROUP BY MONTH_CHAR
	UNION
	SELECT DISTINCT 'ECL_Post_Adj_Undrawn3' AS ECL_COL, SUM(ECL_Post_Adj_Undrawn3) AS TOTAL, MONTH_CHAR FROM CCAR_FINAL GROUP BY MONTH_CHAR
	UNION
	SELECT DISTINCT 'ECL_Post_Adj_Drawn_PostSec1' AS ECL_COL, SUM(ECL_Post_Adj_Drawn_PostSec1) AS TOTAL, MONTH_CHAR FROM CCAR_FINAL GROUP BY MONTH_CHAR
	UNION
	SELECT DISTINCT 'ECL_Post_Adj_Drawn_PostSec2' AS ECL_COL, SUM(ECL_Post_Adj_Drawn_PostSec2) AS TOTAL, MONTH_CHAR FROM CCAR_FINAL GROUP BY MONTH_CHAR
	UNION
	SELECT DISTINCT 'ECL_Post_Adj_Drawn_PostSec3' AS ECL_COL, SUM(ECL_Post_Adj_Drawn_PostSec3) AS TOTAL, MONTH_CHAR FROM CCAR_FINAL GROUP BY MONTH_CHAR;
QUIT;


/*IMPORT AND PROCESS PD_CURVE DATA*/

PROC SQL;
	CREATE TABLE PD_CURVE AS
	SELECT A.MTH_END_DT,
		   A.TRANSACTOR_FLAG,
		   A.PD_BAND,
		   A.PD_VAL,
		   A.PD_MIN_VAL,
		   A.PD_MAX_VAL,
	  SUBSTR(A.CCAR_BASEL_PRD_TP_NM,1,LENGTH(A.CCAR_BASEL_PRD_TP_NM)-9) AS BASEL_PRODUCT_NAME2,
	  SUBSTR(A.CCAR_BASEL_PRD_TP_NM,LENGTH(A.CCAR_BASEL_PRD_TP_NM)-7,2) AS PD_SEG,
	  CASE 
			WHEN B.TM_ID = &MTH_TM_ID THEN "&CURR"
			WHEN B.TM_ID = &PREV_MTH_TM_ID THEN "&PREV"
		END AS MONTH_CHAR
FROM NZRRAP.BASEL_CCAR_PD_CURVE A
      INNER JOIN (
            SELECT TM_ID,
                  TM_LVL_END_DT
            FROM NZRRAP.TM_DIM
            where TM_LVL = 'Month' 
			and tm_id in (&MTH_TM_ID. , &PREV_MTH_TM_ID.)
      ) B ON A.MTH_END_DT = B.TM_LVL_END_DT
WHERE A.PD_VAL NE 0;
QUIT;

PROC SORT DATA=PD_CURVE NODUPKEY;
	BY MTH_END_DT BASEL_PRODUCT_NAME2 TRANSACTOR_FLAG PD_SEG PD_BAND;
RUN;

