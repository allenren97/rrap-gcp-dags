%macro etls_loopRCCheck(statusTable=, returnCodeVariable=,start=,end=); 
   %macro etls_loopRCError(_iteration); 
      /* Abort with a return code of  5  */ 
      %abort return  5; 
   %mend etls_loopRCError; 
   
   %local etls_rows etls_dsid rc etls_varnum;
   
   %let etls_rows = 0; 
