                         * The table testdata.excluded_obs saves the observations that are exluded from the model.
                         * The table testdata.status_excl includes the model_excl for all account.
                         * The table testdata.status_excl_final includes only those account that have model_excl="N".
                         *----------------------------------------------------------------------------------------------------------------*/
                        
                        proc sql;
                           create table &_output_tbl_excl as
                              select a.* ,
