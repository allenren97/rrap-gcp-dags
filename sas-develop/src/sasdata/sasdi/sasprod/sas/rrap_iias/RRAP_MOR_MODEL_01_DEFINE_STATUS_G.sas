                        /*---------------------------------------------------------------------
                         * Generates status of each mortgage account. User can define name of
                         * output table
                         *---------------------------------------------------------------------*/
                        proc sql noprint;
                           create table &_output_tbl as
                           select a.* ,
                        
                                 /*-----------------------------------------
                                  * Calculates temporary delq_days_2 var -->
                                  * used in later case statement
                                  *-----------------------------------------*/
                                 case 
                                    when upcase(float_ind) in('W','B','S') then intck('day', datepart(unpd_wkl_pay_date), datepart(process_date))
                                    else intck('day', datepart(unpd_mth_pay_date), datepart(process_date))
                                 end as temp_delq_days_2 ,
                        
                                 
                                  /* Calculates delq_days_2 var */
                                 case
                                    when paid_off_date ^=. or upcase(paid_off_ind)='Y' or calculated temp_delq_days_2=. or calculated temp_delq_days_2 < 0 then 0
                                    else calculated temp_delq_days_2
                                 end as delq_days_2 ,
                        
                                 /*-----------------------------------------
                                  * Calculates temporary delq_months_2 var
                                  * ---> used in later case statement
                                  *-----------------------------------------*/
                                 case 
                                    when calculated delq_days_2=0 then 0
                                    when upcase(float_ind) in ('W','B','S') then intck ('month', datepart(Unpd_Wkl_Pay_Date), datepart(Process_Date)) +1
                                    else intck ('month', datepart(unpd_mth_pay_date), datepart(process_date)) +1
                                 end as temp_delq_months_2 ,
                        
                                 /* Calculates delq_months_2 var */
                                 case 
                                    when calculated delq_days_2 >= 90 and calculated temp_delq_months_2=3 then 4
                                    else calculated temp_delq_months_2
                                 end as delq_months_2 ,
                        
                                 /*-----------------------------------------
                                  * Determines the STATUS of an account as
                                  * either CUR or DEF
                                  *-----------------------------------------*/
                                 /* RRMSS-2842 take Pit override if there is Step default */
                                 case 
                                    when not missing(b.mort_num) then b.cross_dflt_pit_status
                                    when upcase(comm_type)="RESIDENTIAL" and paid_off_date = . and (( delq_days <90 and delq_months <4)  and upcase(foreclose_ind) ^= "Y" and
                                       current_bal ^= 0 and upcase(lra_status) ^= "Y" ) or current_bal < 0 then 'CUR'
                                    when (upcase(comm_type)="RESIDENTIAL" and paid_off_date =. and ((delq_days >= 90 or delq_months >=4) or upcase(foreclose_ind) = "Y" or upcase(lra_status) ="Y") and current_bal > 0 ) 
                                    or (upcase(comm_type)="RESIDENTIAL"  and upcase(foreclose_ind) = "Y" and upcase(paid_off_ind) = "Y" and (max(current_bal, -total_suspense)>0)) then 'DEF'
                                 end as new_status 
                        
                               from &_input_tbl as a
                               /* RRMSS-2842 join edrtlrp1d.PIT_STATUS_PRE_STEP to check Pit override for Step cross default */
                               left join NZRRAP.PIT_STATUS_PRE_STEP as b
                                      on b.src_sys_cd='MOR' 
                                     and b.cross_dflt_pit_override_f='Y'
                                     and a.mortgage_no=b.mort_num
                                     and a.process_date=b.mort_process_date;
                        quit;
                        
                        
                        
                        
                        
