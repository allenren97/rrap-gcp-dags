                                       (intnx('month', datepart(a.process_date), 0, 'e') LE intnx('month', "&&mth&ii"d, 0, 'e') and
                                        intnx('month', datepart(a.process_date), 0, 'e') GE intnx('month', "&&mth&ii"d, -24, 'e'))
                                 order by a.mortgage_no, a.process_date desc;
                              quit;
                           
                              /*-------------------------------------------------------
                               * Stores BACKWARD history for defaulted accounts
                               *------------------------------------------------------*/
                              data work.backward_history (drop = status
                                                                 comm_type
                                                                 paid_off_ind
                                                                 current_bal
                                                                 foreclose_ind
                                                                 delq_days
                                                                 delq_months
                                                                 lra_status
                                                                 paid_off_date
                                                                 int_accr_amt
                                                                 counter
                                                                 base_process_date);
                        
                                 format process_date date9.;
                        
