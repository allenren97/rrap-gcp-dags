                                            (upcase(comm_type) = "RESIDENTIAL" and upcase(foreclose_ind) = "Y"  and upcase(paid_off_ind) = "Y" and
                                            (max(current_bal, -total_suspense) >0))
                                    then status = "DEF";
                                    else status = '';
                        			*/

                                    /* Define total_bal */
                                    if status = 'CUR' then total_bal = (current_bal + int_accr_amt);
                                    else if (status ne 'CUR' and total_suspense <= 0) then total_bal = max((current_bal+int_accr_amt), -total_suspense);
                                    else if (status ne 'CUR' and total_suspense > 0) then total_bal = max((current_bal+int_accr_amt), -total_suspense);
                                    else total_bal = .;
                        
                                    _status_neg(counter) = status;
                                    _current_bal_neg(counter) = current_bal;
                                    _paid_off_ind_neg(counter) = paid_off_ind;
                                    _foreclose_ind_neg(counter)= foreclose_ind;
                                    _total_bal_neg(counter) = total_bal;
                                 end;
                        
                                 if counter = 25 or last.mortgage_no = 1 then output;
                              run;
                        
                        
                           /*-----------------------------------------
                            * Renaming variables to fit code below
                            *-----------------------------------------*/
                              proc sql noprint;
                                 create table intmed.def_history_d_&pn.(drop = mortgage_no_back process_date_back insurance_back bulk_ind_back total_bal_back total_suspense_back) as
                                 select a.*,
                                        b.*
                                 from work.forward_history as a
                                      inner join
                                      work.backward_history (rename = (mortgage_no = mortgage_no_back 
                                                                       process_date = process_date_back
                                                                       insurance = insurance_back
                                                                       bulk_ind = bulk_ind_back
                                                                       total_bal = total_bal_back
                                                                       total_suspense = total_suspense_back)) as b
                                      on (a.mortgage_no = b.mortgage_no_back and
                                          a.process_date = b.process_date_back);
                              quit;
                        
                              %if &ii = 1 %then
                              %do;
                                 proc datasets lib=intmed nolist nodetails;
                                    delete all_def_history_d_&pn.;
                                    change def_history_d_&pn. = all_def_history_d_&pn.;
                                 run;
                                 quit;
                              %end;
                              %else
                              %do;
                                 proc append base = intmed.all_def_history_d_&pn. 
                                             data = intmed.def_history_d_&pn.;
                        
                                 run;
                              %end;
                           %end;
                        
                           /* Define end processing time */
                           data _null_;
                              call symput('end_time', datetime());
                           run;
                        
                           /* Calculate processing time */
                           data work.bns_mor_lggd_hist_timer;
                              format start_time end_time datetime21. seconds comma21.4 minutes hours comma21.2; 
                              start_time = &start_time;
                              end_time = &end_time;
                              seconds = &end_time - &start_time;
                              minutes = seconds/60;
                              hours = minutes/60;
                           run;
                        %mend create_lgdd_history;
                        %create_lgdd_history(_input_tbl = source.base_bns_lgd_d_&pn.)
                        
                        /*------------------------------------------
                         * Identifies the number of months back that
                         * account went from current to DEF
                         *-----------------------------------------*/
                        %macro defmonths;
                        
                           data  intmed.all_def_history_d_1_&pn.;
                              retain month_def24 month_def status_tmp;
                              set intmed.all_def_history_d_&pn.;
                              
                              month_def24 = 0;
                        
                              /* First occurrence of default */
                              month_def = 0;
                        
                             _status_0 = "DEF";  
                        
                            /*-----------------------------------------
                             * Counts the number of defaulted months in
                             * months prior to observation point (hence
                             * the _neg suffix)
                             *-----------------------------------------*/
                              %do jj = 1 %to 24;
                                 if _status_neg&jj in ("DEF") then month_def24 = month_def24 + 1; 
                              %end;
                        
                              if month_def24 = 24 then
                              do; 
                                 status_tmp = "DEF"; 
                                 month_def = 24; 
                              end;
                        
                              else 
                              do;
                        
                                 %do i = 1 %to 23;
                                    %let j=%eval(&i.+1);
                        
                                    if upcase(_status_neg&i) EQ "DEF" and upcase(_status_neg&j) EQ "CUR" then
                                    do; 
                                       status_tmp = _status_neg&j; 
                                       month_def = &i. ; 
                                       goto skip;
                                    end;
                                 %end;   
                                 skip:;
                              end;
                         
                              if upcase(_status_0) EQ "DEF" and upcase(_status_neg1) EQ "CUR" then month_def = 0;
                        run;
                        
                        %mend defmonths;
                        %defmonths;
                        
                        
                        %macro recovery24_window;
                        
                           /*------------------------------------------
                            * Creates start and end months of recovery
                            * period
                            *-----------------------------------------*/
                           data intmed.all_def_history_d_2_&pn.;
                              retain rec_start24 rec_end_max24;
                              set  intmed.all_def_history_d_1_&pn.(where = (upcase(_status_0) EQ 'DEF')); 
                        
                              rec_start24 = 1;
                              rec_end_max24 = 24 - month_def;
                        
                              if month_def24 = 24 or _total_bal_0 <= 0.01 then acct_lgd24_filter = 'Y';
                           run;
                        
                           /*------------------------------------------
                            * Resets the end month recovery if account
                            * meets conditions
                            *-----------------------------------------*/
                           data  intmed.all_def_history_d_3_&pn.;
                              retain rec_start24 rec_end24 rec_end_max24;
                              set intmed.all_def_history_d_2_&pn.;
                              rec_end24 = rec_end_max24;
                        
                              %do i = 1 %to 23;
                                 if  rec_start24 <= &i.<= rec_end_max24 and acct_lgd24_filter ^= 'Y' and 
                                     (upcase(_status_&i) EQ 'CUR' or 
                                      (_foreclose_ind_&i EQ '' and upcase(_paid_off_ind_&i) NE 'N') or 
                                      _total_bal_&i EQ 0)  
                                 then 
                                 do; 
                                    rec_end24 = &i.; 
                                    goto skip;
                                 end; 
                              %end;   
                              skip:;
                        
                           run;
                        %mend recovery24_window;
                        %recovery24_window;
                        
                        
                        %macro recovery24_cal;
                        
                        /* 21Sep2015 - JD - Adding recoveries24 to keep= for CR#47 */
                        data intmed.all_def_history_d_4_&pn.(keep = mortgage_no
                                                             process_date
                                                             month_def
                                                             insurance
                                                             bulk_ind
                                                             _total_bal_0
                                                             _foreclose_ind_0
                                                             total_suspense
                                                             rec_end24
                                                             rec_start24
                                                             _status_0 - _status_24
                                                             acct_lgd24_filter
                                                             month_def24
                                                             acct_lgd24_nocost
                                                             acct_lgd24_nocost_cap
                                                             npvrecoveries24
                                                             recoveries24
                        									 recovery24_1 - recovery24_24); /*10MAY2018 - keep recoveries for use in all_def_history_d_5_&pn.*/
                           set  intmed.all_def_history_d_3_&pn.;
                        
                        
                           /*------------------------------------------
                            * Loads values to recovery periods to be 
                            * used in LGD calculation
                            *-----------------------------------------*/
                           %do i = 1 %to 24; 
                        
                              %let j=%eval(&i.-1);
                        
                              if rec_start24 <=&i. and &i.<=rec_end24 then
                              do; 
                        
                                 /* Recovery is previous month's balance if CURRENT */
                                 if  upcase(_status_&i) EQ 'CUR' then recovery24_&i.= _total_bal_&j.;    
                        
                                 /* Recovery is different of previous months */
                                 else if (upcase(_status_&i) in ('DEF', '') and (_foreclose_ind_&i NE '' or _paid_off_ind_&i EQ 'N') and _total_bal_&i ne 0) then 
                                          recovery24_&i. = _total_bal_&j. - _total_bal_&i.; 
                        
                                 else if (_status_&i = '' and _total_bal_&i = 0 and _current_bal_&j ne 0 and _paid_off_ind_&j = "N") then 
                                          recovery24_&i.= _total_bal_&j.; 
                                                
                                 else recovery24_&i.=.; 
                                  
                              end;
                           %end;
                        
                          /*-------------------------------------------
                           * Calculates Net Present Value of recoveries
                           *-------------------------------------------*/
                           %do jj = 1 %to 24; 
                              if recovery24_&jj.^=. or  recovery24_&jj.^=0 then NPVrecovery24_&jj.=recovery24_&jj./(1.1**((&jj.)/12));
                           %end;
                        
                           /*-------------------------------------------
                            * Calculates LGD without costs
                            *-------------------------------------------*/
                           recoveries24 = sum(of recovery24_1 - recovery24_24);
                           npvrecoveries24 = sum(of npvrecovery24_1 - npvrecovery24_24);
                        
                           if upcase(acct_lgd24_filter) NE 'Y' then 
                           do;
                              if npvrecoveries24 = . then npvrecoveries24 = 0;
                        
                              acct_lgd24_nocost = (_total_bal_0 - npvrecoveries24)/_total_bal_0;
                              acct_lgd24_nocost_cap = acct_lgd24_nocost;
                        
                              if acct_lgd24_nocost < 0 then acct_lgd24_nocost_cap = 0; 
                              if acct_lgd24_nocost > 1.25 then acct_lgd24_nocost_cap = 1.25; 
                           end;
                        
                           if upcase(acct_lgd24_filter) EQ 'Y' then
                           do; 
                              if month_def24 = 24 then 
                              do; 
                                 acct_lgd24_nocost = 1; 
                                 acct_lgd24_nocost_cap = 1;
                              end;
                        
                               if _total_bal_0 <= 0.01 then 
                               do; 
                                 acct_lgd24_nocost = .; 
                                 acct_lgd24_nocost_cap=.;
                               end;
                           end;
                        run;
                        %mend recovery24_cal;
                        %recovery24_cal;
                        
                        /*----------------------------------------------------
                         * This table is created in order to join to direct 
                         * cost table to get full history (i.e., all months in
                         * a given time period). A value of missing is used for
                         * the direct cost for that missing period in history.
                         *----------------------------------------------------*/
                        
                        /* Dynamically defines range in current direct costs table */
                        proc sql noprint;
                           select max(datepart(a.reporting_date)) format date9.,  
                                  min(datepart(a.reporting_date)) format date9. into :max_rpt_dt, :min_rpt_dt
                           from source.lgd_direct_costs as a
                           where intnx('month', datepart(a.reporting_date), 0, 'e') GE intnx('month', "&_list_start_dt"d, 0, 'e'); 
                        quit;
                        
                        data work.full_dates_missing_dir_cost (drop = ii);
                           format report_dt date9.;
                           /*** FF 23FEB2015 Added +1 to the to statment below to capture last month of time period ***/
                           do ii = 1 to intck('month', "&min_rpt_dt"d, "&max_rpt_dt"d)+1;
                              report_dt = intnx('month', "&min_rpt_dt"d, ii - 1, 'e');
                              direct_costs = .;
                              output;
                           end;
                        run;
                        proc sql noprint;
                           create table work.distinct_dir_cost_accts as
                           select distinct a.mortgage_no
                           from source.lgd_direct_costs as a
                        
                           /* Only need to keep those mortages that are used in LGD-D calculation */
                           where a.mortgage_no in (select distinct b.mortgage_no from intmed.all_def_history_d_4_&pn. as b);
                        quit;
                        
                        proc sql noprint;
                           create table work.dir_cost_full_hist as
                           select a.mortgage_no,
                                  b.report_dt,
                                  b.direct_costs
                        
                                /* Intentional Cartesian join */
                           from work.distinct_dir_cost_accts as a,
                                work.full_dates_missing_dir_cost as b;
                        quit;
                        
                        
                        proc sql noprint;
                           create table work.lgdd_direct_costs1 as
                           select a.mortgage_no,
                                  intnx('month', datepart(a.reporting_date), 0, 'e') format = date9. as report_dt,
                                  sum(a.costs) as direct_costs
                           from source.lgd_direct_costs as a
                           group by a.mortgage_no, report_dt;
                        quit;
                        
                        proc sql noprint;
                           create table work.lgdd_costs as
                           select a.mortgage_no,
                                  a.report_dt,
                                  coalesce(b.direct_costs, a.direct_costs) as direct_costs,
                                  c.indirect_unit_costs as indirect_costs
                           from work.dir_cost_full_hist as a
                                left join
                                work.lgdd_direct_costs1 as b
                                on (a.mortgage_no = b.mortgage_no and 
                                    a.report_dt = b.report_dt)
                        
                                left join
                                source.lgd_indirect_cost as c
                                on a.report_dt = intnx('month', datepart(c.reporting_date), 0, 'e')
                           order by a.mortgage_no, a.report_dt;
                        quit;
                        
                        
                        %macro create_24_month_costs(_in_ds=, _out_ds=);
                        
                           /*----------------------------------------------------
                            * Defines the range of months that act as the start
                            * periods for an observation window
                            *----------------------------------------------------*/
                           data _null_;
                              num_months = intck('month', "&_list_start_dt"d, "&_list_end_dt"d) + 1;
                        
                              format month_dt date9.;
                        
                              do ii = 1 to num_months;
                                 call symput(cats('mth', put(ii,best32.)), cats(put(intnx('month', "&_list_start_dt"d, ii-1, 'e'), date9.)));
                              end;
                        
                              call symput('num_months', cats(put(num_months, best32.)));
                           run;
                        
                           data &_out_ds (rename = (mth_end_dt = report_dt) 
                                          drop = jj
                                                 direct_costs
                                                 indirect_costs
                                                 report_dt
                                                 %do zz = 1 %to &num_months;
                                                   mth_end_dt&zz
                                                   counter&zz
                                                 %end;
                                           );
                              set &_in_ds;
                        
                              length mth_end_dt 8;
                        
                              /*----------------------------------------
                               * Holds direct_costs for 24 month forward
                               * window from observation date
                               *----------------------------------------*/
                              array direct_cost_(0:24) direct_cost_0 - direct_cost_24;
                              array indirect_costs_(0:24) indirect_costs_0 - indirect_costs_24;
                        
                              /*-------------------------------------------
                               * For each quarter end period needs separate
                               * array to hold intermediate values
                               *-------------------------------------------*/
                              %do aa = 1 %to &num_months;
                                 array direct_cost&aa(0:24) _temporary_;
                                 array indirect_costs&aa(0:24) _temporary_;
                              %end;
                        
                              retain mortgage_no
                                     mth_end_dt
                                     direct_cost_0 -- direct_cost_24
                                     indirect_costs_0 -- indirect_costs_24
                        
                                     /* These vars have to be dynamically determined */
                                     %do ii = 1 %to &num_months;
                                        mth_end_dt&ii
                                        counter&ii
                                     %end;
                                     ;
                        
                              by mortgage_no;
                        
                              format mth_end_dt date9.;
                        
                              /* Reset counters for every mortgage number */
                              if first.mortgage_no = 1 then
                              do;
                                 %do jj = 1 %to &num_months;
                                    counter&jj = 0;
                                 %end;
                              end;
                        
                              /*------------------------------------------------------------
                               * For every month end period requested by a user...
                               *------------------------------------------------------------*/
                              %do mm = 1 %to &num_months;
                        
                                 /*------------------------------------------------------------
                                  * If a process date falls into the observation window...
                                  *------------------------------------------------------------*/
                                 if report_dt GE "&&mth&mm"d and report_dt LE intnx('month', "&&mth&mm"d, 24, 'e') then
                                 do;
                        
                        
                                    /* Used to determine which observation period is being created */
                                    if intnx('month', report_dt, 0, 'e') EQ "&&mth&mm"d then mth_end_dt&mm = report_dt;
                        
                                    direct_cost&mm(counter&mm) = direct_costs;
                                    indirect_costs&mm(counter&mm) = indirect_costs;
                        
                                    /*------------------------------------------------------------
                                     * If last period of observation window OR there are no more
                                     * periods in data for mortgage, then output results
                                     *------------------------------------------------------------*/
                                    if counter&mm = 24 or last.mortgage_no = 1 then 
                                    do;
                                       do jj = 0 to 24;
                                          direct_cost_(jj) = direct_cost&mm(jj);
                                          indirect_costs_(jj) = indirect_costs&mm(jj);
                                       end;
                        
                                       mth_end_dt = mth_end_dt&mm;
                                       output;
                                    end;
                        
                                    counter&mm + 1; 
                                 end;
                              %end;
                        
                           run;
                        
                        
                        %mend create_24_month_costs;
                        %create_24_month_costs(_in_ds = work.lgdd_costs, 
                                               _out_ds =  intmed.costs_24_month_window_&pn.)
                        
                          
                        
                        %macro lgdcalc;
                        
                           /*--------------------------------------------------------------
                            * Join costs to main historical table
                            * JD - 15Oct2015 - Changing inner join to left join.   Accounts 
                            *                  without costs being dropped
                            *--------------------------------------------------------------*/
                           proc sql noprint;
                              create table intmed.all_def_history_d_5_&pn. as
                              select a.*
                        /*		 , b.direct_cost_0 */
                        		 , 0 as direct_cost_0 /**** 31JUL2018 -- Hadi- added to zero out direct costs where reporting date  of the cost EQUALS the time_key;*/
                                     %do xx = 1 %to 24;
                                     , case when a.recovery24_&xx.<0 and a.recovery24_&xx. ne . then 0
                        				else b.direct_cost_&xx
                        				end 
                        				as direct_cost_&xx
                                     %end; 	 /**** 10MAY2018 -- Hadi- added to zero out direct costs;*/
                        			
                                     %do yy = 0 %to 24;
                                     , b.indirect_costs_&yy
                                     %end;
                              from intmed.all_def_history_d_4_&pn. as a 
                                   left join 
                                   intmed.costs_24_month_window_&pn. as b
                              on (a.mortgage_no = b.mortgage_no and
                                  intnx('month', datepart(a.process_date), 0, 'e')= b.report_dt);
                           quit;
                        
                        
                           /* 24Sep2015 - JD - Adding recoveries24 to keep= for CR#47 */
                           data &_output_tbl (keep = mortgage_no
                                                     time_key
                                                     month_def
                                                     insurance
                                                     bulk_ind
                                                     _total_bal_0
                                                     _foreclose_ind_0
                                                     total_suspense
                                                     acct_lgd24_nocost
                                                     acct_lgd24_nocost_cap
                                                     acct_lgd24_cost
                                                     acct_lgd24_cost_cap15
                                                     recoveries24
                                              rename = (_total_bal_0 = total_bal
                                                        _foreclose_ind_0 = foreclose_ind));
                        
                              retain mortgage_no time_key;
                        
                              set  intmed.all_def_history_d_5_&pn.;
                        
                              format time_key date9.;
                        
                              time_key = intnx('month', datepart(process_date), 0, 'e');
                        
                              %let rec_start24 = 0;
                              %let rec_end_MAX24 = 24;
                        
                              %do ii = &rec_start24. %to &rec_end_MAX24.; 
                        
                                 if &rec_start24. <= &ii. and &ii.<= rec_end24 then
                                 do;
                                    direct_cost24_&ii. = direct_cost_&ii.; 
                                    indirect_cost24_&ii. = indirect_costs_&ii.; 
                        
                                    if &ii. = rec_start24 or upcase(_status_&ii.) = 'CUR' then 
                                    do;
                                       indirect_cost24_&ii. = 0;
                                    end;
                                 end; 
                                 
                                 else 
                                 do; 
                                    direct_cost24_&ii. = .;
                                    indirect_cost24_&ii. = .;
                                 end; 
                        
                              %end;
                        
                              /*--------------------------------------------
                               * Calculate NPV of direct and indirect costs
                               *--------------------------------------------*/
                              NPVdirectcost24_0 = direct_cost24_0;
                        
                              %do jj = &rec_start24. %to &rec_end_MAX24.;  
                                 if (direct_cost24_&jj ^= . or  direct_cost24_&jj ^= 0)  then NPVdirectcost24_&jj = direct_cost24_&jj/(1.1**((&jj)/12)); 
                                 if ((indirect_cost24_&jj ^= . or  indirect_cost24_&jj ^= 0) and &jj ^= 0) then NPVindirectcost24_&jj=indirect_cost24_&jj/(1.1**((&jj)/12));
                              %end;
                        
                              /*--------------------------------------------
                               * Sums direct and indirect costs to be used
                               * in LGD cost calculation
                               *--------------------------------------------*/
                              npvdirectcost24 = sum(of npvdirectcost24_0 - npvdirectcost24_24);
                              npvindirectcost24 = sum(of npvindirectcost24_1 - npvindirectcost24_24); 
                        
                              /*--------------------------------------------
                               * Calculates LGD using NPV of recoveries, 
                               * direct, and indirect costs
                               *--------------------------------------------*/
                              if upcase(acct_lgd24_filter) ^= 'Y' then
                              do; 
                                 if npvdirectcost24 = . then npvdirectcost24 = 0; 
                                 if npvindirectcost24 = . then npvindirectcost24 = 0;
                                 if npvrecoveries24 = . then npvrecoveries24 = 0;
                        
                                 acct_lgd24_cost = (_total_bal_0 - npvrecoveries24 + npvdirectcost24 + npvindirectcost24)/_total_bal_0;
                                 acct_lgd24_cost_cap15 = acct_lgd24_cost;
                                 if acct_lgd24_cost < 0 then acct_lgd24_cost_cap15 = 0; 
                                 if acct_lgd24_cost > 1.25 then acct_lgd24_cost_cap15 = 1.25; 
                              end;
                        
                              /*--------------------------------------------
                               * All other accounts get capped at 1 LGD or
                               * a missing value
                               *--------------------------------------------*/
                              if upcase(acct_lgd24_filter) = 'Y' then 
                              do; 
                                 if month_def24 = 24 then 
                                 do; 
                                    acct_lgd24_cost = 1; 
                                    acct_lgd24_cost_cap15 = 1;
                                 end;
                                 if _total_bal_0 <= 0.01 then 
                                 do; 
                                    acct_lgd24_cost = .; 
                                    acct_lgd24_cost_cap15 = .;
                                 end;
                              end;
                        
                           run;
                        %mend lgdcalc;
                        %lgdcalc;
                        /*---- End of User Written Code  ----*/ 
                        
                        %etls_setClientSideStatus; 
            
         %mend etls_jobWGNZYPT; 
         
         %etls_jobWGNZYPT; 
         
      endrsubmit;
      
   %mend etls_processToLoopWGNZYPJ;
   
   %local etls_controlTable etls_statusTable etls_controlName 
      etls_processesRunning etls_maxProcesses etls_parameterTable 
      etls_additionalSignonOptions etls_signonRetries;
   %let etls_controlName = L82_; 
   %let etls_statusTable = work.WSJDM5; 
   %let etls_parameterTable = work.WGNZYUQ; 
   %let etls_gridOptionSet = ;
   %let etls_workload = ;
   %let etls_additionalSignonOptions = ;
   %let etls_signonRetries = 3;
   %let etls_gridSuppJobOptions = %nrstr();
   %let &etls_controlName = 0;
   %let etls_controlTable = work.Partitions_Table;
   
   %put %str(NOTE: Creating status table...);
   data &etls_statusTable 
      (keep = etls_handleName etls_machineId etls_startTime etls_endTime etls_status 
              etls_jobRC i PARTS PN
      );
      attrib etls_handleName length = $32
         label = 'Name of handle to remote session'; 
      attrib etls_machineId length = $32
         label = 'Name of machine executing the task'; 
      attrib etls_startTime length = 8
         format = nldatmap.
         label = 'Start time of task'; 
      attrib etls_endTime length = 8
         format = nldatmap.
         label = 'End time of task'; 
      attrib etls_status length = $32
         label = 'Current status of task'; 
      attrib etls_jobRC length = 8
         label = 'Return code of task'; 
      attrib i length = 8
         format = 5.
         informat = 5.; 
      attrib PARTS length = 8
         format = 5.
         informat = 5.; 
      attrib PN length = 8
         format = 5.
         informat = 5.; 
      set &etls_controlTable;
   run;
   
   %rcSet(&syserr); 
   
   %put %str(NOTE: Creating parameter table...);
   proc sql; 
      create table &etls_parameterTable as 
         select PN as pn, 
                PARTS as parts 
         from &etls_controlTable; 
   quit; 
   
   %rcSet(&sqlrc); 
   
   /* Get the number of times to iterate from the number of rows in the source  */ 
   /*  table                                                                    */ 
   proc sql noprint; 
      select count(*) into :&etls_controlName._max from &etls_statusTable;
      %let &etls_controlName._max = &&&etls_controlName._max;
   quit;
   
   %rcSet(&sqlrc); 
   
   /* Initialize checks for status handling per iteration  */ 
   %do i=1 %to &&&etls_controlName._max; 
      %local etls_statusReported&i; 
      %let etls_statusReported&i = 0; 
   %end; 
   
   %let etls_maxProcesses = &etls_controlName._max; 
   
   %if (&etls_maxProcesses > 0) %then 
   %do; 
      %do %until (&&&etls_controlName ge &&&etls_controlName._max); 
      
         %let etls_lastLoopPtr = &&&etls_controlName;
         
