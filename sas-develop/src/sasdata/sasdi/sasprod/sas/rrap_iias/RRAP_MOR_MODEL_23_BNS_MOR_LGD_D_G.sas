									/* July 2024: commented for step pit status change
                                    if upcase(comm_type) = "RESIDENTIAL" and paid_off_date = . and 
                                       (((delq_days < 90 and delq_months < 4) and upcase(foreclose_ind) ne "Y" and current_bal ne 0 and upcase(lra_status) ne "Y") or
                                       (current_bal < 0 ))
                                    then status = "CUR";
                        
                                    else if (upcase(comm_type) = "RESIDENTIAL" and paid_off_date = . and 
