                              run;
                        
                              /*-------------------------------------------------------
                               * Obtains BACKWARD history to be used in calculating LGD 
                               * for defaulted accounts.
                               *------------------------------------------------------*/
                              proc sql noprint;
                                 create table work.for_backward_history as
