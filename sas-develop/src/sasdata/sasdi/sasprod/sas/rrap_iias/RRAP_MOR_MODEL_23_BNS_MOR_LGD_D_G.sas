                              select intnx('month', a.month_dt, 0, 'e') format = best32. into :mth_end_dt_list separated by ','
                              from work.lgd_nd_obs_dates as a;
                           quit;
                        
                           /*-------------------------------------------------------
                            * Creates a table of mortgages at a given quarter end
                            * that meet DEFAULT criteria (where clause). These 
                            * will define the accounts that go through LGD process.
                            *------------------------------------------------------*/
                           proc sql noprint;
                              create table work.accts_in_default as
                              select a.mortgage_no,
                                     a.process_date
                              from &_input_tbl as a
                        
                                     /* The criteria used to determine default */
                               where /*((upcase(a.comm_type)="RESIDENTIAL" and a.paid_off_date =.  and current_bal > 0 and ((a.delq_days >= 90 or a.delq_months >= 4) OR
                                     upcase(a.foreclose_ind) = "Y"  OR upcase(a.lra_status) = "Y")) or 
                                     (upcase(a.comm_type)="RESIDENTIAL" and upcase(a.foreclose_ind) = "Y" and 
                                     upcase(a.paid_off_ind) = "Y" and (max(a.current_bal,-a.total_suspense) >0)))*/ STATUS='DEF' and
                        
                                     /* Used to subset only on quarter end dates */
                                     intnx('month', datepart(a.process_date), 0, 'e') in (&mth_end_dt_list);
                           quit;
                        
