                                        a.total_suspense,
                                        a.int_accr_amt
                                 from &_input_tbl as a,
                                      work.def_mort_accts as b
                        
                                       /* Subsets on mortgages that were in default */
                                 where a.mortgage_no = b.mortgage_no and
                        
