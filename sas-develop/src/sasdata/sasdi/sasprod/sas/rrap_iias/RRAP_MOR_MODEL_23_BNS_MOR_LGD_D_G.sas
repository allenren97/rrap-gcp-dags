      select count(*) into :etls_rows 
         from &statusTable where &statusVariable = &runningStatusSetting; 
      %let etls_rows = &etls_rows; 
      %if (&etls_rows gt 0) %then 
      %do; 
         select &handleVariable into :etlsHandles1 - :etlsHandles&etls_rows 
            from &statusTable where &statusVariable = &runningStatusSetting; 
      %end; 
   quit; 

   %rcSet(&sqlrc); 

   %if (&etls_rows gt 0) %then 
   %do; 
      waitfor &waitType 
         %do i=1 %to &etls_rows; 
            &&etlsHandles&i 
         %end; 
      ; 
   %end; 

