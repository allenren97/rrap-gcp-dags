proc import datafile="&rrap_dir./flat_files/rrap/statscan_unemp_rates.csv"
     out=output_csv
     dbms=csv
     replace;
     getnames=yes;
run;
data unemp(keep=time_key province urate) unemp_can(keep=time_key province urate); 
set output_csv;
format ref_date date9.;
/*ref_date=datepart(ref_date);*/
ref_date=intnx('Month',datepart(ref_date),0,'e');
	if GEOGRAPHY='Alberta' then PROVINCE='AB';
else if GEOGRAPHY='British Columbia' then PROVINCE='BC';
else if GEOGRAPHY='Manitoba' then PROVINCE='MB';
else if GEOGRAPHY='New Brunswick' then PROVINCE='NB';
else if GEOGRAPHY='Newfoundland and Labrador' then PROVINCE='NF';
else if GEOGRAPHY='Nova Scotia' then PROVINCE='NS';
else if GEOGRAPHY='Ontario' then PROVINCE='ON';
else if GEOGRAPHY='Prince Edward Island' then PROVINCE='PE';
else if GEOGRAPHY='Quebec' then PROVINCE='QC';
else if GEOGRAPHY='Saskatchewan' then PROVINCE='SK';

value=value/100;
	rename value = urate ref_date=time_key;

if GEOGRAPHY='Canada' then do;
	output unemp_can;

end;
	else do;
	output unemp;
	end;
run;

proc sort data=unemp_can(rename=(urate=can_urate) drop=province) nodupkey; by time_key; run;
proc sort data=unemp nodupkey; by time_key province; run;

data unemployment_rate;
	merge unemp_can unemp;
	by time_key;
	ratio=(urate - can_urate)/can_urate;
run;

proc sql;
create table test as
select distinct province, time_key
from unemployment_rate
order by 1,2;
quit;

proc sort data=unemployment_rate out=dist(keep=province time_key) nodupkey;
	by province time_key;
run;

data _null_;
	set dist;
	call symputx('prov'||trim(left(_n_)),province);
	call symputx('time_key'||trim(left(_n_)),time_key);
	call symputx('sas_date'||trim(left(_n_)),put(time_key,date9.));
	call symputx('nobs',_n_);
run;



