                                  a.unpd_wkl_pay_date,
                                  a.status,
                                  a.int_accr_amt,
                                  a.insurance,
                                  a.bulk_ind,
                                  a.default_ind,
                                  a.default_bal as orig_default_bal,
                        
                                  /* Resets default_date to end of month */
                                  (case
                                    when a.default_date not in (0,.) then intnx('month', default_date, 0, 'e')
                                    else .
                                    end) format date9. as default_date,
                                  b.tm_id,
                                  b.time_key 
                           from source.base_lgd_nd_&pn. as a
                                inner join
                                work.calendar as b
                        
                                /* Need to shift process date - not always end of month day */
                                on intnx('month', datepart(a.process_date), 0, 'e') = b.time_key;
                        quit;
                        
                        /*--------------------------------------------------
                         * 5. Recalculates default balance by including accrued
                         * interest with current balance
                         *--------------------------------------------------*/
                        proc sql noprint;
                           create table work.lgd_data2 as
                           select a.*,
                                  b.current_bal as def_bal,
                                  b.int_accr_amt as def_int,
                        
                                  /* Recalculats default balance */
                                  (case 
                                    when a.default_ind = 1 then b.current_bal + b.int_accr_amt
                                    else . 
                                   end) as default_bal,
                        
                                   /* Calculates total balance */
                                  (case 
                        
                                    /* When status is CURENT */
                                    when upcase(a.status) = 'CUR' then (a.current_bal + a.int_accr_amt) 
                        
                                    /* Had two lines of code - both with same calc - diff total_suspense */
                                    when (upcase(a.status) ne 'CUR' /*and a.total_suspense <= 0*/) then max((a.current_bal + a.int_accr_amt), -a.total_suspense) 
                                   end) as total_bal
                           from work.lgd_data1 as a
                                left join   
                                 work.lgd_data1 as b 
                              on (a.mortgage_no = b.mortgage_no and 
                                  a.default_date = b.time_key)
                           order by a.mortgage_no, a.time_key;
                        quit;
                        
                        /*--------------------------------------------------
                         * 6. Retrieve DIRECT costs from SQL table based on 
                         * mortgage_no. Do EXPLICIT pass_through.
                         *--------------------------------------------------*/
                        proc sql noprint;
                           create table work.lgd_dir_costs as 
                           select a.mortgage_no,
                                  a.reporting_date,
                                  sum(a.costs) as costs
                           from source.lgd_direct_costs as a
                           where a.mortgage_no in (select b.mortgage_no from work.distinct_mort_no as b)
                           group by a.mortgage_no, a.reporting_date;
                        quit;
                        
                        
                        /*--------------------------------------------------
                         * 7. Joins DIRECT and INDIRECT costs to base LGD table
                         * and sorts by mortgage_no & time_key. 
                         *--------------------------------------------------*/
                        proc sql noprint;
                           create table work.lgd_data3 as 
                           select a.*,
                                  datepart(b.reporting_date) as dc_report_date format=date9.,
                                  b.costs as dir_cost,
                                  c.indirect_unit_costs as ind_cost
                           from work.lgd_data2 as a
                                left join 
                        
                                /*-----------------------------------------------
                                 * Append DIRECT costs - need to modify reporting 
                                 * date because not necessarily last day of month
                                 *-----------------------------------------------*/
                                work.lgd_dir_costs as b 
                                on (a.mortgage_no = b.mortgage_no and 
                                    a.time_key = intnx('month', datepart(b.reporting_date), 0, 'e'))
                        
                                /*-------------------------------------------------
                                 * Append INDIRECT costs - need to modify reporting 
                                 * date because not necessarily last day of month
                                 *-------------------------------------------------*/
                                left join source.lgd_indirect_cost as c
                                on a.time_key = intnx('month', datepart(c.reporting_date), 0, 'e')
                           order by a.mortgage_no, a.tm_id;
                        quit;
                        
                        
                        /*--------------------------------------------------
                         * 8. Calculate RECOVERIES and COSTS
                         * 
                         * Updates
                         * JD - 23Sep2015 - CR #47 - Adding new array cum_rec_nonpv_ 
                         *                  for a non-NPV cummlative recoveries
                         *--------------------------------------------------*/
                        data work.recoveries_and_costs_lgd_nd_&pn. (drop = rec
                                                               npv_rec
                                                               tot_cost
                                                               npv_cost_dir
                                                               npv_cost_ind
                                                               npv_cost
                                                               cum_rec
                                                               cum_cost
                                                               cum_npv_cost
                                                               cum_npv_rec
                                                               lra_status
                                                               insurance
                                                               bulk_ind
                                                               comm_type
                                                               current_bal
                                                               delq_days
                                                               delq_months
                                                               float_ind
                                                               foreclose_ind
                                                               paid_off_date
                                                               paid_off_ind
                                                               process_date
                                                               total_suspense
                                                               unpd_mth_pay_date
                                                               unpd_wkl_pay_date
                                                               status
                                                               int_accr_amt
                                                               orig_default_bal
                                                               tm_id
                                                               time_key
                                                               def_bal
                                                               def_int
                                                               default_bal
                                                               default_ind
                                                               default_date
                                                               total_bal
                                                               dc_report_date
                                                               dir_cost
                                                               ind_cost
                                                               month_rec
                                                               ii);
                        
                           set work.lgd_data3;
                        
                           by mortgage_no;
                        
                           array cum_rec_(&total_months_in_history);
                           array cum_cost_(&total_months_in_history);
                           array month_rec_(&total_months_in_history);
                           array cum_rec_nonpv_(&total_months_in_history);
                        
                           retain mortgage_no
                                  month_rec
                                  cum_rec_1 -- cum_rec_&total_months_in_history
                                  cum_cost_1 -- cum_cost_&total_months_in_history
                                  month_rec_1 -- month_rec_&total_months_in_history
                                  cum_rec_nonpv_1 -- cum_rec_nonpv_&total_months_in_history;
                        
                           rec = .;
                        
                           /* Defines LAG_BALANCE */
                           lag_bal=lag(total_bal);
                        
                           /* Defines LAG_STATUS */
                           lag_status=lag(status);
                        
                           if first.mortgage_no then 
                           do; 
                              lag_status=.;
                              lag_bal=.; 
                        
                              do ii = 1 to &total_months_in_history;
                                 cum_rec_(ii) = .;
                                 cum_cost_(ii) = .;
                                 month_rec_(ii) = .; 
                                 cum_rec_nonpv_(ii) = .;
                              end;
                        
                           end; 
                        
                           *Calculate month in recovery;
                           if upcase(status) eq ('DEF') and upcase(lag_status) eq 'CUR' then month_rec = 1;
                           else if upcase(status) eq ('DEF') then month_rec + 1;
                           else if upcase(status) eq ('CUR') and upcase(lag_status) eq ('DEF') then  month_rec+1;
                           else if upcase(status) eq '' and upcase(lag_status) eq ('DEF') and upcase(paid_off_ind) eq 'Y' then month_rec+1;
                           else if upcase(status) eq '' and upcase(lag_status) eq '' and upcase(paid_off_ind) eq 'Y' then month_rec+1;
                           else month_rec=.;
                                 
                           *Calculate Recoveries;
                           if upcase(status) in ('DEF') and upcase(lag_status) ne 'CUR' then rec = -1*(total_bal-lag_bal);
                           else if upcase(status)='CUR' and upcase(lag_status) in ('DEF') then rec = (lag_bal);
                           else if upcase(status)='' and upcase(lag_status) in ('DEF') and upcase(paid_off_ind) eq 'Y' and total_bal ge 0 and lag_bal ne 0 then rec = lag_bal-total_bal;
                           else if upcase(status)='' and upcase(lag_status) in ('DEF') and upcase(paid_off_ind) eq 'Y' and total_bal<0 and lag_bal ne 0 then rec=lag_bal-total_bal;
                           else if upcase(status)='' and upcase(lag_status) = '' and upcase(paid_off_ind) eq 'Y' and upcase(foreclose_ind) eq 'Y' and total_bal GT 0 and lag_bal GE 0 then rec = lag_bal-total_bal;
                           else if upcase(status)='' and upcase(lag_status) = '' and upcase(paid_off_ind) eq 'Y' and upcase(foreclose_ind) eq 'Y' and total_bal EQ 0 and lag_bal GT 0 then rec = 0;
                        
                           /*10MAY2018 - HADI -- Adding new logic to zero out direct costs*/
                           if rec<0 and rec ne . then dir_cost=0;
                        
                           *NPV recovery;
                           if month_rec ne . then
                           do;
                              npv_rec=rec/((1.1)**((month_rec-1)/12));
                           end;
                        
                           /*-------------------------------------------------
                            * Calculate NPV
                            *-------------------------------------------------*/
                           if month_rec ne . then
                           do;
                              if month_rec=1 or upcase(status) ne 'DEF' then
                              do;
                                 ind_cost=0;
                           /*      dir_cost=0;*/
                              end;
                        
                              /* Changed: 13JAN2015 per model team request */
                              if dir_cost = . then dir_cost = 0;
                        
                              tot_cost=dir_cost+Ind_Cost;
                        
                              npv_cost_dir=dir_cost/((1.1)**((month_rec-1)/12));
                              npv_cost_ind=ind_cost/((1.1)**((month_rec-1)/12));
                              npv_cost=tot_cost/((1.1)**((month_rec-1)/12));
                        
                           end;
                        
                           *Cummulative Recoveries and costs;
                           cum_rec+rec;
                           cum_cost+tot_cost;
                        
                           cum_npv_cost+npv_cost;
                           cum_npv_rec+npv_rec;
                        
                           if month_rec eq . or month_rec eq 1 then cum_rec=.;
                           if month_rec eq . or month_rec eq 1 then cum_npv_rec=.; 
                        
                           if (month_rec eq . ) then cum_cost=0;
                           if (month_rec eq . ) then cum_npv_cost=0; 
                        
                           drop lag_:;
                        
                           cum_rec_(tm_id) = cum_npv_rec;
                           cum_cost_(tm_id) = cum_npv_cost;
                           month_rec_(tm_id) = month_rec;
                        
                           /* JD - 23Sep2015 - CR #47 - Adding new array for a non-NPV cummlative recoveries */
                           cum_rec_nonpv_(tm_id) = cum_rec;
                        
                           /*-------------------------------------------------
                            * Output history of cumulative costs etc... per
                            * mortgage - used for *all* quarter end dates
                            *-------------------------------------------------*/
                           if last.mortgage_no then
                           do;
                              output;
                           end;
                        
                        run;
                        
                        
                        proc sql noprint;
                           create table work.lgd_data_mod_def_dt as
                           select a.mortgage_no,
                                  a.insurance,
                                  a.bulk_ind,
                                  a.total_bal,
                                  a.default_bal,
                                  a.default_ind,
                                  a.default_date,
                                  a.time_key,
                                  a.process_date,
                                  a.tm_id,
                        			 a.status,
                                  b.tm_id as default_date_id
                           from work.lgd_data3 as a
                                left join 
                                (select distinct c.time_key, c.tm_id from work.lgd_data3 as c) as b 
                                on a.default_date=b.time_key
                           order by a.mortgage_no, a.time_key;
                        quit;
                        
                        /*----------------------------------------------------
                         * 9. Defines the range of months given parameters 
                         * input by user
                         *----------------------------------------------------*/
                        data work.lgdd_date_range (keep=lgdd_dates);
                           format start_dt end_dt lgdd_dates date9.;
                           start_dt = "&_start_data_range"d;
                        /*   end_dt = intnx('month', "&_end_data_range"d, -&_lgd_window, 'e');*/
                        /*Modified the above statement as part of ANTQ May 2017 requirement to have all months instead of just 3*/
                           end_dt = "&_end_data_range"d;   
                           num_months = intck('month', start_dt, end_dt) + 1;
                           do ii = 1 to num_months;
                              lgdd_dates = intnx('month', start_dt, ii-1, 'e');
                              output;
                           end;
                        
                        run;
                        
                        proc sql noprint;
                           select cats("'", put(intnx('month',a.lgdd_dates, 0, 'e'), date9.), "'d") into :qtr_list separated by ',' 
                           from work.lgdd_date_range as a
                           order by a.lgdd_dates;
                        quit;
                        
                        /*----------------------------------------------------
                         * 10. Defines the range of months given parameters 
                         * input by user
                         *----------------------------------------------------*/
                        
                        proc sql noprint;
                           create table work.prep_for_lgd_nd_&pn. (drop = mortgage_no1) as
                           select a.mortgage_no as mortgage_no1,
                                  a.insurance,
                                  a.bulk_ind,
                                  a.total_bal,
                                  a.time_key,
                                  a.default_bal,
                                  a.default_ind,
                                  a.default_date,
                                  a.process_date,
                                  a.tm_id,
                        			 a.status,
                                  a.default_date_id,
                                  b.*
                           from work.lgd_data_mod_def_dt as a
                                inner join
                                work.recoveries_and_costs_lgd_nd_&pn. as b
                                on a.mortgage_no = b.mortgage_no
                           where a.time_key in (&qtr_list)
                           order by b.mortgage_no, a.time_key;
                        quit;
                        
                        
                        /* JD - 23Sep2015 - CR #47: Adding field cum_rec_nonpv_, creating field */
                        /*                          cum_rec24d and adding it to keep= option */
                        data work.lgd_calcs (keep = mortgage_no
                                                    insurance
                                                    bulk_ind
                                                    total_bal
                                                    time_key
                        									 status
                                                    default_date
                                                    default_date_id
                                                    default_bal
                                                    default_ind   
                                                    lgd24d
                                                    lgdc24d
                                                    npv_cum_cost24d
                                                    npv_cum_rec24d
                                                    cum_rec24d);
                        
                           set work.prep_for_lgd_nd_&pn.;
                        
                           array cum_rec_(&total_months_in_history);
                           array cum_cost_(&total_months_in_history);
                           array month_rec_(&total_months_in_history);
                           array cum_rec_nonpv_(&total_months_in_history);
                        
                           /*-------------------------------------------------------------
                            * Calculate LGD 24 month from default point
                            *-------------------------------------------------------------*/
                           do i = tm_id to &total_months_in_history;    
                              if i >= (default_date_id) and i <= (default_date_id + 25) then
                              do;
                        
                                 if (i > (default_date_id) and (month_rec_(i) eq . or month_rec_(i) > 25)) or 
                                    (i > (default_date_id) and i >= 2 and (month_rec_(i)< month_rec_(i-1) )) then goto out24;
                                 else 
                                 do;
                                    if cum_rec_(i) ne . then 
                                    do;
                                       lgd24d = (default_bal - cum_rec_(i))/default_bal;
                                       lgdc24d = (default_bal - cum_rec_(i) + cum_cost_(i))/default_bal;
                                    end;
                                    else 
                                    do;
                                       lgd24d = (default_bal)/default_bal;
                                       lgdc24d = (default_bal + cum_cost_(i))/default_bal;
                                    end;
                        
                                    npv_cum_cost24d = cum_cost_(i);
                                    npv_cum_rec24d = cum_rec_(i);
                        
                                    /* JD - 23Sep2015 - Saving a non-discounted recovery value for CR #47 */
                        			   cum_rec24d=cum_rec_nonpv_(i);
                                 end;
                              end;                
                           end;
                           out24:;
                        
                        run;
                        
                        /*-------------------------------------------------------------
                         * This table will be used to calculate the LGD by segment
                         *-------------------------------------------------------------*/
                        data &_output_bns_lgd_nd_tbl; 
                        /*   set work.lgd_calcs(where = (default_ind = 1));*/
                           set work.lgd_calcs;
                        /*Removed default ind filter as per ANTQ May 2017 requirement*/
                           lgdc_cap_100 = lgdc24d;
                        
                           if lgdc_cap_100 < 0 then lgdc_cap_100 = 0;
                           else if lgdc_cap_100 > 1 then lgdc_cap_100 = 1;
                        
                           lgdc_cap_150 = lgdc24d;
                        
                           if lgdc_cap_150 < 0 then lgdc_cap_150 = 0;
                           else if lgdc_cap_150 > 1.25 then lgdc_cap_150 = 1.25;
                        run;
                        
                        
                        /* Define end processing time */
                        data _null_;
                           call symput('end_time', datetime());
                        run;
                        
                        /* Calculate processing time */
                        data work.timer_bns_lgd_nd;
                           format start_time end_time datetime21. seconds comma21.4 minutes hours comma21.2; 
                           start_time = &start_time;
                           end_time = &end_time;
                           seconds = &end_time - &start_time;
                           minutes = seconds/60;
                           hours = minutes/60;
                        run;
                        
                        
                        /*---- End of User Written Code  ----*/ 
                        
                        %etls_setClientSideStatus; 
            
         %mend etls_jobWWWPYFG; 
         
         %etls_jobWWWPYFG; 
         
      endrsubmit;
      
   %mend etls_processToLoopWWWPYF6;
   
   %local etls_controlTable etls_statusTable etls_controlName 
      etls_processesRunning etls_maxProcesses etls_parameterTable 
      etls_additionalSignonOptions etls_signonRetries;
