PROC SQL;
	connect using nzuser as nzcon;
	CREATE TABLE BNSMORT_ACCT_LVL_DATA   AS SELECT * From connection to nzcon	(

		select	
			cast(t1.Mort_num as char(25)) as MORTGAGE_NO,
			t1.tm_id as MTH_TM_ID,
			t1.mth_end_dt as PROCESS_DATE,
			t1.CRNT_BAL as CRNT_BAL_AMT,
			t1.INEREST_ACCR_AMT as INTR_ACCR_AMT,
			case 
				when t3.STATUS1='CUR' then (t1.CRNT_BAL+t1.INEREST_ACCR_AMT) 
				when ((t3.STATUS1 <> 'CUR' or t3.STATUS1 is null) and nvl(t1.TOT_SUSP_BAL,0)<=0) then max((t1.CRNT_BAL + t1.INEREST_ACCR_AMT),-1*nvl(t1.TOT_SUSP_BAL,0)) 
				when ((t3.STATUS1 <> 'CUR' or t3.STATUS1 is null) and nvl(t1.TOT_SUSP_BAL,0)>0) then max((t1.CRNT_BAL +t1.INEREST_ACCR_AMT),-1*nvl(t1.TOT_SUSP_BAL,0)) 
			end 		as TOTAL_BAL,
			t1.PD_OFF_F,
			t1.PD_OFF_DT,
			t1.FRCLSR_F,
			t1.TOT_SUSP_BAL as TOT_SUSP_BAL_AMT,
			t3.STATUS1,	
			last_day(t3.default_date) as DEFAULT_DATE,
			case 
				when t3.DEFAULT_IND=1 then (t11.CRNT_BAL+t11.INEREST_ACCR_AMT) 
				else null 
			end  as default_bal,
			t3.DEFAULT_IND,
			t3.LTV,
			t3.AMORT,
			t3.NODE as PD_SEG
			
		from &target_lib3..airb_mort_mth_snapshot t1
				
		left join &target_lib3..SCORED_SEGMENTED_ACCTS_ANTQ t3
				on t1.mort_num=t3.mortgage_no 	and t1.mth_end_dt=t3.PROCESS_DATE

		left join &target_lib3..airb_mort_mth_snapshot t11
				on t11.mort_num=t1.mort_num and t11.mth_end_dt = last_day(t3.default_date)
				
					
		where t1.tm_id >= &mth_tm_id. -40 and t1.tm_id <= &mth_tm_id.
		order by t1.mort_num, t1.tm_id);
quit;	

proc sql;
	create table work.MORT_TOTAL_BAL_WITH_LAG as
		select 
					t1.MORTGAGE_NO,
					t1.MTH_TM_ID,
					t1.STATUS1,
					t1.PD_OFF_F,
					t1.FRCLSR_F,
					t1.CRNT_BAL_AMT,
					t1.INTR_ACCR_AMT,
					t1.TOT_SUSP_BAL_AMT,
					t1.TOTAL_BAL,
					t1.PROCESS_DATE,
			t2.TOTAL_BAL as PREV_TOTAL_BAL,
			t2.STATUS1 as PREV_STATUS,
			t2.PD_OFF_F as PREV_PD_OFF_F
		from work.BNSMORT_ACCT_LVL_DATA t1
			left join work.BNSMORT_ACCT_LVL_DATA t2
				on t1.MORTGAGE_NO=t2.MORTGAGE_NO
				and (t1.MTH_TM_ID-40)=t2.MTH_TM_ID
		where t1.MTH_TM_ID = &mth_tm_id.
order by t1.MORTGAGE_NO;
quit;

