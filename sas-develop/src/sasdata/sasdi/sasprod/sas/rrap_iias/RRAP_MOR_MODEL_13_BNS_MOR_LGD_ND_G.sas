                        %rcSet(&sqlrc); 
                        
                        %rcSet(&syscc); 
                                    
                                    
                                    
                                    /**  Step end AM_rrap_mor_bns_autoexec **/
                                    
                                    /*---- Start of User Written Code  ----*/ 
                        
                        /*---------------------------------------------------------------------
                         * NAME:       03_BNS_MOR_LGD_ND.sas
                         *
                         * PURPOSE:    Determines LGD-ND for BNS mortgages.
                         *             
                         * NOTES: 
                         *             
                         * MODIFIED:
                         *    21DEC2014 - JL - Created
                         *    13JAN2015 - JL - Updated logic for NPV calc
                         *    15JAN2015 - JL - Updated for monthly processing
                         *
                         * Copyright (c) 2014 by The Financial Risk Group, Cary, NC, USA.
                         *---------------------------------------------------------------------*/
                        
                        
                        /* Assumption for this section:
                           - results.twelve_mon_def_window has been created by PD process
                           - lgd_direct_costs & lgd_indirect_cost are not in NZ
                           - Separate table has been created that contains the scorecard variables
                           - The table with scorecard variables includes: mortgage_no and process_date (as datetime)
                        */

						x /sashome/SASFoundation/9.4/utilities/bin/cleanwork /saswork;
						
                        %let _default_status_tbl = results.twelve_mon_def_window_&pn.;
                        %let _src_tbl = results.status_final_&pn.;
                        %let _output_bns_lgd_nd_tbl = results.all_lgd_nd_&pn.; 
                        %let output_rcvry_table=MOR_MTH_ACCT_RCVRY_BNS_LGDND;
                        
                         /* EXTRACT RUN DATE FROM CONTROL TABLE */
                        
                        %get_model_period_dates(product=mor);
                        
                        data _null_;
                        	x=put(intnx('month',"&end_period_dt."d,-38,'e'),date9.);
                        	call symputx('start_period_dt',x);
                        run;
                        %put Start and End Dates for Mortgage Models:;
                        %put start_period_dt: &start_period_dt ;
                        %put end_period_dt: &end_period_dt;
                        
                        %let _start_data_range = &start_period_dt.;
                        %let _end_data_range = &end_period_dt.;
                        /*%let _start_data_range = 30JUN2012;*/
                        /*%let _end_data_range = 31JUL2015;*/
                        %let _lgd_window = 36;
                        
                        /* Define start processing time */
                        data _null_;
                           call symput('start_time', datetime());
                        run;
                        
                        /*-----------------------------------------------
                         * 1. Creates a table of months with order number 
                         * associated to date. Note: defined by user when 
                         * setting start and end date range macros.
                         *-----------------------------------------------*/
                        data work.calendar (drop =  month_count);
                           format process_date datetime21. time_key date9.;
                        
                           month_count = intck('month', "&_start_data_range"d, "&_end_data_range"d) + 1;
                        
                           /* Define macro var to be used in arrays */
                           call symput ('total_months_in_history', cats(put(month_count, best32.)));
                        
                           do tm_id = 1 to month_count; /*prefer month_id - change after tested */
                              process_date = intnx('month', "&_start_data_range"d, tm_id - 1, 'e')*86400;
                              time_key = intnx('month', "&_start_data_range"d, tm_id - 1, 'e');
                              output;
                           end;
                        
                        run;
                        
                        /*-----------------------------------------------
                         * 2. Selects only those mortgages that were on the
                         * books 36 months ago. LGD calculation needs 36 
                         * month window.
                         *-----------------------------------------------*/
                        
                        /* Make more efficient - index on source table for mortgage no? */
                        proc sql noprint;
                           create table work.distinct_mort_no as
                           select distinct a.mortgage_no
                           from &_src_tbl as a
                        /*   where intnx('month', datepart(a.process_date), 0, 'e') <= intnx('month', "&_end_data_range"d, -&_lgd_window, 'e');*/
                        ;
                        quit;
                        
                        /*-----------------------------------------------
                         * THIS COULD BE MADE MORE EFFICIENT IF:
                         *    -  Default indicator appended to NZ table 
                         *       after they are created
                         *    -  The table is pulled from NZ 
                         *
                         * 3. For now this code is used to append DEFAULT
                         * vars to account
                         *-----------------------------------------------*/
					x /sashome/SASFoundation/9.4/utilities/bin/cleanwork /saswork;
					options compress=YES;

                        proc sql noprint;
                           create table source.base_lgd_nd_&pn. as
                           select a.*,
                                  b.default_ind,
                                  b.default_bal,
                                  b.default_date
                        
                           from &_src_tbl as a
                                left join 
                                &_default_status_tbl as b
                                on (a.mortgage_no = b.mortgage_no and
                                    intnx('month', datepart(a.process_date), 0, 'e')  = intnx('month', b.process_date, 0, 'e'))
                        		inner join work.distinct_mort_no as c
                                on a.mortgage_no = c.mortgage_no;
                        quit;
                        
                        proc sql;
                        create index process_date on source.base_lgd_nd_&pn.;
                        create index mortgage_no on source.base_lgd_nd_&pn.;
                        quit;
                        
						x /sashome/SASFoundation/9.4/utilities/bin/cleanwork /saswork;
						
                        /*------------------------------------------------
                         * 4. Appends time variables needed for LGD process.
                         * Perhaps done in NZ?
                         *------------------------------------------------*/
                        proc sql noprint;
                           create table work.lgd_data1 as
                           select a.lra_status,
                                  a.comm_type,
                                  a.current_bal,
                                  a.delq_days,
                                  a.delq_months,
                                  a.float_ind,
                                  a.foreclose_ind,
                                  a.mortgage_no,
                                  a.paid_off_date,
                                  a.paid_off_ind,
                                  a.process_date,
                                  a.total_suspense,
