%macro etls_signon(handleName=etlsRemote,
                   cmacvar=etls_signonStatus,
                   gridRC=rc,
                   useGrid=1,
                   machineIdMacroVariable=etls_machineId,
                   gridOptionSet=,
                   workloadMacroVariable=,
                   log=,
                   output=,
                   additionalSignonOptions=,
                   signonRetries=3,
                   gridJobName=&&etls_jobName&row);

   %let etls_gridInstalled =;
   %etls_tsLevel(macroName=etls_gridInstalled, featureName=uwugrdsv); 

   %if (&useGrid = 1) %then 
   %do; 

      %if ("&etls_gridInstalled" ne "") %then 
      %do; 
         %if (&gridRC eq ) %then 
            %let gridRC = &handleName.RC ; 

         %global &gridRC;
         %let workload = ; 
         %if (&workloadMacroVariable ne %str()) %then 
         %do; 
            data _null_;
               call symput('workload','; workload = '||symget("&workloadMacroVariable"));
            run;
         %end; 
         %let gridoptset = ;
         %if (&gridOptionSet ne %str()) %then 
         %do; 
            data _null_;
               call symput('gridoptset',"; gridoptset = &gridOptionSet");
            run;
         %end; 
         %let gridJobOpts = ;
         %let gridSuppOpts = ;
         %if (&etls_gridSuppJobOptions ne %str()) %then 
         %do; 
            data _null_;
               call symput('gridJobOpts', "&etls_gridSuppJobOptions");
            run;
            data _null_;
               call symput('gridSuppOpts', '; JOBOPTS=gridJobOpts');
            run;
         %end; 
            data _null_;
               call symput('gridJbName', "; jobname = gridJobName");
            run;
         %let &gridRC = %sysfunc(grdsvc_enable("&handleName", server = SASApp &gridoptset &workload &gridSuppOpts &gridJbName));
      %end; 
      %else 
         %put %str(NOTE: Grid service functions are not installed.);
   %end; 

   %local sleeptime sleepIncreaseAmount tryCount; 
   %let sleepIncreaseAmount=5; 
   %let sleeptime=5; 
   %let tryCount=1; 
   %let &cmacvar=1; 

   /* Store original return code values to reset them if a signon succeeds  */ 
   %local etls_sysrc etls_syscc;
   %let etls_sysrc = &sysrc;
   %let etls_syscc = &syscc;

   %do %until((&&&cmacvar ne 1) or (&tryCount gt %eval(&signonRetries+1))); 
      data _null_; 
      signon &handleName cmacvar=&cmacvar 
         %if ("&log" ne "") %then 
            log=&log; 
         %if ("&output" ne "") %then 
            output=&output; 
         %if ("&additionalSignonOptions" ne "") %then 
            &additionalSignonOptions; 
      ;run; 

      %if "&&&cmacvar" eq "1" %then 
      %do; 
         %if &tryCount lt %eval(&signonRetries+1) %then 
         %do; 
            %put NOTE: Signon attempt #&tryCount failed. Retrying in &sleeptime seconds.;
            %let rc=%sysfunc(sleep(&sleeptime,1)); 
         %end; 
         %else %if &signonRetries gt 0 %then 
            %put ERROR%QUOTE(:) Final signon attempt, #&tryCount, failed.;

         %let sleeptime=%sysevalf(&sleeptime+&sleepIncreaseAmount,int); /* increase sleeptime by factor */ 
         %let tryCount=%eval(&tryCount+1); 
      %end; 
      %else
      %do;
         /* Signon succeeded make sure return codes are reset to original values  */ 
         %let sysrc = &etls_sysrc;
         %let syscc = &etls_syscc;
      %end;
   %end; 
   %rcSet(&syserr); 

   /* On successful signon, fetch and report machine name if grid was requested. */ 
   %if ("&machineIdMacroVariable" ne "") %then %let &machineIdMacroVariable = ; 
   %if ("&&&cmacvar" ne "1" and "&machineIdMacroVariable" ne "" and 
        &useGrid = 1 and "&etls_gridInstalled" ne "") %then 
   %do; 
      %put; 
      %if ("&&&gridRC" eq "0") %then 
      %do; 
         %let &machineIdmacroVariable = %sysfunc(grdsvc_getname(&handleName)); 
         %put %str(NOTE: Signed on to grid machine &&&machineIdmacroVariable..);
      %end; 
      %else 
         %put %str(NOTE: GRID SERVICES WERE NOT ENABLED.  Signed on to LOCAL machine.);
      %put; 
   %end; 

%mend etls_signon; 

%macro etls_serverConnected(serverId=,macvarname=isConnected); 
   %let &macvarname=0; 
   %local search_str none_str savenotes; 

   /* setup information for listtask output */ 
   /* listtask output on OS/390 differs */ 
   %if %bquote(&sysscp) eq OS %then 
   %do; 
      %let search_str=Remote submit for; 
      %let token=5; 
   %end; 
   %else  
   %do; 
      %let search_str=--------------; 
      %let token=1; 
   %end; 

   /* Issue listtask within PROC PRINTTO - send output to file */ 
   filename __tmptxt TEMP; 
   %let savenotes=%sysfunc(getoption(notes)); 
   options nonotes; 

   proc printto log=__tmptxt new; 
   run; 

   options notes; 
   listtask; 
   proc printto; 
   run; 

   options nonotes; 

   /* read in the output from listtask */ 
   %let dsname=_null_; 
   data _null_(keep=Session); 
      length line $256 sessionId $60; 
      infile __tmptxt length=len; 
      input @1 line $varying. len; 

      if line=:'There are no' then 
         stop; 
      /* look for the search string and scan for server name */ 
      if index(line,"&search_str") then  
      do; 
         sessionId=scan(line,&token," "); 
         sessionId=upcase(trim(left(tranwrd(sessionId,'"',' ')))); 
         if sessionId=upcase(symget("serverId")) then 
         do;  
            call symput("&macvarname","1"); 
            stop; 
         end; 
      end; 
   run; 
   filename __tmptxt clear; 
   options &savenotes; 
%mend etls_serverConnected; 

