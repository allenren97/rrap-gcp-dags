   %end; 
   
   %let etls_maxProcesses = &etls_controlName._max; 
   
   %if (&etls_maxProcesses > 0) %then 
   %do; 
      %do %until (&&&etls_controlName ge &&&etls_controlName._max); 
      
         %let etls_lastLoopPtr = &&&etls_controlName;
         
         %etls_getProcessesRunning(statusTable=&etls_statusTable, statusVariable=etls_status, 
            processCountMacro=etls_processesRunning, statusSetting="Running");
            
         %do %while(&etls_processesRunning lt &&&etls_controlName._max 
            and &etls_processesRunning lt &etls_maxProcesses 
            and &&&etls_controlName lt &&&etls_controlName._max);
            
            %let &etls_controlName = %eval(&&&etls_controlName+1);
            
            %let etls_signonMacVar = etls_signonStatus&&&etls_controlName;
            %global &etls_signonMacVar;
            
            %etls_createHandle(statusTable=&etls_statusTable,
                               statusVariable=etls_status,
                               handleVariable=etls_handleName,
                               handlePrefix=&etls_controlName,
                               statusSetting="Running",
                               row=&&&etls_controlName,
                               machineVariable=etls_machineId,
                               startTimeVariable=etls_startTime,
                               cmacvar=&etls_signonMacVar,
                               signon=1,
                               useGrid=1,
                               additionalSignonOptions=&etls_additionalSignonOptions,
                               signonRetries=&etls_signonRetries);
            
         %etls_getProcessesRunning(statusTable=&etls_statusTable, statusVariable=etls_status, 
            processCountMacro=etls_processesRunning, statusSetting="Running");
            
         %if &etls_processesRunning > 0 and &&&etls_signonMacVar ne 1 %then 
            %etls_processToLoopWWWPYF6(parameterTable=&etls_parameterTable, row=&&&etls_controlName,
               handleName=%etls_getHandle(statusTable=&etls_statusTable,
               handleVariable=etls_handleName, row=&&&etls_controlName)); 
         %else 
         %do; /* if signon error, set iterator to max to force loop to stop. */ 
            %let &etls_controlName = &&&etls_controlName._max; 
            %put %str(ERROR%QUOTE(:) A parallel process did not start.  Exiting loop.);
         %end; 
      %end; 
      
   %end; 
   
   %etls_waitFor(statusTable=&etls_statusTable, statusVariable=etls_status, 
      runningStatusSetting="Running", handleVariable=etls_handleName, 
      completeStatusSetting="Finished", endTimeVariable=etls_endTime, 
      startTimeVariable=etls_startTime, waitType=_ALL_, signoff=1, 
      returnCodeVariable=etls_jobRC, 
      statusUnknownReturnCode=.); 
      
   %etls_loopRCCheck(statusTable=&etls_statusTable, returnCodeVariable=etls_jobRC, 
      start=%eval(&etls_lastLoopPtr+1),end=&&&etls_controlName); 
%end;

