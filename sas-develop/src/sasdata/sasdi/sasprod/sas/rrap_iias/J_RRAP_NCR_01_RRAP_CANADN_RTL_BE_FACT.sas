%MACRO basel_candn_rtl_ncr_be_fact;
	/*FETCH AND STORE THE SEGEMENT IDs AS A PART OF LOOKUP NECESSITY. THESE 
	VARIABLES WILL BE EVENTUALLY USED IN THE INSERT STATEMENT BELOW*/
	options notes;

	PROC SQL NOPRINT;
		SELECT NCR_PD_SEG_ID INTO :V_NCR_PD_SEG_ID FROM DDB2CON.BASEL_NCR_PD_SEG_DIM 
			WHERE NCR_PD_SEG_KEY_VAL='0999' 
				/*AND CRNT_F='Y'*/
		AND INPUT(EFF_FROM_YR_MTH,6.) <= &yearmonth and &yearmonth <= 
		INPUT(EFF_TO_YR_MTH,6.);
		SELECT NCR_LGD_SEG_ID INTO :V_NCR_LGD_SEG_ID FROM DDB2CON.BASEL_NCR_LGD_SEG_DIM 
			WHERE NCR_LGD_SEG_KEY_VAL='3299' 
				/*AND CRNT_F='Y'*/
		AND INPUT(EFF_FROM_YR_MTH,6.) <= &yearmonth and &yearmonth <= 
		INPUT(EFF_TO_YR_MTH,6.);
		SELECT NCR_EAD_SEG_ID INTO :V_NCR_EAD_SEG_ID FROM DDB2CON.BASEL_NCR_EAD_SEG_DIM 
			WHERE NCR_EAD_SEG_KEY_VAL='3399' 
				/*AND CRNT_F='Y'*/
		AND INPUT(EFF_FROM_YR_MTH,6.) <= &yearmonth and &yearmonth <= 
		INPUT(EFF_TO_YR_MTH,6.);
	QUIT;

	/*HANDLE NULL VALUES FOR THE ABOVE MACRO VARIABLES. */

	/*THESE MACRO VARIABLES WILL BE PART OF PRIMARY KEY IN THE TARGET TABLE AND 
	HENCE NULL SHOULD BE REPLACED WITH -1*/
	%IF &V_NCR_PD_SEG_ID= %THEN
		%LET V_NCR_PD_SEG_ID=-1;

	%IF &V_NCR_LGD_SEG_ID= %THEN
		%LET V_NCR_LGD_SEG_ID=-1;

	%IF &V_NCR_EAD_SEG_ID= %THEN
		%LET V_NCR_EAD_SEG_ID=-1;

	/*USE DB2 PASS THROUGH TECHNIQUE TO INSERT DATA INTO 
	EDRRAPT.BASEL_CANDN_RTL_NCR_BE_FACT*/
	;
	QUIT;

	proc sql noprint;
		connect using edrrapt as dbcon;
		EXECUTE(delete from &DBSCHEMA..BASEL_CANDN_RTL_NCR_BE_FACT where mth_tm_id=&MTH_TM_ID.) BY DBCON;
		disconnect from dbcon;
	QUIT;

	PROC SQL;
		CONNECT using EDRRAPT AS DB3CON;

		/*THIS STATEMENT GETS EXECUTED IN THE DB2 DATABASE*/
		/*FIRST MAPPING AS PER BSTM*/

		/*EXECUTE(DELETE FROM &DBSCHEMA..BASEL_CANDN_RTL_NCR_BE_FACT WHERE 
		MTH_TM_ID=&MTH_TM_ID) BY DB3CON;*/
		EXECUTE (
			INSERT INTO &DBSCHEMA..BASEL_CANDN_RTL_NCR_BE_FACT
				SELECT DISTINCT SUBQ.MTH_TM_ID, 
					NVL(RISK.NCR_RISK_RT_SYS_ID,-1) AS NCR_RISK_RT_SYS_ID, 
					NVL(EXPSR.EXPSR_CL_ID,-1) AS EXPSR_CL_ID, 
					NVL(PD_SEG.NCR_PD_SEG_ID,-1) AS NCR_PD_SEG_ID,
					NVL(LGD_SEG.NCR_LGD_SEG_ID,-1) AS NCR_LGD_SEG_ID,
					NVL(EAD_SEG.NCR_EAD_SEG_ID,-1) AS NCR_EAD_SEG_ID,
					SUBQ.PD_REALZ_ACCT_CNT,
					SUBQ.LGD_REALZ_ACCT_CNT,
					SUBQ.EAD_REALZ_ACCT_CNT,
					SUBQ.RPTG_QTR_ACCT_CNT,
					SUBQ.PD_ESTD_RTO,
					SUBQ.LGD_ESTD_RTO,
					SUBQ.EAD_ESTD_RTO,
					SUBQ.PD_REALZ_RTO,
					SUBQ.LGD_REALZ_RTO,
					SUBQ.EAD_REALZ_RTO,
					SUBQ.PD_REALZ_DEFLTD_ACCT_CNT,
					SUBQ.LGD_REALZ_DEFLTD_ACCT_CNT,
					SUBQ.EAD_REALZ_DEFLTD_ACCT_CNT,
					SUBQ.PD_REALZ_DEFLTD_OS_BAL_AMT,
					SUBQ.LGD_REALZ_DEFLTD_OS_BAL_AMT,
					SUBQ.EAD_REALZ_DEFLTD_OS_BAL_AMT,
					SUBQ.ECONMC_CAPTL_AMT,
					CURRENT_TIMESTAMP AS INSRT_PROCESS_TMSTMP,
					CURRENT_TIMESTAMP AS UPDT_PROCESS_TMSTMP
				FROM ( 
					SELECT 
						MTH_TM_ID, 
						NCR_RT_SYS_KEY_VAL,
						NCR_EXPSR_CL_KEY_VAL, 
						NCR_PD_SEG_KEY_VAL, 
						NCR_LGD_SEG_KEY_VAL, 
						NCR_EAD_SEG_KEY_VAL,
						SUM(PRIOR_12_MTH_REALZ_PD_ACCT_CNT) AS PD_REALZ_ACCT_CNT, /*SIMPLE AGGREGATE*/
						SUM(PRIOR_36_MTH_REALZ_LGD_ACCT_CNT) AS LGD_REALZ_ACCT_CNT, /*SIMPLE 
						AGGREGATE*/
						SUM(PRIOR_12_MTH_REALZ_EAD_ACCT_CNT) AS EAD_REALZ_ACCT_CNT, /*SIMPLE 
						AGGREGATE*/
						SUM(RPTG_QTR_ACCT_CNT) AS RPTG_QTR_ACCT_CNT, /*SIMPLE AGGREGATE*/
						NVL(SUM(PD_FINAL_RPTG_RTO*RPTG_QTR_ACCT_CNT)/NULLIF(SUM(RPTG_QTR_ACCT_CNT),0),0) 
					AS PD_ESTD_RTO, /*HANDLE DIVIDE BY 0*/
						NVL(SUM(LGD_FINAL_RPTG_RTO*RPTG_QTR_ACCT_CNT)/NULLIF(SUM(RPTG_QTR_ACCT_CNT),0),0) 
					AS LGD_ESTD_RTO, /*AGGREGATE AND REPLACE DENOMINATOR AS NULL IF 0 AND REPLACE 
						FINAL RESULT AS 0 IF NULL*/
						NVL(SUM(EAD_FINAL_RPTG_RTO*RPTG_QTR_ACCT_CNT)/NULLIF(SUM(RPTG_QTR_ACCT_CNT),0),0) 
					AS EAD_ESTD_RTO, /*AGGREGATE AND REPLACE DENOMINATOR AS NULL IF 0 AND REPLACE 
						FINAL RESULT AS 0 IF NULL*/
						NVL(SUM(PRIOR_12_MTH_REALZ_PD_RTO*PRIOR_12_MTH_REALZ_PD_ACCT_CNT)/NULLIF(SUM(PRIOR_12_MTH_REALZ_PD_ACCT_CNT),0),0) 
					AS PD_REALZ_RTO, /*AGGREGATE AND REPLACE DENOMINATOR AS NULL IF 0 AND REPLACE 
						FINAL RESULT AS 0 IF NULL*/
						NVL(SUM(PRIOR_36_MTH_REALZ_LGD_RTO*PRIOR_36_MTH_REALZ_LGD_ACCT_CNT)/NULLIF(SUM(PRIOR_36_MTH_REALZ_LGD_ACCT_CNT),0),0) 
					AS LGD_REALZ_RTO, /*AGGREGATE AND REPLACE DENOMINATOR AS NULL IF 0 AND REPLACE 
						FINAL RESULT AS 0 IF NULL*/
						NVL(SUM(PRIOR_12_MTH_REALZ_EAD_RTO*PRIOR_12_MTH_REALZ_EAD_ACCT_CNT)/NULLIF(SUM(PRIOR_12_MTH_REALZ_EAD_ACCT_CNT),0),0) 
					AS EAD_REALZ_RTO, /*AGGREGATE AND REPLACE DENOMINATOR AS NULL IF 0 AND REPLACE 
						FINAL RESULT AS 0 IF NULL*/
						SUM(PR_12_M_REALZ_PD_DEF_ACCT_CNT) AS PD_REALZ_DEFLTD_ACCT_CNT, /*SIMPLE 
						AGGREGATE*/
						SUM(PR_36_M_REALZ_LGD_DEF_ACCT_CNT) AS LGD_REALZ_DEFLTD_ACCT_CNT, /*SIMPLE 
						AGGREGATE*/
						SUM(PR_12_M_REALZ_EAD_DEF_ACCT_CNT) AS EAD_REALZ_DEFLTD_ACCT_CNT, /*SIMPLE 
						AGGREGATE*/
						SUM(PR_12_M_RLZ_DEF_LN_OS_PD_BAL_AM) AS PD_REALZ_DEFLTD_OS_BAL_AMT, /*SIMPLE 
						AGGREGATE*/
						SUM(PR_36_M_RLZ_DEF_LN_OS_LGD_BAL_AM) AS LGD_REALZ_DEFLTD_OS_BAL_AMT, /*SIMPLE 
						AGGREGATE*/
						SUM(PR_12_M_RLZ_DEF_LN_OS_EAD_BAL_AM) AS EAD_REALZ_DEFLTD_OS_BAL_AMT, /*SIMPLE 
						AGGREGATE*/
						NULL AS ECONMC_CAPTL_AMT
					FROM &DBSCHEMA..BASEL_RPTG_BL_AGGRTD_NCR_BE_FACT /*DBSCHEMA IS DEFINED IN 
						AUTOCALL MACRO*/
					WHERE MTH_TM_ID=&MTH_TM_ID
						GROUP BY MTH_TM_ID, NCR_EXPSR_CL_KEY_VAL, NCR_RT_SYS_KEY_VAL, 
							NCR_PD_SEG_KEY_VAL, NCR_LGD_SEG_KEY_VAL, NCR_EAD_SEG_KEY_VAL) SUBQ
						LEFT OUTER JOIN EDRRAPT.BASEL_NCR_RISK_RT_SYS_DIM RISK ON 
							TRIM(SUBQ.NCR_RT_SYS_KEY_VAL) = TRIM(RISK.NCR_RISK_RT_KEY_VAL) 
							/*AND RISK.CRNT_F='Y'*/
		AND TO_NUMBER(RISK.EFF_FROM_YR_MTH) <= &YEARMONTH and &YEARMONTH <= 
		TO_NUMBER(RISK.EFF_TO_YR_MTH)
		LEFT OUTER JOIN EDRRAPT.BASEL_EXPSR_CL_DIM EXPSR ON 
			TRIM(SUBQ.NCR_EXPSR_CL_KEY_VAL) = TRIM(EXPSR.NCR_EXPSR_CL_KEY_VAL) 
			/*AND EXPSR.CRNT_F='Y'*/
		AND TO_NUMBER(EXPSR.EFF_FROM_YR_MTH) <= &YEARMONTH and &YEARMONTH <= 
		TO_NUMBER(EXPSR.EFF_TO_YR_MTH)
		LEFT OUTER JOIN EDRRAPT.BASEL_NCR_PD_SEG_DIM PD_SEG ON 
			TRIM(SUBQ.NCR_PD_SEG_KEY_VAL) = TRIM(PD_SEG.NCR_PD_SEG_KEY_VAL) 
			/*AND PD_SEG.CRNT_F='Y'*/
		AND TO_NUMBER(PD_SEG.EFF_FROM_YR_MTH) <= &YEARMONTH and &YEARMONTH <= 
		TO_NUMBER(PD_SEG.EFF_TO_YR_MTH)
		LEFT OUTER JOIN EDRRAPT.BASEL_NCR_LGD_SEG_DIM LGD_SEG ON 
			TRIM(SUBQ.NCR_LGD_SEG_KEY_VAL) = TRIM(LGD_SEG.NCR_LGD_SEG_KEY_VAL) 
			/*AND LGD_SEG.CRNT_F='Y'*/
		AND TO_NUMBER(LGD_SEG.EFF_FROM_YR_MTH) <= &YEARMONTH and &YEARMONTH <= 
		TO_NUMBER(LGD_SEG.EFF_TO_YR_MTH)
		LEFT OUTER JOIN EDRRAPT.BASEL_NCR_EAD_SEG_DIM EAD_SEG ON 
			TRIM(SUBQ.NCR_EAD_SEG_KEY_VAL) = TRIM(EAD_SEG.NCR_EAD_SEG_KEY_VAL) 
			/*AND EAD_SEG.CRNT_F='Y'*/
		AND TO_NUMBER(EAD_SEG.EFF_FROM_YR_MTH) <= &YEARMONTH and &YEARMONTH <= 
		TO_NUMBER(EAD_SEG.EFF_TO_YR_MTH)
		) BY DB3CON;

		/*THIS STATEMENT GETS EXECUTED IN THE DB2 DATABASE*/
		/*SECOND MAPPING AS PER BSTM*/
		EXECUTE (
			INSERT INTO &DBSCHEMA..BASEL_CANDN_RTL_NCR_BE_FACT
				(MTH_TM_ID, NCR_RISK_RT_SYS_ID, EXPSR_CL_ID, NCR_PD_SEG_ID, NCR_LGD_SEG_ID, 
				NCR_EAD_SEG_ID, ECONMC_CAPTL_AMT, INSRT_PROCESS_TMSTMP,UPDT_PROCESS_TMSTMP)
			SELECT A.MTH_TM_ID,
				NVL(RISK.NCR_RISK_RT_SYS_ID,-1) AS NCR_RISK_RT_SYS_ID,
				NVL(EXPSR.EXPSR_CL_ID,-1) AS EXPSR_CL_ID,
				&V_NCR_PD_SEG_ID AS NCR_PD_SEG_ID,
				&V_NCR_LGD_SEG_ID AS NCR_LGD_SEG_ID,
				&V_NCR_EAD_SEG_ID AS NCR_EAD_SEG_ID,
				A.ECONMC_CAPTL_AMT,
				CURRENT_TIMESTAMP AS INSRT_PROCESS_TMSTMP,
				CURRENT_TIMESTAMP AS UPDT_PROCESS_TMSTMP
			FROM &DBSCHEMA..BASEL_NCR_BUS_AGGRTD_FACT A
				LEFT OUTER JOIN &DBSCHEMA..BASEL_NCR_RISK_RT_SYS_DIM RISK ON 
					TRIM(A.RT_SYS_KEY_VAL) = TRIM(RISK.NCR_RISK_RT_KEY_VAL) 
					/*AND RISK.CRNT_F='Y'*/
		AND TO_NUMBER(RISK.EFF_FROM_YR_MTH) <= &yearmonth and &yearmonth <= 
		TO_NUMBER(RISK.EFF_TO_YR_MTH)
		LEFT OUTER JOIN &DBSCHEMA..BASEL_EXPSR_CL_DIM EXPSR ON 
			TRIM(A.NCR_EXPSR_CL_KEY_VAL) = TRIM(EXPSR.NCR_EXPSR_CL_KEY_VAL) 
			/*AND EXPSR.CRNT_F='Y'*/
		AND TO_NUMBER(EXPSR.EFF_FROM_YR_MTH) <= &yearmonth and &yearmonth <= 
		TO_NUMBER(EXPSR.EFF_TO_YR_MTH)
		WHERE A.MTH_TM_ID=&MTH_TM_ID AND RISK.NCR_RISK_RT_KEY_VAL = '0201'
			) BY DB3CON;

		/*DISCONNECT FROM THE DB2 DATABASE*/
		DISCONNECT FROM DB3CON;

		/*PROC SQL EXIT*/
	QUIT;

	/*END THE MACRO DEFINITION*/
%MEND;

/*EXECUTING THE MACRO*/
%basel_candn_rtl_ncr_be_fact;
%datalog;
%PUT 
	PROCESSING MONTH IS &MTH_TM_ID 
	YEARMONTH IS &YEARMONTH 
	PRELOAD DATA COUNT IN TARGET FOR &MTH_TM_ID IS &PRELOAD_DATA_COUNT 
	&INPUT00. COUNT IS &SRCCOUNT00 
	&INPUT01. COUNT IS &SRCCOUNT01
	&TGT00. COUNT IS &TGTCOUNT00;

%exitetls_conditionW36M42QW:
%mend etls_conditionW36M42QW;

