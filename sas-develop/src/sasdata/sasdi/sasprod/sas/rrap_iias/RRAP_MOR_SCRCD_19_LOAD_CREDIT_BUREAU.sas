* Define customer list file in DB2;
%delete_table(sas.SCORECARD_VARS_CUST_LIST2);
proc sql;
	connect USING OWSTAR as dbcon;
          execute (CREATE TABLE FRG.SCORECARD_VARS_CUST_LIST2(    MORTGAGE_NO   INTEGER
                             ,    TIME_KEY      DATE
                             ,    CIS_TM_ID     VARCHAR(4)
                             ,    CID           VARCHAR(16)
                             ,    CID_NUM       DOUBLE
                             ,    CUST_BASE_KEY INTEGER
                             ,    FROM_DT       DATE
                             ,    TO_DT         DATE
                             ,    RDM_FROM_DT   INTEGER
                             ,    RDM_TO_DT     INTEGER)    
                   IN &db2tblspc._DM    
                   DISTRIBUTE BY HASH (CUST_BASE_KEY)  
                   COMPRESS YES) by dbcon;
          execute (CREATE INDEX FRG.CUST_LIST_X01_2    
                   ON FRG.SCORECARD_VARS_CUST_LIST2(CUST_BASE_KEY)
                   ALLOW REVERSE SCANS PAGE SPLIT SYMMETRIC COMPRESS YES) by dbcon;
          execute (CREATE INDEX FRG.CUST_LIST_X02_2    
                   ON FRG.SCORECARD_VARS_CUST_LIST2(RDM_FROM_DT,RDM_TO_DT)
                   ALLOW REVERSE SCANS PAGE SPLIT SYMMETRIC COMPRESS YES) by dbcon;
	disconnect from dbcon;

insert into sas.SCORECARD_VARS_CUST_LIST2(bulkload=yes BL_METHOD=CLILOAD)
select MORTGAGE_NO
                             ,    TIME_KEY
                             ,    CIS_TM_ID
                             ,    CID      
                             ,    CID_NUM
