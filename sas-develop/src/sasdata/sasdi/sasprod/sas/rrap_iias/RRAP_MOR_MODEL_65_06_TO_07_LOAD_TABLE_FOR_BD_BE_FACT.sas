 *---------------------------------------------------------------------*/

/* USED ONLY TO POPULATE CONTROL TABLE WITH PROCESSING MONTH */
%get_model_period_dates(product=mor);
%put Start and End Dates for Mortgage Models:;

%put start_period_dt: &start_period_dt ;
%put end_period_dt: &end_period_dt;

%let start_date= &start_period_dt.;
%let end_date= &end_period_dt.;

%let _input_base_tbl = BASEL_ANLYT_BL_INST_FCT_BNS_DLGD;
%let _time_dim_tbl = tm_dim;
%let _pd_seg_tbl = basel_ncr_pd_seg_dim;
%let _lgd_seg_tbl = basel_ncr_lgd_seg_dim;
%let _default_tbl = twelve_mon_def_window;
%global mth_tm_id;

/*fetch the time id for process date*/

proc sql NOPRINT;
select tm_Id into :mth_tm_Id from nzuser.tm_dim where tm_lvl_End_dt="&end_period_dt"d and tm_lvl='Month';
quit;


proc sql NOPRINT;
   connect USING NZUSER as nzcon ;
   execute (drop table &target_lib3..prep_for_bd_be_history_bns if exists) by nzcon;
   execute (
   create table &target_lib3..prep_for_bd_be_history_bns as (
/*		insert into prep_for_bd_be_history_bns*/
		select cast(a.mort_num as integer) as mortgage_no ,
             cast(b.tm_lvl_end_dt as datetime) as process_date,
             a.mth_tm_id,
             a.ncr_expsr_cl_key_val,
             a.ncr_geo_key_val,
             COALESCE(F.ncr_pd_band_key_val, A.ncr_pd_band_key_val) AS ncr_pd_band_key_val,
             a.ncr_rt_sys_key_val,
             a.src_sys_cd,
             COALESCE(F.STEP_PIT_STATUS, A.pit_stat_cd) AS pit_stat_cd,
             a.pd_final_rptg_rto,
             a.lgd_final_rptg_rto,
             a.lgd_model_rto,  /* added 24FEB2015 during UAT testing */
             a.os_bal_amt,
			 	 a.intr_accr_amt,
             a.DLGD_RPTG_RTO, /*added as part of DLGD*/
 
          /*ff added 18FEB2015 to fill in missing key values for PD and LGD */
          /*JD - 21Feb2015 - Updated Order of criteria */
             (case when upper(a.pit_stat_cd)='DEF' then '0923'
                   when a.pd_final_rptg_rto >= 1 then '0922'
                   else c.ncr_pd_seg_key_val
              end) as ncr_pd_seg_key_val,

             (case when upper(a.pit_stat_cd)='DEF' then '3210'
                   when a.DLGD_RPTG_RTO >= 1 then '3209'
                   else d.ncr_lgd_seg_key_val
              end) as ncr_lgd_seg_key_val,	


             (case
               when upper(a.pit_stat_cd) = 'CUR' then '3307'
               when upper(a.pit_stat_cd) in ('DEF', 'CHG') then '3308'
               else NULL
              end) as ncr_ead_seg_key_val,
             e.default_ind,
             e.default_bal

           /* Table from instrument fact */
      from &FRG_DB..&_input_base_tbl as a

           /* Join to time dim to get value for process date*/
           left join
           &FRG_DB..&_time_dim_tbl as b
           on a.mth_tm_id = b.tm_id 
         
             /* Table containing PD segments */
           left join
           &FRG_DB..&_pd_seg_tbl as c
           on (a.pit_stat_cd = c.pit_stat_cd and 
               a.pd_final_rptg_rto >= c.pd_min_val and a.pd_final_rptg_rto < c.pd_max_val)
         
           /* Table containing LGD segments */
           left join
           &FRG_DB..&_lgd_seg_tbl as d
           on (a.pit_stat_cd = d.pit_stat_cd and 
               a.DLGD_RPTG_RTO >= d.lgd_min_val and a.DLGD_RPTG_RTO < d.lgd_max_val)
            
   
           /* Table with default content */
           left join
           &FRG_DB..&_default_tbl as e
           on (b.tm_lvl_end_dt = last_day(date_trunc('day', e.process_date))and 
               cast(a.mort_num as integer)= cast(e.mortgage_no as integer))
            LEFT JOIN
           &EDRTLRP1D..STEP_DEF_ACCT_POST_CCAR_RMA F
           ON A.MTH_TM_ID = F.MTH_TM_ID AND cast(a.mort_num as integer) = F.MORT_NUM AND F.MTH_TM_ID < &MTH_TM_ID.
				/* Additional conditions provided by EDW */
      where (a.mth_tm_id between (&mth_tm_id.-120) and &mth_tm_id.) and  /* BD requires 3-months history */
			upper(a.consm_prd_treatmnt_cd) = 'A' and 
            upper(a.sml_bus_f) = 'N' and 
            upper(a.pit_stat_cd) in ('CUR', 'DEF') and
            upper(a.trnst_exclsn_f) = 'N'
/*			and a.mth_tm_Id=&mth_tm_Id) by nzcon;		*/
        /* For speed at creating table */
			) WITH DATA distribute BY (mortgage_no)) by nzcon;
	  /*   distribute on (mortgage_no)) by nzcon; */
   *execute (generate statistics on &FRG_DB..prep_for_bd_be_history_bns) by nzcon;
   Execute (CALL SYSPROC.ADMIN_CMD (%nrbquote('RUNSTATS
								ON TABLE ) %nrbquote(&target_lib3..prep_for_bd_be_history_bns)
											%nrbquote(ON KEY COLUMNS and INDEXES ALL'))) by nzcon;
   disconnect from nzcon;
quit;


proc sql NOPRINT;
   connect USING NZUSER as nzcon ;
	
   /* JD - 30Apr2015 - commenting out truncate - HD 13OCT2015 added truncate again */
    *execute (truncate table &target_lib3..history_tbl_for_bd_be_fact_bns ) by nzcon; 
	execute (truncate table &target_lib3..history_tbl_for_bd_be_fact_bns IMMEDIATE) by nzcon; 
	disconnect from nzcon;
quit;


proc sql;
  	insert into NZUSER.history_tbl_for_bd_be_fact_bns (bulkload=yes BL_METHOD=CLILOAD)
   	select a.mortgage_no,
         a.process_date,
         a.mth_tm_id,
         a.ncr_geo_key_val,
         a.ncr_pd_band_key_val,
         a.ncr_rt_sys_key_val,
         a.ncr_pd_seg_key_val,
         a.ncr_lgd_seg_key_val,
         a.ncr_ead_seg_key_val,
         a.ncr_expsr_cl_key_val,
         a.src_sys_cd,
         a.pit_stat_cd,
         a.pd_final_rptg_rto,
         a.lgd_final_rptg_rto,
         a.default_ind,
         a.default_bal,
         a.os_bal_amt,
         a.intr_accr_amt,
         a.lgd_model_rto,
			a.dlgd_rptg_rto
         from NZUSER.prep_for_bd_be_history_bns as a  ;
		 
quit;
	
proc sql NOPRINT;
   connect USING NZUSER as nzcon ;	
  * execute (generate statistics on &target_lib3..history_tbl_for_bd_be_fact_bns) by nzcon;
    Execute (CALL SYSPROC.ADMIN_CMD (%nrbquote('RUNSTATS
								ON TABLE ) %nrbquote(&target_lib3..prep_for_bd_be_history_bns)
											%nrbquote(ON KEY COLUMNS and INDEXES ALL'))) by nzcon;
   disconnect from nzcon;
quit;



