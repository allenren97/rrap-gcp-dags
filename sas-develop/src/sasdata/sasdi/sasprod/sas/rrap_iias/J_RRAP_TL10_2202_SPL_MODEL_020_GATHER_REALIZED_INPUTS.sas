/*options sastrace=',,,d' sastraceloc=saslog;*/
%let MODULE=TL;
%let BATCH=2.2;
/*--------------------------------------------------------
 * Assigning start and end dates to run in the code. Note:
 * this is the beginning and ending dates for history. 
 * For a one month run the dates will be the same.
 *--------------------------------------------------------*/

%get_model_period_dates(product=spl);

/*   %let start_period_dt = 30NOV2014; */
/*   %let end_period_dt = 31AUG2015;  */
%put Start and End Dates for SPL Models:;
%put start_period_dt: &start_period_dt ;
%put end_period_dt: &end_period_dt;


/* Get the tm_id for the end date */
proc sql noprint;
select tm_key into :start_period_tm_key
from control.tm_id_lkp
where sas_date="&start_period_dt"d;
quit;

proc sql noprint;
select tm_key into :end_period_tm_key
from control.tm_id_lkp
where sas_date="&end_period_dt"d;
quit;



%put start_period_tm_key: &start_period_tm_key;
%put end_period_tm_key: &end_period_tm_key;

%let mth_tm_id=&end_period_tm_key;

%etl_job_start(target_table=NZUSER.MODEL_REALIZED_INPUTS_SPL,TRUNCATE=Y);


/* Run the following macro to find the 36 month look back start date */
%get_interval_dates;
%put begin_dt_36_tm is &begin_dt_36_tm;
 
 
%delete_table(nzuser.MODEL_REALIZED_INPUTS_SPL);



proc sql noprint;
connect using nzuser as nzcon;
execute(

         create table &FRG_DB..MODEL_REALIZED_INPUTS_SPL as (
         select m.mth_tm_id, 
		          m.basel_acct_id,
				    m.prim_basel_cust_id as basel_cust_id,
                m.crnt_br_loctn_trnst as cab,
                m.loan_num as loan_no,
                m.tot_crnt_bal_amt as principal_bal,
                m.add_on_bal_amt as addon_bal,
                m.accr_intr as accr_int,
                m.recd_stat_cd as recstat_code,
                m.chrg_off_dt as chg_off_date,
                m.tot_crnt_bal_amt + m.add_on_bal_amt + m.accr_intr as os_bal_amt,


				t.TM_LVL_END_DT as process_date,
				now() as INSRT_PROCESS_TMSTMP
 

         from &RRAP_DB..BASEL_PSNL_LOAN_MTH_SNAPSHOT as m 
         left join &RRAP_DB..BASEL_PSNL_LOAN_ACCT_DRVD_VARS as d
              on m.basel_acct_id=d.basel_acct_id and
                 m.mth_tm_id=d.mth_tm_id 

          
         left join &FRG_DB..TM_DIM as t
              on m.MTH_TM_ID=t.tm_id

	      where m.mth_tm_id between &begin_dt_36_tm and &end_period_tm_key and
               m.RECD_STAT_CD in (4,5,6,7,8) ) WITH DATA;

         ) by nzcon;
 quit;

%etl_job_end;
/*---- End of User Written Code  ----*/ 

