%delete_table(nzuser.SCORECARD_VARS_COMBINED);
proc sql;
	connect USING NZUSER as nzcon ;

	execute(
	create table &target_lib3..SCORECARD_VARS_COMBINED as (
	select 
	   cast(a.mortgage_no as integer) as mortgage_no
    , a.eff_tmstmp
    , a.time_key
    , b.at36_mth_since_most_recnt_dlqn 
    , b.at94_available_cr_not_utilized 
	 , b.br147_max_crnt_utilztn_bnk_rev
    , b.go04_num_of_inqrs
	 , d.d2dbalp
 	 , d.d2dbal
    , e.payroll_amt
	 , e.nsf_num
	 , a.dlqnt_day
    , a.DLQNT_MTH
	 , g.CUST_ACCT_CNT
    , a.amort
    , a.prepay_ytd
    , date(a.PROCESS_DATE) as PROCESS_DATE
    , b.bi33_tot_bal_bnk_instlmnt
    , a.province
		from 
		&target_lib3..SCORECARD_VARS_BSL as a
		left join &target_lib3..SCORECARD_VARS_CUST_TU as b on a.cust_base_key=b.cust_base_key and a.process_date>=b.EFF_FROM_DT and a.process_date<=b.EFF_TO_DT
		left join &target_lib3..iwd_time as c on c.TIME_LVL_END_DT=date_trunc('day',a.EFF_TMSTMP) and c.TIME_LVL='Day'
		left join &target_lib3..SCORECARD_VARS_CUST_PRODUCTS_AGG as d on a.cust_base_key=d.cust_base_key and c.MO_FNCL_KEY=d.time_key 
		/*left join &target_lib3..SC_VAR_CUST_PROD_AGG_temp3 as d on a.cust_base_key=d.cust_base_key and c.MO_FNCL_KEY=d.time_key  */ /*change for parallel run */
		left join &target_lib3..SCORECARD_VARS_D2D_ACTIVITY_AGG as e on a.cust_base_key=e.cust_base_key and c.MO_FNCL_KEY=e.time_key
		left join &target_lib3..SCORECARD_VARS_CUSTOMER_PROF as g on to_number(a.cid,'9999999999999999')=to_number(g.cid,'9999999999999999') and c.MO_FNCL_KEY=g.time_key
      ) WITH DATA
		) by nzcon;

     /* execute (grant select, insert, update, delete on &target_lib3...&ds._final to frg_user) by nzcon; */
     *execute (generate statistics on &target_lib3..SCORECARD_VARS_COMBINED ) by nzcon;
		execute(CALL SYSPROC.ADMIN_CMD (%nrbquote('RUNSTATS
					ON TABLE ) %nrbquote(&target_lib3..SCORECARD_VARS_COMBINED)
						%nrbquote(ON KEY COLUMNS and INDEXES ALL'))) by nzcon;
	disconnect from nzcon;
	quit;

