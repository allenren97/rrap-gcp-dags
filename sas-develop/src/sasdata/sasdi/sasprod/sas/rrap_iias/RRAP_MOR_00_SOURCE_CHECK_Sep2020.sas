data final;
	set pre_final;
	attrib OK LENGTH=$8.;
	put monthend=;
	if upcase(table) in ('TERANET_HOUSE_PRC_INDEX','PROVNCL_HOUSE_INDEX_SUM') and monthend ge &exp_date_1 then do;
		OK='OK';
	end;
	else if upcase(table) in ('GENWORTH_BULKINS','IWD_CHNL_RM') and monthend ge '27FEB2012'd then do;
		OK='OK';
	end;
	else if upcase(table) = 'IWD_PD_PLN' and monthend ge '15MAY2015'd then do;
		OK='OK';
	end;
	else if monthend ge &exp_date then do;
		OK='OK';
	end;
 /*sud* - Adding beloe 3 lines code for May2019 test run as IWD_CUST table has month end date of 15th May   
	else if upcase(table) = 'IWD_CUST' and monthend ge '15MAY2015'd then do;
		OK='OK';
	end; */
	else OK='NOT OK!!';
	if OK NE 'OK' then put table monthend ok;
run;

data _null_;
	set final end=last;
	retain error 0;
	if OK ne 'OK' then do;
	error+1;
	put table monthend ok;
	end;
	if last and error gt 0 then abort;
run;
