data output_tmid;
	set output;
	where upcase(table) in (
	'CUST_MODEL'
	,'IWF_CUST_ACTY_RLP'
	,'IWF_CUST_ACCT'
	,'PROVNCL_HOUSE_INDEX_SUM' 
	,'TERANET_HOUSE_PRC_INDEX'
/*	,'BASELAYER_MOR'*/
	/*,'HOUSE_INDEX_JAN_2013_CALC'*/
	);
	date=input(strip(max_date),5.);
run;

proc sql;
	create table output_tmid2 as
	select a.table, b.tm_lvl_end_dt as monthend
	from output_tmid a, nzrrap.tm_dim b
	where a.date=b.tm_id and b.tm_lvl='Month'
	order by a.table;
quit;

data output_2;
	set output;
	where table in (
	'DELI_FILE'
	,'IWD_CUST'
	,'IWD_PD_PLN'
/*	,'BASEL_MORT'*/
	,'IWD_TIME'
	,'CIS_DATA_NEW2'
/*	,'MO_NEW'*/
	,'UNEMP_RATE'
/*	,'GEN_LKP'*/
	,'GENWORTH_BULKINS'
	,'IWD_CHNL_RM'
/*	,'LGD_DIRECT_COSTS'*/
/*	,'LGD_INDIRECT_COST'*/
	)
	;
	format monthend date9.;
	if upcase(table)='CIS_DATA_NEW2' then monthend=intnx('Month',input(max_date,date9.),0,'e');
	else if upcase(table)='UNEMP_RATE' then monthend=intnx('Month',input(max_date,date9.),0,'e');
	else if upcase(table)='DELI_FILE' then monthend=intnx('Month',input(max_date,date9.),0,'e');
	else monthend=input(max_date,date9.);
	*put monthend =;
	drop max_date;
run;
proc sort; by table; run;

