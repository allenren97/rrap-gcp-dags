data loop_dates_1 loop_dates_rep;
	format loop_date date9.;
	do i = 4 to 0 by -1;
		loop_date= intnx('YEAR',intnx('QTR.2',"&rundate."d,-1,'e'),-1*i,'s');
		if i = 0 then call symputx('CURRENT_QTR_END',put(loop_date,date9.));
		if i = 0 or i = 1 then output loop_dates_rep;
		output loop_dates_1;
	end;
	drop i;
run;
proc sort data=loop_dates_1; by loop_date; run;
proc sort data=loop_dates_rep; by loop_date; run;

proc sql;
	create table &_output1. as
	select tm_id as MTH_TM_ID, tm_lvl_end_dt as LOOP_DATE
	from nz_frg.tm_dim a, loop_dates_1 b
	where tm_lvl='Month' and tm_lvl_end_dt = loop_date
	order by 1;
quit;

/*data &_output1.; set &_output1. end=last; if last; run;*/
proc sql;
	create table &_output2. as
	select tm_id as mth_tm_id, tm_lvl_end_dt as LOOP_DATE
	from nz_frg.tm_dim a, loop_dates_rep b
	where tm_lvl='Month' and tm_lvl_end_dt = loop_date
	order by 1;
quit;

proc sql noprint;
	select loop_date format=5. into :sas_date_range separated by ', '
	from &_output1.;
	
	select loop_date format=5. into :sas_date_range_2mth separated by ', '
	from &_output2.;
quit;

proc sql noprint;
	select tm_id into :mth_tm_id_date_range separated by ', '
	from nz_frg.tm_dim
	where tm_lvl='Month' and tm_lvl_end_dt in (&sas_date_range)
	order by 1;

	select tm_id into :mth_tm_id_date_range_2mth separated by ', '
	from nz_frg.tm_dim
	where tm_lvl='Month' and tm_lvl_end_dt in (&sas_date_range_2mth)
	order by 1;
	
	select tm_id into :CURRENT_QTR_END_MTH_TM_ID 
	from nz_frg.tm_dim
	where tm_lvl='Month' and tm_lvl_end_dt = "&CURRENT_QTR_END."d;
quit;

