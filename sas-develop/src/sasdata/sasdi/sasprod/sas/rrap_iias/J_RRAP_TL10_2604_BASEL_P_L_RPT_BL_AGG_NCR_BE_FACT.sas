         		FROM &RRAP_DB..BASEL_PSNL_LOAN_RPTG_DRVD_VARS A, &RRAP_DB..BASEL_PSNL_LOAN_ACCT_DRVD_VARS_2 B  /*CR 27 ADDED*/
         		WHERE A.BASEL_ACCT_ID = B.BASEL_ACCT_ID AND A.MTH_TM_ID = &MTH_TM_ID_36 AND B.MTH_TM_ID = &MTH_TM_ID_36
         		GROUP BY 
         		A.EXPSR_CL_ID, 
         		A.NCR_PD_SEG_ID,
         		A.NCR_LGD_SEG_ID,
         		A.NCR_EAD_SEG_ID) QUERY3 
         		
         	ON QUERY1.EXPSR_CL_ID = QUERY3.EXPSR_CL_ID AND  
         	QUERY1.NCR_PD_SEG_ID = QUERY3.NCR_PD_SEG_ID AND 
         	QUERY1.NCR_LGD_SEG_ID = QUERY3.NCR_LGD_SEG_ID AND
         	QUERY1.NCR_EAD_SEG_ID = QUERY3.NCR_EAD_SEG_ID);
         
         /*PRIOR_36_MTH_REALZ_LGD_RTO*/
         CREATE TABLE BE_FACT_P_36_MTH_R_LGD_RTO AS 
         SELECT * FROM CONNECTION TO NZCON (
         SELECT 
         		A.EXPSR_CL_ID, 
         		A.NCR_PD_SEG_ID,
         		A.NCR_LGD_SEG_ID,
         		A.NCR_EAD_SEG_ID,
         		NVL(AVG(B.LGD_NPV_ALL_COST_FLR_CAP_150_RTO),0) AS PRIOR_36_MTH_REALZ_LGD_RTO
         		FROM &RRAP_DB..BASEL_PSNL_LOAN_RPTG_DRVD_VARS A, &RRAP_DB..PSNL_LN_LGD_OBSVT_PT_RELZ_VAL B
