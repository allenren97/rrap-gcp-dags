         A.NCR_PD_SEG_ID,
         A.NCR_LGD_SEG_ID,
         A.NCR_EAD_SEG_ID);
         
         QUIT;
         
         PROC SQL;
         CONNECT USING NZRRAP AS NZCON;
         CREATE TABLE BE_FACT_P_12_M_R_D_LN_OS_AM AS 
         SELECT * FROM CONNECTION TO NZCON (
         /*PR_12_M_RLZ_DEF_LN_OS_PD_BAL_AM*/
         /*PR_12_M_RLZ_DEF_LN_OS_EAD_BAL_AM*/
         SELECT QUERY1.*, 
         CASE WHEN QUERY1.PIT_STATUS_V2 = 'DEF' THEN NVL(QUERY3.AMOUNT_SUM2,0) 
         	 WHEN QUERY1.PIT_STATUS_V2 = 'CUR' THEN NVL(QUERY2.AMOUNT_SUM1,0) 
         	 ELSE 0 END AS PR_12_M_RLZ_DEF_LN_OS_PD_BAL_AM,
         CASE WHEN QUERY1.PIT_STATUS_V2 = 'DEF' THEN NVL(QUERY3.AMOUNT_SUM2,0)
         	 WHEN QUERY1.PIT_STATUS_V2 = 'CUR' THEN NVL(QUERY2.AMOUNT_SUM1,0) 
         	 ELSE 0 END AS PR_12_M_RLZ_DEF_LN_OS_EAD_BAL_AM
         	 FROM (
         		SELECT 
         		A.EXPSR_CL_ID, 
         		A.NCR_PD_SEG_ID,
         		A.NCR_LGD_SEG_ID,
         		A.NCR_EAD_SEG_ID,
         		MAX(PIT_STATUS_V2) AS PIT_STATUS_V2,
         		COUNT(A.BASEL_ACCT_ID) AS ACCT_COUNT
         		FROM &RRAP_DB..BASEL_PSNL_LOAN_RPTG_DRVD_VARS A, &RRAP_DB..BASEL_PSNL_LOAN_ACCT_DRVD_VARS_2 B
         		WHERE A.BASEL_ACCT_ID = B.BASEL_ACCT_ID AND A.MTH_TM_ID = &MTH_TM_ID_12 AND B.MTH_TM_ID = &MTH_TM_ID_12
         		GROUP BY 
         		A.EXPSR_CL_ID, 
         		A.NCR_PD_SEG_ID,
         		A.NCR_LGD_SEG_ID,
         		A.NCR_EAD_SEG_ID) QUERY1 
         		
         		LEFT OUTER JOIN 
         		(SELECT 
         		A.EXPSR_CL_ID, 
         		A.NCR_PD_SEG_ID,
         		A.NCR_LGD_SEG_ID,
         		A.NCR_EAD_SEG_ID,
         		SUM(CASE WHEN B.LAST_NEW_DFT_BAL_AMT < 0 THEN 0 ELSE B.LAST_NEW_DFT_BAL_AMT END) AS AMOUNT_SUM1
         		FROM &RRAP_DB..BASEL_PSNL_LOAN_RPTG_DRVD_VARS A, &RRAP_DB..PSNL_LOAN_OBSVTN_PT_DRVD_VAR B
         		WHERE B.MODEL_DFT_F = 'Y' AND A.BASEL_ACCT_ID = B.BASEL_ACCT_ID AND A.MTH_TM_ID = &MTH_TM_ID_12 AND B.OBSVTN_MTH_TM_ID = &MTH_TM_ID_12
         		GROUP BY 
         		A.EXPSR_CL_ID, 
         		A.NCR_PD_SEG_ID,
         		A.NCR_LGD_SEG_ID,
         		A.NCR_EAD_SEG_ID) QUERY2 
         		
         	ON QUERY1.EXPSR_CL_ID = QUERY2.EXPSR_CL_ID AND  
         	QUERY1.NCR_PD_SEG_ID = QUERY2.NCR_PD_SEG_ID AND 
         	QUERY1.NCR_LGD_SEG_ID = QUERY2.NCR_LGD_SEG_ID AND
         	QUERY1.NCR_EAD_SEG_ID = QUERY2.NCR_EAD_SEG_ID
         	
         		LEFT OUTER JOIN 
         		(SELECT 
         		A.EXPSR_CL_ID, 
         		A.NCR_PD_SEG_ID,
         		A.NCR_LGD_SEG_ID,
         		A.NCR_EAD_SEG_ID,
         		SUM(CASE WHEN B.OS_BAL_AMT_V2 < 0 THEN 0 ELSE B.OS_BAL_AMT_V2 END) AS AMOUNT_SUM2  /*CR 27 ADDED*/
         		FROM &RRAP_DB..BASEL_PSNL_LOAN_RPTG_DRVD_VARS A, &RRAP_DB..BASEL_PSNL_LOAN_ACCT_DRVD_VARS_2 B     /*CR 27 ADDED*/
         		WHERE A.BASEL_ACCT_ID = B.BASEL_ACCT_ID AND A.MTH_TM_ID = &MTH_TM_ID_12 AND B.MTH_TM_ID = &MTH_TM_ID_12
         		GROUP BY 
         		A.EXPSR_CL_ID, 
         		A.NCR_PD_SEG_ID,
         		A.NCR_LGD_SEG_ID,
         		A.NCR_EAD_SEG_ID) QUERY3 
         		
         	ON QUERY1.EXPSR_CL_ID = QUERY3.EXPSR_CL_ID AND  
         	QUERY1.NCR_PD_SEG_ID = QUERY3.NCR_PD_SEG_ID AND 
         	QUERY1.NCR_LGD_SEG_ID = QUERY3.NCR_LGD_SEG_ID AND
         	QUERY1.NCR_EAD_SEG_ID = QUERY3.NCR_EAD_SEG_ID);
         
         /*PR_36_M_RLZ_DEF_LN_OS_LGD_BAL_AM*/
         CREATE TABLE BE_FACT_P_36_M_R_D_LN_OS_LGD_AM AS 
         SELECT * FROM CONNECTION TO NZCON (
