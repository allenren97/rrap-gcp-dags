         SELECT 
         DRIVER.EXPSR_CL_ID, 
         DRIVER.NCR_PD_SEG_ID,
         DRIVER.NCR_LGD_SEG_ID,
         DRIVER.NCR_EAD_SEG_ID,
         NCR_EXPSR_CL_KEY_VAL,
         NCR_PD_SEG_KEY_VAL,
         NCR_LGD_SEG_KEY_VAL,
         NCR_EAD_SEG_KEY_VAL,
         COUNT(DRIVER.BASEL_ACCT_ID) AS RPTG_QTR_ACCT_CNT 
         FROM nzrrap.BASEL_PSNL_LOAN_RPTG_DRVD_VARS DRIVER
         LEFT OUTER JOIN nzrrap.BASEL_EXPSR_CL_DIM_NZ EXPSR ON DRIVER.EXPSR_CL_ID = EXPSR.EXPSR_CL_ID AND  "&mth_tm_id_yrmth." BETWEEN EXPSR.EFF_FROM_YR_MTH AND EXPSR.EFF_TO_YR_MTH
         LEFT OUTER JOIN nzrrap.BASEL_NCR_PD_SEG_DIM_NZ PDSEG ON DRIVER.NCR_PD_SEG_ID = PDSEG.NCR_PD_SEG_ID AND "&mth_tm_id_yrmth." BETWEEN PDSEG.EFF_FROM_YR_MTH AND PDSEG.EFF_TO_YR_MTH
         LEFT OUTER JOIN nzrrap.BASEL_NCR_LGD_SEG_DIM_NZ LGDSEG ON DRIVER.NCR_LGD_SEG_ID = LGDSEG.NCR_LGD_SEG_ID AND "&mth_tm_id_yrmth." BETWEEN LGDSEG.EFF_FROM_YR_MTH AND LGDSEG.EFF_TO_YR_MTH
         LEFT OUTER JOIN nzrrap.BASEL_NCR_EAD_SEG_DIM_NZ EADSEG ON DRIVER.NCR_EAD_SEG_ID = EADSEG.NCR_EAD_SEG_ID AND "&mth_tm_id_yrmth." BETWEEN LGDSEG.EFF_FROM_YR_MTH AND LGDSEG.EFF_TO_YR_MTH
         WHERE DRIVER.MTH_TM_ID=&MTH_TM_ID
         GROUP BY 
         DRIVER.EXPSR_CL_ID, 
         DRIVER.NCR_PD_SEG_ID,
         DRIVER.NCR_LGD_SEG_ID,
         DRIVER.NCR_EAD_SEG_ID,
         NCR_EXPSR_CL_KEY_VAL,
         NCR_PD_SEG_KEY_VAL,
         NCR_LGD_SEG_KEY_VAL,
         NCR_EAD_SEG_KEY_VAL;
         quit;
