         /*CALCULATE PD/LGD RPTG RTO*/
         proc sql;
         CONNECT USING NZRRAP AS NZCON;
         CREATE TABLE BE_FACT_SECOND AS
         SELECT * FROM CONNECTION TO NZCON (
         SELECT 
         B.EXPSR_CL_ID, 
         B.NCR_PD_SEG_ID,
         B.NCR_LGD_SEG_ID,
         B.NCR_EAD_SEG_ID,
         AVG(A.PD_FINAL_RPTG_RTO) AS PD_FINAL_RPTG_RTO,
         /*AVG(A.LGD_FINAL_RPTG_RTO) AS LGD_FINAL_RPTG_RTO - Hadi Changed as per BSTM*/
         AVG(A.DLGD_RPTG_RTO) AS LGD_FINAL_RPTG_RTO
         FROM &RRAP_DB..BASEL_PSNL_LOAN_RPTG_DRVD_VARS B, &RRAP_DB..BASEL_PSNL_LN_ANL_BL_INST_FACT A
         WHERE B.BASEL_ACCT_ID = A.BASEL_ACCT_ID
         AND B.MTH_TM_ID = &MTH_TM_ID AND A.MTH_TM_ID = &MTH_TM_ID
         GROUP BY B.EXPSR_CL_ID, 
         B.NCR_PD_SEG_ID,
         B.NCR_LGD_SEG_ID,
         B.NCR_EAD_SEG_ID);
         
         QUIT;
         
         /*CALCLUATE 12 MONTH ACCT ATTRIBUTES*/
         PROC SQL;
         CONNECT USING NZRRAP AS NZCON;
         CREATE TABLE BE_FACT_P_12_M_REALZ_ACNT AS 
         SELECT * FROM CONNECTION TO NZCON (
         /*PRIOR_12_MTH_REALZ_PD_ACCT_CNT*/
         SELECT QUERY1.*, 
         CASE WHEN QUERY1.PIT_STATUS_V2 = 'DEF' THEN 0 
         	 WHEN QUERY1.PIT_STATUS_V2 = 'CUR' THEN QUERY1.ACCT_COUNT END AS PRIOR_12_MTH_REALZ_PD_ACCT_CNT,
         CASE WHEN QUERY1.PIT_STATUS_V2 = 'DEF' THEN 0
         	 WHEN QUERY1.PIT_STATUS_V2 = 'CUR' THEN NVL(QUERY2.ACCT_COUNT,0) END AS PRIOR_12_MTH_REALZ_EAD_ACCT_CNT
         	 FROM (
         		SELECT 
         		A.EXPSR_CL_ID, 
         		A.NCR_PD_SEG_ID,
         		A.NCR_LGD_SEG_ID,
         		A.NCR_EAD_SEG_ID,
         		MAX(PIT_STATUS_V2) AS PIT_STATUS_V2,
         		COUNT(A.BASEL_ACCT_ID) AS ACCT_COUNT
         		FROM &RRAP_DB..BASEL_PSNL_LOAN_RPTG_DRVD_VARS A, &RRAP_DB..BASEL_PSNL_LOAN_ACCT_DRVD_VARS_2 B
         		WHERE A.BASEL_ACCT_ID = B.BASEL_ACCT_ID AND A.MTH_TM_ID = &MTH_TM_ID_12 AND B.MTH_TM_ID = &MTH_TM_ID_12
         		GROUP BY 
         		A.EXPSR_CL_ID, 
         		A.NCR_PD_SEG_ID,
         		A.NCR_LGD_SEG_ID,
         		A.NCR_EAD_SEG_ID) QUERY1 
         		
         /*		PRIOR_12_MTH_REALZ_EAD_ACCT_CNT*/
         		LEFT OUTER JOIN 
         		(SELECT 
         		A.EXPSR_CL_ID, 
         		A.NCR_PD_SEG_ID,
         		A.NCR_LGD_SEG_ID,
         		A.NCR_EAD_SEG_ID,
         		COUNT(A.BASEL_ACCT_ID) AS ACCT_COUNT
         		FROM &RRAP_DB..BASEL_PSNL_LOAN_RPTG_DRVD_VARS A, &RRAP_DB..PSNL_LOAN_OBSVTN_PT_DRVD_VAR B
         		WHERE B.MODEL_DFT_F = 'Y' AND A.BASEL_ACCT_ID = B.BASEL_ACCT_ID AND A.MTH_TM_ID = &MTH_TM_ID_12 AND B.OBSVTN_MTH_TM_ID = &MTH_TM_ID_12
         		GROUP BY 
         		A.EXPSR_CL_ID, 
         		A.NCR_PD_SEG_ID,
         		A.NCR_LGD_SEG_ID,
         		A.NCR_EAD_SEG_ID) QUERY2 
         		
         	ON QUERY1.EXPSR_CL_ID = QUERY2.EXPSR_CL_ID AND  
         	QUERY1.NCR_PD_SEG_ID = QUERY2.NCR_PD_SEG_ID AND 
         	QUERY1.NCR_LGD_SEG_ID = QUERY2.NCR_LGD_SEG_ID AND
         	QUERY1.NCR_EAD_SEG_ID = QUERY2.NCR_EAD_SEG_ID); 
         
         QUIT;
         
         /*PRIOR_36_MTH_REALZ_LGD_ACCT_CNT*/
         PROC SQL;
         CONNECT USING NZRRAP AS NZCON;
         CREATE TABLE BE_FACT_P_36_M_REALZ_LGD_ACNT AS 
         SELECT * FROM CONNECTION TO NZCON (
         SELECT 
         A.EXPSR_CL_ID, 
         A.NCR_PD_SEG_ID,
         A.NCR_LGD_SEG_ID,
         A.NCR_EAD_SEG_ID,
         NVL(COUNT(A.BASEL_ACCT_ID),0) AS ACCT_COUNT
         FROM &RRAP_DB..BASEL_PSNL_LOAN_RPTG_DRVD_VARS A, &RRAP_DB..PSNL_LN_LGD_OBSVT_PT_RELZ_VAL B
         WHERE B.LGD_RTO <> 0 AND B.LGD_RTO IS NOT NULL AND A.BASEL_ACCT_ID = B.BASEL_ACCT_ID AND
         A.MTH_TM_ID = &MTH_TM_ID_36 AND B.OBSVTN_MTH_TM_ID = &MTH_TM_ID_36
         GROUP BY 
         A.EXPSR_CL_ID, 
         A.NCR_PD_SEG_ID,
         A.NCR_LGD_SEG_ID,
         A.NCR_EAD_SEG_ID);
         
         /*CALCLUATE 12 MONTH DEF ACCT ATTRIBUTES*/
         /*PR_12_M_REALZ_PD_DEF_ACCT_CNT*/
         /*PR_12_M_REALZ_EAD_DEF_ACCT_CNT*/
         CREATE TABLE BE_FACT_P_12_M_REALZ_DEF_ACNT AS
         SELECT * FROM CONNECTION TO NZCON (
         SELECT QUERY1.*, 
         CASE WHEN QUERY1.PIT_STATUS_V2 = 'DEF' THEN QUERY1.ACCT_COUNT 
         	 WHEN QUERY1.PIT_STATUS_V2 = 'CUR' THEN NVL(QUERY2.ACCT_COUNT,0) END AS PR_12_M_REALZ_PD_DEF_ACCT_CNT,
         CASE WHEN QUERY1.PIT_STATUS_V2 = 'DEF' THEN QUERY1.ACCT_COUNT
         	 WHEN QUERY1.PIT_STATUS_V2 = 'CUR' THEN NVL(QUERY2.ACCT_COUNT,0) END AS PR_12_M_REALZ_EAD_DEF_ACCT_CNT
         	 FROM (
         		SELECT 
         		A.EXPSR_CL_ID, 
         		A.NCR_PD_SEG_ID,
         		A.NCR_LGD_SEG_ID,
         		A.NCR_EAD_SEG_ID,
         		MAX(PIT_STATUS_V2) AS PIT_STATUS_V2,
         		COUNT(A.BASEL_ACCT_ID) AS ACCT_COUNT
         		FROM &RRAP_DB..BASEL_PSNL_LOAN_RPTG_DRVD_VARS A, &RRAP_DB..BASEL_PSNL_LOAN_ACCT_DRVD_VARS_2 B
         		WHERE A.BASEL_ACCT_ID = B.BASEL_ACCT_ID AND A.MTH_TM_ID = &MTH_TM_ID_12 AND B.MTH_TM_ID = &MTH_TM_ID_12
         		GROUP BY 
         		A.EXPSR_CL_ID, 
         		A.NCR_PD_SEG_ID,
         		A.NCR_LGD_SEG_ID,
         		A.NCR_EAD_SEG_ID) QUERY1 
         		
         
         		LEFT OUTER JOIN 
         		(SELECT 
         		A.EXPSR_CL_ID, 
         		A.NCR_PD_SEG_ID,
         		A.NCR_LGD_SEG_ID,
         		A.NCR_EAD_SEG_ID,
         		COUNT(A.BASEL_ACCT_ID) AS ACCT_COUNT
         		FROM &RRAP_DB..BASEL_PSNL_LOAN_RPTG_DRVD_VARS A, &RRAP_DB..PSNL_LOAN_OBSVTN_PT_DRVD_VAR B
         		WHERE B.MODEL_DFT_F = 'Y' AND A.BASEL_ACCT_ID = B.BASEL_ACCT_ID AND A.MTH_TM_ID = &MTH_TM_ID_12 AND B.OBSVTN_MTH_TM_ID = &MTH_TM_ID_12
         		GROUP BY 
         		A.EXPSR_CL_ID, 
         		A.NCR_PD_SEG_ID,
         		A.NCR_LGD_SEG_ID,
         		A.NCR_EAD_SEG_ID) QUERY2 
         		
         	ON QUERY1.EXPSR_CL_ID = QUERY2.EXPSR_CL_ID AND  
         	QUERY1.NCR_PD_SEG_ID = QUERY2.NCR_PD_SEG_ID AND 
         	QUERY1.NCR_LGD_SEG_ID = QUERY2.NCR_LGD_SEG_ID AND
         	QUERY1.NCR_EAD_SEG_ID = QUERY2.NCR_EAD_SEG_ID);
         
         
         /*PR_36_M_REALZ_LGD_DEF_ACCT_CNT*/
         CREATE TABLE BE_FACT_P_36_M_R_LGD_DEF_ACNT AS 
         SELECT * FROM CONNECTION TO NZCON (
         SELECT 
         A.EXPSR_CL_ID, 
         A.NCR_PD_SEG_ID,
         A.NCR_LGD_SEG_ID,
         A.NCR_EAD_SEG_ID,
         NVL(COUNT(A.BASEL_ACCT_ID),0) AS ACCT_COUNT
         FROM &RRAP_DB..BASEL_PSNL_LOAN_RPTG_DRVD_VARS A, &RRAP_DB..PSNL_LN_LGD_OBSVT_PT_RELZ_VAL B
         WHERE B.LGD_RTO <> 0 AND B.LGD_RTO IS NOT NULL AND A.BASEL_ACCT_ID = B.BASEL_ACCT_ID AND
         A.MTH_TM_ID = &MTH_TM_ID_36 AND B.OBSVTN_MTH_TM_ID = &MTH_TM_ID_36
         GROUP BY 
