                        				  b.PRPTY_DESC_3,
                        				  b.PROVINCE as prop_prov2,
                        				  c.PROVINCE_CD as PRPTY_PROV,
                        				  b.LEND_VAL2,
                        				  b.MADE_DATE as made_date2a,
