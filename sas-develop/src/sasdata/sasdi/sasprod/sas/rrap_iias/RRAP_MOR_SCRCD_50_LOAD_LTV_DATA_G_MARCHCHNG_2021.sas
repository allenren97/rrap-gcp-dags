                           if made_date = . then made_date = INT_ADJ_DATE;
                           if made_date>process_date then made_date = INT_ADJ_DATE;
                        	
                           format process_date2 date9.;
                           process_date2 = datepart(process_date);
                        
                           /*If Process_Date is in exceptions quarters, use nearest available date*/
                           if yymth = 200904 then process_date2 = '31Jul2009'd;
                           if yymth in (201001, 201004, 201007) then process_date2 = '29Oct2010'd;
                        
                           made_date2 = datepart(made_date);
                           format made_date2 date9.;
                           made_date3 = compress(put(made_date2, MONYY5.));
                           /*if made_date3=. then made_date3 =put(CR_LMT_DT,monyy5.);*/
                           obs_date = put(datepart(process_date),monyy5.);
                        
                           /*If made_date3 < JULY 1990 then made_date3 = JULY 1990*/
