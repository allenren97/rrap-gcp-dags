/***************************************************************************\
*   Name:   create_var_stat.sas                                    *
*   Usage:   create_var_stat(table_name,id,time_key)                     *
*   Last update: 14/05/2012                                       *
*   Author: Leon Kushnir                                       *
*   Description: A macro that will create statistic variations for all      *
*             numeric variables in the specified data set.            *
\***************************************************************************/


%macro create_var_stat(table_name,id,time_key);

   data _null_;
      starttime = datetime();
      call symputx('starttime', starttime, 'g');
   run;

   options validvarname=any;

   proc sort data=&table_name.;
      by &id. &time_key.;
   run;

   proc contents data=&table_name. 
      out=col_list(where=(type=1 and format not in ('DATE' 'DATETIME')) keep=NAME TYPE FORMAT) noprint;
   run;

   data col_list;
      set col_list(where=(lowcase(name) not in ("&time_key." "&id.")));
      name2=compress(name,'_');
      if length(name2)<=30 then do;
         output;
      end;
   run;

   proc sql noprint;

      select count(name) into :nvar trimmed
      from col_list;

   quit;

   %put number of variables = &nvar;

   %if %eval(&nvar < 1) %then
   %do;
      data &table_name._stat;
         set &table_name.;
      run;

      %goto out;
   %end;
   %else %do;
      proc sql noprint;

         select name into :keep_list separated by ' '
         from col_list;

         select name into :var1 - :var&nvar
         from col_list;

      quit;

      proc transpose data=&table_name out=work.tdata(rename=(_name_=name col1=value));
         by &id. &time_key.;
         var &keep_list;
      run; 

      proc sort data=work.tdata;
         by &id. name &time_key.;
      run;

      %let maxlag = 23;
      
      data tdata2(keep=&id. name &time_key.
                           valavg24
                           min3 min6 
                           max3 max6 max12 max24
                           );
         set work.tdata;
         by &id. name &time_key.;
         retain mcounter;
         if first.name then mcounter = 1;
         else mcounter + 1; 
         vmm1 = value;
         %do ii = 1 %to &maxlag;
            %let jj = %eval(&ii. + 1); 
            lagval&ii. = lag&ii.(value);
            if mcounter >= &jj then 
            vmm&jj. = lagval&ii.;
            else vmm&jj. = .;   
         %end;
         valsum3 = sum(of vmm1-vmm3);
         valavg3 = mean(of vmm1-vmm3);
         min3 = min(of vmm1-vmm3);
         max3 = max(of vmm1-vmm3); 
         valsum6 = sum(of vmm1-vmm6);
         valavg6 = mean(of vmm1-vmm6);
         min6 = min(of vmm1-vmm6);
         max6 = max(of vmm1-vmm6);
         valsum12 = sum(of vmm1-vmm12);
         valavg12 = mean(of vmm1-vmm12);
         min12 = min(of vmm1-vmm12);
         max12 = max(of vmm1-vmm12);
         valsum24 = sum(of vmm1-vmm24);
         valavg24 = mean(of vmm1-vmm24);
         min24 = min(of vmm1-vmm24);
         max24 = max(of vmm1-vmm24);
         if mcounter = 1 then
         do;
            chg1 = .;
            chg3 = .;
            chg6 = .;
            slp1 = .;
            slp3 = .;
            slp6 = .;
         end;
         else if mcounter < 3 then
         do;
            if vmm2 ne 0 then chg1 = (vmm1 - vmm2)/vmm2;
            if vmm2 ne 0 then chg3 = (vmm1 - vmm2)/vmm2;
            if vmm2 ne 0 then chg6 = (vmm1 - vmm2)/vmm2;
            slp1 = (vmm1 - vmm2);
            slp3 = (vmm1 - vmm2)/(mcounter-1);
            slp6 = (vmm1 - vmm2)/(mcounter-1);
         end;    
         else if mcounter < 6 then
         do;
            if vmm2 ne 0 then chg1 = (vmm1 - vmm2)/vmm2;
            if vmm3 ne 0 then chg3 = (vmm1 - vmm3)/vmm3;
            %do kk = 3 %to 5;
               if mcounter = &kk and vmm&kk. ne 0 then chg6 = (vmm1 - vmm&kk.)/vmm&kk.;
               if mcounter = &kk then slp6 = (vmm1 - vmm&kk.)/(mcounter-1);
            %end;
            slp1 = (vmm1 - vmm2);
            slp3 = (vmm1 - vmm3)/ 2;
         end;
         else
         do;
            if vmm2 ne 0 then chg1 = (vmm1 - vmm2)/vmm2;
            if vmm3 ne 0 then chg3 = (vmm1 - vmm3)/vmm3;
            if vmm6 ne 0 then chg6 = (vmm1 - vmm6)/vmm6;
            slp1 = (vmm1 - vmm2);
            slp3 = (vmm1 - vmm3)/ 2;
            slp6 = (vmm1 - vmm6)/ 5;
         end; 
      run;
   %end;

proc sql;
drop table tdata;
quit;

   proc sort data=tdata2;
     by &id. &time_key.;
   run;
   %delete_table(nzuser.scorecard_var_&pn);
   data nzuser.scorecard_var_&pn (bulkload=yes keep= &id. &time_key. d2dbalpmin6m br147max6m d2dbalmax12m 
                 DLQNT_DAYavg24m dlqnt_mthmax24m go04max6m BI33max3m nsf_nummax6m
                 payroll_amtmin3m prepay_ytdmax24m);
     set tdata2;
     by &id. &time_key.;
     retain d2dbalpmin6m br147max6m d2dbalmax12m  DLQNT_DAYavg24m dlqnt_mthmax24m 
         go04max6m BI33max3m nsf_nummax6m payroll_amtmin3m prepay_ytdmax24m;

     if first.&time_key. then do;
       d2dbalpmin6m = 0;
	    br147max6m = 0;
	    d2dbalmax12m = 0;
	    DLQNT_DAYavg24m = 0;
	    dlqnt_mthmax24m = 0;
	    go04max6m = 0;
	    BI33max3m = 0;
	    nsf_nummax6m = 0;
	    payroll_amtmin3m = 0;
	    prepay_ytdmax24m = 0;
     end;

     if name  = 'D2DBALP' then d2dbalpmin6m = min6;
     if name  = 'BR147_MAX_CRNT_UTILZTN_BNK_REV' then br147max6m = max6;
     if name  = 'D2DBAL' then d2dbalmax12m = max12;
     if name  = 'DLQNT_DAY' then DLQNT_DAYavg24m = valavg24;
     if name  = 'DLQNT_MTH' then dlqnt_mthmax24m = max24;
     if name  = 'GO04_NUM_OF_INQRS' then go04max6m = max6;
     if name  = 'BI33_TOT_BAL_BNK_INSTLMNT' then BI33max3m = max3;
     if name  = 'NSF_NUM' then nsf_nummax6m = max6;
     if name  = 'PAYROLL_AMT' then payroll_amtmin3m = min3;
     if name  = 'PREPAY_YTD' then prepay_ytdmax24m = max24;
  
     if last.&time_key. then output;

   run;

%out:;

data _null_;
      endtime = datetime();
      call symputx('endtime', endtime, 'g');
run;

