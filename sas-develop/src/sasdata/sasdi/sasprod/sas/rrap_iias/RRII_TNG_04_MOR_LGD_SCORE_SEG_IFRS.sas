/*---------------------------------------------------------------------
 * NAME:    04_tng_mor_lgd_score_segment.sas
 *
 * PURPOSE: Excludes the observations from the process and then 
 *          scores & segments results.
 *             
 * NOTES: 
 *             
 * MODIFIED:
 *    02JAN2014 - WP - Created
 *    12JAN2015 - JL - Updated names, variables, join logic
 *    13JAN2015 - JL - Added three new vars to table per request from
 *                     modelers: recovery, indirect_cost, final_cost
 *    15JAN2015 - JL - Corrected exlcusion logic.
 *    28JAN2015 - WP - Added insert into NZ and new librefs to input tbls.
 *
 * Copyright (c) 2015 by The Financial Risk Group, Cary, NC, USA.
 *---------------------------------------------------------------------*/
%get_model_period_dates(product=mor);

%put Start and End Dates for Mortgage Models:;
%put start_period_dt: &start_period_dt ;
%put end_period_dt: &end_period_dt;


%let _rundate=&start_period_dt.;
 data _null_;
	 
	call symputx('_rundate', (put(intnx('month', "&_rundate"d, 0, 'e'), date9.)));
	call symputx('nz_rundate', (put(intnx('month', "&_rundate"d, 0, 'e'), yymmdd10.)));

	call symputx("min_24_mon_period", (put(intnx('month', "&_rundate"d, -24, 'e'), date9.)));
	call symputx("nz_min_24_mon_period", (put(intnx('month', "&_rundate"d, -24, 'e'), yymmdd10.)));
	
run;

/* Input table */
%let _lgdd_input_tbl = nz_frg.tng_mor_lgdd;
%let _tng_scorecard_vars = nz_frg.tng_pd_var_creation_final;

/* Output table */
%let _lgdd_excluded_accts = results.tng_lgdd_excluded_obs;
%let _lgdd_non_excluded_accts = results.tng_lgdd_non_excluded_obs;
%let _lgd_segmentation_tbl = results.tng_lgdd_segmentation;

/*----------------------------------------------
 * Exclude accounts process
 *----------------------------------------------*/
proc sql noprint;
   create table work.lgdd_with_scorevars as
   select a.account_id,
          a.month_end_dt,
          a.recovery,
          a.indirect_cost,
          a.final_cost,
          a.lgd,
          a.lgd_costs,
          a.lgd_costs_cap_100,
          a.lgd_costs_cap_150,
          a.accrued_interest_amt,
          a.end_principal_balance,
          a.months_in_default,
          a.close_dt,
          b.ltv_teranet,
          b.ins_id_group
   from &_lgdd_input_tbl as a
        inner join
        &_tng_scorecard_vars as b
        on (a.account_id = b.account_id and
            a.month_end_dt = b.month_end_dt)
where a.month_end_dt between "&min_24_mon_period."d and "&_rundate"d 
;
quit;

data work.lgdd_flagged_for_excl;
   set work.lgdd_with_scorevars;
   if accrued_interest_amt ne . then balance_interest = end_principal_balance + accrued_interest_amt;
   else balance_interest= end_principal_balance;

   if close_dt ne . or end_principal_balance <= 0 then excl = 'Y';  
   else excl = 'N';
run;


proc sql noprint;

   /* Create table of excluded LGDD accounts */
   create table &_lgdd_excluded_accts as
   select a.*
   from work.lgdd_flagged_for_excl as a
   where upcase(excl) = 'Y';

   /* Create table of non-excluded LGDD accounts */
   create table &_lgdd_non_excluded_accts as 
   select a.*
   from work.lgdd_flagged_for_excl as a
   where upcase(excl) = 'N';
quit;

/*----------------------------------------------
 * Exclude accounts process
 *----------------------------------------------*/
data &_lgd_segmentation_tbl;
   set &_lgdd_non_excluded_accts;

   if months_in_default > 23 then lgdd_segment = 11;
   else if balance_interest < 5000 then lgdd_segment = 10;
   else if upcase(substr(account_id,1,3)) = 'RES' then lgdd_segment = 10;
   else if ins_id_group = 100 then 
   do; 
      /*calculted field:  see brd*/ 
      if not missing(months_in_default) and 6.5 <= months_in_default  then lgdd_segment = 3;

      /*calculted field:  see brd*/
      else if not missing(ltv_teranet) and ltv_teranet < 0.77 then lgdd_segment = 1;
      else lgdd_segment = 2;
   end;
   else if ins_id_group = 300 then 
   do; 
      if not missing(months_in_default) and 6.5 <= months_in_default then lgdd_segment = 6;
      else if not missing(ltv_teranet) and ltv_teranet  <0.77 then lgdd_segment = 4;
      else lgdd_segment = 5;
   end;
   else 
   do;
      if  not missing(months_in_default) and 6.5 <= months_in_default then lgdd_segment  = 9;
      else if  not missing(ltv_teranet) and ltv_teranet  < 0.77 then lgdd_segment  =7;
      else lgdd_segment  = 8;  
   end;
run;


/*--------------------------------------------------------
 * Code to truncate before inserting into NZ table.
 *--------------------------------------------------------*/

proc sql noprint;
   create table tng_lgdd_segmentation1 as
      select a.*
         from &_lgd_segmentation_tbl as a
where month_end_dt >= "&min_24_mon_period."d and month_end_dt <= "&_rundate."d;
quit;

DATA tng_lgdd_segmentation1;
   SET tng_lgdd_segmentation1;
      LGD_BKUP = LGD;
		LGD_COSTS_BKUP = LGD_COSTS;
		LGD_COSTS_CAP_100_BKUP = LGD_COSTS_CAP_100;
		LGD_COSTS_CAP_150_BKUP = LGD_COSTS_CAP_150;
RUN;

/*--------------------------------------------------------
 * Code to truncate before inserting into NZ table.
 *--------------------------------------------------------*/

proc sql noprint;
connect using nz_frg as nz_frg;
   execute (delete from &frg_db..tng_lgdd_segmentation_ifrs where month_end_dt >=%nrbquote('&nz_min_24_mon_period.') and month_end_dt <=%nrbquote('&nz_rundate.')) by nz_frg;
   disconnect from nz_frg;
quit;


proc sql noprint;
   insert into nz_frg.tng_lgdd_segmentation_ifrs (BULKLOAD=YES BL_METHOD=CLILOAD)
      select a.*
         from tng_lgdd_segmentation1 as a;
quit;

