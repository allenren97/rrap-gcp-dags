proc sql;
	create table STEP_1_c as
	select  distinct a.STEP_PLN_SNAPSHOT_ID, a.MTH_TM_ID, a.PRIM_BASEL_CUST_ID as BASEL_CUST_ID, 
			CASE 
				WHEN b.LOCTN_LABEL_2 = 'N/A' then '11'
				ELSE COALESCE(b.LOCTN_LABEL_2,'11') 
			END as METRPL_AREA_NM Length=32 format=$32. informat=$32., 

			COALESCE(C.INDEX,D.HOUSE_INDEX_RTO,E.INDEX) as CRNT_METRPL_TERANET_INDEX,
			COALESCE(CC.INDEX,DD.HOUSE_INDEX_RTO,EE.INDEX) as PREV_12_QTR_METRPL_TERANET_HOUSE,

			b.LOCTN_LABEL_1 as PROV, a.PRPTY_PROV_CD, 
			c.INDEX, d.HOUSE_INDEX_RTO, e.INDEX as COMPOSITE_11,
			cc.INDEX as INDEX_2, dd.HOUSE_INDEX_RTO as HOUSE_INDEX_RTO_2, ee.INDEX as COMPOSITE_11_2,
			ccc.INDEX as INDEX_3, ddd.HOUSE_INDEX_RTO as HOUSE_INDEX_RTO_3, eee.INDEX as COMPOSITE_11_3,
			a.APRSD_VAL, COALESCE(a.APRSD_DT,a.CR_LMT_DT) format=date9. as APRSD_DT, f.FNCL_MTH_KEY as APRSD_DT_MTH_TM_ID,
			COALESCE(CCC.INDEX,DDD.HOUSE_INDEX_RTO,EEE.INDEX) as APRSD_DT_INDEX,
	        ROUND((a.APRSD_VAL/calculated APRSD_DT_INDEX),0.001) as APPRSL_DT_PRPTY_VAL_AMT, 
		 /*	ROUND(calculated APPRSL_DT_PRPTY_VAL_AMT,0.001) * calculated CRNT_METRPL_TERANET_INDEX as CRNT_PRPTY_VAL_AMT,
			ROUND(calculated APPRSL_DT_PRPTY_VAL_AMT,0.001) * calculated PREV_12_QTR_METRPL_TERANET_HOUSE as PREV_12_QTR_PRPTY_VAL_AMT */
		 	ROUND((calculated APPRSL_DT_PRPTY_VAL_AMT * calculated CRNT_METRPL_TERANET_INDEX),0.001) as CRNT_PRPTY_VAL_AMT,
			ROUND((calculated APPRSL_DT_PRPTY_VAL_AMT * calculated PREV_12_QTR_METRPL_TERANET_HOUSE),0.001) as PREV_12_QTR_PRPTY_VAL_AMT  

	FROM 

	NZRRAP.BASEL_STEP_PLN_MTH_SNAPSHOT a 

	inner join NZRRAP.BASEL_STEP_PLN_BASE_DRVD_VAR_CMA b
	on  a.mth_tm_id=b.mth_tm_id and a.STEP_PLN_SNAPSHOT_ID=b.BASEL_STEP_PLN_SNAPSHOT_ID
	
	left join NZUSER.TERANET_HOUSE_PRC_INDEX_tmp_c c
	on upcase(b.LOCTN_LABEL_1)=upcase(c.LABEL_1) and %translate(b.LOCTN_LABEL_2) = %translate(c.LABEL_2)
	and c.mth_tm_id = (select max(mth_tm_id) from NZUSER.TERANET_HOUSE_PRC_INDEX_tmp_c where mth_tm_id le &mth_tm_id.
	and upcase(b.LOCTN_LABEL_1)=upcase(LABEL_1) and %translate(b.LOCTN_LABEL_2) = %translate(LABEL_2))

	left join NZUSER.PROVNCL_HOUSE_INDEX_SUM_tmp_c d
	on a.mth_tm_id=d.mth_tm_id and a.PRPTY_PROV_CD = d.PROV_CD

	left join NZUSER.TERANET_HOUSE_PRC_INDEX_tmp_c e
	on STRIP(UPCASE(e.LABEL_1)) = 'COMPOSITE' and STRIP(e.LABEL_2) = '11'
	and e.mth_tm_id = (select max(mth_tm_id) from NZUSER.TERANET_HOUSE_PRC_INDEX_tmp_c where mth_tm_id le &mth_tm_id.
	and STRIP(UPCASE(LABEL_1)) = 'COMPOSITE' and STRIP(LABEL_2) = '11')


	left join NZUSER.TERANET_HOUSE_PRC_INDEX_tmp_c cc
	on upcase(b.LOCTN_LABEL_1)=upcase(cc.LABEL_1) and %translate(b.LOCTN_LABEL_2) = %translate(cc.LABEL_2)
	and cc.mth_tm_id = &mth_tm_id -12*3*40

	left join NZUSER.PROVNCL_HOUSE_INDEX_SUM_tmp_c dd
	on dd.mth_tm_id =&mth_tm_id -12*3*40 and a.PRPTY_PROV_CD = dd.PROV_CD

	left join NZUSER.TERANET_HOUSE_PRC_INDEX_tmp_c ee
	on UPCASE(ee.LABEL_1) = 'COMPOSITE' and ee.LABEL_2 = '11'
	and ee.mth_tm_id = &mth_tm_id -12*3*40


	left join NZRRAP.TM_DIM f
	on COALESCE(a.APRSD_DT,a.CR_LMT_DT) = f.day_dt 


	left join NZUSER.TERANET_HOUSE_PRC_INDEX_tmp_c ccc
	on upcase(b.LOCTN_LABEL_1)=upcase(ccc.LABEL_1) and %translate(b.LOCTN_LABEL_2) = %translate(ccc.LABEL_2)
	and ccc.mth_tm_id = f.FNCL_MTH_KEY

	left join NZUSER.PROVNCL_HOUSE_INDEX_SUM_tmp_c ddd
	on ddd.mth_tm_id = f.FNCL_MTH_KEY and a.PRPTY_PROV_CD = ddd.PROV_CD

	left join NZUSER.TERANET_HOUSE_PRC_INDEX_tmp_c eee
	on UPCASE(eee.LABEL_1) = 'COMPOSITE' and eee.LABEL_2 = '11'
	and eee.mth_tm_id = f.FNCL_MTH_KEY

	where a.mth_tm_id = &mth_tm_id. 
	order by a.STEP_PLN_SNAPSHOT_ID;
quit;


