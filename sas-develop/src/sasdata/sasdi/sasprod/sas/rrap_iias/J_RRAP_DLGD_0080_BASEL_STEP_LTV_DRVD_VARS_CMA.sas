/*
If join on step plan id and month time id, if could found LOAN_TO_VAL_WITH_TERANET_INDEX_RTO then retreive it, otherwise, Perform calculation below:

Step 1: Retrieve the Sum of Outstanding Balances for all the Mortgage Account IDs belonging to the same Step Plan Number 
(a) Retrieve all the Mortgage accounts from table [Basel Mortgage Monthly Snapshot] that have same Step plan ID  for the processing month
(b) For the mortgage accounts in step (a), calculate the sum of 'Outstanding Balance Amount' ' from [Basel Mortgage Account Derived variables] for the processing month

Step 2: Retrieve the Sum of Outstanding Balances for all the Personal Loan Account IDs belonging to the same Step Plan Number
(a) Retrieve all the  Personal Loan accounts from table [Basel Personal Loan Monthly Snapshot] that have same Step plan ID  for the processing month
(b) For the Personal Loan accounts in step (a), calculate the sum of 'Outstanding Balance Amount' from [Basel Personal Loan Account Derived variables] for the processing month

Step 3: Calculate LTV using Teranet
LTV using Teranet = (Add up the Balance calculated in Step 1 and step 2) / (Current House Price Value for this step plan id)
*/

/*NOTE: Table WORK.TERA_LTV created, with 576256 rows and 5 columns.*/

proc sql;
	create table KS_c as
	select  distinct a.STEP_PLN_SNAPSHOT_ID, a.MTH_TM_ID , SUM(c.TOT_NEW_BAL_AMT) as KS_BAL
	FROM 

	NZRRAP.BASEL_STEP_PLN_MTH_SNAPSHOT a 

	inner join NZRRAP.BASEL_REVLVNG_CR_MTH_SNAPSHOT c
	on a.mth_tm_id = c.mth_tm_id and a.STEP_PLN_SNAPSHOT_ID = c.STEP_PLN_SNAPSHOT_ID 

/*	inner join nzrrap.BASEL_REVLVNG_CR_ACCT_DRVD_VARS d*/
/*	on a.mth_tm_id = d.mth_tm_id and c.BASEL_ACCT_ID=d.BASEL_ACCT_ID*/

	where a.mth_tm_id = &mth_tm_id.
	group by 1,2
	order by a.STEP_PLN_SNAPSHOT_ID
;quit;

proc sql;
	create table MOR_c as
	select distinct a.STEP_PLN_SNAPSHOT_ID, a.MTH_TM_ID ,sum(c.OS_BAL_AMT) as MOR_BAL
	FROM 

	NZRRAP.BASEL_STEP_PLN_MTH_SNAPSHOT a 

	inner join nzrrap.BASEL_MORT_MTH_SNAPSHOT b
	on a.mth_tm_id = b.mth_tm_id 
	and a.STEP_PLN_SNAPSHOT_ID = b.STEP_PLN_SNAPSHOT_ID

	inner join nzrrap.BASEL_MORT_ACCT_DRVD_VARS c
	on a.mth_tm_id = c.mth_tm_id
	and b.BASEL_ACCT_ID = c.BASEL_ACCT_ID

	where a.mth_tm_id = &mth_tm_id.
	group by 1,2
	order by a.STEP_PLN_SNAPSHOT_ID
;quit;

proc sql;
	create table SPL_c as
	select distinct a.STEP_PLN_SNAPSHOT_ID, a.MTH_TM_ID ,sum(c.OS_BAL_AMT) as SPL_BAL
	FROM 

	NZRRAP.BASEL_STEP_PLN_MTH_SNAPSHOT a 

	inner join nzrrap.BASEL_PSNL_LOAN_MTH_SNAPSHOT b
	on a.mth_tm_id = b.mth_tm_id 
	and a.STEP_PLN_SNAPSHOT_ID = b.STEP_PLN_SNAPSHOT_ID

	inner join nzrrap.BASEL_PSNL_LOAN_ACCT_DRVD_VARS c
	on a.mth_tm_id = c.mth_tm_id
	and b.BASEL_ACCT_ID = c.BASEL_ACCT_ID

	where a.mth_tm_id = &mth_tm_id.
	group by 1,2
	order by a.STEP_PLN_SNAPSHOT_ID
;quit;

data STEP_LTV_DRVD_VARS_PRELOAD_c;
	KEEP 
		STEP_PLN_SNAPSHOT_ID
		MTH_TM_ID
		BASEL_CUST_ID
		METRPL_AREA_NM
		CRNT_METRPL_TERANET_INDEX
		PREV_12_QTR_METRPL_TERANET_HOUSE
		APPRSL_DT_PRPTY_VAL_AMT
		CRNT_PRPTY_VAL_AMT
		PREV_12_QTR_PRPTY_VAL_AMT
		INSRT_PROCESS_TMSTMP
		UPDT_PROCESS_TMSTMP;

	merge STEP_1_c (in=one) spl_c (in=spl_c) mor_c (in=mor_c) ks_c (in=ks_c);
	by STEP_PLN_SNAPSHOT_ID;
	if one;* and (spl and mor and ks);
/*	INDEXED_CCLTV_RTO=SUM(KS_BAL,SPL_BAL,MOR_BAL)/CRNT_PRPTY_VAL_AMT;*/
	FORMAT INSRT_PROCESS_TMSTMP UPDT_PROCESS_TMSTMP datetime25.6;
	INSRT_PROCESS_TMSTMP = "&SYSDATE9.:&SYSTIME"dt;
	UPDT_PROCESS_TMSTMP = "&SYSDATE9.:&SYSTIME"dt;
run;

