         create table BASEL_PSNL_LOAN_INSTRMNT_ADJ as 
         select * from connection to nzcon(	
         
         WITH TOTAL_SPL_by_GL as
         (SELECT a.gl_acct_num , a.gl_trnst_num , a.mth_end_dt ,a.crncy_cd , a.AIRB_Adj_Coa_Amt Adj_Amt, sum(abs(e.OS_BAL_AMT_V2)) GL_TOT_CRNT_BAL_SUM
            FROM 	   &RRAP_DB..AIRB_RECON_APRVD_SNAPSHOT a,
                        &RRAP_DB..BASEL_PSNL_LOAN_MTH_SNAPSHOT b,
                        &RRAP_DB..BASEL_PSNL_LOAN_ACCT_DRVD_VARS c,
                        &RRAP_DB..BASEL_PSNL_LOAN_ACCT_DRVD_VARS_2 e,
                        &RRAP_DB..TM_DIM d
         WHERE a.gl_acct_num=b.gl_acct_num
             AND a.gl_trnst_num=b.gl_trnst_num
             AND a.mth_end_dt=d.tm_lvl_end_dt
             AND tm_lvl='Month'
             AND b.mth_tm_id = d.tm_id
             AND a.src_sys_cd = 'SPL'
         /*    AND a.crncy_cd = b.crncy_cd*/
             AND a.crncy_cd = 'CAD'
             AND b.basel_acct_id = c.basel_acct_id
             AND b.mth_tm_id = c.mth_tm_id
             AND c.basel_acct_id = e.basel_acct_id
             AND c.mth_tm_id = e.mth_tm_id
             AND e.TREATMNT_F = 'A'
             AND c.TRNST_EXCLSN_F = 'N'
             AND e.PIT_STATUS_V2 IN ('CUR','DEF')
             AND a.mth_end_dt=&nz_rundate.
         GROUP BY a.gl_acct_num, a.gl_trnst_num, a.mth_end_dt,a.crncy_cd, a.AIRB_Adj_Coa_Amt)
         
         SELECT 
         		 b.mth_tm_id
         		,b.basel_acct_id
         		,cast(round(round(abs(e.OS_BAL_AMT_V2)/a.GL_TOT_CRNT_BAL_SUM,6)*a.Adj_Amt,3) as decimal(17,3)) GENL_LEDGER_BAL_ADJ_AMT
         		,cast(round(round(abs(e.OS_BAL_AMT_V2)/a.GL_TOT_CRNT_BAL_SUM,6)*a.Adj_Amt + e.OS_BAL_AMT_V2,3) as decimal(17,3)) AF_ADJ_OS_BAL_AMT
         		,e.OS_BAL_AMT_V2 as OS_BAL_AMT
         		,'Adjustments' as AUTO_GENRTD_CMNT
         		,now() as INSRT_PROCESS_TMSTMP
         		,now() as UPDT_PROCESS_TMSTMP
         
          FROM TOTAL_SPL_by_GL a,
                       &RRAP_DB..BASEL_PSNL_LOAN_MTH_SNAPSHOT b,
                       &RRAP_DB..BASEL_PSNL_LOAN_ACCT_DRVD_VARS c,
                       &RRAP_DB..BASEL_PSNL_LOAN_ACCT_DRVD_VARS_2 e,
                       &RRAP_DB..TM_DIM d
           WHERE a.gl_acct_num=b.gl_acct_num
             AND a.gl_trnst_num=b.gl_trnst_num
             AND a.mth_end_dt=d.tm_lvl_end_dt
             AND tm_lvl='Month'
             AND b.mth_tm_id = d.tm_id
         /*    AND a.crncy_cd = b.crncy_cd*/
             AND a.crncy_cd = 'CAD'
             AND b.basel_acct_id = c.basel_acct_id
             AND b.mth_tm_id = c.mth_tm_id
             AND c.basel_acct_id = e.basel_acct_id
             AND c.mth_tm_id = e.mth_tm_id
             AND e.TREATMNT_F = 'A'
             AND c.TRNST_EXCLSN_F = 'N'
             AND e.PIT_STATUS_V2 IN ('CUR','DEF')
             AND a.mth_end_dt=&nz_rundate.
            AND c.basel_acct_id not in   
         /*    --- EXCLUDE misclassification*/
                         (SELECT b.basel_acct_id 
                           FROM &RRAP_DB..BASEL_PSNL_LOAN_MTH_SNAPSHOT b,
                                        &RRAP_DB..BASEL_PSNL_LOAN_ACCT_DRVD_VARS c,
                                        &RRAP_DB..BASEL_PSNL_LOAN_ACCT_DRVD_VARS_2 e,
                                        &RRAP_DB..TM_DIM d
                         WHERE tm_lvl='Month'
                             AND b.mth_tm_id = d.tm_id
                             AND b.basel_acct_id = c.basel_acct_id
                             AND b.mth_tm_id = c.mth_tm_id
                             AND c.basel_acct_id = e.basel_acct_id
                             AND c.mth_tm_id = e.mth_tm_id
                             AND c.TRNST_EXCLSN_F = 'N'
