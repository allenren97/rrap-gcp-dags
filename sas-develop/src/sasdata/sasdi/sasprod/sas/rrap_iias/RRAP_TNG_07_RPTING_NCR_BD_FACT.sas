/*---------------------------------------------------------------------
 * NAME:       07_bns_rpting_ncr_bd_fact.sas
 *
 * PURPOSE:    Pulls together the data needed to feed into the reporting
 *             table BASEL_RPTG_BL_AGGRTD_NCR_BD_FACT
 *             
 * NOTES:    
 *             1. This needs to be run on a monthly basis because the 
 *                1 year and 3 year historical months will change each
 *                month. 
 * 
 * MODIFIED:
 *    20JAN2015 - JL - Created
 *    24JAN2015 - JL - Change to macro vars
 *    01FEB2015 - JL - Updated join logic
 *    26FEB2015 - JL - Updated count of defaults in 3 months window
 *
 * Copyright (c) 2014 by The Financial Risk Group, Cary, NC, USA.
 *---------------------------------------------------------------------*/

 
/* EXTRACT RUN DATE FROM CONTROL TABLE */

%get_model_period_dates(product=mor);

%put Start and End Dates for Mortgage Models:;
%put start_period_dt: &start_period_dt ;
%put end_period_dt: &end_period_dt;

 /*-------------------------------------------------------
 * Assigning the start and end dates to run the code.
 *-------------------------------------------------------*/

%let start_period_dt = &start_period_dt.; 
%let end_period_dt = &end_period_dt.;


%macro delete_table(table_name);

  %if %sysfunc(exist(&table_name)) %then %do;
     proc sql noprint;
     drop table &table_name.;
     quit;
  %end;

%mend delete_table;

/*-------------------------------------------------------
 * Assigning table databases and table names.
 *-------------------------------------------------------*/

%let nz_intmed_db = &FRG_DB;
%let nz_results_db = &FRG_DB;

%let sas_nz_source_lib = nzuser;
%let input_history_tbl_db=nz_frg;
%let sas_nz_intmed_lib = nz_frg;
%let sas_nz_results_lib = nz_frg;



%let _in_tbl_for_bd_fact=history_tbl_for_bd_be_fact_tng;

%let spl_bd_fact_table=basel_rptg_bd_fact_tng;


/*--------------------------------------------------------
 * Beginning of macro to process each month incrementally.
 *--------------------------------------------------------*/

%macro tng_ncr_bd_fact(start_period_dt=,end_period_dt=);

   /*--------------------------------------------------------
    * Defining the number of periods the status process will 
    * run.  Each period will be processed incrementally.
    *--------------------------------------------------------*/
   data _null_;
      call symput('number_periods', cats(intck('month', "&start_period_dt"d, "&end_period_dt"d)));
   run;

   /*--------------------------------------------------------
    * Loop over all months for the range specified by the 
    * start and end period dates.
    *--------------------------------------------------------*/
    %do ii = 0 %to &number_periods;

      /*----------------------------------------------------
       * Setting date macros variables for NZ date
       * literal format based off of start_period_dt and 
       * end_period_dt formats. NZ requires date literals to
       * be in following format: YYYY-MM-DD
       *----------------------------------------------------*/
      data _null_;
         call symput('period_dt', cats(put(intnx('month', "&start_period_dt"d, &ii, 'e'), date9.)));
         call symput('period_dt_nz', cats(put(intnx('month', "&start_period_dt"d, &ii, 'e'), yymmdd10.)));
         call symput('three_months_ago', cats(put(intnx('month', "&start_period_dt"d, -3 + &ii, 'e'), yymmdd10.)));
      run;

      proc sql noprint;
         select tm_id into :_mth_tm_id from &sas_nz_source_lib..tm_dim where tm_lvl_end_dt="&period_dt"d and tm_lvl='Month';
      quit;

      %put NOTE: USER DEFINED: SPL NCR BD FACT table process for Process date: &period_dt;


      /*---------------------------------------------------
       * 1. Gets a table of distinct values. This will
       *    define the aggregations available
       *---------------------------------------------------*/
      proc sql noprint;
         create table work.bd_distinct_groupings1 as 
         select distinct a.process_date,
                         a.mth_tm_id,
                         a.ncr_expsr_cl_key_val,
                         a.ncr_geo_key_val,
                         a.ncr_pd_band_key_val,
                         a.src_sys_cd
         from &input_history_tbl_db..&_in_tbl_for_bd_fact as a
         where intnx('month', datepart(a.process_date), 0, 'e') = "&period_dt"d;
      quit;      

      /*---------------------------------------------------
       * 2. Count of realized defaults - 3 months ago
       *---------------------------------------------------*/

      %delete_table(&sas_nz_intmed_lib..period_accts);

      proc sql noprint;
			connect using &sas_nz_source_lib as nzcon;
/*         connect to netezza as nzcon (server=cs2iwntzp01 database=frg_user_q3_2015 user = &_userid password = &_pwd_nz);*/
         execute (      

            create table %nrbquote(&nz_intmed_db..period_accts) as (
               select a.process_date,
                      a.mortgage_no      

            from %nrbquote(&nz_intmed_db..&_in_tbl_for_bd_fact) as a      

            /* Subset on date */     
            where last_day(date_trunc('day', a.process_date)) = %nrbquote('&period_dt_nz')       

            /* For speed at creating table */
           /* distribute on (mortgage_no)) by nzcon; */
		  ) WITH DATA distribute By (mortgage_no) ) by nzcon;
         disconnect from nzcon;
      quit; 

      %delete_table(&sas_nz_intmed_lib..period_def_cnt);   

      proc sql noprint;
		connect using &sas_nz_source_lib as nzcon;
/*         connect to netezza as nzcon (server=cs2iwntzp01 database=frg_user_q3_2015 user = &_userid password = &_pwd_nz);*/
         execute (      

            create table %nrbquote(&nz_intmed_db..period_def_cnt) as (
               select a.process_date,
                      a.mortgage_no,
                      a.ncr_expsr_cl_key_val,
                      a.ncr_geo_key_val,
                      a.ncr_pd_band_key_val,
                      a.src_sys_cd,
                      a.pit_stat_cd      

            from %nrbquote(&nz_intmed_db..&_in_tbl_for_bd_fact) as a
                 inner join
                 %nrbquote(&nz_intmed_db..period_accts) as b
                 on a.mortgage_no = b.mortgage_no      

            /* Subset on date */     
            where last_day(date_trunc('day', a.process_date)) >= %nrbquote('&three_months_ago') and
                  last_day(date_trunc('day', a.process_date)) <= %nrbquote('&period_dt_nz')       

            order by a.mortgage_no,
                     a.process_date desc      

              /* For speed at creating table */
            /* distribute on (mortgage_no)) by nzcon; */
			 ) WITH DATA distribute By (mortgage_no)) by nzcon;
         disconnect from nzcon;
      quit;            

      /* Counts those accounts that go into default in a three month period */
      data work.period_def_cnt1;
         set &sas_nz_intmed_lib..period_def_cnt;      

         retain def_in_period 0 
                already_defaulted 0;      

         by mortgage_no process_date;      

         /* First period - if in DEF then count as default */
         if first.mortgage_no = 1 and first.process_date = 1 then
         do;
            def_in_period = 0;
            already_defaulted = 0;
            if upcase(pit_stat_cd) = 'DEF' then 
            do;
               def_in_period = 1;
               already_defaulted = 1;
            end;
         end;      

         /* All other periods - if in DEF then count as default */
         else if first.mortgage_no = 0 and already_defaulted = 0 then
         do;
            if upcase(pit_stat_cd) = 'DEF' then 
            do;
               def_in_period = 1;
               already_defaulted = 1;
            end;
         end;      

         if last.mortgage_no = 1 then output;
      run;      

      proc summary data=work.period_def_cnt1 nway missing;
         class ncr_expsr_cl_key_val
               ncr_geo_key_val
               ncr_pd_band_key_val
               src_sys_cd;      

         var def_in_period;      

         output out = work._3mos_ago_def_cnt (drop = _freq_ _type_)
         sum = prior_3_mth_realz_defltd_cnt;
      run;
             
      /*---------------------------------------------------
       * 3. Estimated defaulted loan count process
       *---------------------------------------------------*/
      proc sql noprint;
         create table work._est_def_metrics as 
         select a.ncr_expsr_cl_key_val,
                a.ncr_geo_key_val,
                a.ncr_pd_band_key_val,
                a.src_sys_cd,      

                /* Count and average PD */
                count(*) as count_by_segment,
                avg(a.pd_final_rptg_rto) as avg_by_segment
              
         from &input_history_tbl_db..&_in_tbl_for_bd_fact as a
         where intnx('month', datepart(a.process_date), 0, 'e') = "&period_dt"d 
         group by a.ncr_expsr_cl_key_val, 
                  a.ncr_geo_key_val,
                  a.ncr_pd_band_key_val,
                  a.src_sys_cd ;
      quit;      

      /*---------------------------------------------------
       * 4. Join results together 
       *---------------------------------------------------*/
      proc sql noprint;
         create table work.ncr_bd_fact as
         select a.process_date,
                a.mth_tm_id,
                a.ncr_expsr_cl_key_val,
                a.ncr_geo_key_val,
                a.ncr_pd_band_key_val,
                a.src_sys_cd,      

                /* Prior three months realized defaulted loan count */
                (case 
                  when b.prior_3_mth_realz_defltd_cnt EQ . then 0
                  else b.prior_3_mth_realz_defltd_cnt
                  end) as prior_3_mth_realz_defltd_cnt,      

                /* Estimated defaulted loan count */
                (case
                  when c.count_by_segment NE . and c.avg_by_segment NE . then round(c.count_by_segment*c.avg_by_segment, 1)
                  else .
                  end) as estd_defltd_loan_cnt      

         from work.bd_distinct_groupings1 as a
              left join 
              work._3mos_ago_def_cnt as b
              on (a.ncr_expsr_cl_key_val = b.ncr_expsr_cl_key_val and
                  a.ncr_geo_key_val = b.ncr_geo_key_val and
                  a.ncr_pd_band_key_val = b.ncr_pd_band_key_val and
                  a.src_sys_cd = b.src_sys_cd)      

              left join
              work._est_def_metrics as c
              on (a.ncr_expsr_cl_key_val = c.ncr_expsr_cl_key_val and
                  a.ncr_geo_key_val = c.ncr_geo_key_val and
                  a.ncr_pd_band_key_val = c.ncr_pd_band_key_val and
                  a.src_sys_cd = c.src_sys_cd);
      quit;      

      /*----------------------------------------------------
       * 5. Load to final table
       *----------------------------------------------------*/  

      /*---------------------------------------------
       * Checks to see if the date is in NZ table 
       *---------------------------------------------*/
   
      /*---------------------------------------------
       * If data already exists for the month, then 
       * run delete from code.
       *---------------------------------------------*/

         proc sql noprint;
            connect using &sas_nz_results_lib as nzcon;
            execute (
               delete from %nrbquote(&nz_results_db..&spl_bd_fact_table)
               where mth_tm_id = %nrbquote('&_mth_tm_id')
            ) by nzcon;
         quit;
  
      proc sql noprint;
         insert into &sas_nz_results_lib..&spl_bd_fact_table 
         select a.mth_tm_id,
                a.ncr_expsr_cl_key_val,
                a.ncr_pd_band_key_val,
                a.ncr_geo_key_val,
                a.src_sys_cd,
                a.prior_3_mth_realz_defltd_cnt,
                a.estd_defltd_loan_cnt,
               datetime() as insrt_process_tmstmp format = datetime21.,
               datetime() as updt_process_tmstmp format = datetime21.
         from work.ncr_bd_fact as a ;
      quit;

		/* Load to BD fact table for MOR/TNG */
		proc sql;
        	connect using &sas_nz_results_lib as nzcon;
            execute (delete from &nz_results_db..BASEL_RPTG_BL_AGGRTD_NCR_BD_FACT where SRC_SYS_CD = 'TNG-MOR') by nzcon; 
            disconnect from nzcon;

			insert into &sas_nz_results_lib..BASEL_RPTG_BL_AGGRTD_NCR_BD_FACT (bulkload=yes bl_method=cliload) 
		    select * from &sas_nz_results_lib..&spl_bd_fact_table where MTH_TM_ID = &_mth_tm_id.;
        quit;
   %end;
%mend tng_ncr_bd_fact;
%tng_ncr_bd_fact(start_period_dt = &start_period_dt, end_period_dt =&end_period_dt);


/*---- End of User Written Code  ----*/ 

