		 did = dopen(fref);
		 rc = filename(fref);
		end;
		else do;
		 length msg $200.;
		 msg = sysmsg();
		 put msg=;
		 did = .;
		end;
		if did <= 0 then putlog 'ERR' 'OR: Unable to open directory.';
		dnum = dnum(did);
		do i = 1 to dnum;
		 files = dread(did, i);
