/*********************************************************************************************************
		TNG_ACCT_INDCOST data fix - as per the indirect cost changes - Feb2017
**********************************************************************************************************/
proc sql;
	create table Delq_Accounts as
	select YEAR(MONTH_END_DT) as YEAR, 'Delinquent Accounts' as COST_TYPE, count( distinct ACCOUNT_ID) as AMOUNT
	FROM netcon.TNG_ACCT_MO 
	WHERE DAYS_ARREARS_CNT > 0 
	group by 1,2
	order by 1;
QUIT;


data MIS_DATES;
	format YEAR 5. ;
	length COST_TYPE $ 200;
	YEAR=2005;  COST_TYPE="Estimated costs"; Amount=346000;
run;

proc sql;
	CREATE TABLE IND_TABLE AS 
	select 	*
	from nz_frg.TNG_ACCT_INDCOST
	where COST_TYPE ne 'Defaulted accounts' and COST_TYPE ne 'Cost per account'
	union 
	select * from MIS_DATES
	order by year, cost_type;
quit;

proc sql;
create table ACcount_cost as
select t1.year, 'Cost per account' as COST_TYPE, t1.Amount/t2.amount as Amount
from  
	(select p1.*
	from WORK.IND_TABLE p1
	where p1.COST_TYPE='Estimated costs') 
t1
left join 
WORK.Delq_Accounts t2

on t1.Year=t2.year
;
quit;

proc sql;
	create table TNG_ACCT_INDCOST as 
		select t1.*
			from WORK.IND_TABLE t1
				union 
			select t2.*
				from WORK.Delq_Accounts t2
					union 
				select t3.*
					from work.ACcount_cost t3;
quit;



proc sql;
delete from netcon.TNG_ACCT_INDCOST;
quit;

proc append base=netcon.TNG_ACCT_INDCOST (BULKLOAD=YES BL_METHOD=CLILOAD) data=TNG_ACCT_INDCOST force; run;

