         proc sql noprint;
            create table work.with_pd_lgd_ccar_2 as
               select a.*,
                      b.ccar_expsr_cl_nm
                  from work.with_pd_lgd_ccar as a
                       left join
                       &_ref_expr_class as b
                       on upcase(a.ncr_expsr_cl_key_val)=upcase(b.ncr_expsr_cl_key_val);
         quit;
            
         
         /*-------------------------------------------------------------------------------
          * Adding the logic for outstanding transformation logic per Sreeraj email.
          *-------------------------------------------------------------------------------*/
         
         /*Logic to calculate ncr_geo_key_val*/
         
         data work.ncr_geo;
            length prop_desc $30;
            set tngdata.tng_acct_mo (keep= account_id
                                           month_end_dt
                                           prop_province_code
                                           fsa);
         
           if prop_province_code='' or prop_province_code='?' then 
                                                                do;
                                                                   if substr(FSA ,1,1)='A' then province='NL';
                                                                      else if  substr(FSA ,1,1)='B' then province='NS';
                                                                      else if  substr(FSA ,1,1)='C' then province='PE';
                                                                      else if  substr(FSA ,1,1)='E' then province='NB';
                                                                      else if  substr(FSA ,1,1)='G' or  substr(FSA ,1,1)='H' or substr(FSA ,1,1)='J' then province='QC';
                                                                      else if  substr(FSA ,1,1)='R' then province='MB';
                                                                      else if  substr(FSA ,1,1)='S' then province='SK';
                                                                      else if  substr(FSA ,1,1)='T' then province='AB';
                                                                      else if  substr(FSA ,1,1)='V' then province='BC';
                                                                      else if  substr(FSA ,1,1)='X' then province='NT';
                                                                      else if  substr(FSA ,1,1)='Y' then province='YT';
                                                                      else if account_id='MBS~370528'  then province='MB';
                                                                      else if account_id='MBS~370579'  then province='BC';
                                                                      else province='ON';
                                                               end;
               else 
                    do;
                       province=prop_province_code;
                    end;
            if province='NW' then province='NT';
            if province='NO' then province='NS';
            if upcase(province)='ON' then prop_desc='Ontario';
            else if upcase(province)='QC' then prop_desc='Quebec';
            else if upcase(province)='NT' then prop_desc='Northwest Territories';
            else if upcase(province)='SK' then prop_desc='Saskatchewan';
            else if upcase(province)='PE' then prop_desc='Prince Edward Island';
            else if upcase(province)='YT' then prop_desc='Yukon';
            else if upcase(province)='NU' then prop_desc='Nunavut';
            else if upcase(province)='NS' then prop_desc='Nova Scotia';
            else if upcase(province)='MB' then prop_desc='Manitoba';
            else if upcase(province)='NL' then prop_desc='Newfoundland and Labrador';
            else if upcase(province)='NB' then prop_desc='New Brunswick';
            else if upcase(province)='AB' then prop_desc='Alberta';
            else if upcase(province)='BC' then prop_desc='British Columbia';
         run;        
          
