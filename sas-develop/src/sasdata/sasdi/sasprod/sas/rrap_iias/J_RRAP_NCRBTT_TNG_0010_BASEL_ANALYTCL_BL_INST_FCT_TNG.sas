                      a.close_dt as pd_off_dt,
                      case
                         when a.close_dt ^= . then 'Y'
                         when a.close_dt = . then 'N'
                      end as pd_off_f,
                      case 
                         when upcase(a.final_default_ind)='N' then 'CUR'
                         when upcase(a.final_default_ind)='Y' then 'DEF'
                         else ''
                      end as pit_stat_cd,
              
                      /* Hard-coded values */ 
                      'TNG-MOR' as src_sys_cd length = 10,
                      '0207' as ncr_rt_sys_key_val length = 4,
                      1 as utltn_rto format = 20.8,
                      0 as cr_lmt_amt format = 20.8,
                      0 as unadjusted_add_on_bal_amt format = 17.3,
                      . as ead_acct_score,
                      0 as cust_behv_score,
                      '' as acct_num length = 23,
                      '' as loan_num length = 15,
                      '' as prd_cd length = 10,
                      '' as sub_prd_cd length = 10,
                      . as last_pymt_dt,
                      '' as scrty_tp_cd length = 10,
                      . as last_acty_dt,
                      . as e_mat_dt,
                      . as note_dt,
                      . as last_rgl_pay_dt,
                      'N' as sml_bus_f length = 1,
         
                      /* Per Sreeraj email - leave blank */
                      . as basel_acct_id,
         
                      /* PD Variables */
                      '3.0' as pd_model_ver length = 10,
                      'TNG MOR PD' as pd_model_nm length = 40,
                      'TNG MOR PD Scorecard' as pd_basel_scorecrd_nm length = 40,
                      '3.0' as pd_scorecrd_ver length = 10,
         
                      '3.0' as pd_seg_ver length = 10,
                      . as pd_basel_seg_id,
                      -1 as pd_basel_model_rel_id,
         
         
         
         
                      /* EAD variables */
                      '' as ead_model_nm length = 40,
                      '' as ead_model_ver length = 10,
                      '' as ead_basel_scorecrd_nm  length = 40,
                      '' as ead_scorecrd_ver length = 10,
                      01 as ead_basel_seg_num,
                      '' as ead_seg_ver length = 10,
                      . as ead_basel_seg_id,
                      -1 as ead_basel_model_rel_id,
                      1.0 as ead_model_rto format = 28.8,
                      1.0 as ead_lr_rptg_rto format = 28.8,
                      0 as ead_lr_pv_rptg_rto format = 28.8,
                      0 as ead_lr_pv_ad_rptg_rto format = 28.8,
                      0 as ead_ld_pv_ad_sv_rptg_rto format = 28.8,
                      0 as ead_ld_pv_ad_sv_dt_rptg_rto format = 28.8,
                      1.0 as ead_final_rptg_rto format = 28.8,
                      0 as ead_unadjusted_rptg_rto format = 28.8,
                      0 as ead_lr_pv_ad_sv_dt_aa_rto format = 28.8,
         
                      e.def_ind as default_ind,
                      e.final_defaultbal as default_bal
         
                  from &_in_status_tbl as a 
                 
         
                       left join
                       &_ref_time_tbl as d
                       on (intnx('month', a.month_end_dt, 0, 'e') = d.tm_lvl_end_dt and
                           upcase(d.tm_lvl) = 'MONTH')
                       
                      left join
                      &_12mth_def_tbl as e
                      on (a.account_id = e.account_id and
                           intnx('month', a.month_end_dt, 0, 'e') = intnx('month', e.month_end_dt, 0, 'e'))
         /*          where intnx('month', a.month_end_dt, 0, 'e')="31OCT2014"d;*/
                  where "&forty_mth_window"d <= intnx('month', a.month_end_dt, 0, 'e') <= "&_run_date"d;
         quit;
         
         
         /*------------------------------------------------------------------------
          * Calculating months_in_default and joining result to base table.
          *------------------------------------------------------------------------*/
         
         
         proc sql noprint;
               create table work.accts_in_def as
               select a.account_id
               from work.tng_pd_ead as a
               where upcase(a.pit_stat_cd) = 'DEF' and intnx('month', a.month_end_dt, 0, 'e') = "&_run_date"d;
         
           
               create table work.for_month_def as
               select a.account_id,
                      a.pit_stat_cd,
                      a.month_end_dt,
                      (case 
                        when upcase(a.pit_stat_cd) = 'DEF' and intnx('month', a.month_end_dt, 0, 'e') = "&_run_date"d then 0
                        when upcase(a.pit_stat_cd) = 'DEF' and intnx('month', a.month_end_dt, 0, 'e') < "&_run_date"d then 1
                        else 0
                        end) as def_counter
               from work.tng_pd_ead as a
                    inner join 
                    work.accts_in_def as b
                    on a.account_id = b.account_id 
               where intnx('month', a.month_end_dt, 0, 'e') <= "&_run_date"d and
                     intnx('month', a.month_end_dt, 0, 'e') >= "&_run_date24"d
               order by a.account_id, a.month_end_dt desc;
           
         quit;
         
         
         data work.count_def_month (rename=(month_def=months_in_default)drop = status_cur p_date def_counter pit_stat_cd);
            set work.for_month_def (rename = (month_end_dt = p_date));
            retain month_def status_cur month_end_dt;
         
            by account_id descending p_date;
            format month_end_dt date9.;
         
            if first.account_id = 1 then
            do;
               month_def = 0;
               status_cur = '';
               month_end_dt = p_date;
            end;
         
            if first.account_id ^= 1 then 
            do;
               if status_cur = '' and upcase(pit_stat_cd) = 'DEF' then month_def = month_def + 1;
               else status_cur = 'Y';
            end;
         
            if last.account_id = 1 then output;
         run;
         
         
         proc sql noprint;
            create table work.with_pd_ead_mth_def as
               select a.*,
                      b.months_in_default
                  from work.tng_pd_ead as a
                       left join
                       work.count_def_month as b
                       on (a.account_id = b.account_id and
                           intnx('month', a.month_end_dt, 0, 'e') = intnx('month', b.month_end_dt, 0, 'e'));
         quit;
                      
         
         
         
         
         
         /*Joining LGD-ND and LGD-D calculation components to the PD and EAD components*/
         
         proc sql noprint;
            create table work.tng_pd_ead_lgd1 as
               select a.*,
                      case 
                         when upcase(a.pit_stat_cd) in ('CUR', '') then 'TNG MOR LGD-ND'
                         when upcase(a.pit_stat_cd) EQ 'DEF' then 'TNG MOR LGD-D'
                      end as lgd_model_nm,
         
                      case 
                         when upcase(a.pit_stat_cd) in ('CUR', '') then 'TNG MOR LGD-ND Scorecard'
                         when upcase(a.pit_stat_cd) EQ 'DEF' then 'TNG MOR LGD-D Scorecard'
                      end as lgd_basel_scorecrd_nm,
         
                      '3.0' as lgd_model_ver length=10,
                      '3.0' as lgd_scorecrd_nm length=40,
                      '3.0' as lgd_seg_ver length=10,
                      -1 as lgd_basel_model_rel_id,
                      . as lgd_basel_seg_id,
         
                      d.prop_val_new as indexed_prpty_val_amt format = 20.8,
                      d.ltv_teranet as indexed_loan_to_val_rto format = 20.8
                   
                 
          
                  from work.with_pd_ead_mth_def as a
         
                       left join 
                       &_pd_var_creation as d
                       on (a.account_id = d.account_id and
                           intnx('month', a.month_end_dt, 0, 'e') = intnx('month', d.month_end_dt, 0, 'e'));
         
         quit;
         
         
         /*---------------------------------------------------------------
          * Joining variables from scorecard variable creation process
          * in order to score all accounts.
          *---------------------------------------------------------------*/
         proc sql noprint;
            create table work.with_scorecard_vars as
               select a.*,
                      b.END_PRINCIPAL_BALANCE,  
                      b.CLOSE_DT, 
                      b.NEW_DEF_IND, 
                      b.NEW_DEFAULT_IND, 
                      b.WRITE_OFF_MONTH,
                      b.WRITE_OFF_IND, 
                      b.WRITE_OFF_AMT, 
                      b.FINAL_DEFAULT_IND, 
                      b.TRADES_STSFCT_CNTSLP6M, 
                      b.TRADES_ACTIVE_UTIL_PCTMAX12M, 
                      b.DEROGATORY_PUBLIC_REC_CNT, 
                      b.COLLECTIONS_CNT, 
                      b.BANKRUPTCIES_CNT, 
                      b.CREDIT_TRBLE_BNKRPTCY_COLL_DER, 
                      b.INS_ID_GROUP, 
                      b.DAYS_ARREARS_CNT, 
                      b.NSF_YTD_CNT, 
                      b.EVER_30_CNT, 
                      b.REMAIN_AMORT2, 
                      b.PROP_VAL_NEW, 
                      b.LTV_TERANET 
                  from work.tng_pd_ead_lgd1 as a
                       left join
                       &_pd_var_creation as b
                       on (a.account_id = b.account_id and
                           intnx('month', a.month_end_dt, 0, 'e') = intnx('month', b.month_end_dt, 0, 'e'));
         quit;
         
         /*------------------------------------------------
          * PD Scoring and segmenting for all accounts.
          *------------------------------------------------*/
         
         %macro pd_score_segment;
         
            data work.with_pd_score;
               set work.with_scorecard_vars;
         
            
               /*------------------------------------------------------------
                * SECTION: DETERMINING SCORES
                *------------------------------------------------------------*/
         
               SCORECARD_POINTS = 546;
             
               /*------------------------------------------------------------
                * Variable: days_arrears_cnt
                *------------------------------------------------------------*/
               if missing(days_arrears_cnt) then 
               do;
                  scorecard_points = scorecard_points + 98;
                  SCR_days_arrears_cnt= 98;
               end;
               else if not missing(days_arrears_cnt) AND days_arrears_cnt < 1 then 
               do;
                  scorecard_points = scorecard_points + 98;
                  SCR_days_arrears_cnt = 98;
               end;
               else if not missing(days_arrears_cnt) and 1 <= days_arrears_cnt AND days_arrears_cnt < 30 then 
               do;
                  scorecard_points = scorecard_points + 44;
                  SCR_days_arrears_cnt = 44;
               end;
               else if not missing(days_arrears_cnt) and 30 <= days_arrears_cnt AND days_arrears_cnt < 60 then 
               do;
                  scorecard_points = scorecard_points + 17;
                  SCR_days_arrears_cnt = 17;
               end;
               else if not missing(days_arrears_cnt) and 60 <= days_arrears_cnt then 
               do;
                  scorecard_points = scorecard_points + 0;
                  SCR_DAYS_ARREARS_CNT = 0;
               end;
             
               /*------------------------------------------------------------
                * Variable: ever_30_cnt
                *------------------------------------------------------------*/
               if missing(ever_30_cnt) then 
               do;
                  scorecard_points = scorecard_points + 40;
                  SCR_ever_30_cnt= 40;
               end;
               else if not missing(ever_30_cnt) AND ever_30_cnt < 1 then 
               do;
                  scorecard_points = scorecard_points + 40;
                  SCR_ever_30_cnt = 40;
               end;
               else if not missing(ever_30_cnt) and 1 <= ever_30_cnt then 
               do;
                  scorecard_points = scorecard_points + 0;
                  SCR_ever_30_cnt = 0;
               end;
             
               /*------------------------------------------------------------
                * Variable: ltv_teranet
                *------------------------------------------------------------*/
               if missing(ltv_teranet) then 
               do;
                  scorecard_points = scorecard_points + 0;
                  SCR_ltv_teranet= 0;
               end;
               else if not missing(ltv_teranet) AND ltv_teranet < 0.48 then 
               do;
                  scorecard_points = scorecard_points + 12;
                  SCR_ltv_teranet = 12;
               end;
               else if not missing(ltv_teranet) and 0.48 <= ltv_teranet AND ltv_teranet < 0.72 then 
               do;
                  scorecard_points = scorecard_points + 5;
                  SCR_ltv_teranet = 5;
               end;
               else if not missing(ltv_teranet) and 0.72 <= ltv_teranet then 
               do;
                  scorecard_points = scorecard_points + 0;
                  SCR_ltv_teranet = 0;
               end;
             
               /*------------------------------------------------------------
                * Variable: nsf_ytd_cnt
                *------------------------------------------------------------*/
               if missing(nsf_ytd_cnt) then 
               do;
                  scorecard_points = scorecard_points + 40;
                  SCR_nsf_ytd_cnt= 40;
               end;
               else if not missing(nsf_ytd_cnt) AND nsf_ytd_cnt < 1 then 
               do;
                  scorecard_points = scorecard_points + 53;
                  SCR_nsf_ytd_cnt = 53;
               end;
               else if not missing(nsf_ytd_cnt) and 1 <= nsf_ytd_cnt AND nsf_ytd_cnt < 2 then 
               do;
                  scorecard_points = scorecard_points + 28;
                  SCR_nsf_ytd_cnt = 28;
               end;
               else if not missing(nsf_ytd_cnt) and 2 <= nsf_ytd_cnt AND nsf_ytd_cnt < 3 then 
               do;
                  scorecard_points = scorecard_points + 17;
                  SCR_nsf_ytd_cnt = 17;
               end;
               else if not missing(nsf_ytd_cnt) and 3 <= nsf_ytd_cnt then 
               do;
                  scorecard_points = scorecard_points + 0;
                  SCR_nsf_ytd_cnt = 0;
               end;
         
               /*------------------------------------------------------------
                * Variable: trades_active_util_pctmax12m
                *------------------------------------------------------------*/
               if missing(trades_active_util_pctmax12m) then 
               do;
                  scorecard_points = scorecard_points + 33;
                  SCR_trades_active_util_pctmax12m= 33;
               end;
               else if not missing(trades_active_util_pctmax12m) AND trades_active_util_pctmax12m < 60 then 
               do;
                  scorecard_points = scorecard_points + 33;
                  SCR_trades_active_util_pctmax12m = 33;
               end;
               else if not missing(trades_active_util_pctmax12m) and 60 <= trades_active_util_pctmax12m AND trades_active_util_pctmax12m < 84 then 
               do;
                  scorecard_points = scorecard_points + 16;
                  SCR_trades_active_util_pctmax12m = 16;
               end;
               else if not missing(trades_active_util_pctmax12m) and 84 <= trades_active_util_pctmax12m then 
               do;
                  scorecard_points = scorecard_points + 0;
                  SCR_trades_active_util_pctmax12m = 0;
               end;
               /*------------------------------------------------------------
                * Variable: trades_stsfct_cntslp6m
                *------------------------------------------------------------*/
               if missing(trades_stsfct_cntslp6m) then 
               do;
                  scorecard_points = scorecard_points + 17;
                  SCR_trades_stsfct_cntslp6m= 17;
               end;
               else if not missing(trades_stsfct_cntslp6m) AND trades_stsfct_cntslp6m < 0 then 
               do;
                  scorecard_points = scorecard_points + 0;
                  SCR_trades_stsfct_cntslp6m = 0;
               end;
               else if not missing(trades_stsfct_cntslp6m) and 0 <= trades_stsfct_cntslp6m then 
               do;
                  scorecard_points = scorecard_points + 17;
                  SCR_trades_stsfct_cntslp6m = 17;
               end;
         
               /*------------------------------------------------------------
                * Variable: remain_amort2
                *------------------------------------------------------------*/
               if missing(remain_amort2) then 
               do;
                  scorecard_points = scorecard_points + 13;
                  SCR_remain_amort2= 13;
               end;
               else if not missing(remain_amort2) AND remain_amort2 < 149 then 
               do;
                  scorecard_points = scorecard_points + 37;
                  SCR_remain_amort2 = 37;
               end;
               else if not missing(remain_amort2) and 149 <= remain_amort2 AND remain_amort2 < 207 then 
               do;
                  scorecard_points = scorecard_points + 25;
                  SCR_remain_amort2 = 25;
               end;
               else if not missing(remain_amort2) and 207 <= remain_amort2 AND remain_amort2 < 369 then 
               do;
                  scorecard_points = scorecard_points + 13;
                  SCR_remain_amort2 = 13;
               end;
               else if not missing(remain_amort2) and 369 <= remain_amort2 then 
               do;
                  scorecard_points = scorecard_points + 0;
                  SCR_remain_amort2 = 0;
               end;
             
               /*------------------------------------------------------------
                * Variable: credit_trble_bnkrptcy_coll_der
                *------------------------------------------------------------*/
               if missing(credit_trble_bnkrptcy_coll_der) then 
               do;
                  scorecard_points = scorecard_points + 19;
                  SCR_credit_trble_bnkrptcy_coll_d = 19;
               end;
               else if credit_trble_bnkrptcy_coll_der eq 1 then 
               do;
                  scorecard_points = scorecard_points + 0;
                  SCR_credit_trble_bnkrptcy_coll_d = 0;
               end;
               else if credit_trble_bnkrptcy_coll_der eq 0 then 
               do;
                  scorecard_points = scorecard_points + 19;
                  SCR_credit_trble_bnkrptcy_coll_d = 19;
               end;
               else 
               do;
                  scorecard_points = scorecard_points + 19;
                  SCR_credit_trble_bnkrptcy_coll_d = 19;
               end;
             
               /*------------------------------------------------------------
                * Variable: ins_id_group
                *------------------------------------------------------------*/
               if missing(ins_id_group) then 
               do;
                  scorecard_points = scorecard_points + 0;
                  SCR_ins_id_group = 0;
               end;
               else if ins_id_group eq 300 then 
               do;
                  scorecard_points = scorecard_points + 0;
                  SCR_ins_id_group = 0;
               end;
               else if ins_id_group eq 100 or ins_id_group eq 200 then 
               do;
                  scorecard_points = scorecard_points + 33;
                  SCR_ins_id_group = 33;
               end;
               else do;
                  scorecard_points = scorecard_points + 0;
                  SCR_ins_id_group = 0;
               end;
         
               /*------------------------------------------------------------
                * SECTION: Assigning segment
                *------------------------------------------------------------*/
               if close_dt ne . or end_principal_balance<=0 then segment=99;  /*Leon H confirmed that 98=99.  WP changed it.*/
                     
      			/*defaulted accounts*/
     			 else if final_default_ind='Y' then segment = 99;
      			else if scorecard_points <757 then segment = 4;
      			else if scorecard_points <801 then segment = 3;
      			else if scorecard_points <842.5 then segment = 2;
      			else segment = 1;

            run;
         
         %mend pd_score_segment;
         
         %pd_score_segment;
         
         
         /*-----------------------------------------------------
          * LGD-ND scoring for all current accounts.
          *-----------------------------------------------------*/
         
         
         data work.with_lgd_nd_segs;
            set work.with_scorecard_vars;
            if upcase(pit_stat_cd) in ('CUR', '');
			 if substr(account_id, 1, 3) = 'RES' then segment = 10;
      		else segment = 1;       
         run;
         
         
         /*----------------------------------------------------------
          * Performing LGD-D scoring for all defaulted accounts.
          *----------------------------------------------------------*/
         
         proc sql noprint;
            create table work.for_lgdd as
               select a.*,
                      b.accrued_interest_amt
                  from work.with_scorecard_vars as a
                       left join
                       nz_frg.tng_mor_lgdd as b
                       on (a.account_id = b.account_id and
                           intnx('month', a.month_end_dt, 0, 'e') = intnx('month', b.month_end_dt, 0, 'e'));
         quit;
         
         data work.with_lgd_d_segs;
            set work.for_lgdd;
            if upcase(pit_stat_cd)='DEF';
            if accrued_interest_amt ne . then balance_interest = end_principal_balance + accrued_interest_amt;
               else balance_interest= end_principal_balance;

			 if months_in_default > 23 then lgdd_segment = 11;
   			 else if balance_interest < 5000 then lgdd_segment = 10;
   			else if upcase(substr(account_id,1,3)) = 'RES' then lgdd_segment = 10;
   			else lgdd_segment = 1;           
         run;
         
         
         /*--------------------------------------------------------------------------------------------
          * Joining the PD score and segment values and LGD segment values.  Also getting pd_model_rto
          *--------------------------------------------------------------------------------------------*/
         
         proc sql noprint;
            create table work.tng_pd_ead_lgd2 as
               select a.*,
                      b.segment as pd_basel_seg_num,
                      b.scorecard_points as pd_acct_score,
                      case
                         when upcase(a.pit_stat_cd) in ('CUR', '') then c.segment
                      end as lgdnd_segment,
                      case
                         when upcase(a.pit_stat_cd) EQ 'DEF' then d.lgdd_segment
                      end as lgd_d_segment,
                         
                      case
                         when upcase(a.pit_stat_cd) in ('CUR', '') then c.segment 
                         when upcase(a.pit_stat_cd) EQ 'DEF' then d.lgdd_segment
                      end as lgd_basel_seg_num,
         
                      e.segment_dr as pd_model_rto,
                      
                      d.accrued_interest_amt as intr_accr_amt
                      
         
                  from work.tng_pd_ead_lgd1 (rename=(months_in_default=cons_dft_mth_cnt)) as a
                       left join 
                       work.with_pd_score as b
                       on (a.account_id = b.account_id and
                           intnx('month', a.month_end_dt, 0, 'e') = intnx('month', b.month_end_dt, 0, 'e'))
         
                       left join 
                       work.with_lgd_nd_segs as c
                       on (a.account_id = c.account_id and
                           intnx('month', a.month_end_dt, 0, 'e') = intnx('month', c.month_end_dt, 0, 'e'))
         
                       left join
                       work.with_lgd_d_segs as d
                       on (a.account_id = d.account_id and
                           intnx('month', a.month_end_dt, 0, 'e') = intnx('month', d.month_end_dt, 0, 'e'))
         
                       left join
                       &_in_pd_segs_with_pds_tbl as e
                       on (b.segment = e.segment and
                           intnx('month', a.month_end_dt, 0, 'e') = intnx('month', e.month_end_date, 0, 'e'));
         quit;
         
         
         
                      
         
         
         /*Adding the lgd realized values to the table*/
         
         proc sql noprint;
            create table work.tng_pd_ead_lgd_final as 
               select a.*,
                      case 
                         when upcase(a.pit_stat_cd) in ('CUR', '') and default_ind=1 then b.segment_lgd_costs_cap_150
                         when upcase(a.pit_stat_cd) EQ 'DEF' then c.segment_lgd_costs_cap_150
                      end as lgd_model_rto
                  from work.tng_pd_ead_lgd2 as a
                       left join
                       &_in_lgdnd_segs_with_lgds_tbl as b
                       on (a.lgdnd_segment = b.segment and
                           intnx('month', a.month_end_dt, 0, 'e') = intnx('month', b.month_end_dt, 0, 'e'))
         
                       left join
                       &_in_lgdd_segs_with_lgds_tbl as c
                       on (a.lgd_d_segment = c.lgdd_segment and
                           intnx('month', a.month_end_dt, 0, 'e') = intnx('month', c.month_end_dt, 0, 'e'));
         quit;
         
         /*-----------------------------------------------------------------------------
          * 2.  Gathering variables from CPD tables.
          *-----------------------------------------------------------------------------*/
         
         proc sql noprint;
            create table work.with_model_cpd as
               select a.*,
                      b.customer_key,
         /*             b.accrued_interest_amt as intr_accr_amt,*/
                      b.bulk_nsurer_desc,
                      case 
                         when upcase(b.bulk_nsurer_desc)='BULKINSURED' then 'Y'
                         else 'N'
                      end as bulk_ind,
                      b.maturity_dt as mat_dt,
         /*             Next three variables are outstanding logic*/
                      b.days_arrears_cnt as dlqnt_day_cnt,
                      cats(put(b.customer_key,best12.)) as basel_cif_key length=17,
                      b.property_type_desc as HOUSE_TP_NM length=20,
                      case
                         when b.loan_to_value_ratio/100 > 1 then 1
                         else b.loan_to_value_ratio/100 
                      end as loan_to_val_rto,
                      b.account_key as account_key_pad format=z24.,
         /*             scan(b.account_id,2,'~') as mort_num length=50,*/
                      b.rate_type_desc,
                      case
                         when upcase(b.rate_type_desc)='FIXED' then '0701'
                         when upcase(b.rate_type_desc)='VARIABLE' then '0702'
                         else '0701'
                      end as ncr_rt_key_val,
                      b.open_dt as acct_odt,
                      b.tot_advanced_amt as advnc_amt,
                      b.COMMITTED_AMT as AUTH_AMT,
                      b.orig_prop_appraisal_val as orig_prpty_val_amt,
                      b.remain_amort as amort,
                      b.insurer_desc as insur_group,
                      c.customer_id as prim_cust_cid length=20
                      
                  from work.tng_pd_ead_lgd_final as a
                       left join
                       tngdata.tng_acct_mo as b
                       on (a.account_id = b.account_id and
