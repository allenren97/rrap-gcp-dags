         ,EAD_LR_PV_AD_SV_DT_AA_RTO
         ,NULL AS INSUR_F
         ,NULL AS OS_PRNCPL_BAL_AMT
         ,HPV_12_QTR_AGO AS PREV_12_QTR_PRPTY_VAL_AMT
         ,DLGD_F
         ,CRNT_LTV_RTO
         ,METROPOLITAN AS METRPL_AREA_N
         ,DELTA_P AS PRPTY_VAL_CORR_PCTG
         ,ADDON AS LNG_RUN_LGD_ADD_ON_RTO
         ,DLGD_FINAL_RPTG_RTO AS DLGD_RPTG_RTO
         FROM
         (
         SELECT FINAL3.*,
                  CASE WHEN FINAL3.DLGD_F='Y' AND ADDON IS NOT NULL THEN 
                  
                  /*		MAX(0.1, MIN(1, FINAL3.LGD_FINAL_RPTG_RTO+ADDON)) */
                  /*Changed Feb10, 2017*/
                        MAX(0.1, MIN(1, MAX(FINAL3.lgd_unadjusted_rptg_rto + ADDON , FINAL3.LGD_FINAL_RPTG_RTO))) 
                  
                        ELSE FINAL3.LGD_FINAL_RPTG_RTO 
                  END AS DLGD_FINAL_RPTG_RTO
         FROM (
            SELECT FINAL2.*,
                  CASE 
                     WHEN FINAL2.DLGD_F='Y' AND FINAL2.CRNT_LTV_RTO IS NOT NULL AND DELTA_P IS NOT NULL AND FINAL2.INDEXED_CCLTV_RTO IS NOT NULL 
                        THEN MAX((MIN(FINAL2.CRNT_LTV_RTO, MAX(FINAL2.INDEXED_CCLTV_RTO-0.8*(1-DELTA_P),0))-MAX(FINAL2.INDEXED_CCLTV_RTO-0.8,0))/NULLIF(FINAL2.CRNT_LTV_RTO,0),0) 
                     WHEN FINAL2.DLGD_F='Y' AND FINAL2.CRNT_LTV_RTO IS NOT NULL AND DELTA_P IS NOT NULL AND FINAL2.INDEXED_CCLTV_RTO IS NULL THEN (MAX(FINAL2.CRNT_LTV_RTO-0.8*(1-DELTA_P),0)-MAX(FINAL2.CRNT_LTV_RTO-0.8,0))/NULLIF(FINAL2.CRNT_LTV_RTO,0)
                     ELSE NULL 
                  END AS ADDON
            FROM
            (
               SELECT FINAL1.*, 
                  CASE WHEN FINAL1.DLGD_F='N' THEN NULL 
                     WHEN FINAL1.DLGD_F<>'N' AND FINAL1.METRPL_BREACH_F='Y' THEN MAX(1-(HPV_12_QTR_AGO/NVL(FINAL1.PROP_VAL_NEW,NULL)),0.25) 
                     WHEN FINAL1.DLGD_F<>'N' AND FINAL1.METRPL_BREACH_F<>'Y' THEN MAX(1-(HPV_12_QTR_AGO/NVL(FINAL1.PROP_VAL_NEW,NULL)),0) 
                  END AS DELTA_P
               FROM
               (
                  SELECT SUBQ2.*, INDX.INDEX, INDX12.INDEX AS INDEX_12_QTR_AGO, (SUBQ2.PROP_VAL_NEW/INDX.INDEX)*INDX12.INDEX AS HPV_12_QTR_AGO, SCRI.METRPL_BREACH_F
                  FROM (
                  SELECT SUBQ1.*, FIR.PROP_CITY, FIR.PROP_VAL_NEW, FIR.PROP_PROVINCE_CODE, LTVVAR.CRNT_LTV_RTO, LTVVAR.INDEXED_CCLTV_RTO,
                  CASE WHEN SUBQ1.DLGD_F='N' THEN NULL  
                     WHEN SUBQ1.DLGD_F<>'N' AND (FIR.PROP_CITY IS NULL OR UPPER(FIR.PROP_CITY) LIKE '%OTHER%') THEN '11'
                     WHEN SUBQ1.DLGD_F<>'N' AND TRIM(FIR.PROP_CITY)='Ottawa - Gatineau' THEN 'OTTAWA_GATINEAU' ELSE FIR.PROP_CITY END AS METROPOLITAN
                  FROM (
                  SELECT A.*, B.OPEN_DT, B.LAST_RENEWAL_DT,
                  CASE WHEN A.LGD_BASEL_SEG_NUM NOT IN (10,11) AND A.PIT_STAT_CD='CUR' AND A.SCRTY_TP_DESC='Uninsured' AND (B.OPEN_DT>='11-01-2016' OR B.LAST_RENEWAL_DT>='11-01-2016') THEN 'Y' ELSE 'N' END AS DLGD_F
                  FROM 
                  &bttdb..BASEL_ANALYTCL_BL_INST_FCT_TNG A,TNGSTP1D.TNG_ACCT_MO B 
                  WHERE 
                  TRIM(A.MORT_NUM)=TRIM(B.ACCOUNT_ID) AND A.MTH_TM_ID=&MTH_TM_ID AND B.MONTH_END_DT=&NZDATEFORMAT
                  ) SUBQ1
                  LEFT OUTER JOIN &FRG_DB..TNG_PD_VAR_CREATION_FINAL FIR ON TRIM(SUBQ1.MORT_NUM)=TRIM(FIR.ACCOUNT_ID) AND FIR.MONTH_END_DT=&NZDATEFORMAT
                  LEFT OUTER JOIN &RRAP_DB..BASEL_ACCT_LTV_DRVD_VARS LTVVAR ON TRIM(SUBQ1.MORT_NUM)=TRIM(LTVVAR.ACCT_NUM) AND LTVVAR.ACCT_SENRTY_CD=1 AND LTVVAR.MTH_TM_ID=&MTH_TM_ID) SUBQ2
                  LEFT OUTER JOIN (SELECT DISTINCT MTH_TM_ID, LABEL_2, INDEX FROM &RRAP_DB..TERANET_HOUSE_PRC_INDEX WHERE MTH_TM_ID=(SELECT MAX(MTH_TM_ID) FROM &RRAP_DB..TERANET_HOUSE_PRC_INDEX)) INDX ON UPPER(TRIM(INDX.LABEL_2))=UPPER(TRIM(SUBQ2.METROPOLITAN))
                  LEFT OUTER JOIN (SELECT DISTINCT MTH_TM_ID, LABEL_2, INDEX FROM &RRAP_DB..TERANET_HOUSE_PRC_INDEX WHERE MTH_TM_ID=(SELECT MAX(MTH_TM_ID)-1440 FROM &RRAP_DB..TERANET_HOUSE_PRC_INDEX)) INDX12 ON UPPER(TRIM(INDX12.LABEL_2))=UPPER(TRIM(SUBQ2.METROPOLITAN))
                  LEFT OUTER JOIN &RRAP_DB..DLGD_SCRI_QTR_DRVD_VARS SCRI ON UPPER(TRIM(SCRI.METRPL_AREA_NM))=UPPER(TRIM(SUBQ2.METROPOLITAN)) AND SCRI.MTH_TM_ID=&CURR_QTR_MTH_TM_ID
               ) FINAL1
            ) FINAL2
         ) FINAL3
         ) FINAL
         ) BY NZCON;
