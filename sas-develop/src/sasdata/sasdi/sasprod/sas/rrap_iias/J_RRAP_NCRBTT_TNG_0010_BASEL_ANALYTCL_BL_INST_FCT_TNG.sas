                   b.product_id as prd_id length = 10,
                   b.basel_sub_product_name as src_prd_desc length = 255,
         
                   /* JL - CHANGED: 22JAN2015 (ADD) */
                   b.pd_band_exposure_class_key_value,
         
                   /* Needed to define ccar_basel_prd_tp_nm later in process and will be dropped */
