            format pd_basel_seg_num z2. lgd_basel_seg_num z2.;
            pd_segc=put(pd_basel_seg_num,z2.);
            if pd_basel_seg_num=. then pd_segc='00';
            lgd_segc=put(lgd_basel_seg_num, z2.);
            if lgd_basel_seg_num=. then lgd_segc='00';
            ccar_basel_prd_tp_nm=cats(CCAR_BASEL_PRODUCT_TYPE_NAME,'_',pd_segc,'_01_',lgd_segc);
         run;
         
         
