%macro sendemail;
	%if &email_alert = 1 %then
		%do;
			/* manager and business user got email every month */
			FILENAME OUTMAIL EMAIL ATTACH="&file_path.&file_name"
				SUBJECT= "[RRAP] SI above threshold for TL Scorecard Model Variables Report - &MonthYear.";

			DATA _NULL_;
				FILE OUTMAIL
					TO= (&si_email_list);
				put;
			RUN;

		%end;
	%else
		%do;
			/* business user got email every month */
			FILENAME OUTMAIL EMAIL ATTACH="&file_path.&file_name"
				SUBJECT= "[RRAP] TL Scorecard Model Variables Report - &MonthYear.";

			DATA _NULL_;
				FILE OUTMAIL
					TO= (&email_list);
				put;
			RUN;

		%end;
%mend sendemail;

