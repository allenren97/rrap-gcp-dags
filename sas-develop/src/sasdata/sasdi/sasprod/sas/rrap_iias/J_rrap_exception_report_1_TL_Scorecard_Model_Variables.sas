proc sql;
	create table work.SPL_SCORECRD_LGD_NM as 
	/*	select b.BASEL_SCORECRD_NM,a.mth_tm_id,c.VAR_NM, c.bin, count(*),avg(c.PT_CNT) as points_assigned */
		select b.BASEL_SCORECRD_NM,a.mth_tm_id,c.VAR_NM, c.bin, count(*) as COUNT ,avg(c.PT_CNT) as points_assigned 
			from NZRRAP.BASEL_PNL_LN_SCORE_DTL_SNAPSHOT a
				left outer join NZRRAP.BASEL_MODEL_SCORECRD_HDR b
					on a.BASEL_MODEL_SCORECRD_HDR_ID=b.BASEL_MODEL_SCORECRD_HDR_ID
				left outer join NZRRAP.BASEL_MODEL_SCORECRD_DTL c
					on a.BASEL_MODEL_SCORECRD_DTL_ID=c.BASEL_MODEL_SCORECRD_DTL_ID
				inner join NZRRAP.BASEL_PSNL_LOAN_ACCT_DRVD_VARS_2 d
					on a.basel_acct_id=d.basel_acct_id and a.mth_tm_id=d.mth_tm_id
				inner join NZRRAP.BASEL_PSNL_LOAN_ACCT_DRVD_VARS e
					on a.basel_acct_id=e.basel_acct_id and a.mth_tm_id=e.mth_tm_id
				inner join NZRRAP.BASEL_PNL_LN_LGD_SEG_ACCT_XREF f
					on a.basel_acct_id=f.basel_acct_id and a.mth_tm_id=f.mth_tm_id and a.BASEL_MODEL_ID=f.BASEL_MODEL_ID
				where a.mth_tm_id in (&base_tm_id, &current_tm_id)
					and b.SRC_SYS_CD='SPL' and d.PIT_STATUS_V2 in ('CUR','DEF')
					and e.TRNST_EXCLSN_F='N' and e.CONSM_PRD_TREATMNT_CD='A' and VAR_NM NE 'Intercept'
					and f.BASEL_SEG_ID not in (16127,16128,16136,16135,16156,16155,16162,16163,16164,16133, 16134)			
					and c.BASEL_MODEL_SCORECRD_HDR_ID NE 8020 /*THIS IS TO REMOVE DTL LGD-ND BASED ON RRMSS-3188*/
				group by b.BASEL_SCORECRD_NM,a.mth_tm_id,c.VAR_NM,c.BIN
					order by a.mth_tm_id,b.BASEL_SCORECRD_NM,a.mth_tm_id,c.VAR_NM,c.BIN
	;
quit;

