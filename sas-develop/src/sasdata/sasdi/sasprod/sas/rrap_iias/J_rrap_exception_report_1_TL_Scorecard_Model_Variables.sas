%macro process(type);
	%do i=1 %to &COUNT;

		proc sql;
			create table work.SPL_&type._NM_&i as 
				select *, sum(count) as sub_total from work.SPL_SCORECRD_&type._NM
					where BASEL_SCORECRD_NM = "&&SPL_&type._&i"
						group by BASEL_SCORECRD_NM,VAR_NM,mth_tm_id
							order by BASEL_SCORECRD_NM,VAR_NM,mth_tm_id;
		quit;

		proc sort data=work.SPL_&type._nm_&i;
			by BASEL_SCORECRD_NM VAR_NM points_assigned;
		run;

		PROC TRANSPOSE DATA=work.SPL_&type._nm_&i OUT=WORK.SPL_&type._&i._1;
			var count;
			by BASEL_SCORECRD_NM VAR_NM points_assigned;
		RUN;

		data WORK.SPL_&type._&i._1;
			set WORK.SPL_&type._&i._1;
			drop _Name_ _Label_;
			rename col1 = BASE_CNT;
			rename  col2 = CURRENT_CNT;
		run;

		PROC TRANSPOSE DATA=work.SPL_&type._nm_&i OUT=WORK.SPL_&type._&i._2;
			var sub_total;
			by BASEL_SCORECRD_NM VAR_NM points_assigned;
		RUN;

		data WORK.SPL_&type._&i._2;
			set WORK.SPL_&type._&i._2;
			drop _Name_;
			rename  col1 = base_tot;
			rename  col2 = next_tot;
		run;

		proc sql;
			create table work.SPL_&type._&i._3 as
				select distinct a.* , b.base_tot, b.next_tot
					from WORK.SPL_&type._&i._1 as a
						inner join WORK.SPL_&type._&i._2 as b
							on a.BASEL_SCORECRD_NM = b.BASEL_SCORECRD_NM 
							and a.VAR_NM = b.VAR_NM 
							and a.points_assigned = b.points_assigned 
						order by BASEL_SCORECRD_NM,VAR_NM 
			;
		quit;

		data work.SPL_&type._&i._final;
			set work.SPL_&type._&i._3;
			retain total_si 0;
			by BASEL_SCORECRD_NM VAR_NM;

			if first.BASEL_SCORECRD_NM or first.VAR_NM then
				do;
					total_si=0;
				end;

			BASE_PCT = BASE_CNT/base_tot;
			CURRENT_pct = CURRENT_cnt/next_tot;

			/*si1 = next_pct - base_pct;*/
			/*si2= log(next_pct/base_pct);*/
			si = (CURRENT_pct - BASE_PCT) * log(CURRENT_pct/BASE_PCT);
			total_si = total_si +si;
		run;

		%if &i eq 1 %then
			%do;

				data work.SPL_&type._final;
					set work.SPL_&type._&i._final;
				run;

			%end;
		%else
			%do;

				proc append base=work.SPL_&type._final data=work.SPL_&type._&i._final;
				run;

			%end;
	%end;
%mend process;

