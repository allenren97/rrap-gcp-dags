%macro build_html_report(outpath=, outfile=);

	ods html
		path="&outpath"
		file="&outfile"
		style=htmlblue
		nogtitle nogfootnote;
	
	%if &cnt_final EQ 0 %then %do;
	ods html text='<p align="left">No CMA&#39;s experienced a change in Breach Status this Quarter. No reporting to OSFI is required.</p>';
	%end;
	%else %do;
	ods html text='<p align="left">The following CMA&#39;s experienced a change in breach status this quarter and should be reported.</p>';
	%end;

	proc sql;
		select METRPL_AREA_NM label="CMA", breach_f_curr_qtr label="Current Qtr Breached", breach_f_prev_qtr label="Previous Qtr Breached",
		METRPL_SCRI_VAL label="Current SCRI Value", THRSHD_VAL label="Current Threshold Value", INITIAL_BREACH_YRMTH label="Month Initial Breach Occured"
		from final;
	quit;

	ods html text='<p align="left"></p>';
	ods html text='<p align="left"></p>';
	ods html text='<p align="left">The following list is a snapshot of CMA breach status for this quarter. CMA&#39;s with Breach Flag = &#39;Y&#39; are breaching their thresholds.</p>';

	proc sql;
	select put(t.tm_lvl_end_dt,date9.) as mth label="Quarter Ending", c.METRPL_AREA_NM label="CMA", C.METRPL_SCRI_VAL label="SCRI Value", b.THRSHD_VAL label="Threshold Value", METRPL_BREACH_F label="Breach Flag" 
	from nzrrap.DLGD_SCRI_QTR_DRVD_VARS c, nzrrap.DLGD_METRPL_THRSHD_VAL_DIM b, nzrrap.tm_dim t
	where 
	  %translate(c.METRPL_AREA_NM) = %translate(b.METRPL_AREA_NM) 
				 and put(t.tm_lvl_end_dt,yymmn6.) GE b.EFF_FROM_YR_MTH and put(t.tm_lvl_end_dt,yymmn6.) LT b.EFF_TO_YR_MTH
	 
	 	and &qtr_end_mth_tm_id = c.mth_tm_id
		and c.mth_tm_id = t.tm_id and t.tm_lvl='Month'
	order by c.METRPL_AREA_NM;
	quit;

	ods html text='<p align="left"></p>';
	ods html text='<p align="left"></p>';
	ods html text='<p align="left">The following list is a snapshot of CMA breach status for the previous quarter. CMA&#39;s with Breach Flag = &#39;Y&#39; are breaching their thresholds.</p>';

	proc sql;
	select put(t.tm_lvl_end_dt,date9.) as mth label="Quarter Ending", c.METRPL_AREA_NM label="CMA", C.METRPL_SCRI_VAL label="SCRI Value", b.THRSHD_VAL label="Threshold Value", METRPL_BREACH_F label="Breach Flag" 
	from nzrrap.DLGD_SCRI_QTR_DRVD_VARS c, nzrrap.DLGD_METRPL_THRSHD_VAL_DIM b, nzrrap.tm_dim t
	where 
	  %translate(c.METRPL_AREA_NM) = %translate(b.METRPL_AREA_NM) 
				 and put(t.tm_lvl_end_dt,yymmn6.) GE b.EFF_FROM_YR_MTH and put(t.tm_lvl_end_dt,yymmn6.) LT b.EFF_TO_YR_MTH
	 
	 	and &qtr_end_mth_tm_id -120 = c.mth_tm_id
		and c.mth_tm_id = t.tm_id and t.tm_lvl='Month'
	order by c.METRPL_AREA_NM;
	quit;
	
	ods html close;
%mend build_html_report;

