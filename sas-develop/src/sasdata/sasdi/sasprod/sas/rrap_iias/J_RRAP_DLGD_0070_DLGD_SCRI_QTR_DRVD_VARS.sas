%put NOTE: Check7: qtr_end_mth_tm_id=&qtr_end_mth_tm_id.;
/**************************************************************************/
proc sql;
create table SCRI_PRELOAD as
	select &qtr_end_mth_tm_id. as MTH_TM_ID, abc.YRMTH, abc.METRPL_AREA_NM length=32 format=$32., 
			abc.SMOOTHED_INDEX as METRPL_SMTHD_12_MTH_TERANET_INDE, 
			abc.QTRLY_POP as CANDN_POPN_QTR_AVG_THSNDTH_VAL, 
			abc.HH_DISP_INCOME as CANDN_HH_DSPSBL_INCM_MILLNTH_AMT, 
			(1000*abc.HH_DISP_INCOME/abc.QTRLY_POP) format=comma25.10 as CANDN_PER_CAPITA_INCM_AMT,
			((abc.SMOOTHED_INDEX*d.SCALNG_FACTR_VAL)/(calculated CANDN_PER_CAPITA_INCM_AMT)) format=9.4 as METRPL_SCRI_VAL,
			case
				when calculated METRPL_SCRI_VAL GT e.THRSHD_VAL THEN 'Y'
				else 'N'
			end as METRPL_BREACH_F,
			"&SYSDATE9.:&SYSTIME"dt format=datetime25.6 as INSRT_PROCESS_TMSTMP,
			"&SYSDATE9.:&SYSTIME"dt format=datetime25.6 as UPDT_PROCESS_TMSTMP

	from 

	(select a.MTH_TM_ID, b.QTRLY_POP, c.HH_DISP_INCOME, a.SMOOTHED_INDEX, a.METRPL_AREA_NM, put(f.tm_lvl_end_dt,yymmn6.) as YRMTH
		from AVG_INDEX a, QTRLY_POP b, HH_DISP_INCOME c, nzrrap.tm_dim f
		where a.mth_tm_id = f.tm_id and f.tm_lvl='Month') abc

	left join NZRRAP.DLGD_METRPL_SCALNG_FACTR_DIM d
	on %translate(d.METRPL_AREA_NM) = %translate(abc.METRPL_AREA_NM)
			 and calculated YRMTH GE d.EFF_FROM_YR_MTH and calculated YRMTH LT d.EFF_TO_YR_MTH

	left join NZRRAP.DLGD_METRPL_THRSHD_VAL_DIM e	
	 on %translate(e.METRPL_AREA_NM) = %translate(abc.METRPL_AREA_NM)
			 and calculated YRMTH GE e.EFF_FROM_YR_MTH and calculated YRMTH LT e.EFF_TO_YR_MTH

	order by METRPL_AREA_NM;
quit;


