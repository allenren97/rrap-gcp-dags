/*Smoothed 12 month Teranet Index*/
proc sql noprint;

	create table AVG_INDEX as
	select LABEL_2 as METRPL_AREA_NM, &mth_tm_id as MTH_TM_ID, AVG(INDEX) as SMOOTHED_INDEX
	from nzrrap.TERANET_HOUSE_PRC_INDEX 
	where MTH_TM_ID between &mth_tm_id. -40*(12-1+2) and &mth_tm_id. -40*2 
	and LABEL_2 ne '6'
	/*15996 and 16476*/
	group by LABEL_2, calculated MTH_TM_ID
	order by LABEL_2;
quit;
%put DATE RANGE USED TO SMOOTH TERANET: %eval(&mth_tm_id. -40*(12-1+2)) - %eval(&mth_tm_id. -40*2);


/*CANADIAN_POPULATION*/
proc sql;
	create table QTRLY_POP as
	select AVG(CANDN_POPN_THSNDTH_VAL) format=comma20.4 as QTRLY_POP
	from NZRRAP.CANDN_POPN_MTH_SNAPSHOT
	where mth_tm_id between  &mth_tm_id. -40*6 and &mth_tm_id. -40*4;
quit;
%put DATE RANGE USED TO AVERAGE POPULATION DATA: %eval(&mth_tm_id. -40*6) - %eval(&mth_tm_id. -40*4);


/*HOUSEHOLD_DISP_INCOME*/
proc sql;
	create table HH_DISP_INCOME as
	select a.HH_DSPSBL_INCM_MILLNTH_AMT as HH_DISP_INCOME

		from NZRRAP.HH_DSPSBL_INCM_QTR a 

	where a.mth_tm_id = &mth_tm_id - 40*4
	and "&yyyymm." GE EFF_FROM_YR_MTH and  "&yyyymm." LT  EFF_TO_YR_MTH;

quit;
%put DATE USED FROM HH_DISP_INCOME: %eval(&mth_tm_id. -40*4) ;

