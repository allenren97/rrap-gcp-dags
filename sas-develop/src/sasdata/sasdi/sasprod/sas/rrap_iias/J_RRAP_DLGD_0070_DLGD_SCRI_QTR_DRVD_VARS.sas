data current;
	set nzrrap.DLGD_SCRI_QTR_DRVD_VARS;
	keep mth_tm_id metrpl_area_nm metrpl_breach_f;
	where mth_tm_id = &qtr_end_mth_tm_id. AND metrpl_area_nm NE '11';
	rename metrpl_breach_f = breach_f_curr_qtr;
run;
proc sort; by metrpl_area_nm; run;

data previous;
	set nzrrap.DLGD_SCRI_QTR_DRVD_VARS;
	keep mth_tm_id metrpl_area_nm metrpl_breach_f;
	where mth_tm_id = &qtr_end_mth_tm_id. -120 AND metrpl_area_nm NE '11';
	rename metrpl_breach_f = breach_f_prev_qtr;
run;
proc sort; by metrpl_area_nm; run;

data same different;
	merge  previous current;
	by metrpl_area_nm;
	if breach_f_curr_qtr EQ breach_f_prev_qtr then output same;
	if breach_f_curr_qtr ne breach_f_prev_qtr and not missing(breach_f_prev_qtr) then output different;
run;

proc sql;
	create table SCRI as
	select put(t.tm_lvl_end_dt,yymmn6.) as YRMTH, a.metrpl_area_nm, a.metrpl_breach_f, a.mth_tm_id
	from nzrrap.DLGD_SCRI_QTR_DRVD_VARS a, nzrrap.tm_dim t
	where a.metrpl_area_nm in (select metrpl_area_nm from different)
	and a.mth_tm_id=t.tm_id and t.tm_lvl='Month'
	order by a.metrpl_area_nm, a.mth_tm_id;
quit;

proc sql;
	create table scri_lag as
	select a.*, b.metrpl_breach_f as breach_lag
	from scri a left join scri b
	on a.mth_tm_id = b.mth_tm_id +120 and a.metrpl_area_nm = b.metrpl_area_nm
	order by a.metrpl_area_nm,  a.mth_tm_id descending;
quit;


data t;
		set scri_lag;
		by METRPL_AREA_NM;
		RETAIN XX 1;
		IF FIRST.METRPL_AREA_NM THEN DO;
			X=0; XX=1;
		END;
		if METRPL_BREACH_F='Y' and breach_lag='N' then X=1;
		if LAST.METRPL_AREA_NM AND METRPL_BREACH_F='Y' AND missing(breach_lag) then X=1;
		if FIRST.METRPL_AREA_NM AND METRPL_BREACH_F='Y' and breach_lag='N' then DO;
			X=0; XX=0;
		END;
		IF X=1 AND XX=1 THEN OUTPUT;
run;

data tt;
	set t;
	by METRPL_AREA_NM DESCENDING mth_tm_id ;
	if FIRST.METRPL_AREA_NM;
	keep METRPL_AREA_NM YRMTH mth_tm_id ;
	rename YRMTH=INITIAL_BREACH_YRMTH mth_tm_id=initial_mth_tm_id;
run;

data pre_final;
	/*retain MTH_TM_ID METRPL_AREA_NM THRSHD_VAL METRPL_SCRI_VAL breach_f_curr_qtr INITIAL_BREACH_YRMTH;*/
	merge different tt;
	by METRPL_AREA_NM;
run;

proc sql;
	create table final as
	select a.*, c.METRPL_SCRI_VAL, b.THRSHD_VAL, put(t.tm_lvl_end_dt,yymmn6.) as YRMTH
	from pre_final a, nzrrap.DLGD_SCRI_QTR_DRVD_VARS c, nzrrap.DLGD_METRPL_THRSHD_VAL_DIM b, nzrrap.tm_dim t
	where 
	  %translate(a.METRPL_AREA_NM) = %translate(b.METRPL_AREA_NM)
				 and calculated YRMTH GE b.EFF_FROM_YR_MTH and calculated YRMTH LT b.EFF_TO_YR_MTH
	 and   %translate(a.METRPL_AREA_NM) = %translate(c.METRPL_AREA_NM) 
	 	and a.mth_tm_id = c.mth_tm_id
		and a.mth_tm_id = t.tm_id and t.tm_lvl='Month';
quit;

proc sql noprint;
	select count(*) into :cnt_final from final;
	select tm_lvl_end_dt into :qtr_end_dt
	from nzrrap.tm_dim
	where tm_id=&qtr_end_mth_tm_id and tm_lvl='Month';
quit;
%put &qtr_end_dt.;
%put &cnt_final.;
