/*---------------------------------------------------------------------
 * Assigning macro variables for input and output tables.
 *---------------------------------------------------------------------*/

%let _exclusion_input_tbl=nz_frg.tng_pd_var_creation_final;
%let _exlcuded_obs_output_tbl=results.tng_lgdnd_exluded_obs;
%let _non_excluded_obs_output_tbl=results.tng_lgdnd_non_excluded_obs;
%let _segment_output_tbl=results.tng_lgd_nd_segmentation;
%let _seg_lgd_combine_tbl=results.tng_lgdnd_lgd_seg_combine;


/*--------------------------------------------------------------
 * Exclusion logic added by Will.  This logic was not used in
 * the original developement code, but was provided to Will
 * by Bill via email.
 *--------------------------------------------------------------*/
/*----------------------------------------------
 * Exclude accounts process
 *----------------------------------------------*/

data work.lgdnd_exclusions;
   set &_exclusion_input_tbl.;
   if end_principal_balance<=0 or close_dt ne . or provider='RES'  then model_excl='Y' ;
      else model_excl='N';
run;

proc sql noprint;
   /* Create table of excluded LGDD accounts */
   create table &_exlcuded_obs_output_tbl. as
   select a.*
   from work.lgdnd_exclusions as a
   where upcase(model_excl) = 'Y';

   /* Create table of non-excluded LGDD accounts */
   create table &_non_excluded_obs_output_tbl. as 
   select a.*
   from work.lgdnd_exclusions as a
   where upcase(model_excl) = 'N';
quit;



/*--------------------------------------------------------------------
 * This segmentation logic was updated from original by Bill. 
 *--------------------------------------------------------------------*/


data &_segment_output_tbl.;
   set &_non_excluded_obs_output_tbl.;
   if substr(account_id, 1, 3) = 'RES' then segment = 10;
      else segment = 1;
run;

/*----------------------------------------------------------------------
 * Joining the segments to the LGD calculations table.  The resulting
 * table will be used as input into the 05_tng_lgd_nd_realized code.
 *----------------------------------------------------------------------*/

proc sql noprint;
   create table &_seg_lgd_combine_tbl. as
      select a.account_id,
             a.month_end_dt,
             a.lgd,
             a.lgd_cap_100,
             a.lgd_cap_150,
             a.lgd_costs,
             a.lgd_costs_cap_100,
             a.lgd_costs_cap_150,
             b.segment
         from nz_frg.tng_lgd_nd_realized_final as a,  /*CHANGE: WP -29JAN2015*/
              &_segment_output_tbl. as b
         where a.account_id=b.account_id and a.month_end_dt=b.month_end_dt;
quit;

/*--------------------------------------------------------
 * Code to truncate before inserting into NZ table.
 *--------------------------------------------------------*/

proc sql noprint;
connect using nz_frg as nz_frg;
   execute (delete from &frg_db..tng_lgd_nd_segmentation ) by nz_frg;
   disconnect from nz_frg;
quit;


proc sql noprint;
     insert into nz_frg.tng_lgd_nd_segmentation (BULKLOAD=YES BL_METHOD=CLILOAD)
     select ACCOUNT_ID
,MONTH_END_DT
,END_PRINCIPAL_BALANCE
,DEFAULT_IND
,CLOSE_DT
,NEW_DEF_IND
,NEW_DEFAULT_IND
,WRITE_OFF_MONTH
,WRITE_OFF_IND
,WRITE_OFF_AMT
,FINAL_DEFAULT_IND
,TRADES_STSFCT_CNTSLP6M
,TRADES_ACTIVE_UTIL_PCTMAX12M
,DEROGATORY_PUBLIC_REC_CNT
,COLLECTIONS_CNT
,BANKRUPTCIES_CNT
,CREDIT_TRBLE_BNKRPTCY_COLL_DER
,INS_ID_GROUP
,DAYS_ARREARS_CNT
,NSF_YTD_CNT
,EVER_30_CNT
,REMAIN_AMORT2
,PROP_VAL_NEW
,LTV_TERANET
,PROVIDER
,MODEL_EXCL
,SEGMENT
         from &_segment_output_tbl;
quit;

