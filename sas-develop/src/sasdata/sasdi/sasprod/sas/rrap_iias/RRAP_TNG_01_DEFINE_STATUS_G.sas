/*---------------------------------------------------------------------
 * NAME:    01_tng_define_status.sas
 *
 * PURPOSE: Assigns the PIT default status for TNG mortgage accounts 
 *             
 * NOTES: 
 *             
 * MODIFIED:
 *    02JAN2014 - WP -  Created
 *    19JAN2014 - WP -  Added code to make array numbers more dynamic
 *                      with latest date in data.
 *    28JAN2014 - WP -  Added insert into NZ table at end of code.
 *
 * Copyright (c) 2015 by The Financial Risk Group, Cary, NC, USA.
 *---------------------------------------------------------------------*/


%let _status_output_tbl = results.tng_status;


proc sql;
   create table work.defaults as
      select distinct account_id
         from netcon.tng_acct_mo 
         where default_ind='Y';
quit;

%put &=syserr;
%put &=sqlrc;

proc sql;
   create table work.tests as
      select *
         from netcon.tng_acct_mo
         where account_id in (select account_id from defaults);
quit; 

%put &=syserr;
%put &=sqlrc;




data work.tests2;
   set work.tests;
   new_default_ind=default_ind;
   date=intck('month','31DEC2004'd,month_end_dt); 
run; 

%put &=syserr;
%put &=sqlrc;


PROC SORT data =work.tests2;
   by ACCOUNT_ID month_end_dt;
run;

%put &=syserr;
%put &=sqlrc;


/* Query added by will to make arrays more dynamic by using a macro variable*/

proc sql noprint;
   select intck('month','31DEC2004'd, max(a.month_end_dt))
      into :month
   from work.tests2 as a;
quit;

%put &=syserr;
%put &=sqlrc;

/* Used to make sure the value is stripped of blanks */
%let month_num=&month;


   

data work.tests4;   
   array Months[&month_num.] Months1 - Months&month_num.;
   array Default[&month_num.] $  Default1 - Default&month_num. ;
   array acct[&month_num.] $80. acct1-acct&month_num. ;
   array days[&month_num.]  days1-days&month_num.;
   array arrears[&month_num.]  arrears1-arrears&month_num.;
   array pymt[&month_num.]  pymt1-pymt&month_num.;
   array sundry[&month_num.]  sundry1-sundry&month_num.;
   retain Months1 - Months&month_num. Default1 - Default&month_num. acct1-acct&month_num.   
           days1-days&month_num. arrears1-arrears&month_num.  pymt1-pymt&month_num.
           sundry1-sundry&month_num.;
   set work.tests2;
   by ACCOUNT_ID ;
   if first.ACCOUNT_ID then 
                         do i=1 to &month_num.;
                            Months[i] = . ;
                            Default[i] = . ;
                            acct[i]=.;
                            days[i]=.;
                            arrears[i]=.;
                            pymt[i]=.;
                            sundry[i]=.;
                         end ;

   Months[date] = MONTH_END_DT ;
   Default[date] = new_default_ind ;
   acct[date]=ACCOUNT_ID;
   days[date]=days_arrears_cnt;
   arrears[date]=tot_arrears_amt;
   pymt[date]=pymts_arrears_cnt;
   sundry[date]=sundry_balance;
   if last.ACCOUNT_ID then output;
   drop i date ;
run ;

%put &=syserr;
%put &=sqlrc;



/**************************************************************************************/ 
/*First adjustments made the default indicator. In order to ensure that a defaulted   */
/*account truly goes back to performing we check to ensure that there are no arrears  */
/*status (i.e. all arears are zero) or missing payments or existing sundry costs      */
/*before we set the indicator back to no default. This was done because of            */
/*observations where an account's default indicator is switched off even though the   */
/*account is still in arrears and a month or two later the flag goes back on. Fields  */
/*checked are days_arrears_cnt, tot_arrears_amt, pymts_arrears_cnt and sundry_balance */
/**************************************************************************************/

data work.tests4b;
   set work.tests4;
   array Default[&month_num.] ;
   array days[&month_num.] ;
   array arrears[&month_num.] ;
   array pymt[&month_num.] ;
   array sundry[&month_num.] ;
   do i=2 to &month_num.;
      if Default(i-1)='Y' and Default(i)='N' and (days(i)>0 or arrears(i)>0 or pymt(i)>0 or sundry(i) > 250) then Default(i)='Y';
   end;
 run;

 %put &=syserr;
%put &=sqlrc;



/**************************************************************************************/
/*Un-arraying the data and creation of field new_def_ind for an adjusted default      */
/*indicator                                                                           */
/**************************************************************************************/
data work.tests4c (keep= account month new_def_ind);
   array Months{*} Months1 - Months&month_num. ;
   array Default{*} $  Default1 - Default&month_num. ;
   array acct{*} $80. acct1-acct&month_num.;
   format month DATE9.0;
   format account $80.;
   set work.tests4b;
   do i=1 to DIM(Months);
      account=acct(i) ;
      month= Months(i);
      new_def_ind=Default(i);
      output;
   end;
run;

%put &=syserr;
%put &=sqlrc;


data work.tests4d;
   set  work.tests4c;
   where month ne .;
run;

%put &=syserr;
%put &=sqlrc;


/**************************************************************************************/
/*Taking extracting accounts that were written off. Write offs based on file created  */
/*by Tangerine that is reconciled to the G/L and audited financial statements. Note   */
/*that a feew write offs were excluded because they appear to still be performing     */
/*accounts. These write offs are in the G/L but may have been costs accidentally      */
/*placed in the write off G/L. Accounts excluded are MBS~7000174901, MBS~7000225553,  */
/*MBS~7700206059, MCAP~8207220~1, MBS~7000068947, MBS~7000034722, MBS~203566,         */
/*MBS~7000039018, MBS~7000124332, MCAP~8268926~1, MBS~7700174435.                     */
/**************************************************************************************/


data work.temp_write_off;
   set netcon.tng_acct_writeoff;
   format account_id $80.;
   if substrn(mtg_num,1,1) ='F' or substrn(mtg_num,1,1) ='M' or substrn(mtg_num,1,1) ='R' then account_id=mtg_num;
      else if Provider="FNAL" then account_id=catt("FNAL~",mtg_num,"~1");
      else if  Provider="MCAP" then account_id=catt("MCAP~",mtg_num,"~1");
      else if  Provider="DIR" and substrn(mtg_num,1,1) ne '7' then account_id=catt("MCAP~",mtg_num,"~1");
      else account_id=catt("MBS~",mtg_num);
run;

%put &=syserr;
%put &=sqlrc;


data work.temp_write_off;
   set work.temp_write_off;
   where account_id not in('MBS~7000174901' 'MBS~7000225553' 'MBS~7700206059' 'MCAP~8207220~1' 'MBS~7000068947' 'MBS~7000034722' 'MBS~203566'         
                           'MBS~7000039018' 'MBS~7000124332' 'MCAP~8268926~1' 'MBS~7700174435');
run;

%put &=syserr;
%put &=sqlrc;


proc sql;
   create table work.temp1 as
      select account_id, min(month_end_dt) as month_end, min(writeoff_date) as write_off_month
         from work.temp_write_off
         group by account_id;
quit;

%put &=syserr;
%put &=sqlrc;

proc sql;
   create table work.temp2 as
      select account_id, sum(writeoff_amt) as write_off_amt
         from work.temp_write_off
         group by account_id;
quit;

%put &=syserr;
%put &=sqlrc;


proc sql;
   create table work.write_offs as
      select a.*,b.write_off_amt
         from work.temp1 as a 
              left join 
              work.temp2 as b
         on a.account_id=b.account_id;
quit;

%put &=syserr;
%put &=sqlrc;


proc sql;
   create table work.tests6 as
      select a.*
         from netcon.tng_acct_mo as a
         where a.account_id in (select b.account_id 
                                   from work.write_offs as b) /*check tangerine requirements list for the precise table name for write off data*/;
quit; 

%put &=syserr;
%put &=sqlrc;

data work.tests6;
   set work.tests6;
   write_off_ind='Y';
run;

%put &=syserr;
%put &=sqlrc;



/********************************/
/*Joinging write off information*/
/********************************/
proc sql;
   create table work.tests7 as
      select a.*,b.Write_off_month, b.WRITE_OFF_AMT
         from work.tests6 as a 
              left join 
              work.write_offs as b  /* ensure there are no duplicate accounts in cpd9*/
         on a.account_id =b.account_id ;
quit; 

%put &=syserr;
%put &=sqlrc;

/**************************************************************************************/
/*The second change to the default indicator takes place in the code below.Whenever   */
/*there is a write off the default indicator is to be switched on until the mortgage  */
/*goes out of the data set. This step relies on the authenticity of the wrie offs     */ 
/**************************************************************************************/
data work.tests7;
   set work.tests7;
   if Write_off_month<=month_end_dt then new_default_ind='Y';
      else new_default_ind=default_ind;
run;

%put &=syserr;
%put &=sqlrc;



/***************************************/
/*Joining different indicators together*/
/***************************************/
proc sql;
   create table work.PIT_def as
      select a.account_id, 
             a.month_end_dt, 
             a.end_principal_balance, 
             a.default_ind, 
             a.close_dt
         from netcon.tng_acct_mo as a;
quit; 

%put &=syserr;
%put &=sqlrc;





proc sql;
   create table work.PIT_def2 as
      select a.* ,
             b.new_def_ind
         from work.PIT_def as a 
              left join tests4d As b
         on a.account_id=b.account and a.month_end_dt=b.month;
quit;

%put &=syserr;
%put &=sqlrc;


proc sql;
   create table work.PIT_def3 as
      select a.*,
             b.new_default_ind,
             b.Write_off_Month, 
             b.write_off_ind, 
             b.write_off_amt
         from work.PIT_def2 as a 
             left join 
             work.tests7 As b
         on a.account_id=b.account_id and a.month_end_dt=b.month_end_dt;
quit;

%put &=syserr;
%put &=sqlrc;



/**************************************************************************************/
/*Below is the third and final change to default indicator. In order for the default  */
/*indicator to be on the balance has to be greater than zero unless there was a write */ 
/*off on the account. Also below the final default indicator is switched on if any of */
/*the other 2 created indicators are on.                                              */
/**************************************************************************************/

data &_status_output_tbl;
   set work.PIT_def3;
   if end_principal_balance=0 and new_default_ind ne 'Y' then final_default_ind='N' ;
      else if new_def_ind='Y' or new_default_ind='Y' then final_default_ind='Y' ;
      else final_default_ind=default_ind;
run;

%put &=syserr;
%put &=sqlrc;

