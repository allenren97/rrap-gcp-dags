/* EXTRACT RUN DATE FROM CONTROL TABLE */

%get_model_period_dates(product=mor);
/*%let start_period_dt=31JAN2010;*/
/*%let end_period_dt=31MAY2015;*/
%put Start and End Dates for Mortgage Models:;
%put start_period_dt: &start_period_dt ;
%put end_period_dt: &end_period_dt;


%let _avg_start_qtr = 31DEC2004;
/*%let _avg_end_qtr = 31JUL2015;*/
%let _avg_end_qtr = &end_period_dt.;

%let _input_base_seg_tbl =results.tng_lgdnd_lgd_seg_combine;
%let _output_tbl = results.tng_lgd_nd_realized;
%let _output_avg_tbl = results.tng_lgd_nd_historical;

%let _qtr_cntrl_tbl=control.qtr_end_dates;



proc summary data = &_input_base_seg_tbl nway missing;

   var lgd lgd_costs lgd_costs_cap_100 lgd_costs_cap_150;

   /* Aggregate by observation start date and segment */
   class month_end_dt segment;
   output out = work.lgd_components (drop = _TYPE_ rename = (_freq_ = current_count))
   sum = lgd lgd_costs lgd_costs_cap_100 lgd_costs_cap_150;
run;


/*--------------------------------------------------------------------
 * Segmented realized Values
 *--------------------------------------------------------------------*/
proc sql noprint;
   create table &_output_tbl as
      select a.segment,
             a.month_end_dt,
             a.current_count,
             a.lgd,
             (case
               when a.current_count NE . and a.lgd NE . then a.lgd/a.current_count
               when a.current_count NE . and a.lgd EQ . then .
               when a.current_count EQ . and a.lgd NE . then .
               else .
             end) as segment_lgd,
             a.lgd_costs,
             (case
               when a.current_count NE . and a.lgd_costs NE . then a.lgd_costs/a.current_count
               when a.current_count NE . and a.lgd_costs EQ . then .
               when a.current_count EQ . and a.lgd_costs NE . then .
               else .
             end) as segment_lgd_costs,
             a.lgd_costs_cap_100,
             (case
               when a.current_count NE . and a.lgd_costs_cap_100 NE . then a.lgd_costs_cap_100/a.current_count
               when a.current_count NE . and a.lgd_costs_cap_100 EQ . then .
               when a.current_count EQ . and a.lgd_costs_cap_100 NE . then .
               else .
             end) as segment_lgd_costs_cap_100,
             a.lgd_costs_cap_150,
             (case
               when a.current_count NE . and a.lgd_costs_cap_150 NE . then a.lgd_costs_cap_150/a.current_count
               when a.current_count NE . and a.lgd_costs_cap_150 EQ . then .
               when a.current_count EQ . and a.lgd_costs_cap_150 NE . then .
               else .
             end) as segment_lgd_costs_cap_150
      from work.lgd_components as a
      order by segment;
quit;


/*-----------------------------------------------------------------
 * Keeping only quarter end date observations for the historical
 * average LGD calculations. logic change for select quarter end date - CV 02DEC2015
 *-----------------------------------------------------------------*/
proc sql noprint;
   create table intmed.tng_lgd_nd_realized_quarter_end as
   select a.*
   from &_output_tbl as a
    where month(a.month_end_dt) in (1,4,7,10);
quit;

/*Added month_end_dt to class statement - CV 02DEC2015*/

/*-----------------------------------------------------------------
 * Creating the LGD Historical Average
 *-----------------------------------------------------------------*/
proc summary data = intmed.tng_lgd_nd_realized_quarter_end nway missing;
   where month_end_dt GE "&_avg_start_qtr"d and month_end_dt LE "&_avg_end_qtr"d;
   class segment month_end_dt;
   var current_count lgd lgd_costs lgd_costs_cap_100 lgd_costs_cap_150;
   output out = work.summarized_vals_lgdnd (drop = _type_ _freq_)
   sum = current_count lgd lgd_costs lgd_costs_cap_100 lgd_costs_cap_150;
quit;


proc sql noprint;
   create table work.qtr_end_values_lgdnd as
      select a.segment,
				month_end_dt,
				min(a.month_end_dt) format=date9. as start_date,
				max(a.month_end_dt) format=date9. as seg_end_date,
             (case
               when a.current_count NE . and a.lgd NE . then a.lgd/a.current_count
               when a.current_count NE . and a.lgd EQ . then .
               when a.current_count EQ . and a.lgd NE . then .
               else .
             end) as qtr_lgd,
             (case
               when a.current_count NE . and a.lgd_costs NE . then a.lgd_costs/a.current_count
               when a.current_count NE . and a.lgd_costs EQ . then .
               when a.current_count EQ . and a.lgd_costs NE . then .
               else .
             end) as qtr_lgd_costs,
             (case
               when a.current_count NE . and a.lgd_costs_cap_100 NE . then a.lgd_costs_cap_100/a.current_count
               when a.current_count NE . and a.lgd_costs_cap_100 EQ . then .
               when a.current_count EQ . and a.lgd_costs_cap_100 NE . then .
               else .
             end) as qtr_lgd_costs_cap_100,
             (case
               when a.current_count NE . and a.lgd_costs_cap_150 NE . then a.lgd_costs_cap_150/a.current_count
               when a.current_count NE . and a.lgd_costs_cap_150 EQ . then .
               when a.current_count EQ . and a.lgd_costs_cap_150 NE . then .
               else .
             end) as qtr_lgd_costs_cap_150
      from work.summarized_vals_lgdnd as a
      order by segment, month_end_dt;
quit;

/* Added data step to create a complete timespan for each segment, The segments now have a data point
	 for each quarter inbetween their min dates and the most recent date - CV 2DEC2015*/

data work.fill_in_dates_lgdnd (keep=segment end_date);
	retain end_date;
	set work.qtr_end_values_lgdnd (keep=segment seg_end_date month_end_dt);
	by segment;
	end_date= month_end_dt;
	if first.segment then 
		do until (end_date gt seg_end_date);
				if month(end_date) in (1,4,7,10) then output;
				end_date= intnx('MONTH',end_date,1,'e');
		end;
	format end_date date9.;
run;

/* Calculate qtr averages - CV 02DEC2015*/

data work.quarter_averages_lgdnd (keep= segment start_date end_date avg_lgd avg_lgd_costs avg_lgd_costs_cap_100 avg_lgd_costs_cap_150);
		set work.qtr_end_values_lgdnd (rename= (month_end_dt = end_date));
		retain new_lgd new_lgd_costs new_lgd_costs_cap_100 new_lgd_costs_cap_150;
		by segment;
		if first.segment then do;
			counter = 0;	
			new_lgd = 0;
			new_lgd_costs = 0;
			new_lgd_costs_cap_100 = 0;
			new_lgd_costs_cap_150 = 0;
		end;
		counter + 1;		
		new_lgd = sum(new_lgd,qtr_lgd);
		new_lgd_costs = sum(new_lgd_costs,qtr_lgd_costs);
		new_lgd_costs_cap_100 = sum(new_lgd_costs_cap_100,qtr_lgd_costs_cap_100);
		new_lgd_costs_cap_150 = sum(new_lgd_costs_cap_150,qtr_lgd_costs_cap_150);
		
		avg_lgd = (new_lgd/counter);
		avg_lgd_costs = (new_lgd_costs/counter);
		avg_lgd_costs_cap_100 = (new_lgd_costs_cap_100/counter);
		avg_lgd_costs_cap_150 = (new_lgd_costs_cap_150/counter);

		format end_date date9. start_date date9.;
run;

/* Joins the complete list of dates with the averages for the quarter - CV 2DEC2015*/

proc sql;
	create table work.hist_with_missing_lgdnd as
	select a.*,
			b.start_date,
			b.avg_lgd,
			b.avg_lgd_costs,
			b.avg_lgd_costs_cap_100,
			b.avg_lgd_costs_cap_150
	from work.fill_in_dates_lgdnd as a
			left join
	   	work.quarter_averages_lgdnd as b
	on a.segment = b.segment and
		a.end_date = b.end_date;
quit;

/*Fills in the data points that do not have averages associated with them by retaining the previous
values - CV 2DEC2015*/

data &_output_avg_tbl (keep= end_date start_date segment avg_lgd avg_lgd_costs avg_lgd_costs_cap_100 avg_lgd_costs_cap_150);
	set work.hist_with_missing_lgdnd;
	retain ret_start_date ret_avg_lgd ret_avg_lgd_costs ret_avg_lgd_costs_cap_100 ret_avg_lgd_costs_cap_150;
	if start_date = . then start_date = ret_start_date;
	if avg_lgd = . then avg_lgd = ret_avg_lgd;
	if avg_lgd_costs = . then avg_lgd_costs = ret_avg_lgd_costs;
	if avg_lgd_costs_cap_100 = . then avg_lgd_costs_cap_100 = ret_avg_lgd_costs_cap_100;
	if avg_lgd_costs_cap_150 = . then avg_lgd_costs_cap_150 = ret_avg_lgd_costs_cap_150;
	
	ret_start_date = start_date;
	ret_avg_lgd = avg_lgd ;
	ret_avg_lgd_costs = avg_lgd_costs;
	ret_avg_lgd_costs_cap_100 = avg_lgd_costs_cap_100;
	ret_avg_lgd_costs_cap_150 = avg_lgd_costs_cap_150;
run; 

