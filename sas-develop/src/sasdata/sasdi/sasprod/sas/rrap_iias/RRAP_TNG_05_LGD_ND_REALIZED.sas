quit;

proc sql;
   insert into nz_frg.tng_lgd_nd_historical (BULKLOAD=YES BL_METHOD=CLILOAD)
      select a.segment,
					a.end_date,
					a.start_date,
					a.avg_lgd,
					a.avg_lgd_costs,
					a.avg_lgd_costs_cap_100,
					a.avg_lgd_costs_cap_150
         from &_output_avg_tbl as a;
quit;



