proc sql noprint;
connect using nz_frg as nz_frg;
   /*execute (truncate table &frg_db..tng_lgd_nd_historical ) by nz_frg; */
   execute (truncate table &frg_db..tng_lgd_nd_historical IMMEDIATE ) by nz_frg;
