%let _06_all_input = nz_frg.BASEL_ANLYT_BL_INST_FCT_TNG_DLGD;
%let _pd_seg_tbl = nzuser.basel_ncr_pd_seg_dim;
%let _lgd_seg_tbl = nzuser.basel_ncr_lgd_seg_dim;

%get_model_period_dates(product=mor); 

%put Start and End Dates for Mortgage Models:;
%put start_period_dt: &start_period_dt ;
%put end_period_dt: &end_period_dt;

%global mth_tm_id;

/*fetch the time id for process date*/
proc sql NOPRINT;
select tm_id into :mth_tm_id from nzuser.tm_dim where tm_lvl_end_dt="&end_period_dt"d and tm_lvl='Month';
quit;


proc sql noprint;
      create table work._prep_for_bd_be_history_intmed as 
      select a.*,
             d.tm_lvl_end_dt*86400 as process_date format=datetime21.,
             a.mort_num as mortgage_no,
             b.ncr_pd_seg_key_val,
             c.ncr_lgd_seg_key_val,
             case
                when upcase(a.pit_stat_cd)='CUR' then '3307'
                when upcase(a.pit_stat_cd) in ('DEF','CHG') then '3308'
             end as ncr_ead_seg_key_val length=4
             , a.DLGD_RPTG_RTO /*DLGD REQUIREMENT*/            

      from &_06_all_input as a
           left join
           &_pd_seg_tbl as b
           on (a.pit_stat_cd = b.pit_stat_cd and 
               a.pd_final_rptg_rto GE b.pd_min_val and a.pd_final_rptg_rto LT b.pd_max_val)
           left join
           &_lgd_seg_tbl as c
           on (a.pit_stat_cd = c.pit_stat_cd and 
               a.DLGD_RPTG_RTO GE c.lgd_min_val and a.DLGD_RPTG_RTO LT c.lgd_max_val)
           left join
           nzuser.tm_dim as d
           on a.mth_tm_id = d.tm_id and upcase(d.tm_lvl) = 'MONTH'
					
			  
      where (a.mth_tm_id between (&mth_tm_id.-120) and &mth_tm_id.) and 
			upcase(a.consm_prd_treatmnt_cd)='A'  and upcase(a.sml_bus_f)='N' and upcase(a.pit_stat_cd) in ('CUR', 'DEF')
            and upcase(a.trnst_exclsn_f)='N';
        
quit;


data work._prep_for_bd_be_history;
   set work._prep_for_bd_be_history_intmed;
   if pd_final_rptg_rto >= 1 then ncr_pd_seg_key_val='0922';
   if Dlgd_rptg_rto >= 1 then ncr_lgd_seg_key_val='3209';
   if upcase(pit_stat_cd)='DEF' then do;
                                        ncr_pd_seg_key_val='0923';
                                        ncr_lgd_seg_key_val='3210';
                                     end;
run;

/*--------------------------------------------------------
 * Code to truncate before inserting into NZ table.
 *--------------------------------------------------------*/

proc sql noprint;
	connect using nz_frg as nz_frg;
/*   connect to netezza as nz_frg (server=cs2iwntzp01 database=frg_user_q3_2015 user = &_userid_nz password = &_pwd_nz);*/
 /*  execute (TRUNCATE TABLE &frg_db..history_tbl_for_bd_be_fact_tng ) by nz_frg; */
   execute (TRUNCATE TABLE &frg_db..history_tbl_for_bd_be_fact_tng IMMEDIATE ) by nz_frg;
   disconnect from nz_frg;
quit;

proc sql noprint;
   insert into nz_frg.history_tbl_for_bd_be_fact_tng (BULKLOAD=YES BL_METHOD=CLILOAD)
   select a.mortgage_no,
         a.process_date,
         a.mth_tm_id,
         a.ncr_geo_key_val,
         a.ncr_pd_band_key_val,
         a.ncr_rt_sys_key_val,
         a.ncr_pd_seg_key_val,
         a.ncr_lgd_seg_key_val,
         a.ncr_ead_seg_key_val,
         a.ncr_expsr_cl_key_val,
         a.src_sys_cd,
         a.pit_stat_cd,
         a.pd_final_rptg_rto,
         a.lgd_final_rptg_rto,
		 . as default_ind,   /* not used by BD-set to null */
		 . as default_bal,   /* not used by BD-set to null */
         a.intr_accr_amt,
         a.os_bal_amt,
         a.lgd_model_rto,
			a.DLGD_RPTG_RTO
   from work._prep_for_bd_be_history as a;
quit;















