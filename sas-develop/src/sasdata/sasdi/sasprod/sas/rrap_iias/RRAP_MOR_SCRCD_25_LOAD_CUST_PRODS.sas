proc sql;
	connect USING NZUSER as nzcon ;
	execute (
create table &target_lib3..SCORECARD_VARS_CUST_PRODS as (
		select
			a.*, nullif(b.MORT_NO,'') as mort_no, b.ACCOUNT, b.PRODUCT, b.file_yr_mth,
		case 
			when b.product in ('SCL', 'VLR', 'VGD', 'VCL', 'VAX', 'VZX', 'SSL', 'VIC', 'LOC') then 'KS'
			when b.product in ('MOR') then 'MOR'
			when b.product in ('SPL') then 'SPL' 
