		from 
			&target_lib3..SCORECARD_VARS_CUST_LIST as a
		left join &target_lib2..CIS_DATA_NEW2 as b on a.cid=b.cid
			and file_yr_mth=cis_tm_id AND B.PRODUCT IN ('SCL', 'VLR', 'MOR', 'VGD', 'VCL', 'VAX', 'VZX', 'SSL', 'VIC', 'SPL', 'LOC')
			and a.cis_tm_id <> '0907'
union all
		select
			a.*, nullif(b.MORT_NO,'') as mort_no, b.ACCOUNT, b.PRODUCT, b.file_yr_mth,
		case 
			when b.product in ('SCL', 'VLR', 'VGD', 'VCL', 'VAX', 'VZX', 'SSL', 'VIC', 'LOC') then 'KS'
			when b.product in ('MOR') then 'MOR'
			when b.product in ('SPL') then 'SPL' 
		end 
	as system
		from 
			&target_lib3..SCORECARD_VARS_CUST_LIST as a
		left join &target_lib2..CIS_DATA_NEW2 as b on a.cid=b.cid
			and b.file_yr_mth='1009' AND B.PRODUCT IN ('SCL', 'VLR', 'MOR', 'VGD', 'VCL', 'VAX', 'VZX', 'SSL', 'VIC', 'SPL', 'LOC')
			and a.cis_tm_id = '0907'
		/*	DISTRIBUTE ON (cid,file_yr_mth)  */
		  
			) WITH DATA DISTRIBUTE BY (cid,file_yr_mth) 
) by nzcon;
