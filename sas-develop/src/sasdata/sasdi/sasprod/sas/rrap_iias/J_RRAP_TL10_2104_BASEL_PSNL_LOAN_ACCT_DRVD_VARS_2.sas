/*-----------------------------------------------------------
 * Implement Commercial Flag Fix
 *
 * Logic to create a new commercial flag for the months,
 * JAN 2011-APR2011.  This is a correction made in the data.
 * The correction will be based on the commercial flag values
 * from MAY 2011.  The second query was build off of data 
 * step match merge logic provided by RRM.  This was changed
 * to a query to aid in efficiency by using pass-through to
 * Netezza.
 * This has been moved outside of the monthly macro run.
 *-----------------------------------------------------------*/   

%macro comm_flag_fix;

   %delete_table(&sas_nz_intmed_lib..spl_status_input_copy)

   proc sql noprint;
      connect using &sas_nz_intmed_lib as nzcon;
      execute(
         create table %nrbquote(&nz_intmed_db).spl_status_input_copy as
         (select a.loan_no,
                a.cab,
                a.process_date,
                a.perf_ym,
                a.commercial_loan_flag
         from %nrbquote(&nz_input_db..&input_table) as a
       ) WITH DATA DISTRIBUTE BY HASH (loan_no)) by nzcon;
   quit;

   %put &=syserr;
%put &=sqlrc;

   %delete_table(&sas_nz_intmed_lib..comm_flag_subset)
   %delete_table(&sas_nz_intmed_lib..spl_status_comm_fix)

   proc sql noprint;
      connect using &sas_nz_intmed_lib as nzcon;
      execute (       

         create table %nrbquote(&nz_intmed_db).comm_flag_subset as
         (select a.cab,
                a.loan_no,
                a.commercial_loan_flag as commercial_flag_v2
         from %nrbquote(&nz_input_db..&input_table) as a
         where a.perf_ym = 201105       

       )  WITH DATA DISTRIBUTE BY HASH (loan_no)) by nzcon;

      execute (
                
         create table %nrbquote(&nz_intmed_db).spl_status_comm_fix as (
		select e.*,coalesce(e.comm_flag_intmed, e.commercial_flag_v2) as commercial_flagv2 from
		( select a.process_date,
                a.perf_ym,
                coalesce(a.cab,b.cab) as cab,
                coalesce(a.loan_no,b.loan_no) as loan_no,
                case 
                   when (a.perf_ym = '201101' or 
                         a.perf_ym = '201102' or 
                         a.perf_ym = '201103' or 
                         a.perf_ym = '201104') then null
                   else a.commercial_loan_flag
                end as comm_flag_intmed,
                b.commercial_flag_v2 as commercial_flag_v2      

         from %nrbquote(&nz_intmed_db).spl_status_input_copy as a
              left join
              %nrbquote(&nz_intmed_db).comm_flag_subset as b
              on (a.loan_no = b.loan_no and
                  a.cab = b.cab)     
			) e
          ) WITH DATA DISTRIBUTE BY HASH (loan_no)) by nzcon;
      disconnect from nzcon;
   quit;  

   %put &=syserr;
%put &=sqlrc;
%mend comm_flag_fix;
%comm_flag_fix 


/* Clean Up */
%delete_table(&sas_nz_intmed_lib..spl_status_input_copy);

