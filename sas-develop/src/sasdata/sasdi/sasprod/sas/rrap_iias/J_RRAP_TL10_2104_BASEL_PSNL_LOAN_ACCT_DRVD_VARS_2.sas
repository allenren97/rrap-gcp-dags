/*--------------------------------------------------------
 * Beginning of macro to process each month incrementally.
 *--------------------------------------------------------*/

%macro spl_status(start_period_dt=,end_period_dt=);

   /*--------------------------------------------------------
    * Defining the number of periods the status process will 
    * run.  Each period will be processed incrementally.
    *--------------------------------------------------------*/
   data _null_;
      call symput('number_periods', cats(intck('month', "&start_period_dt"d, "&end_period_dt"d)));
   run;

   /*--------------------------------------------------------
    * Loop over all months for the range specified by the 
    * start and end period dates.
    *--------------------------------------------------------*/
    %do ii=0 %to &number_periods;

       /*----------------------------------------------------
       * Setting date macros variables for NZ date
       * literal format based off of start_period_dt and 
       * end_period_dt formats. NZ requires date literals to
       * be in following format: YYYY-MM-DD
       *----------------------------------------------------*/
       data _null_;
          call symput('period_dt', cats(put(intnx('month', "&start_period_dt"d, &ii, 'e'), date9.)));
          call symput('period_dt_nz', cats(put(intnx('month', "&start_period_dt"d, &ii, 'e'), yymmdd10.)));
       run;

       %put NOTE: USER DEFINED: SPL Status process for Observation Period: &period_dt;
   
       /*--------------------------------------------------------
        * I. Assign PIT Status
        *
        * Code to assign status to each SPL direct and indirect
        * account.
        *--------------------------------------------------------*/       

       %delete_table(&sas_nz_intmed_lib..spl_pit)

       %put &=syserr;
%put &=sqlrc;

       proc sql noprint;
          connect using &sas_nz_intmed_lib as nzcon;
          execute (       

             create table %nrbquote(&nz_intmed_db).spl_pit as 
            ( select last_day(date_trunc('day',a.process_date)) as process_date,
                    a.perf_ym,
                    a.cab,
                    a.loan_no,
                    a.product_id,
                    a.daysover,
                    a.recstat_code,
                    a.chg_off_date,
                    a.commercial_loan_flag,
                    a.select_status_new,
                    a.principal_bal,
                    a.addon_bal,
                    a.addon_int_amt,
                    a.accr_int,
                    a.commercial_flagv2,
					a.basel_acct_id, 
					a.mth_tm_id,
					a.basel_cust_id,
					a.prd_tp,
					a.prd,
					a.sub_product,
					a.prd_id,
					b.CROSS_DFLT_PIT_STATUS as pit_status

                    /* Order should be CLO -> CHG -> DEF -> CUR */
/*----- RRMSS-2841 logic migrated to Step Pit job, look up final Pit from edrtlrp1d.PIT_STATUS_PRE_STEP -----
*                    case
*                      when (a.recstat_code = 9 or a.recstat_code = 0 or a.recstat_code is null) then 'CLO'
*                      when (a.recstat_code = 6 or a.recstat_code = 7 or a.recstat_code = 8) then 'CHG'
*                      when a.chg_off_date is not null then 'CHG'   
*                      when a.daysover >= 90 or a.recstat_code = 5 then 'DEF'
*                      when a.daysover < 90 and a.recstat_code = 4 then 'CUR'
*                      else null
*                   end as pit_status
*-----------------------------------------------------------------------------------------------------------*/
                
             from %nrbquote(&nz_input_db..&input_table) as a 
                  left join
                  %nrbquote(&nz_results_db..PIT_STATUS_PRE_STEP) as b
                  on a.MTH_TM_ID=b.MTH_TM_ID and
                     a.BASEL_ACCT_ID=b.BASEL_ACCT_ID and 
                     b.SRC_SYS_CD='SPL' 
             where %nrbquote('&period_dt_nz') = last_day(date_trunc('day', a.process_date))      

             ) WITH DATA DISTRIBUTE BY HASH (loan_no)) by nzcon;
          disconnect from nzcon;
       quit;  

       %put &=syserr;
%put &=sqlrc;


       /*---------------------------------------------------------------------
        * Creating the table needed to calculate pe_last_new_default_date. 
        *---------------------------------------------------------------------*/
       %delete_table(&sas_nz_intmed_lib..last_new_default_date_data)

       %put &=syserr;
%put &=sqlrc;

       proc sql noprint;
          connect using &sas_nz_intmed_lib as nzcon;
          execute (       

             create table %nrbquote(&nz_intmed_db).last_new_default_date_data as 
          (   select a.*,
                    b.pit_status_v2 as pit_status_lag,
                    b.cons_dft_mth_cnt as cons_mths_default_lag
             from %nrbquote(&nz_intmed_db).spl_pit as a
                  left join
                  %nrbquote(&nz_results_db..&output_table) as b
                  on a.loan_no=b.loan_num and
                     a.cab=b.cab and 
		     a.BASEL_ACCT_ID=B.BASEL_ACCT_ID and
                     last_day(date_trunc('day',a.process_date))=last_day(date_trunc('day',add_months(b.process_dt,1)))
             ) WITH DATA DISTRIBUTE BY HASH (loan_no)) by nzcon;
          disconnect from nzcon;
       quit;  

       %put &=syserr;
%put &=sqlrc;


       /*---------------------------------------------------------------
        * Calculating last new default date and the consecutive months
        * in default.
        *---------------------------------------------------------------*/
       %delete_table(&sas_nz_intmed_lib..last_new_default_date)

       %put &=syserr;
%put &=sqlrc;

       proc sql noprint;
          connect using &sas_nz_intmed_lib as nzcon;
          execute (    
             
             create table %nrbquote(&nz_intmed_db).last_new_default_date as
           (  select a.*,
                    
                    /* Deriving consecutive months in default */

                    case 
                       when (upper(a.pit_status_lag)='CUR' or upper(a.pit_status_lag) is null) and
                            (upper(a.pit_status)='DEF' or upper(a.pit_status)='CHG') then 1
                       when (upper(a.pit_status_lag)='DEF' or upper(a.pit_status_lag)='CHG') and
                             (upper(a.pit_status)='DEF' or upper(a.pit_status)='CHG')  then cons_mths_default_lag+1
                       else 0
                    end as cons_mths_default

             from %nrbquote(&nz_intmed_db).last_new_default_date_data as a
              ) WITH DATA DISTRIBUTE BY HASH (loan_no)) by nzcon;
          disconnect from nzcon;
       quit;  

       %put &=syserr;
%put &=sqlrc;

       /*----------------------------------------------------------
        * II. Derive "Other Variables"
        *
        * Logic from "Other Definitions" development code.  This 
        * logic assigns os_bal and segment.
        *----------------------------------------------------------*/     

       %delete_table(&sas_nz_intmed_lib..spl_status_other_vars)

       %put &=syserr;
%put &=sqlrc;

       proc sql noprint;
          connect using &sas_nz_intmed_lib as nzcon;
          execute (
             
             create table %nrbquote(&nz_intmed_db).spl_status_other_vars as 
          (   select a.*,
                    a.principal_bal + a.addon_bal + a.accr_int as os_bal_amt,
                    case
                      when a.product_id = 'S01' or 
                           a.product_id = 'S02' or 
                           a.product_id = 'S03' or 
                           a.product_id = 'S04' or
                           a.product_id = 'S05' or 
                           a.product_id = 'S06' or 
                           a.product_id = 'S07' or 
                           a.product_id = 'S08'
                         then 'DIRECT'
                      when a.product_id='S09' or 
                           a.product_id='S10' or 
                           a.product_id='S11' or
                           a.product_id='S12' or
                           a.product_id='S13' or
                           a.product_id='S14' or
                           a.product_id='S15' 
                         then 'INDIRECT'
                    end as sub_portfolio
             from %nrbquote(&nz_intmed_db).last_new_default_date as a      

              ) WITH DATA DISTRIBUTE BY HASH (loan_no)) by nzcon;
          disconnect from nzcon;
       quit;    
        
        %put &=syserr;
%put &=sqlrc;

     /*---------------------------------------------------
	   * II. Derive "Other Variables" - Addendum for CR27
	   * 
	   * The following code was adapted from the LGDD Realized process
      *
	   * If the account is in default at the observation
       * date, we need to see if that default state began
       * at an earlier date.  If it did, we need to capture
       * the amount of accrued interest at the beginning of
       * the defaulted state so that it can be used in the 
       * derivation of the the balance used to calculate 
       * LGD.
       *---------------------------------------------------*/
   
	  

      %delete_table(&sas_nz_intmed_lib..spl_distinct_default_accts)

      %put &=syserr;
%put &=sqlrc;

	  /* Get a distinct list of loans/cabs from the current month */
      proc sql;
         connect using &sas_nz_intmed_lib as nzcon;
         execute(

            create table %nrbquote(&nz_intmed_db).spl_distinct_default_accts as
           (    select distinct a.loan_no,
                      a.cab
			   from %nrbquote(&nz_intmed_db).spl_status_other_vars as a
               where upper(a.pit_status) in ('DEF','CHG') 

                ) WITH DATA DISTRIBUTE BY HASH (loan_no)) by nzcon;
         disconnect from nzcon;
      quit; 

      %put &=syserr;
%put &=sqlrc;




      %delete_table(&sas_nz_intmed_lib..spl_default_accts_hist)

      %put &=syserr;
%put &=sqlrc;

	  /* Pull history from the status table, using the current month's distinct info as a filter */
	  /* Also appending status info for current month with union. */
      proc sql;
         connect using &sas_nz_intmed_lib as nzcon;
         execute(

            create table %nrbquote(&nz_intmed_db).spl_default_accts_hist as
             (  select a.loan_no,
                      a.cab,
                      a.process_date,
                      a.pit_status,
                      a.accr_int
               from %nrbquote(&nz_intmed_db..&input_status_table) as a
                    inner join
                    %nrbquote(&nz_intmed_db).spl_distinct_default_accts as c
                    on a.loan_no=c.loan_no and
                       a.cab=c.cab and 
                       %nrbquote('&period_dt_nz') >= last_day(date_trunc('day', a.process_date))   

                union all
 
				select o.loan_no,
                       o.cab,
                       o.process_date,
                       o.pit_status,
                       o.accr_int
				from %nrbquote(&nz_intmed_db).spl_status_other_vars as o

                ) WITH DATA DISTRIBUTE BY HASH (loan_no)) by nzcon;
         disconnect from nzcon;
      quit; 

      %put &=syserr;
%put &=sqlrc;


       
      /*----------------------------------------------
       * Sorting in SAS to ensure that order is 
       * correct
       *----------------------------------------------*/

      %delete_table(work.spl_default_accts_hist)

      %put &=syserr;
%put &=sqlrc;

      proc sort data=&sas_nz_intmed_lib..spl_default_accts_hist
                out=work.spl_default_accts_hist;
         by loan_no
            cab
            descending process_date;
      run;

      %put &=syserr;
%put &=sqlrc;


       /*-----------------------------------------------
       * Finding the start of the default state, and 
       * capturing the accrued interest.
       *-----------------------------------------------*/

      %delete_table(&sas_nz_intmed_lib..spl_default_beg_int)

      %put &=syserr;
%put &=sqlrc;

      data &sas_nz_intmed_lib..spl_default_beg_int;
         set work.spl_default_accts_hist;
         by loan_no cab;
         retain flag;
        
         int_def=lag(accr_int);
         pit=lag(pit_status);
         if first.loan_no=1 or first.cab=1 then flag=0;
         if flag=0;
         if (upcase(pit_status)='CUR' and upcase(pit)='DEF') or ((last.loan_no=1 or last.cab=1) and upcase(pit_status)='DEF') then 
         do;
            if (upcase(pit_status)='CUR' and upcase(pit)='DEF') then 
            do;
               int_at_default=int_def;
               
            end;
            else 
            do;
                int_at_default=accr_int;
               
            end;
            flag+1;
             
            output;
         end;
      run;

      %put &=syserr;
%put &=sqlrc;



      %delete_table(&sas_nz_intmed_lib..spl_status_other_vars2)

      %put &=syserr;
%put &=sqlrc;

	  /* Pull history from the status table, using the current month's distinct info as a filter */
	  /* Also appending status info for current month with union. */
      proc sql;
         connect using &sas_nz_intmed_lib as nzcon;
         execute(

            create table %nrbquote(&nz_intmed_db).spl_status_other_vars2 as
            (   select a.*,
                      b.int_at_default,
                      case 
                         when upper(a.pit_status) in ('DEF', 'CHG') then a.principal_bal + a.addon_bal + b.int_at_default
						 when upper(a.pit_status) in ('CUR', 'CLO') then a.principal_bal + a.addon_bal + a.accr_int
                      end as os_bal_amt_v2

               from %nrbquote(&nz_intmed_db..spl_status_other_vars) as a
                    left join
                    %nrbquote(&nz_intmed_db).spl_default_beg_int as b   
                    on a.loan_no=b.loan_no and
                       a.cab=b.cab

                ) WITH DATA DISTRIBUTE BY HASH (loan_no)) by nzcon;
         disconnect from nzcon;
      quit; 

      %put &=syserr;
%put &=sqlrc;








       /*------------------------------------------------------------
        * III. Exclusions
        *
        * This step assigns exclusion flags.  Per modelers, these 
        * flags do not determine which accounts are exluded from 
        * scoring and segmentation models, but are used elsewhere in
        * the modeling process.
        *------------------------------------------------------------*/      

       %delete_table(&sas_nz_intmed_lib..spl_status_excl_flags)

       %put &=syserr;
%put &=sqlrc;

       proc sql noprint;
          connect using &sas_nz_intmed_lib as nzcon;
          execute (
             
             create table %nrbquote(&nz_intmed_db).spl_status_excl_flags as
          (   select a.*,     

                    /* Small balance exclusions */
                    case
                       when (upper(a.pit_status) = 'CUR' and (a.os_bal_amt < 100 or a.principal_bal <= 0))
                            or (upper(a.pit_status) = 'DEF' and (a.principal_bal <= 0 or os_bal_amt < 1 )) then 1
                       else 0
                    end as ind_bal_excl,       

                    /* Home improvement loan exclusions */
                    case
                       when a.product_id = 'S11' then 1
                       else 0
                    end as ind_hl_excl,     

                    /* Other indirect loans exclusions */
                    case 
                       when a.product_id = 'S14' then 1
                       else 0
                    end as ind_othind_excl,       

                    /* Small business loans exclusions */
                    case 
                       when a.commercial_flagv2 = 1 then 1
                       when a.commercial_flagv2 = 2 then 1
                       else 0
                    end as ind_com_excl,       

                    /* Invalid cab exclusions */
                    case 
                       when a.cab = 18192 or a.cab = 99432 then 1
                       else 0
                    end as ind_cab_excl,       

                    /* Greater 24 months in default */
                    case 
                       when a.cons_mths_default > 24 then 1 
                       else 0
                    end as ind_24mos_excl
             from %nrbquote(&nz_intmed_db).spl_status_other_vars2 as a       

              ) WITH DATA DISTRIBUTE BY HASH (loan_no)) by nzcon;
          disconnect from nzcon;
       quit;    

       %put &=syserr;
%put &=sqlrc;
 
       %delete_table(&sas_nz_intmed_lib..spl_status_with_excl)

       %put &=syserr;
%put &=sqlrc;

       proc sql noprint;
          connect using &sas_nz_intmed_lib as nzcon;
          execute (       

             create table %nrbquote(&nz_intmed_db).spl_status_with_excl as
           (  select a.*,
                    /* Setting model exclusion*/
                    case 
                       when a.ind_bal_excl = 1 or 
                            a.ind_hl_excl = 1 or 
                            a.ind_othind_excl = 1 or 
                            a.ind_com_excl = 1 or
                            a.ind_cab_excl=1 or 
                            a.ind_24mos_excl = 1 
                          then 'Y'
                       else 'N'
                    end as model_excl       

             from %nrbquote(&nz_intmed_db).spl_status_excl_flags as a
              ) WITH DATA DISTRIBUTE BY HASH (loan_no)) by nzcon;
          disconnect from nzcon;
       quit;    

       %put &=syserr;
%put &=sqlrc;
    
       /*---------------------------------------------------------------
        * IV.  Assigning Treatment Flag
        *
        * Assigning the treatment flg, which is derived based on
        * the sub-exclusion flags from the previous step.
        *---------------------------------------------------------------*/      
       %delete_table(&sas_nz_intmed_lib..&output_insrt_table)

       %put &=syserr;
%put &=sqlrc;

       proc sql noprint;
          connect using &sas_nz_intmed_lib as nzcon;
          execute (       

             create table %nrbquote(&nz_intmed_db).&output_insrt_table as
          (   select a.*,     

                    /* Setting treatment flag*/
                    case 
                       when a.ind_com_excl = 1 or a.ind_cab_excl=1 then 'Z'
                       else 'A'
                    end as treatment_flag
             from %nrbquote(&nz_intmed_db).spl_status_with_excl as a
              ) WITH DATA DISTRIBUTE BY HASH (loan_no)) by nzcon;
          disconnect from nzcon;
       quit; 

       %put &=syserr;
%put &=sqlrc;
 

       /*---------------------------------------------
        * Checks to see if the date is in NZ table 
        *---------------------------------------------*/
       proc sql noprint;
          select count(*) 
          into :date_count trimmed
          from &sas_nz_results_lib..&output_table
          where (month(process_dt) = month("&period_dt"d) and year(process_dt) = year("&period_dt"d));
       quit;

       %put &=syserr;
%put &=sqlrc;

      /*---------------------------------------------
       * If data already exists for the month, the 
       * run delete from code.
       *---------------------------------------------*/

      %if %eval(&date_count) > 0 %then
      %do;
         proc sql;
            connect using &sas_nz_results_lib as nzcon;
            execute (
               
               delete from %nrbquote(&nz_results_db..&output_table)
               where (date_part('month',process_dt) = date_part('month',cast(%nrbquote('&period_dt_nz') as date)) and 
                      date_part('year',process_dt) = date_part('year',cast(%nrbquote('&period_dt_nz') as date)))   

            ) by nzcon;
            disconnect from nzcon;
         quit;
      %end;   

      %put &=syserr;
%put &=sqlrc;
   
      /* Insert data into NZ results table*/
      proc sql noprint;
         connect using &sas_nz_results_lib as nzcon;
         execute(   

            insert into %nrbquote(&nz_results_db..&output_table)
            select a.basel_acct_id,
                   a.mth_tm_id,
                   a.pit_status as pit_status_v2,
                   a.process_date as process_dt,
                   a.loan_no as loan_num,
                   a.cab,
                   a.sub_portfolio as sub_portfl,
                   a.commercial_flagv2 as comm_f_v2,
                   a.ind_bal_excl,
                   a.ind_hl_excl,
                   a.ind_cab_excl,
                   a.ind_24mos_excl,
                   a.model_excl as model_excl_f,
                   a.treatment_flag as treatmnt_f,
				   a.basel_cust_id,
				   a.prd_tp,
				   a.prd,
				   a.cons_mths_default as cons_dft_mth_cnt,
				   a.sub_product,
				   a.prd_id,
                   now() as insrt_process_tmstmp,
                   now() as updt_process_tmstmp,
               a.os_bal_amt_v2
            from %nrbquote(&nz_intmed_db..&output_insrt_table) as a
            where last_day(date_trunc('day', a.process_date))=%nrbquote('&period_dt_nz')
         ) by nzcon;
         disconnect from nzcon;
      quit;
   %end;

