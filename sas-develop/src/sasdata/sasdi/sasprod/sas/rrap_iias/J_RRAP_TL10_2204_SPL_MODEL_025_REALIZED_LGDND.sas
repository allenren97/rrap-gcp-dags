%let output_table_obsvtn_pt = psnl_loan_obsvtn_pt_drvd_var;




/*--------------------------------------------------------
 * Creating partition number macro variable to use with
 * parallel processing in DI.
 *--------------------------------------------------------*/

%let pn=1;



/*--------------------------------------------------------
 * Wrapper macro to loop through the process for each 
 * monthly incremental load.
 *--------------------------------------------------------*/

%macro lgd_nd(start_period_dt =, end_period_dt =);

   /*--------------------------------------------------------
    * Macro to get LGD discount parameters from the SPL 
    * parameters control table.
    *--------------------------------------------------------*/

   %macro get_rrap_parameters(name=);
      %global &name._value;

      data _null_;
         set control.parameters;
         where name="&name";
         call symput("&name._value", value);
      run;
   %mend get_rrap_parameters;

   %get_rrap_parameters(name=spl_lgd_nd_disc_rate);
   
   /*-------------------------------------------------------
    * Defines the number of months for which the process
    * will be run.  This will determine how many times
    * the code will be looped.
    *-------------------------------------------------------*/

   data _null_;
      call symput('number_periods', cats(intck('month', "&start_period_dt"d, "&end_period_dt"d)));
   run;
   

   /*----------------------------------------------------
    * Loop over all months for the process run
    *----------------------------------------------------*/

   %do ii = 0 %to &number_periods;


      /*----------------------------------------------------
       * Setting date macros variables for NZ date
       * literal format based off of start_period_dt and 
       * end_period_dt formats. NZ requires date literals to
       * be in following format: YYYY-MM-DD
       *----------------------------------------------------*/
      data _null_;
         call symput('period_dt', cats(put(intnx('month', "&start_period_dt"d, &ii, 'e'), date9.)));
         call symput('period_dt_nz', cats(put(intnx('month', "&start_period_dt"d, &ii, 'e'), yymmdd10.)));
      run;  
		
		proc sql noprint;
			select tm_id into :mth_tm_id 
			from nzrrap.tm_dim
			where tm_lvl='Month' and tm_lvl_end_dt="&period_dt"d;
		quit;
		
		%etl_job_start(target_table=&sas_nz_results_lib..&output_table_realized,PROCESS_MTH_TM_ID=PROCESS_MTH_TM_ID,condition=%nrquote(upcase(lgd_type)='LGD-ND'));
		
      data _null_;   

         /* Dates for querying from NZ */
         call symput ('obs_date_nz', cats(put(intnx('month', "&period_dt"d, -&length_performance_window, 'e'), yymmdd10.)));  
         call symput ('start_perf_nz', cats(put(intnx('month', "&period_dt"d, -&length_performance_window + 1, 'e'), yymmdd10.)));
         call symput ('end_perf_nz', cats(put(intnx('month', "&period_dt"d, 0, 'e'), yymmdd10.))); 

         /* Dates for processing in SAS */
         call symput ('obs_date_sas', cats(put(intnx('month', "&period_dt"d, -&length_performance_window, 'e'), date9.)));  
         call symput ('start_perf_sas', cats(put(intnx('month', "&period_dt"d, -&length_performance_window + 1, 'e'), date9.)));
         call symput ('end_perf_sas', cats(put(intnx('month', "&period_dt"d, 0, 'e'), date9.)));
      run;  

      %put NOTE: USER DEFINED: SPL Realized LGD-ND process for Observation Period: &obs_date_nz;
      %put NOTE: USER DEFINED: SPL Realized LGD-ND Performance Window: &start_perf_nz to &end_perf_nz;
      %put; 

      /*-------------------------------------------------
       * Finding the accounts that were on the books 36
       * months to the process date.  Only these accounts 
       * should be considered for the LGD-ND process.
       *-------------------------------------------------*/
    
      %delete_table(&sas_nz_intmed_lib..spl_lgd_nd_distinct_accts);  

      proc sql;
         connect using &sas_nz_intmed_lib as nzcon;
         execute( 

            create table %nrbquote(&nz_intmed_db).spl_lgd_nd_distinct_accts as (
            select distinct a.loan_no,
                            a.cab
            from %nrbquote(&nz_input_db..&input_table) as a
                 inner join
                 %nrbquote(&nz_status_tbl_db..&input_status_table) as b
                 on a.loan_no=b.loan_no and
                    a.cab=b.cab and 
                    last_day(date_trunc('day', a.process_date))=last_day(date_trunc('day', b.process_date))
                 
                 left join 
                 %nrbquote(&nz_pd_rlzd_tbl_db..&input_pd_rlzd_table) as c
                 on a.loan_no=c.loan_no and 
                    a.cab=c.cab and 
                    last_day(date_trunc('day', a.process_date))=last_day(date_trunc('day', c.obsvtn_date))
                    
            where last_day(date_trunc('day', a.process_date))=%nrbquote('&obs_date_nz') and 
                  upper(b.pit_status)='CUR' and
                  upper(c.model_dft_f)='Y' and
                  upper(b.treatment_flag)='A'
     		        )
				   WITH DATA distribute BY HASH (loan_no);
			) by nzcon;
      *   execute (generate statistics on %nrbquote(&nz_intmed_db)..spl_lgd_nd_distinct_accts) by nzcon;

            execute(CALL SYSPROC.ADMIN_CMD (
							%nrbquote('RUNSTATS ON TABLE ) 
							%nrbquote(&nz_intmed_db).spl_lgd_nd_distinct_accts
							%nrbquote(ON KEY COLUMNS and INDEXES ALL')
											)
					) by nzcon;
         disconnect from nzcon;
      quit;
         
            
      /*-------------------------------------------------
       * Gathering the input data for the process.
       *-------------------------------------------------*/
      %delete_table(&sas_nz_intmed_lib..spl_lgd_nd_base) ;  

      proc sql;
         connect using &sas_nz_intmed_lib as nzcon;
         execute (
         
            create table %nrbquote(&nz_intmed_db).spl_lgd_nd_base as (
            select a.basel_acct_id,
                   a.loan_no,
                   a.cab,
                   a.process_date as process_dt,
                   a.principal_bal,
                   a.addon_bal,
                   a.accr_int,
                   a.recstat_code,
                   a.chg_off_date,
                   b.pit_status,
                   b.sub_portfolio,
                   b.os_bal_amt,
                   case
                      when upper(c.model_dft_f)='Y' then 1
                      else 0
                   end as default_ind,
                   c.last_new_dft_dt as default_dt,
                   c.last_new_dft_bal_amt as default_bal
            from %nrbquote(&nz_input_db..&input_table) as a
                 left join 
                 %nrbquote(&nz_status_tbl_db..&input_status_table) as b
                 on a.loan_no=b.loan_no and 
                    a.cab=b.cab and
                    last_day(date_trunc('day', a.process_date))=last_day(date_trunc('day',  b.process_date))     

                 left join
                 %nrbquote(&nz_pd_rlzd_tbl_db..&input_pd_rlzd_table) as c
                 on a.loan_no=c.loan_no and 
                    a.cab=c.cab and 
                    last_day(date_trunc('day', a.process_date))=last_day(date_trunc('day', c.obsvtn_date)) 

                 inner join
                 %nrbquote(&nz_intmed_db).spl_lgd_nd_distinct_accts as d
                 on a.loan_no=d.loan_no and
                    a.cab=d.cab  

            where last_day(date_trunc('day', a.process_date)) >= %nrbquote('&obs_date_nz') and
                  last_day(date_trunc('day', a.process_date)) <= %nrbquote('&end_perf_nz')   
					)
				   WITH DATA distribute BY HASH (loan_no);
			) by nzcon;
        * execute (generate statistics on %nrbquote(&nz_intmed_db)..spl_lgd_nd_base) by nzcon;
            execute(CALL SYSPROC.ADMIN_CMD (
							%nrbquote('RUNSTATS ON TABLE ) 
							%nrbquote(&nz_intmed_db).spl_lgd_nd_base
							%nrbquote(ON KEY COLUMNS and INDEXES ALL')
											)
					) by nzcon;

         disconnect from nzcon;
      quit; 
   

      /*------------------------------------------------------
       * Creating arrays for capturing 36 months of data for
       * principal_bal, addon_bal, and accr_int.  Data must be 
       * sorted in SAS to ensure that data step logic will work
       * correctly.
       *------------------------------------------------------*/  

      %delete_table(work.spl_lgd_nd_base);

      proc sort data=&sas_nz_intmed_lib..spl_lgd_nd_base
                out=work.spl_lgd_nd_base nodupkey;
         by loan_no
            cab
            process_dt;
      run;  

      %delete_table(&sas_nz_intmed_lib..spl_lgd_nd_data_prep_&pn);   

      data &sas_nz_intmed_lib..spl_lgd_nd_data_prep_&pn (rename=(run_dt=process_dt)
                                              drop=process_dt
                                                   i
                                                   counter);
         set work.spl_lgd_nd_base;
         by loan_no cab;
         length run_dt observation_dt performance_start_dt performance_end_dt 8; 

         array pit_status_window(37) $3;
         array process_dt_window(37);
         array prin_bal_window(37);
         array addon_bal_window(37);
         array accr_int_window(37);
         array recstat_code_window(37);
         array default_ind_window(37);
         array os_bal_amt_window(37);
            

         retain basel_acct_id
                loan_no
                cab
                run_dt
                pit_status_window1--pit_status_window37
                process_dt_window1--process_dt_window37
                prin_bal_window1--prin_bal_window37
                addon_bal_window1--addon_bal_window37
                accr_int_window1--accr_int_window37
                recstat_code_window1--recstat_code_window37
                default_ind_window1--default_ind_window37
                os_bal_amt_window1--os_bal_amt_window37
                def_num
                counter;
         
         /* Process_dt already date
       process_dt=datepart(process_dt); */
         format process_dt_window1--process_dt_window37
                process_dt
                run_dt
                observation_dt
                performance_start_dt
                performance_end_dt date9.;
         if first.cab=1 or first.loan_no=1 then
         do;
            def_num=intck('month',"&obs_date_sas"d,default_dt)+1;
            counter=0;
            do i=1 to 37;
               pit_status_window(i)='';
               process_dt_window(i)=.;
               prin_bal_window(i)=.;
               addon_bal_window(i)=.;
               accr_int_window(i)=.;
               recstat_code_window(i)=.;
               default_ind_window(i)=.;
               os_bal_amt_window(i)=.;
            end;
         end;  

         if intnx('month',process_dt,0,'e') GE "&obs_date_sas"d and intnx('month', process_dt, 0, 'e') LE "&end_perf_sas"d then
            do;
               counter+1;  

               pit_status_window(counter)=pit_status;
               process_dt_window(counter)=process_dt;
               prin_bal_window(counter)=principal_bal;
               addon_bal_window(counter)=addon_bal;
               accr_int_window(counter)=accr_int;
               recstat_code_window(counter)=recstat_code;
               default_ind_window(counter)=default_ind;
               os_bal_amt_window(counter)=os_bal_amt;
               

               /*----------------------------------------------
                * If the last period of the performance window,
                * or this is the last record for the loan_no
                * and cab, then output the results.
                *----------------------------------------------*/ 

               if counter=37 or last.cab=1 or last.loan_no=1 then
               do;
                  /* Stores dates for performance window */
                  performance_start_dt = intnx('month', "&start_perf_sas"d, 0, 'e');
                  performance_end_dt = intnx('month', "&end_perf_sas"d, 0, 'e'); 

                  /* Stores observation date */
                  observation_dt = intnx('month', "&obs_date_sas"d, 0, 'e');  

                  /* Stores the date for when this was run */
                  run_dt = intnx('month', "&period_dt"d, 0, 'e'); 

                  output;
               end;
            end;
      run;  

      /*-----------------------------------------------------------
       * Subsetting the data to contain only those accounts that 
       * are current at the observation date and have default 
       * indicator set to 1.  Also identifying the cure date for 
       * the account, and the date at which the account turn 
       * recstat_code=8.
       *-----------------------------------------------------------*/
      
      %delete_table(&sas_nz_intmed_lib..spl_lgd_nd_data_subset_cure_&pn) ; 

      data &sas_nz_intmed_lib..spl_lgd_nd_data_subset_cure_&pn;
         set &sas_nz_intmed_lib..spl_lgd_nd_data_prep_&pn;
         array pit_status_window(*) pit_status_window1--pit_status_window37;
         array default_ind_window(*) default_ind_window1--default_ind_window37;
         array prin_bal_window(*) prin_bal_window1--prin_bal_window37;
         array process_dt_window(*) process_dt_window1--process_dt_window37;
         array recstat_code_window(*) recstat_code_window1--recstat_code_window37;
         array os_bal_amt_window(*) os_bal_amt_window1--os_bal_amt_window37;
         format cure_date default_date date9.;  

         /*--------------------------------------------------
          * Ensuring only those account current at the 
          * observation date and defaulted over 12 month
          * period are used in LGD calculation.
          *--------------------------------------------------*/   

         where pit_status_window1='CUR' and default_ind_window1=1;   
         pit_status=pit_status_window1;
         if default_ind_window1=1 then model_dft_f='Y';
            else model_dft_f='N';

         /*-----------------------------------------
          * Identifying the point where the loan 
          * has cured.
          *-----------------------------------------*/   

         do jj=def_num+1 to def_num+24;
            if pit_status_window(jj) in ('CUR','CLO') or prin_bal_window(jj)<=0 or os_bal_amt_window(jj)<1 then
            do;
               cure_num=jj;
               leave;
            end;
         end;  

         /*-----------------------------------------
          * Identifying when the loan turns to
          * recstat_code=8.
          *-----------------------------------------*/   

         do ii=1 to 37;
            if recstat_code_window(ii)=8 then
            do;
               rec_stat_num=ii;
               leave;
            end;
         end;
         if cure_num ^= . then cure_date=process_dt_window(cure_num);
         default_date=process_dt_window(def_num);  

         /*-----------------------------------------
          * Identifying charge off num.
          *-----------------------------------------*/   

         if chg_off_date^=. then
         do zz=1 to 37;
            if intnx('month',datepart(chg_off_date),0,'e')=intnx('month',process_dt_window(zz),0,'e') then 
            do;
               chg_off_num=zz;
               leave;
            end;
         end;
      run;  

      /*-----------------------------------------------------
       * LGD-ND Calculation without costs.
       *-----------------------------------------------------*/   

      %delete_table(&sas_nz_intmed_lib..spl_lgd_nd_nocost_&pn);   

      data &sas_nz_intmed_lib..spl_lgd_nd_nocost_&pn;
         set &sas_nz_intmed_lib..spl_lgd_nd_data_subset_cure_&pn;
         array pit_status_window(*) pit_status_window1--pit_status_window37;
         /* Change by WP Begin- 31MAY2015*/
         array process_dt_window(*) process_dt_window1--process_dt_window37;
         /* Change by WP End- 31MAY2015*/
         array prin_bal_window(*) prin_bal_window1--prin_bal_window37;
         array addon_bal_window(*) addon_bal_window1--addon_bal_window37;
         array accr_int_window(*) accr_int_window1--accr_int_window37;
         array recstat_code_window(*) recstat_code_window1--recstat_code_window37;
         array rec(37);
         array drec(37);
       format rcvry_cured_dt date9.;
         
         /*--------------------------------------
          * Calculating balance at default.
          *--------------------------------------*/   

         balance_dft=sum(prin_bal_window(def_num),addon_bal_window(def_num),accr_int_window(def_num));
         
         /*--------------------------------------
          * Calculating Recoveries.
          *--------------------------------------*/   

         do i=def_num+1 to min(def_num+24,cure_num,rec_stat_num-1);
            rcvry_num=min(def_num+24,cure_num,rec_stat_num-1);
            rcvry_cured_dt=intnx('month',"&obs_date_sas"d,rcvry_num-1,'e');


            if i ^= cure_num then
            do;
               rec(i)=sum(prin_bal_window(i),addon_bal_window(i))-sum(prin_bal_window(i-1),addon_bal_window(i-1));
            end;
            else
            do;
               rec(i)= -sum(prin_bal_window(i-1),accr_int_window(def_num),addon_bal_window(i-1));
            end;
         end;  

         tot_rec=0;  

         /*----------------------------------------
          * Discounting recoveries.
          *----------------------------------------*/ 

         do j=def_num+1 to def_num+24;
            drec(j)=rec(j)/(1+&spl_lgd_nd_disc_rate_value.)**((j-def_num)/12);
            tot_rec=sum(tot_rec,drec(j));
         end;  

         lgd_rto=(balance_dft+tot_rec)/balance_dft;
      run;  

      /*----------------------------------------------
       * Loading indirect cost data into NZ to join
       * with the LGD-ND nocost data. Only keeping 
       * those records that fall into the time window
       * being considered in each loop.
       *----------------------------------------------*/
      
      %delete_table(work.spl_indirect_costs); 

     proc sql;
      create table work.spl_indirect_costs as
      select t.tm_lvl_end_dt as reporting_date, 
             a.unit_indrct_cost_amt as indirect_unit_costs
      from nzrrap.DRVD_MTH_INDRCT_COST_SUM as a,
           nzuser.tm_dim as t
      where a.mth_tm_id=t.tm_id and t.tm_lvl='Month' and
            t.tm_lvl_end_dt GE "&obs_date_sas"d and 
            t.tm_lvl_end_dt LE "&end_perf_sas"d;
      quit;

      /*----------------------------------------------
       * Loading direct cost data into NZ to join with
       * the LGD-ND no cost table. Only keeping 
       * those records that fall into the time window
       * being considered in each loop.
       *----------------------------------------------*/ 

      %delete_table(work.spl_direct_costs);   

     proc sql noprint; 
      create table work.spl_direct_costs_tmp as
      select a.basel_acct_id,
             t.tm_lvl_end_dt as reporting_date,
             a.mth_drc_cost_amt as costs,
             a.hghwy_cd as highway
      from nzrrap.DRVD_MTH_DRC_COST as a,
           nzuser.tm_dim as t
      where a.mth_tm_id=t.tm_id and t.tm_lvl='Month' and 
            upcase(a.hghwy_cd) ^= 'RH' and
            t.tm_lvl_end_dt GE "&obs_date_sas"d and 
            t.tm_lvl_end_dt LE "&end_perf_sas"d;
      quit; 


     /* Create a lookup table for loan_no and cab */
      /* Loan no and cab are used in the realized logic */
      proc sql;
      create table work.basel_acct_x_loan_no as 
      select distinct basel_acct_id, 
             crnt_br_loctn_trnst as cab,
             loan_num as loan_no
      from nzrrap.BASEL_PSNL_LOAN_MTH_SNAPSHOT
      where RECD_STAT_CD in ('4','5','6','7','8');
      quit;


     /* Join direct costs with lookup table */
      proc sql;
      create table work.spl_direct_costs as
      select s.*, 
             b.cab,
             b.loan_no
      from work.spl_direct_costs_tmp as s 
      left join 
           work.basel_acct_x_loan_no as b
           on s.basel_acct_id=b.basel_acct_id
      where cab ^= " " and loan_no ^= " ";
      quit;
     

      /*----------------------------------------------
       * Transposing the direct cost data to join to
       * LGD_ND no cost table. 
       *----------------------------------------------*/ 

      proc sort data=work.spl_direct_costs;
         by loan_no
            cab
            reporting_date;
      run;
      
      %delete_table(&sas_nz_intmed_lib..spl_direct_costs_transpose1);   

      data work.spl_direct_costs_transpose1 (drop=ii
                                                  num);
         set work.spl_direct_costs;
         by loan_no
            cab;
         array direct_costs(37);
         observation_dt="&obs_date_sas"d;
         retain observation_dt
                loan_no
                cab
                direct_costs1--direct_costs37;
         if first.loan_no or first.cab then 
         do ii=1 to 37;
            direct_costs(ii)=.;
         end;
         num=intck('month',"&obs_date_sas"d,reporting_date)+1;
         if direct_costs(num)^=. then direct_costs(num)=direct_costs(num)+costs;
         else direct_costs(num)=costs;
         if last.loan_no or last.cab then output;
      run;  
   

      /*----------------------------------------
       * Joining to get default date number to 
       * discount direct costs.
       *----------------------------------------*/ 

      %delete_table(work.spl_direct_costs_transpose);
       
      proc sql;
         create table work.spl_direct_costs_transpose (drop=loan
                                                            cab_no
                                                            obs_dt) as
         select  
                a.loan_no,
                a.cab,
                a.observation_dt,
                a.def_num,
                a.cure_num,
                a.sub_portfolio,
                a.pit_status,
                a.model_dft_f,
                a.default_date,
                a.lgd_rto,
                a.cure_date,
                a.tot_rec,
                a.chg_off_date,
                a.chg_off_num,
            a.rcvry_cured_dt,
                b.*
         from &sas_nz_intmed_lib..spl_lgd_nd_nocost_&pn as a
              left join
              work.spl_direct_costs_transpose1 (rename=(loan_no=loan
                                                        cab=cab_no
                                                        observation_dt=obs_dt)) as b
              on a.loan_no=b.loan and 
                 a.cab=b.cab_no and
                 intnx('month',a.observation_dt,0,'e')=intnx('month',b.obs_dt,0,'e');
      quit; 

      /*---------------------------------------------
       * Discounting Direct Costs and creating total.
       *---------------------------------------------*/  

      %delete_table(work.spl_direct_costs_discount);   

      data work.spl_direct_costs_discount (drop=jj);
         set work.spl_direct_costs_transpose;
         array direct_costs(*) direct_costs1--direct_costs37;
         array discount_direct_costs(37);
         tot_direct_costs=0;
         if cure_num=. then cure_num=99;
         do jj=def_num to min(def_num+24,cure_num);
            discount_direct_costs(jj)=direct_costs(jj)/(1+&spl_lgd_nd_disc_rate_value.)**((jj-def_num)/12);
            tot_direct_costs=sum(tot_direct_costs,discount_direct_costs(jj));
         end;
      run;  

      /*--------------------------------------------
       * Transposing Indirect Costs.
       *--------------------------------------------*/   

      %delete_table(work.spl_indirect_costs_transpose1)  

      data work.spl_indirect_costs_transpose1 (drop=reporting_date);
         set work.spl_indirect_costs end=last;
         array indirect_costs(37);
         retain indirect_costs1--indirect_costs37;
         obs_dt="&obs_date_sas"d;
         num=intck('month',"&obs_date_sas"d,reporting_date)+1;
         indirect_costs(num)=indirect_unit_costs;
         if last then output;
      run;  

      /*--------------------------------------------
       * Joining indirect cost data to each account.
       *--------------------------------------------*/   

      %delete_table(work.spl_indirect_costs_transpose);   

      proc sql;
         create table work.spl_indirect_costs_transpose as
         select a.basel_acct_id,
                a.loan_no,
                a.cab,
                a.observation_dt,
                a.def_num,
                a.cure_num,
                a.sub_portfolio,
                a.pit_status,
                a.model_dft_f,
                a.default_date,
                a.cure_date,
                a.lgd_rto,
                a.chg_off_date,
                a.chg_off_num,
                a.rcvry_cured_dt,
                a.balance_dft,
                a.tot_rec,
					 a.pit_status_window1,
                a.pit_status_window2,
                a.pit_status_window3,
                a.pit_status_window4,
                a.pit_status_window5,
                a.pit_status_window6,
                a.pit_status_window7,
                a.pit_status_window8,
                a.pit_status_window9,
                a.pit_status_window10,
                a.pit_status_window11,
                a.pit_status_window12,
                a.pit_status_window13,
                a.pit_status_window14,
                a.pit_status_window15,
                a.pit_status_window16,
                a.pit_status_window17,
                a.pit_status_window18,
                a.pit_status_window19,
                a.pit_status_window20,
                a.pit_status_window21,
                a.pit_status_window22,
                a.pit_status_window23,
                a.pit_status_window24,
                a.pit_status_window25,
                a.pit_status_window26,
                a.pit_status_window27,
                a.pit_status_window28,
                a.pit_status_window29,
                a.pit_status_window30,
                a.pit_status_window31,
                a.pit_status_window32,
                a.pit_status_window33,
                a.pit_status_window34,
                a.pit_status_window35,
                a.pit_status_window36,
                a.pit_status_window37,
                b.*,
                /*Identifying end period for indirect calculations.*/
                case
                   when a.cure_date=. and a.chg_off_date^=. then min(a.def_num+24,a.chg_off_num)
                   when a.cure_date=. and a.chg_off_date=. then a.def_num+24
                   else min(a.chg_off_num,a.def_num+24,a.cure_num)
                end as end_num
         /*Intentional cartesian join.  Indirect costs data only has 1 record.*/
         from &sas_nz_intmed_lib..spl_lgd_nd_nocost_&pn as a,
              work.spl_indirect_costs_transpose1 as b;
      quit; 

      /*---------------------------------------------------
       * Discounting and totaling indirect costs.
       *---------------------------------------------------*/  

      %delete_table(work.spl_indirect_costs_discount) ;

      data work.spl_indirect_costs_discount;
         set work.spl_indirect_costs_transpose;
         array indirect_costs(*) indirect_costs1--indirect_costs37;
			array pit_status_window(*) pit_status_window1--pit_status_window37;
         array discount_ind_costs(37);
         tot_indirect_costs=0;
         do ii=def_num+1 to end_num-1;
            if upcase(pit_status_window(ii))='DEF' then 
            do;
               discount_ind_costs(ii)=indirect_costs(ii)/(1+&spl_lgd_nd_disc_rate_value.)**((ii-def_num)/12);
               tot_indirect_costs=sum(tot_indirect_costs,discount_ind_costs(ii));
            end;
         end;
      run;  

      /*----------------------------------------------------
       * Joining direct costs data to the indirect costs 
       * table.
       *----------------------------------------------------*/ 

      %delete_table(work.spl_lgd_nd_all_costs); 

      proc sql;
         create table work.spl_lgd_nd_all_costs as
         select a.*,
                b.tot_direct_costs
         from work.spl_indirect_costs_discount as a
              left join
              work.spl_direct_costs_discount as b
              on a.loan_no=b.loan_no and
                 a.cab=b.cab and 
                 intnx('month',a.observation_dt,0,'e')=intnx('month',b.observation_dt,0,'e');
      quit; 
   

      
      /*----------------------------------------------------
       * Calculating LGD with costs.  The following LGD values 
       * will be calculated: 
       * 1. 
       *----------------------------------------------------*/ 

      %delete_table(&sas_nz_intmed_lib..spl_realized_lgd_nd_insert_tbl_1) ;  

      proc sql noprint;
         create table &sas_nz_intmed_lib..spl_realized_lgd_nd_insert_tbl_1 as
         select a.*,
                "&period_dt"d as process_dt format=date9.,
                'LGD-ND' as lgd_type length=6,
                sum(balance_dft,tot_rec,tot_direct_costs)/balance_dft as lgd_npv_drc_cost_rto,
                sum(balance_dft,tot_rec,tot_indirect_costs)/balance_dft as lgd_npv_indrct_cost_rto,
                sum(balance_dft,tot_rec,tot_direct_costs,tot_indirect_costs)/balance_dft as lgd_npv_all_cost_rto,
                case 
                   when calculated lgd_npv_all_cost_rto>1 then 1
						 when calculated lgd_npv_all_cost_rto<0 then 0
                   else calculated lgd_npv_all_cost_rto
                end as lgd_npv_all_cost_flr_cap_100_rto,
                case 
                   when calculated lgd_npv_all_cost_rto>1.25 then 1.25
						 when calculated lgd_npv_all_cost_rto<0 then 0
                   else calculated lgd_npv_all_cost_rto
                end as lgd_npv_all_cost_flr_cap_150_rto,
                case 
                   when a.rcvry_cured_dt is null then 0
                   else b.tm_id 
                end as rcvry_cured_mth_tm_id,
                c.last_new_dft_dt,
					 c.last_new_dft_bal_amt,
                intnx('month',c.last_new_dft_dt,24,'e') as rcvry_window_cutoff_dt format=date9.

              from work.spl_lgd_nd_all_costs (rename=(observation_dt=obsvtn_date)) as a

              left join
              &sas_nz_source_lib..&tim_dim_table as b
              on a.rcvry_cured_dt=b.tm_lvl_end_dt and 
                 upcase(b.tm_lvl) = 'MONTH'
              
              left join
              &sas_nz_intmed_lib..&input_pd_rlzd_table as c
              on a.loan_no=c.loan_no and 
                 a.cab=c.cab and 
                 intnx('month', a.obsvtn_date, 0, 'e')=intnx('month', c.obsvtn_date, 0, 'e');
      quit; 



     /* Join to time dim to update obsvtn_mth_tm_id and process_mth_tm_id */
     %delete_table(&sas_nz_intmed_lib..spl_realized_lgd_nd_insert_tbl_2) ;

      proc sql;
      create table &sas_nz_intmed_lib..spl_realized_lgd_nd_insert_tbl_2 as 
      select s.*, 
             t.tm_id as obsvtn_mth_tm_id
      from &sas_nz_intmed_lib..spl_realized_lgd_nd_insert_tbl_1 as s
          left join
           &sas_nz_intmed_lib..tm_dim as t
           on s.obsvtn_date=t.tm_lvl_end_dt and t.tm_lvl='Month';
      quit;


     %delete_table(&sas_nz_intmed_lib..spl_realized_lgd_nd_insert_tbl_3);

     proc sql noprint;
      connect using nzuser as nzcon;
      execute (
               create table &FRG_DB..spl_realized_lgd_nd_insert_tbl_3 as (
               select s.*, 
                      t.tm_id as process_mth_tm_id
               from &FRG_DB..spl_realized_lgd_nd_insert_tbl_2 as s
                 left join
                    &FRG_DB..tm_dim as t
               on s.process_dt=date_trunc('day', t.tm_lvl_end_dt) and t.tm_lvl='Month'
			   ) WITH DATA;
			) by nzcon;
      disconnect from nzcon;
      quit;
      

     

     %delete_table(&sas_nz_intmed_lib..spl_realized_lgd_nd_insert_tbl) ;

     proc sql noprint;
      connect using nzuser as nzcon;
      execute (
               create table &FRG_DB..spl_realized_lgd_nd_insert_tbl as (
               select s.*,
                      case 
                         when s.rcvry_window_cutoff_dt is null then 0
                         else t.tm_id 
                      end  rcvry_window_cutoff_tm_id,
                      case 
                         when s.rcvry_window_cutoff_dt is null then 0
                         else t.tm_id 
                      end  rcvry_window_cutoff_mth_tm_id,
                         cast(null as decimal(29,8)) LGD_NO_COST_FLR_CAP_150_RTO
                        ,cast(null as decimal(29,8)) LGD_RTO_BKUP
                        ,cast(null as decimal(29,8)) LGD_NPV_ALL_COST_100_RTO_BKP
                        ,cast(null as decimal(29,8)) LGD_NPV_ALL_COST_150_RTO_BKP
                        ,cast(null as decimal(29,8)) LGD_NPV_ALL_COST_RTO_BKUP
                        ,cast(null as decimal(29,8)) LGD_NPV_DRC_COST_RTO_BKUP
                        ,cast(null as decimal(29,8)) LGD_NPV_INDRCT_COST_RTO_BKUP
               from &FRG_DB..spl_realized_lgd_nd_insert_tbl_3 as s
                 left join
                    &FRG_DB..tm_dim as t
                    on s.rcvry_window_cutoff_dt=date_trunc('day', t.tm_lvl_end_dt) and t.tm_lvl='Month'
			) WITH DATA;
			) by nzcon;
      disconnect from nzcon;
      quit;

      /* PROC SQL;
         CONNECT USING NZUSER AS IIASCON;
         EXECUTE (ALTER TABLE &FRG_DB..spl_realized_lgd_nd_insert_tbl
                     ADD COLUMN LGD_NO_COST_FLR_CAP_150_RTO DECIMAL (29,8)
                     ADD COLUMN LGD_RTO_BKUP DECIMAL (29,8)
                     ADD COLUMN LGD_NPV_ALL_COST_100_RTO_BKP DECIMAL (29,8)
                     ADD COLUMN LGD_NPV_ALL_COST_150_RTO_BKP DECIMAL (29,8)
                     ADD COLUMN LGD_NPV_ALL_COST_RTO_BKUP DECIMAL (29,8)
                     ADD COLUMN LGD_NPV_DRC_COST_RTO_BKUP DECIMAL (29,8)
                     ADD COLUMN LGD_NPV_INDRCT_COST_RTO_BKUP DECIMAL (29,8))BY IIASCON;
         DISCONNECT FROM IIASCON;
      QUIT; */


      /*---------------------------------------------
       * Checks to see if the date is in NZ table for
       * the realized value output.
       *---------------------------------------------*/ 

      proc sql noprint;
         select count(*) 
         into :date_count trimmed
         from &sas_nz_results_lib..&output_table_realized
         where (month(process_date) = month("&period_dt"d) and year(process_date) = year("&period_dt"d)) and 
               upcase(lgd_type)='LGD-ND';
      quit;   
   

      /*---------------------------------------------
       * If data already exists for the month, the 
       * run delete from code.
       *---------------------------------------------*/  

      %if %eval(&date_count) > 0 %then
      %do;
         proc sql;
            connect using &sas_nz_results_lib as nzcon;
            execute (
                  
               delete from %nrbquote(&nz_results_db..&output_table_realized)
               where (date_part('month',process_date) = date_part('month',cast(%nrbquote('&period_dt_nz') as date)) and 
                      date_part('year',process_date) = date_part('year',cast(%nrbquote('&period_dt_nz') as date))) and
                     upper(lgd_type)='LGD-ND' 
			
            ) by nzcon;
           * execute (generate statistics on %nrbquote(&nz_results_db..&output_table_realized)) by nzcon;
			execute(CALL SYSPROC.ADMIN_CMD (%nrbquote('RUNSTATS 
						ON TABLE ) %nrbquote(&nz_results_db..&output_table_realized) 
							%nrbquote(ON KEY COLUMNS and INDEXES ALL'))) by nzcon;

            disconnect from nzcon;
         quit;
      %end;   
      
      /* Insert data into NZ results table*/ 

      proc sql;
         connect using &sas_nz_results_lib as nzcon;
         execute(    

            insert into %nrbquote(&nz_results_db..&output_table_realized) 
            select a.basel_acct_id,
                a.obsvtn_mth_tm_id,
               a.process_mth_tm_id,
                   a.process_dt as process_date, 
                   a.obsvtn_date, 
                   a.loan_no, 
                   a.cab, 
                   a.sub_portfolio,
                   a.lgd_type, 
                   a.lgd_rto, 
                   a.lgd_npv_all_cost_flr_cap_100_rto, 
                   a.lgd_npv_all_cost_flr_cap_150_rto,
                   a.lgd_npv_all_cost_rto, 
                   a.lgd_npv_drc_cost_rto, 
                   a.lgd_npv_indrct_cost_rto, 
                   now() as insrt_process_tmstmp,
                   now() as updt_process_tmstmp,
                   a.LGD_NO_COST_FLR_CAP_150_RTO,
                   a.LGD_RTO_BKUP,
                   a.LGD_NPV_ALL_COST_100_RTO_BKP,
                   a.LGD_NPV_ALL_COST_150_RTO_BKP,
                   a.LGD_NPV_ALL_COST_RTO_BKUP,
                   a.LGD_NPV_DRC_COST_RTO_BKUP,
                   a.LGD_NPV_INDRCT_COST_RTO_BKUP

            from %nrbquote(&nz_intmed_db).spl_realized_lgd_nd_insert_tbl as a
            where last_day(date_trunc('day', a.process_dt))=%nrbquote('&period_dt_nz')

         ) by nzcon;
        * execute (generate statistics on %nrbquote(&nz_results_db..&output_table_realized)  ) by nzcon;
		 			execute(CALL SYSPROC.ADMIN_CMD (%nrbquote('RUNSTATS 
						ON TABLE ) %nrbquote(&nz_results_db..&output_table_realized) 
							%nrbquote(ON KEY COLUMNS and INDEXES ALL'))) by nzcon;
         disconnect from nzcon;
      quit;

%etl_job_end;
      /*-------------------------------------------------
       * Checking if date being looped is in the Costs
       * output table.
       *-------------------------------------------------*/
%etl_job_start(target_table=&sas_nz_results_lib..&output_table_costs,PROCESS_MTH_TM_ID=PROCESS_MTH_TM_ID,condition=%nrquote(upcase(lgd_type)='LGD-ND'));

