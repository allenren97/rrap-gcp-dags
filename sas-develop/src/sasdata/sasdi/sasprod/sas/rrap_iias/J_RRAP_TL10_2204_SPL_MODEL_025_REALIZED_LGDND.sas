%etl_job_end;
      /*------------------------------------------------
       * Checking to see if data exists in the recovery
       * output table.
       *------------------------------------------------*/
		 
%etl_job_start(target_table=&sas_nz_results_lib..&output_table_recovery,PROCESS_MTH_TM_ID=PROCESS_MTH_TM_ID,condition=%nrquote(upcase(lgd_type)='LGD-ND'));

      proc sql noprint;
         select count(*) 
         into :date_count3 trimmed
         from &sas_nz_results_lib..&output_table_recovery
         where (month(process_date) = month("&period_dt"d) and year(process_date) = year("&period_dt"d)) and 
               upcase(lgd_type)='LGD-ND';
      quit; 

      %if %eval(&date_count3) > 0 %then
      %do;
         proc sql;
            connect using &sas_nz_results_lib as nzcon;
            execute (
                  
               delete from %nrbquote(&nz_results_db..&output_table_recovery)
               where (date_part('month',process_date) = date_part('month',cast(%nrbquote('&period_dt_nz') as date)) and 
                      date_part('year',process_date) = date_part('year',cast(%nrbquote('&period_dt_nz') as date))) and 
                     upper(lgd_type)='LGD-ND'  

            ) by nzcon;
         *   execute (generate statistics on %nrbquote(&nz_results_db..&output_table_recovery)) by nzcon;
				 execute(CALL SYSPROC.ADMIN_CMD (%nrbquote('RUNSTATS 
						ON TABLE ) %nrbquote(&nz_results_db..&output_table_recovery) 
							%nrbquote(ON KEY COLUMNS and INDEXES ALL'))) by nzcon;
            disconnect from nzcon;
         quit;
      %end; 

      proc sql;
         connect using &sas_nz_results_lib as nzcon;
         execute(
         
            insert into %nrbquote(&nz_results_db..&output_table_recovery)
            select a.basel_acct_id,
                a.obsvtn_mth_tm_id,
               a.process_mth_tm_id,
               a.rcvry_cured_mth_tm_id,
                   a.process_dt as process_date,
                   a.obsvtn_date, 
                   a.loan_no, 
                   a.cab, 
                   a.sub_portfolio,
                   a.lgd_type,
