%macro psi (lib, data_in, subpop, value, base_ym, var, groups, tbl_pref);

data _psicrap;
set &lib..&data_in;
%if &subpop ne 0 %then %do;
where &subpop = "&value";
%end; 
run;


data base;
set  _psicrap;
where yrmth = &base_ym;
run;

data rest;
set _psicrap;
where yrmth>&base_ym;
run; 


proc rank data=base out=base_psicrap2 groups=&groups;
var &var;
ranks scrband;
run;

data base_psicrap2;
set base_psicrap2;
scrband2=scrband+1;
drop scrband;
rename scrband2=scrband;
run; 

proc freq data=base_psicrap2; tables scrband; run; 
proc means data=base_psicrap2 min max; var &var; class scrband; output out=_means; run; 
data _means; set _means (keep=scrband _stat_ &var); if scrband ne .; run; 
proc transpose data=_means out=means_t; id _stat_;  by scrband; run; 


data means_t2;
set means_t;
max_prev=lag(max);
if _n_=1 then min_next=min;
else min_next=max_prev+1;
run; 

proc sql noprint;
select count(1) into :num from means_t2;
select distinct max into :max_1-:max_%sysfunc(compress(&num)) from means_t2;
select distinct min_next into :min_1-:min_%sysfunc(compress(&num)) from means_t2;
select distinct scrband into :scrband_1-:scrband_%sysfunc(compress(&num)) from means_t2;
quit; 

data rest_scrd;
set rest;
%do i=1 %to &num;
%if &i=1 %then %do;
if &var<=&max_1 then scrband=&scrband_1;
%end;
%else %if &i=&num %then %do;
else if &var>=&&min_&i then scrband=&&scrband_&i;
%end;
%else %do;
	%if 1<&i<&num %then %do;
	else if &&min_&i<=&var<=&&max_&i then scrband=&&scrband_&i;
	%end;
%end; 
%end;
run; 

proc freq data=rest_scrd; tables scrband; run; 
data all_data; set base_psicrap2 rest_scrd; run; 

proc freq data=all_data noprint;
tables yrmth * scrband / out=_freqs outpct;
where scrband ne . and yrmth >= &base_ym;
run;

proc sort data=_freqs; by scrband; run;
proc transpose data=_freqs out=_freqs_trans prefix=y_;
id yrmth;
by scrband;
var pct_row;
run;


proc sql noprint;
select count(distinct yrmth) into :num_ym from all_data;
select distinct yrmth into :y1 - :y%sysfunc(compress(&num_ym)) from all_data order by yrmth;
quit;


data _freqs_trans;
drop i;
set _freqs_trans;

array pts {*} y_: ;

do i = 1 to dim(pts);
	pts[i] = pts[i] / 100;
end;


%do j = 2 %to &num_ym;
	partpsi_&&y&j = (y_&&y&j - y_&y1) * log(y_&&y&j / y_&y1);
%end;
run;

proc means data=_freqs_trans noprint;
var partpsi: ;
output out=psi_results sum=;
run;


data psi_%substr(&tbl_pref,1,10)_%substr(&subpop.,1,5)%substr(&value.,1,10);
retain subpop;
drop _freq_ _type_;
set psi_results;

subpop = "&subpop.&value";

run;
%mend; 


