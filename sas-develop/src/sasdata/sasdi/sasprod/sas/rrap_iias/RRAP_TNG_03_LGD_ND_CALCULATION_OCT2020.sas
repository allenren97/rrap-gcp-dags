                  from &_lgd_nocost_output_tbl.) as pt1
             left join
             (select aggregate_key,
                     tot_cost as dir_cost24,
                     lgd_cost as lgd_dircost24,
                     lgd_cost_cap15 as lgd_dircost24_cap15,
                     lgd_cost_cap1 as lgd_dircost24_cap1
				
                 from intmed.mbs_cost24_v3) as pt2
             on pt1.aggregate_key = pt2.aggregate_key
             left join(select aggregate_key,
                              indirect_cost_npv24
                          from intmed.indirect_cost) as pt3
             on pt1.aggregate_key = pt3.aggregate_key;
