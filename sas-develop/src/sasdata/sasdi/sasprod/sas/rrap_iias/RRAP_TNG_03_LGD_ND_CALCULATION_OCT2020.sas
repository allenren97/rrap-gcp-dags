   if lgd_tot_cost24 <= 0 then lgd_tot_cost24_cap15 = 0;
      else if lgd_tot_cost24 > 1.25 then lgd_tot_cost24_cap15 = 1.25;
      else lgd_tot_cost24_cap15 = lgd_tot_cost24;
