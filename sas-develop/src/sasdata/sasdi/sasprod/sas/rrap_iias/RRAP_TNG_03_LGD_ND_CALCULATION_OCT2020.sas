		      intnx('month', a.month_end_dt,0,'end') as process_date format=date9.,
            a.lgd_def_bal as crnt_os_bal_amt,
		      a.nondiscounted_recovery as mth_rcvry_amt,
		      . as prev_mth_os_bal_amt,
		      'TNG' as src_sys_cd,
		      'LGD-ND' as model,
			  b.status,
		      datetime() as insrt_process_tmstmp format=datetime.,
		      datetime() as updt_process_tmstmp format=datetime.
     from RESULTS.TNG_LGD_ND_REALIZED_FINAL as a
	    left join
	 		tng_status as b
			on intnx('month', a.month_end_dt,0,'end')=b.month_end_dt and strip(a.account_id)=strip(b.account_id)
     left join
          work.tm_dim as t
     on intnx('month', a.month_end_dt,0,'end')=t.tm_lvl_end_dt and t.tm_lvl='Month';
     quit;


     /* Insert data into NZ results table*/ 
     proc sql;
     insert into %nrbquote(&frg_lib..&output_rcvry_table) 
     select a.basel_acct_id,
            a.mortgage_no,
            a.mth_tm_id,
	         a.process_date,
            a.crnt_os_bal_amt,
			   a.mth_rcvry_amt,
		   	a.prev_mth_os_bal_amt,
			   a.src_sys_cd,
			   a.model, 
			   
            datetime() as insrt_process_tmstmp,
            datetime() as updt_process_tmstmp  ,
				a.status
     from work.mor_mth_acct_rcvry_insert_tbl as a;
	  quit;

%mend save_recoveries;
%save_recoveries;
 


%macro insert_recoveries;
 
   /*----------------------------------------------------
    * Checks to see if the date is in recoveries NZ table
    *----------------------------------------------------*/ 

   proc sql noprint;
       select count(*) 
       into :date_count trimmed
       from &frg_lib..&master_output_rcvry_table
       where upcase(src_sys_cd)='TNG' and 
             upcase(model)='LGD-ND' and
             process_date in (select distinct process_date from &frg_lib..&output_rcvry_table) ;
       quit;   

	%put Date_count is &date_count;
	  

    /*---------------------------------------------
    * If data already exists for the data being 
    * loaded, delete it from the target table
    *---------------------------------------------*/  

   %if %eval(&date_count) > 0 %then
   %do;
      proc sql;
         connect using nzuser as nzcon;
         execute (
                  
            delete from %nrbquote(&frg_db..&master_output_rcvry_table)
            where upper(src_sys_cd)='TNG' and upper(model)='LGD-ND' and
                  process_date in (select distinct process_date from %nrbquote(&frg_db..&output_rcvry_table))       

         ) by nzcon;
         *execute (generate statistics on %nrbquote(&frg_db..&master_output_rcvry_table)) by nzcon;
         disconnect from nzcon;
      quit;
   %end;   


   /* Insert data into NZ results table*/ 
   proc sql noprint;
   connect using nzuser as nzcon;
   execute(
           insert into %nrbquote(&frg_db..&master_output_rcvry_table) 
           select a.basel_acct_id,
                  a.mortgage_no,
                  a.mth_tm_id,
	               a.process_date,
                  a.crnt_os_bal_amt,
	               a.mth_rcvry_amt,
		            a.prev_mth_os_bal_amt,
		            a.src_sys_cd,
		            a.model, 
					
                  now() as insrt_process_tmstmp,
                  now() as updt_process_tmstmp ,
						a.status 
           from %nrbquote(&frg_db..&output_rcvry_table) as a
            
           ) by nzcon;
   quit;
        

   proc sql;
	connect using nzuser as nzcon;       
      *execute (generate statistics on %nrbquote(&frg_db..&output_rcvry_table)  ) by nzcon;
      disconnect from nzcon;
   quit;

%mend insert_recoveries;
%insert_recoveries;

