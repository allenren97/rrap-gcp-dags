proc sql noprint;
   create table lgd_temp as 
      select * 
         from(select account_id,
                     aggregate_key, /*will removed "insurance_final" from query because it could not be found in source data and is not used in the code*/
                     month_end_dt,
                     lgd24_fix,
                     lgd24_cap15_fix,
