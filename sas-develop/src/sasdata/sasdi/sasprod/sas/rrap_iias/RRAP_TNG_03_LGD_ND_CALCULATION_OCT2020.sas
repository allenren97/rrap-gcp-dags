/*---------------------------------------------------------------------------
 * Change added on 3/10 by Will per direction from Bill.  This change
 * will join the defaulted dates LGD values to all dates with default_ind=1.
 * Before this change, the final output table was only capturing realized LGD
 * values for each account for the record with the same month_end_date as the 
 * final_default_date.  This next step will now assign the lgd values for 
 * each month the account had the default indicator set.  This solves the 
 * problem of data being dropped.
 *---------------------------------------------------------------------------*/
proc sql noprint;

   create table results.tng_lgd_nd_realized_final as 
   select pt1.*,
          pt2.tot_cost24,
          pt2.lgd_costs,
          pt2.lgd_costs_cap_150,
          pt2.lgd_costs_cap_100 
   from (select a.* 
         from intmed.def_obs_with_lgd (rename=(lgd24=lgd 
                                               lgd24_cap1=lgd_cap_100 
                                               lgd24_cap15=lgd_cap_150))as a) as pt1
        left join
        (select b.aggregate_key,
                b.tot_cost24,
                b.lgd_costs,
                b.lgd_costs_cap_150,
                b.lgd_costs_cap_100
         from &_lgd_cost_output_tbl. as b) as pt2
        on pt1.aggregate_key = pt2.aggregate_key;
quit;

