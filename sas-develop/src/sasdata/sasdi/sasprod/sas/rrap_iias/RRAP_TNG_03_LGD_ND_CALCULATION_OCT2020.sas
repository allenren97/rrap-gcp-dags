/*----------------------------------------------------------------------
 * LGD-ND Calculation without costs
 *----------------------------------------------------------------------*/

/*** join cashflow data into default dataset ***/
proc sql noprint;
create table def_points_w_cashflow as 
   select * 
            from(select * from default_points2) as pt1
                left join
                (select * from &_recovery_cashflow_out_tbl.) as pt2
                on pt1.aggregate_key = pt2.aggregate_key
                left join
                (select aggregate_key,
                        month_end_dt,
                        bal_with_interest,
                        accrued_interest_amt,
                        bal_with_interest
                    from &_recovery_output_tbl.) as pt3
                on pt1.aggregate_key = pt3.aggregate_key and pt1.final_defaultdate = pt3.month_end_dt
                left join
                (select aggregate_key, bal_with_interest as bal_fix
                   from write_off_amt_fix
                ) as pt4
                on pt1.aggregate_key = pt4.aggregate_key               
                
                ;
quit;


/*the following code added by will to make write_off_ind numeric*/

data def_points_w_cashflow (drop=write_off_ind rename=(write_off_ind2=write_off_ind)) ;
   set def_points_w_cashflow;
   if upcase(write_off_ind)='Y' then write_off_ind2=1;
      else if upcase(write_off_ind)='N' then write_off_ind2=0;
      else if write_off_ind=' ' then write_off_ind2=.;
run;




/*calculate raw lgd for each individual default point */

data def_points_w_lgd;
   set def_points_w_cashflow;
   /* CR 47 - Storing two years of non-discounted recoveries in new variable so it can be inserted into recovery table downstream */
   nondiscounted_recovery = sum(of recov_1 - recov_25);
   netvalue24 = netpv(0.1, 12, of recov_1 - recov_25);  /* Will changed the names of recov# to add underscore to match variable names from earlier code*/
   netvalue36 = netpv(0.1, 12, of recov_1 - recov_37);
   netvalue48 = netpv(0.1, 12, of recov_1 - recov_49);
   netvalue60 = netpv(0.1, 12, of recov_1 - recov_61);
   write_off_count = intck('month', final_defaultdate, write_off_month);
   if write_off_count <= 24 and write_off_amt ~= . then 
                                                    do;
                                                       netvalue24 = (write_off_amt)/((1+0.1)**(write_off_count/12));
                                                       netvalue36 = (write_off_amt)/((1+0.1)**(write_off_count/12));
                                                       netvalue48 = (write_off_amt)/((1+0.1)**(write_off_count/12));
                                                       netvalue60 = (write_off_amt)/((1+0.1)**(write_off_count/12));
                                                    end;
   else if write_off_count<= 36 and write_off_amt ~= . then 
                                                        do;
                                                           netvalue36 = (write_off_amt)/((1+0.1)**(write_off_count/12));
                                                           netvalue48 = (write_off_amt)/((1+0.1)**(write_off_count/12));
                                                           netvalue60 = (write_off_amt)/((1+0.1)**(write_off_count/12));
                                                        end;
   else if write_off_count<= 48 and write_off_amt ~= . then 
                                                        do;
                                                           netvalue48 = (write_off_amt)/((1+0.1)**(write_off_count/12));
                                                           netvalue60 = (write_off_amt)/((1+0.1)**(write_off_count/12));
                                                        end;
   else if write_off_count<= 60 and write_off_amt ~= . then 
                                                        do;
                                                           netvalue60 = (write_off_amt)/((1+0.1)**(write_off_count/12));
                                                        end;
   lgd_def_bal_fixed = 0;
   if bal_with_interest  = 0 or bal_with_interest = . then 
                                                       do;
                                                          lgd_def_bal = final_defaultbal + accrued_interest_amt;
                                                       end;
      else do;
              lgd_def_bal = bal_with_interest;
           end;

      /* calculate 24 months lgd */
      if (lgd_def_bal - netvalue24) = 0 or (lgd_def_bal - netvalue24) = . then 
                                                                           do;
                                                                              lgd24 = 0;
                                                                              lgd_def_bal_fixed = 0;
                                                                           end;
         else do;
                 lgd24 = (lgd_def_bal - netvalue24)/lgd_def_bal;
                 lgd_def_bal_fixed = lgd_def_bal;
              end;
      /* calculate 36 months lgd*/
      if (lgd_def_bal - netvalue36) = 0 or (lgd_def_bal - netvalue36) = . then 
                                                                           do;
                                                                              lgd36 = 0;
                                                                           end;
      else do;
              lgd36 = (lgd_def_bal - netvalue36)/lgd_def_bal;
           end;
      /* calculate 48 months lgd*/
      if (lgd_def_bal - netvalue48) = 0 or (lgd_def_bal - netvalue48) = . then 
                                                                           do;
                                                                              lgd48 = 0;
                                                                           end;
      else do;
              lgd48 = (lgd_def_bal - netvalue48)/lgd_def_bal;
           end;
      /* calculate 60 months lgd*/
      if (lgd_def_bal - netvalue36) = 0 or (lgd_def_bal - netvalue60) = . then 
                                                                           do;
                                                                              lgd60 = 0;
                                                                           end;
      else do;
              lgd60 = (lgd_def_bal - netvalue60)/lgd_def_bal;
           end;
      if write_off_ind = 1 and write_off_count<=24 then 
                                                    do;
      if bal_fix ~= . then 
                       do;
                          lgd24 = netvalue24/bal_fix;
                          lgd_def_bal_fixed = bal_fix;
                       end;
      else do;
              lgd24 = netvalue24/lgd_def_bal;
              lgd_def_bal_fixed= lgd_def_bal;
           end;
           end;

      if write_off_ind = 1 and write_off_count<=36 then 
                                                    do;
                                                       if bal_fix ~= . then 
                                                                        do;
                                                                           lgd36 = netvalue36/bal_fix;
                                                                        end;
                                                       else do;
                                                               lgd36 = netvalue36/lgd_def_bal;
                                                            end;
                                                    end;
      if write_off_ind = 1 and write_off_count<=48 then 
                                                    do;
                                                       if bal_fix ~= . then 
                                                                        do;
                                                                           lgd48 = netvalue48/bal_fix;
                                                                        end;
                                                          else do;
                                                                  lgd48 = netvalue48/lgd_def_bal;
                                                               end;
                                                    end;
      if write_off_ind = 1 and write_off_count<=60 then 
                                                    do;
                                                       if bal_fix ~= . then 
                                                                        do;
                                                                           lgd60 = netvalue60/bal_fix;
                                                                        end;
                                                          else do;
                                                                  lgd60 = netvalue60/lgd_def_bal;
                                                               end;
                                                    end;

      if lgd24 <= 0 then lgd24_cap15 = 0;
         else if lgd24 >= 1.25 then lgd24_cap15 = 1.25;
         else lgd24_cap15 = lgd24;
      if lgd24_cap15 > 1 then lgd24_cap1 = 1;
         else lgd24_cap1 = lgd24_cap15;
      if lgd36 <= 0 then lgd36_cap15 = 0;
         else if lgd36 >= 1.25 then lgd36_cap15 = 1.25;
         else lgd36_cap15 = lgd36;
      if lgd36_cap15 > 1 then lgd36_cap1 = 1;
         else lgd36_cap1 = lgd36_cap15;
      if lgd48 <= 0 then lgd48_cap15 = 0;
         else if lgd48 >= 1.25 then lgd48_cap15 = 1.25;
         else lgd48_cap15 = lgd48;
      if lgd48_cap15 > 1 then lgd48_cap1 = 1;
         else lgd48_cap1 = lgd48_cap15;
      if lgd60 <= 0 then lgd60_cap15 = 0;
         else if lgd60 >= 1.25 then lgd60_cap15 = 1.25;
         else lgd60_cap15 = lgd60;
      if lgd60_cap15 > 1 then lgd60_cap1 = 1;
         else lgd60_cap1 = lgd60_cap15;
run;



