PROC SQL;
CONNECT TO DB2 AS DB3CON (database=&DBNAME authdomain=db2_auth);
CREATE TABLE SRC40 AS 
SELECT * FROM CONNECTION TO DB3CON
(SELECT
		NCR_RISK_RT_KEY_VAL
		, NCR_EXPSR_CL_KEY_VAL
		, NCR_EAD_SEG_KEY_VAL
		, SUM(RPTG_QTR_ACCT_CNT) AS RPTG_QTR_ACCT_CNT
		, SUM(EAD_REALZ_ACCT_CNT) AS EAD_REALZ_ACCT_CNT
		, CASE WHEN SUM(RPTG_QTR_ACCT_CNT) = 0 THEN 0 ELSE SUM(EAD_ESTD_RTO*RPTG_QTR_ACCT_CNT)/SUM(RPTG_QTR_ACCT_CNT) END AS EAD_ESTD_RTO
		, CASE WHEN SUM(EAD_REALZ_ACCT_CNT) = 0 THEN 0 ELSE SUM(EAD_REALZ_RTO*EAD_REALZ_ACCT_CNT)/SUM(EAD_REALZ_ACCT_CNT) END AS EAD_REALZ_RTO
		, SUM(EAD_REALZ_DEFLTD_OS_BAL_AMT) AS EAD_REALZ_DEFLTD_OS_BAL_AMT
		, SUM(EAD_REALZ_DEFLTD_ACCT_CNT) AS EAD_REALZ_DEFLTD_ACCT_CNT
	FROM EDRRAPT.BASEL_CANDN_RTL_NCR_BE_FACT BE
		INNER JOIN EDRRAPT.BASEL_NCR_RISK_RT_SYS_DIM RISK_RT ON
			RISK_RT.NCR_RISK_RT_SYS_ID = BE.NCR_RISK_RT_SYS_ID
		INNER JOIN EDRRAPT.BASEL_EXPSR_CL_DIM EXPSR_CL ON
			EXPSR_CL.EXPSR_CL_ID = BE.EXPSR_CL_ID
		INNER JOIN EDRRAPT.BASEL_NCR_EAD_SEG_DIM EAD ON
			EAD.NCR_EAD_SEG_ID = BE.NCR_EAD_SEG_ID
/*	WHERE MTH_TM_ID = &MTH_TM_ID*/
	WHERE MTH_TM_ID = &mth_tm_id.
			AND ECONMC_CAPTL_AMT IS NULL
	GROUP BY NCR_RISK_RT_KEY_VAL, NCR_EXPSR_CL_KEY_VAL, NCR_EAD_SEG_KEY_VAL
	ORDER BY NCR_RISK_RT_KEY_VAL, NCR_EXPSR_CL_KEY_VAL, NCR_EAD_SEG_KEY_VAL
);
Quit;




PROC SQL;
CREATE TABLE SRC_ROLLUP40 AS 
SELECT
		NCR_RISK_RT_KEY_VAL
		, NCR_PRNT_KEY_VAL AS NCR_EXPSR_CL_KEY_VAL
		, NCR_EAD_SEG_KEY_VAL
		, CASE WHEN SUM(RPTG_QTR_ACCT_CNT) = 0 THEN 0 ELSE SUM(EAD_ESTD_RTO*RPTG_QTR_ACCT_CNT)/SUM(RPTG_QTR_ACCT_CNT) END AS EAD_ESTD_RTO
		, CASE WHEN SUM(EAD_REALZ_ACCT_CNT) = 0 THEN 0 ELSE SUM(EAD_REALZ_RTO*EAD_REALZ_ACCT_CNT)/SUM(EAD_REALZ_ACCT_CNT) END AS EAD_REALZ_RTO
		, SUM(EAD_REALZ_DEFLTD_OS_BAL_AMT) AS EAD_REALZ_DEFLTD_OS_BAL_AMT
		, SUM(EAD_REALZ_DEFLTD_ACCT_CNT) AS EAD_REALZ_DEFLTD_ACCT_CNT
FROM SRC40
		INNER JOIN OUTFILE.BASEL_NCR_HIERARCHY_LKP EXPSR_CL ON
			EXPSR_CL.NCR_KEY_VAL = SRC40.NCR_EXPSR_CL_KEY_VAL
	GROUP BY NCR_RISK_RT_KEY_VAL, EXPSR_CL.NCR_PRNT_KEY_VAL, NCR_EAD_SEG_KEY_VAL
;
quit;




PROC SQL;
CREATE TABLE Exposure_Class40 AS 
SELECT DISTINCT NCR_EXPSR_CL_KEY_VAL
FROM OUTFILE.BASEL_EXPSR_CL_DIM
WHERE NCR_EXPSR_CL_KEY_VAL IN ('0500', '0501', '0502', '0503', '0504', '0505', '0506', '0507')
;
quit;



PROC SQL;
CREATE TABLE EAD_SEG40 AS
SELECT DISTINCT NCR_EAD_SEG_KEY_VAL
FROM OUTFILE.BASEL_NCR_EAD_SEG_DIM
WHERE NCR_EAD_SEG_KEY_VAL NE '3399'
;
quit;



PROC SQL;
CREATE TABLE risk_rt40 AS 
SELECT DISTINCT NCR_RISK_RT_KEY_VAL
FROM &DB..BASEL_NCR_RISK_RT_SYS_DIM
WHERE   NCR_RISK_RT_KEY_VAL in ('0201','0207')
;
quit;

PROC SQL;
CREATE TABLE BASE_REC40 AS
SELECT 
		'040' AS NCR_RECD_TP
		,Exposure_Class40.NCR_EXPSR_CL_KEY_VAL AS NCR_EXPSR_CL
			,risk_rt40.NCR_RISK_RT_KEY_VAL
		,'0999' AS NCR_PD_SEG
		,'3299' AS NCR_LGD_SEG
		,EAD_SEG40.NCR_EAD_SEG_KEY_VAL AS NCR_EAD_SEG
	FROM Exposure_Class40
		CROSS JOIN EAD_SEG40 
		CROSS JOIN risk_rt40 
;
quit;


PROC SQL;
CREATE TABLE BASEL_P2_040_TMP1 AS
SELECT
	"&tm_lvl_end_dt."d as MTH_END_DT FORMAT DATE9.
	,"&dtime."dt AS EXTRACT_TMSTMP format datetime25.
	,BASE_REC40.NCR_RECD_TP Length=3  FORMAT $3.
	,BASE_REC40.NCR_EXPSR_CL format $4.
	,BASE_REC40.NCR_RISK_RT_KEY_VAL as NCR_RISK_RT_SYS format $4.
	,BASE_REC40.NCR_PD_SEG format $4.
	,BASE_REC40.NCR_LGD_SEG format $4.
	,BASE_REC40.NCR_EAD_SEG format $4.
	,COALESCE(SRC_ROLLUP40.EAD_ESTD_RTO, 0)*100 AS ESTD_EAD format 5.2
	,CASE
		WHEN BASE_REC40.NCR_EAD_SEG = '3308' THEN 100.00
		ELSE COALESCE(SRC_ROLLUP40.EAD_REALZ_RTO, 0)*100
		END AS REALZ_EAD format 5.2
	,ROUND(COALESCE(SRC_ROLLUP40.EAD_REALZ_DEFLTD_OS_BAL_AMT, 0)/1000) AS OS_BAL_AMT
	,COALESCE(SRC_ROLLUP40.EAD_REALZ_DEFLTD_ACCT_CNT, 0) AS REALZ_DFT_CNT
	,"&dtime."dt AS INSRT_PROCESS_TMSTMP format datetime25.
	,"&dtime."dt AS UPDT_PROCESS_TMSTMP format datetime25.

FROM BASE_REC40 
	LEFT JOIN SRC_ROLLUP40 ON
		SRC_ROLLUP40.NCR_EXPSR_CL_KEY_VAL = BASE_REC40.NCR_EXPSR_CL
		AND SRC_ROLLUP40.NCR_EAD_SEG_KEY_VAL = BASE_REC40.NCR_EAD_SEG
		AND SRC_ROLLUP40.NCR_RISK_RT_KEY_VAL= BASE_REC40.NCR_RISK_RT_KEY_VAL
		WHERE BASE_REC40.NCR_EAD_SEG not in ('3298', '3299')
ORDER BY BASE_REC40.NCR_EXPSR_CL, BASE_REC40.NCR_EAD_SEG
;
quit;


