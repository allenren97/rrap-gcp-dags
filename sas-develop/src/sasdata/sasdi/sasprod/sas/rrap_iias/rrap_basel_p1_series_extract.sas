a.NCR_GEO_ID=b.NCR_GEO_ID) as NCR_GEO_KEY_VAL,
NCR_LTV_ID,(select NCR_LTV_KEY_VAL from &LIB..BASEL_NCR_LTV_DIM as b where 
a.NCR_LTV_ID=b.NCR_LTV_ID) as NCR_LTV_KEY_VAL,
