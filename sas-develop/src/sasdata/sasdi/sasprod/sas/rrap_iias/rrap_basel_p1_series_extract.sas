&LIB..BASEL_NCR_SECRTZTN_DIM as b where a.NCR_SECRTZTN_ID=b.NCR_SECRTZTN_ID) 
as NCR_SECRTZTN_KEY_VAL,
NCR_RT_ID,(select NCR_RT_KEY_VAL from &LIB..BASEL_NCR_RT_DIM as b where 
a.NCR_RT_ID=b.NCR_RT_ID) as NCR_RT_KEY_VAL,
