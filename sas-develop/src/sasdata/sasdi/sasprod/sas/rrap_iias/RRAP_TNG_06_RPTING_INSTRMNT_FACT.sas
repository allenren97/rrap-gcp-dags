         SCR_remain_amort2 = 13;
      end;
      else if not missing(remain_amort2) and 369 <= remain_amort2 then 
      do;
         scorecard_points = scorecard_points + 0;
         SCR_remain_amort2 = 0;
      end;
    
      /*------------------------------------------------------------
       * Variable: credit_trble_bnkrptcy_coll_der
       *------------------------------------------------------------*/
      if missing(credit_trble_bnkrptcy_coll_der) then 
      do;
         scorecard_points = scorecard_points + 19;
         SCR_credit_trble_bnkrptcy_coll_d = 19;
      end;
      else if credit_trble_bnkrptcy_coll_der eq 1 then 
      do;
         scorecard_points = scorecard_points + 0;
         SCR_credit_trble_bnkrptcy_coll_d = 0;
      end;
      else if credit_trble_bnkrptcy_coll_der eq 0 then 
      do;
         scorecard_points = scorecard_points + 19;
         SCR_credit_trble_bnkrptcy_coll_d = 19;
      end;
      else 
      do;
         scorecard_points = scorecard_points + 19;
         SCR_credit_trble_bnkrptcy_coll_d = 19;
      end;
    
      /*------------------------------------------------------------
       * Variable: ins_id_group
       *------------------------------------------------------------*/
      if missing(ins_id_group) then 
      do;
         scorecard_points = scorecard_points + 0;
         SCR_ins_id_group = 0;
      end;
      else if ins_id_group eq 300 then 
      do;
         scorecard_points = scorecard_points + 0;
         SCR_ins_id_group = 0;
      end;
      else if ins_id_group eq 100 or ins_id_group eq 200 then 
      do;
         scorecard_points = scorecard_points + 33;
         SCR_ins_id_group = 33;
      end;
      else do;
         scorecard_points = scorecard_points + 0;
         SCR_ins_id_group = 0;
      end;

      /*------------------------------------------------------------
       * SECTION: Assigning segment
       *------------------------------------------------------------*/
      if close_dt ne . or end_principal_balance<=0 then segment=99;  /*Leon H confirmed that 98=99.  WP changed it.*/

      /*defaulted accounts*/
      else if final_default_ind='Y' then segment = 99;
      else if scorecard_points <757 then segment = 4;
      else if scorecard_points <801 then segment = 3;
      else if scorecard_points <842.5 then segment = 2;
      else segment = 1;

   run;

%mend pd_score_segment;

%pd_score_segment;


