												  ELSE FIR.PROP_CITY END AS METROPOLITAN
												
													FROM 
															(
																SELECT A.*, B.OPEN_DT, B.LAST_RENEWAL_DT,
																CASE 
																	WHEN A.MTH_TM_ID >= 17156 AND A.LGD_BASEL_SEG_NUM NOT IN (10,11) AND A.PIT_STAT_CD='CUR' 
																		AND A.SCRTY_TP_DESC in ('Uninsured','Insured') AND (B.OPEN_DT>='11-01-2016' OR B.LAST_RENEWAL_DT>='11-01-2016') 
																		THEN 'Y' 
																	WHEN A.MTH_TM_ID < 17156 AND A.LGD_BASEL_SEG_NUM NOT IN (10,11) AND A.PIT_STAT_CD='CUR' 
																		AND A.SCRTY_TP_DESC='Uninsured' AND (B.OPEN_DT>='11-01-2016' OR B.LAST_RENEWAL_DT>='11-01-2016') 
																		THEN 'Y' 
																	ELSE 'N' 
																END AS DLGD_F 
												
																FROM 
															        &FRG_DB..BASEL_ANALYTCL_BL_INST_FCT_TNG A, &TNG_DB..TNG_ACCT_MO B 
																WHERE 
																TRIM(A.MORT_NUM)=TRIM(B.ACCOUNT_ID) AND A.MTH_TM_ID=&MTH_TM_ID AND B.MONTH_END_DT=&NZDATEFORMAT
														) SUBQ1
											LEFT OUTER JOIN &FRG_DB..TNG_PD_VAR_CREATION_FINAL_CMA FIR ON TRIM(SUBQ1.MORT_NUM)=TRIM(FIR.ACCOUNT_ID) AND FIR.MONTH_END_DT=&NZDATEFORMAT
											LEFT OUTER JOIN &RRAP_DB..BASEL_ACCT_LTV_DRVD_VARS_CMA LTVVAR ON TRIM(SUBQ1.MORT_NUM)=TRIM(LTVVAR.ACCT_NUM) AND LTVVAR.ACCT_SENRTY_CD=1 AND LTVVAR.MTH_TM_ID=&MTH_TM_ID
																		
									) SUBQ2 				 
	
	LEFT OUTER JOIN (SELECT DISTINCT MTH_TM_ID, LABEL_2, INDEX FROM &RRAP_DB..TERANET_HOUSE_PRC_INDEX_CMA WHERE MTH_TM_ID=&MTH_TM_ID) INDX ON UPPER(TRIM(INDX.LABEL_2))=UPPER(TRIM(SUBQ2.METROPOLITAN))
	LEFT OUTER JOIN (SELECT DISTINCT MTH_TM_ID, LABEL_2, INDEX FROM &RRAP_DB..TERANET_HOUSE_PRC_INDEX_CMA WHERE MTH_TM_ID=&MTH_TM_ID-1440) INDX12 ON UPPER(TRIM(INDX12.LABEL_2))=UPPER(TRIM(SUBQ2.METROPOLITAN))

	LEFT OUTER JOIN &RRAP_DB..DLGD_SCRI_QTR_DRVD_VARS SCRI ON UPPER(TRIM(SCRI.METRPL_AREA_NM))=UPPER(TRIM(SUBQ2.METROPOLITAN)) AND SCRI.MTH_TM_ID=&CURR_QTR_MTH_TM_ID
		/* RRMSS-1557 map new CMAs as '11' for breach flag  */
	LEFT OUTER JOIN &RRAP_DB..DLGD_SCRI_QTR_DRVD_VARS SCRI2 ON SCRI.METRPL_AREA_NM IS NULL AND TRIM(SCRI2.METRPL_AREA_NM)='11' AND SCRI2.MTH_TM_ID=&CURR_QTR_MTH_TM_ID 
	) SUBQ3
	) SUBQ4 	
