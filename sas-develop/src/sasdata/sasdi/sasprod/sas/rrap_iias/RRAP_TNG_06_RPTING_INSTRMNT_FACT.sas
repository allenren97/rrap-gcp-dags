/*--------------------------------------------------------------------------------------------
 * Joining the PD score and segment values and LGD segment values.  Also getting pd_model_rto
 *--------------------------------------------------------------------------------------------*/

proc sql noprint;
   create table work.tng_pd_ead_lgd2 as
      select a.*,
             b.segment as pd_basel_seg_num,
             b.scorecard_points as pd_acct_score,
             case
                when upcase(a.pit_stat_cd) in ('CUR', '') then c.segment
             end as lgdnd_segment,
             case
                when upcase(a.pit_stat_cd) EQ 'DEF' then d.lgdd_segment
             end as lgd_d_segment,
                
             case
                when upcase(a.pit_stat_cd) in ('CUR', '') then c.segment 
                when upcase(a.pit_stat_cd) EQ 'DEF' then d.lgdd_segment
             end as lgd_basel_seg_num,

             e.segment_dr as pd_model_rto,
             
             d.accrued_interest_amt as intr_accr_amt
             

         from work.tng_pd_ead_lgd1 (rename=(months_in_default=cons_dft_mth_cnt)) as a
              left join 
              work.with_pd_score as b
              on (a.account_id = b.account_id and
                  intnx('month', a.month_end_dt, 0, 'e') = intnx('month', b.month_end_dt, 0, 'e'))

              left join 
              work.with_lgd_nd_segs as c
              on (a.account_id = c.account_id and
                  intnx('month', a.month_end_dt, 0, 'e') = intnx('month', c.month_end_dt, 0, 'e'))

              left join
              work.with_lgd_d_segs as d
              on (a.account_id = d.account_id and
                  intnx('month', a.month_end_dt, 0, 'e') = intnx('month', d.month_end_dt, 0, 'e'))

              left join
              &_in_pd_segs_with_pds_tbl as e
              on (b.segment = e.segment and
                  intnx('month', a.month_end_dt, 0, 'e') = intnx('month', e.month_end_date, 0, 'e'));
quit;


