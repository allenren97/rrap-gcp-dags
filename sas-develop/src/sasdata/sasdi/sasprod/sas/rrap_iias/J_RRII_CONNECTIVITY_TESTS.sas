/*****************************SAS FOLDER ACCESS AND FILE ACCESS CHECK******************************************/

%MACRO CREATE_DELETE_FILE(FILENAME);

FILENAME MYFILE "&FILENAME.";

DATA _NULL_;
	FILE MYFILE;
RUN;

%LET FILE_EXISTS = %SYSFUNC(FILEEXIST(&FILENAME.));

%IF &FILE_EXISTS %THEN %DO;
	FILENAME DEL "&FILENAME.";

	DATA _NULL_;
		RC = FDELETE('DEL');
	RUN;
	%PUT "The CSV file &FILENAME. has been deleted.";
%END;
%ELSE %DO;
	%PUT "The CSV file &FILENAME. does not exist or could not be created.";
%END;

%MEND;

%MACRO DIRECTORY_TEST(DIRECTORY_PATH,TEST_FILE_NAME);

DATA DIR_OPEN_TEMP;
LENGTH FILE_PATH_NAME $200;
FORMAT FILE_PATH_NAME $200.;
%LET EXIST=%SYSFUNC(FILEEXIST(&DIRECTORY_PATH.));
%PUT &EXIST;
%IF &EXIST>0 %THEN %DO;
	FILE "&DIRECTORY_PATH.&TEST_FILE_NAME";
            FILE_PATH_NAME = "&DIRECTORY_PATH.&TEST_FILE_NAME";
            DIRECTORY_ACCESS = "YES";
	%PUT "Directory is ACCESSIBLE";
%CREATE_DELETE_FILE(&DIRECTORY_PATH.&TEST_FILE_NAME.)
%end;
%ELSE %DO ;
            FILE_PATH_NAME = "&DIRECTORY_PATH.&TEST_FILE_NAME";
            DIRECTORY_ACCESS = "NO";
			%PUT "Directory is NOT ACCESSIBLE";
%END;
RUN;

%MEND;

