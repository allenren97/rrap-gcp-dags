/*CREATE TABLE IIAS - SQL PASSTHROUGH*/
PROC SQL;
      CONNECT TO DB2 AS IIASCON(DATABASE=BLUDBPRD AUTHDOMAIN='IIAS_Auth');
      CREATE TABLE NZRRAP.TEST_IIAS_CONN AS
            SELECT * FROM CONNECTION TO IIASCON
            (SELECT * FROM EDRTLRP1D.TM_DIM);
      DISCONNECT FROM IIASCON;
QUIT;

PROC SQL;
      SELECT COUNT(*) INTO :TEST_COUNT
      FROM NZRRAP.TEST_IIAS_CONN;
QUIT;

%PUT &=TEST_COUNT;

%MACRO CREATE_TEST;
%IF &TEST_COUNT > 0 %THEN %DO;
      %PUT "TABEL CREATED WITH DATA SUCCESSFULLY";
%END;
%ELSE %DO;
      %PUT "KINDLY INVESTIGATE";
%END;
%MEND;

%CREATE_TEST

/*UPDATE TABLE IIAS - SQL PASSTHROUGH*/

PROC SQL;
      CONNECT TO DB2 AS IIASCON(DATABASE=BLUDBPRD AUTHDOMAIN='IIAS_Auth');
      EXECUTE(CREATE TABLE EDRTLRP1D.TM_DIM_MERGE AS (SELECT * FROM EDRTLRP1D.TM_DIM)WITH DATA ORGANIZE BY ROW;)BY IIASCON;
      EXECUTE(UPDATE EDRTLRP1D.TM_DIM_MERGE SET TM_LVL = 'UPDATED';)BY IIASCON;
      DISCONNECT FROM IIASCON;
QUIT;

PROC SQL;
      SELECT COUNT(DISTINCT TM_LVL) INTO :UPDATE_CHECK_ORI FROM NZRRAP.TM_DIM;
QUIT;

PROC SQL;
      SELECT COUNT(DISTINCT TM_LVL) INTO :UPDATE_CHECK_UPD FROM NZRRAP.TM_DIM_MERGE;
QUIT;

%MACRO UPDATE_CHECK;
%IF &UPDATE_CHECK_UPD = 1 %THEN %DO;
      %PUT "TABEL UPDATED SUCCESSFULLY";
%END;
%ELSE %DO;
      %PUT "KINDLY INVESTIGATE";
%END;
%MEND;

%UPDATE_CHECK

/*MERGE CHECK IIAS - SQL PASSTHROUGH*/

PROC SQL;
      CONNECT TO DB2 AS IIASCON(DATABASE=BLUDBPRD AUTHDOMAIN='IIAS_Auth');
      EXECUTE(MERGE INTO EDRTLRP1D.TEST_IIAS_CONN TIC
                  USING (SELECT TM_ID, TM_LVL FROM EDRTLRP1D.TM_DIM_MERGE) TDM
                  ON (TIC.TM_ID = TDM.TM_ID)
                  WHEN MATCHED THEN
                  UPDATE SET
                        TM_LVL = TDM.TM_LVL;)BY IIASCON;
      DISCONNECT FROM IIASCON;
QUIT;

PROC SQL;
      SELECT COUNT(DISTINCT TM_LVL) INTO :MERGE_CHECK_ORI FROM NZRRAP.TM_DIM;
QUIT;

PROC SQL;
      SELECT COUNT(DISTINCT TM_LVL) INTO :MERGE_CHECK_UPD FROM NZRRAP.TM_DIM_MERGE;
QUIT;

%MACRO MERGE_CHECK;
%IF &MERGE_CHECK_UPD = &MERGE_CHECK_ORI %THEN %DO;
      %PUT "TABEL MERGE-UPDATED SUCCESSFULLY";
%END;
%ELSE %DO;
      %PUT "KINDLY INVESTIGATE";
%END;
%MEND;

%MERGE_CHECK

