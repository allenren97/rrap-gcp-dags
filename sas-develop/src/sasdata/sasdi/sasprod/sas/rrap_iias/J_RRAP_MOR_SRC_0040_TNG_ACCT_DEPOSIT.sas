DATA flat_file_count;
	INFILE "&outpath./tng/tng_edwext_acct_deposit_f_mthly_&yyyymmdd..bcr" TRUNCOVER dlm='|';
	INPUT FILENAME $ DATE ROW_CNT BALANCE_BCR SOMETHING $;
	format ROW_CNT BALANCE_BCR comma20.;
	KEEP ROW_CNT BALANCE_BCR;
RUN;


proc sql;
create table myload as
select count(*) format comma20. as load_count, SUM(BAL_CAN) format comma20. AS BALANCE
FROM NETCON.TNG_ACCT_DEPOSIT
WHERE MONTH_END_DT="&start_period_dt."d;
QUIT;



proc sql noprint;
select max(audit_key) +1 as audit_key into :audit_key
from NZWRK.AUDIT_TABLE;
quit;


%let audit_status=PASS;
data compare;
	merge myload flat_file_count;
	FORMAT COUNT_DIFF BALANCE_DIFF PERCENT12.5;
	COUNT_DIFF=ABS(load_count-ROW_CNT)/ROW_CNT;
	BALANCE_DIFF=ABS(BALANCE-BALANCE_BCR)/BALANCE_BCR;
		call symputx('COUNT_DIFF',COUNT_DIFF);
		call symputx('SRC_ROW_CNT',ROW_CNT);
		call symputx('TARGET_ROW_CNT',load_count);

		call symputx('BALANCE_DIFF',BALANCE_DIFF);
		call symputx('SRC_SUM1',BALANCE_BCR);
		call symputx('TARGET_SUM1',BALANCE);
	IF COUNT_DIFF GT 0 THEN DO;
		PUT ;
		PUT "  The count difference is greater than the threshold of &threshold.%.";
		PUT ;
		PUT "  		Rows Loaded: " LOAD_COUNT ", Rows Expected: " ROW_CNT;
		PUT ;
		PUT "  Please investigate prior to restarting this job. The process will now abort.";
		PUT ;
		CALL SYMPUTX('AUDIT_STATUS','FAIL');
	END;
	IF BALANCE_DIFF GT &threshold./100 THEN DO;
		PUT ;
		PUT "  The balance difference is greater than the threshold of &threshold.%.";
		PUT ;
		PUT "  		Balance Loaded: " BALANCE ", Balance Expected: " BALANCE_BCR;
		PUT ;
		PUT "  Please investigate prior to restarting this job. The process will now abort.";
		PUT ;
		CALL SYMPUTX('AUDIT_STATUS','FAIL');
	END;
run;

