%macro load_MOR();
%do i = 1 %to 3;
	data output&i. ; 
	   infile "&outpath./bns/incoming/MORIC&i."
	          lrecl = 1640
	          delimiter = '	'
	          dsd
	          missover
	          firstobs = 1 obs=max
	; 
	
	format INT_ADJ_DATE MADE_DATE MATURITY_DATE RENEWAL_DATE UNPD_WKL_PAY_DATE UNPD_MTH_PAY_DATE PROCESS_DATE DATE9.;
	
	input &columns. ;
	INT_ADJ_DATE = input(INT_ADJ_DATE_TEMP,mmddyy8.);
	MADE_DATE = input(MADE_DATE_TEMP,mmddyy8.);
	MATURITY_DATE = input(MATURITY_DATE_TEMP,mmddyy8.);
	RENEWAL_DATE = input(RENEWAL_DATE_TEMP,mmddyy8.);
	UNPD_WKL_PAY_DATE = input(UNPD_WKL_PAY_DATE_TEMP,mmddyy8.);
	UNPD_MTH_PAY_DATE = input(UNPD_MTH_PAY_DATE_TEMP,mmddyy8.);
	PROCESS_DATE = input(PROCESS_DATE_TEMP,mmddyy8.);
	
	LENGTH CONVERSION_DATE $8 CONVERSION_SOURCE $2;
	DROP INT_ADJ_DATE_TEMP MADE_DATE_TEMP MATURITY_DATE_TEMP RENEWAL_DATE_TEMP UNPD_WKL_PAY_DATE_TEMP UNPD_MTH_PAY_DATE_TEMP PROCESS_DATE_TEMP;
	if missing(mortgage_no) then delete;

/*Added when these fields did not allow values gt 100m	- to be removed when credit_risk.mo_new is updated to allow this.	*/
/*	if mortgage_no = 4010879 then do;*/
/*		COMIT=99999999.99; AUTH_AMOUNT=99999999.99;*/
/*	end;*/
	
	run;
	
	%if &i EQ 1 %then %do;
		proc sql;
		create table &_output. like output1;
		quit;
	%end;
	
	proc append base=&_output. data=output&i. force; run;
%end;
%mend load_MOR;
%load_MOR;

