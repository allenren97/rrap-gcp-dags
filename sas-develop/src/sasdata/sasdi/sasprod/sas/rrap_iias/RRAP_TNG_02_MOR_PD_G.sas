%let _pd_output_tbl = results.tng_12mth_default;

/* Query added by will to make arrays more dynamic by using a macro variable*/

proc sql noprint;
   select intck('month','31DEC2004'd, max(a.month_end_dt))
      into :month1
   from nz_frg.tng_status as a;
quit;

/*----------------------------------------------------------------------------------
 * Used to make sure the value is stripped of blanks. Used the name month_num2 so 
 * that there would be no conflict with macro variable in 01
 *----------------------------------------------------------------------------------*/
%let month_num2=&month1;


%macro twelve_month_window(_in_ds=);
   %do j= 1 %to &month_num2.;
      %let monthahead = intnx('month', '31DEC2004'd, &j+13, 'same');
      %let yearback = intnx('month', '31DEC2004'd, &j, 'same');
      %let yearback2 = intnx('month', '31DEC2004'd, &j-1, 'same');
      options compress=yes;

      data work.sample;
         set &_in_ds.;
         month_end_date=month_end_dt;
         date=intck('month',&yearback2,month_end_date); 
         WHERE month_end_dt > &yearback2 AND month_end_dt < &monthahead ;
      run;

      %put &=syserr;
%put &=sqlrc;

      PROC SORT data =work.sample;
         by ACCOUNT_ID date;
      run;

      %put &=syserr;
%put &=sqlrc;

      data work.sample2 ;
         array Months[13] Months1 - Months13 ;
         array Default[13] $  Default1 - Default13 ;
         array outbal[13] outbal1-outbal13;
         retain Months1 - Months13 Default1 - Default13 outbal1-outbal13   ;
         set work.sample ;
         by ACCOUNT_ID ;
         if first.ACCOUNT_ID then 
                               do i=1 to 13  ;
                                  Months[i] = . ;
                                  Default[i] = . ;
                                  outbal[i]= .;
                               end ;

         Months[date] = MONTH_END_DaTe ;
         Default[date] = final_default_ind ;
         outbal[date]=END_PRINCIPAL_BALANCE;
         if last.ACCOUNT_ID then output ;
         drop i date ;
      run ;

      %put &=syserr;
%put &=sqlrc;

      data work.sample3 ;
         set work.sample2 ;
         If Default1 = 'Y' then delete;
            else if (Default13 eq 'Y' or Default2 eq 'Y' or Default3 eq 'Y' or Default4 eq 'Y' or Default5 eq 'Y' or Default6 eq 'Y' or Default7 eq 'Y' or 
                     Default8 eq 'Y' or Default9 eq 'Y' or Default10 eq 'Y' or Default11 eq 'Y' or Default12 eq 'Y') 
                     then def_ind = 1 ;
            else def_ind = 0 ;   
      run ;

      %put &=syserr;
%put &=sqlrc;



      data work.sample4 ;
         set work.sample3 ;
         array Default[13];
         array Months[13];
         array outbal[13] ;
         format first_defaultdate date9.0;
         format final_defaultdate date9.0;
         flag=0;
         flag2=0;
         Do k=2 to 13 until(flag);
            if  Default(k)='Y' then 
                                do;
                                   flag=(k) ;
                                   first_defaultdate=Months(k); 
                                   first_defaultbal=outbal(k);
                                end ;   
                
            drop k;
         end ;
         do m=2 to 13 ;
            if  Default(m-1)='N' then flag2=0;
            if flag2=0 and  Default(m)='Y' then 
                                            do;
                                               flag2=1;
                                               final_defaultdate=Months(m); 
                                               final_defaultbal=outbal(m);
                                            end ;   
                
            drop m;
         end ;
      run;

      %put &=syserr;
%put &=sqlrc;


   options compress=yes;
   PROC SQL; 
      create table intmed.def_&j as
         select a.*,
                b.def_ind,
                b.first_defaultdate, 
                b.first_defaultbal, 
                b.final_defaultdate, 
                b.final_defaultbal 
            from work.sample as a 
                 left join 
                 work.sample4 as b
                 on a.ACCOUNT_ID = b.ACCOUNT_ID where a.month_end_date=&yearback; 
   quit; 

   %put &=syserr;
%put &=sqlrc;

%end;
%mend twelve_month_window;

%twelve_month_window(_in_ds = nz_frg.tng_status)



/*---------------------------------------------------------------
 * Combining the results data sets into one large dataset
 *---------------------------------------------------------------*/
%macro loop;
   %do i=1 %to &month_num2.;
      intmed.def_&i
   %end;
%mend loop;


data &_pd_output_tbl.;
   set %loop ;
run;

