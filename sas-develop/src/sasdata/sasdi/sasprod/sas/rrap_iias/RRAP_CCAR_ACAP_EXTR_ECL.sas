		FACT.CLP_FLAG,
		FACT.PERIOD_IND,
		FACT.ECL_Drawn_1,
		FACT.ECL_Drawn_2,
		FACT.ECL_Drawn_3,
		FACT.ECL_Undrawn_1,
		FACT.ECL_Undrawn_2,
		FACT.ECL_Undrawn_3,
		FACT.ECL_Drawn_PostSec_1,
		FACT.ECL_Drawn_PostSec_2,
		FACT.ECL_Drawn_PostSec_3,
		NULL AS INSRT_PROCESS_TMSTMP,
		NULL AS UPDT_PROCESS_TMSTMP,
		FACT.PMI,
		FACT.BASEL_ACCT_ID
FROM &net_db..BASEL_CCAR_EXPSR_FACT_ACAP FACT WHERE (FACT.LEGAL_ENTITY IN ('DOM-BANK-BNS') and FACT.PERIOD_IND = 'CURR'
AND (FACT.BEFR_ZERO_NET_ADJ_OS_BAL_AMT <> 0 OR FACT.BEFORE_ZERO_NET_UNDRAWN_AMT <> 0) AND FACT.MTH_TM_ID=&MTH_TM_ID )
OR
(FACT.LEGAL_ENTITY IN ('DOM-BANK-BNS_PREV') and FACT.PERIOD_IND = 'PREV' AND FACT.MTH_TM_ID=&MTH_TM_ID-40 )
OR (FACT.LEGAL_ENTITY IN ('DOM-BANK-BNS_MISS') and FACT.PERIOD_IND = 'MISS' )
) as SUBQ
);
DISCONNECT FROM NZCON;
quit;

PROC SQL NOPRINT;
CONNECT TO DB2 AS NZCON(DATABASE=&IIASDB authdomain="IIAS_Auth");
	CREATE TABLE WORK.TEMP6 AS
	SELECT * FROM CONNECTION TO NZCON
(SELECT DISTINCT
(SELECT TM_LVL_END_DT FROM &net_db..TM_DIM WHERE TM_ID=&MTH_TM_ID) AS MTH_END_DT,
		'DOM-SUB-TNG' as LEGAL_ENTITY,
		TFACT.CCAR_BASEL_PRD_TP_NM,
		TFACT.PD_BAND,
		'DR_A'||LPAD(ROW_NUMBER() OVER (PARTITION BY '' ORDER BY TFACT.LEGAL_ENTITY
		, TFACT.CCAR_BASEL_PRD_TP_NM, TFACT.PD_BAND ASC, TFACT.PMI DESC),7,'0') AS UNQ_RECD_ID,
		TFACT.INSUR_F,
		PD_BASEL_SEG_NUM,
		(case when LGD_BASEL_SEG_NUM=-1 then null else LGD_BASEL_SEG_NUM end) as LGD_BASEL_SEG_NUM,
		(case when EAD_BASEL_SEG_NUM=-1 then null else EAD_BASEL_SEG_NUM end) as  EAD_BASEL_SEG_NUM,
		CASE WHEN TFACT.DEFAULT_F = 'T' THEN 'TRUE' ELSE 'FALSE' END AS DEFAULT_F,
		BEFR_ZERO_NET_ADJ_OS_BAL_AMT,
		AF_ZERO_NET_ADJUSTED_OS_BAL_AMT,
		(CAST(ROUND(TFACT.EXPCTD_LOSS_RTO*100,6) AS DECIMAL(15,6)))||'%' AS EXPCTD_LOSS_RTO_TEXT,
		 BEFORE_ZERO_NET_UNDRAWN_AMT,
		AF_ZERO_NET_UNDRAWN_AMT,
		TFACT.BEFR_ZERO_NET_ALWBL_CR_LOSS_AMT AS BEFR_ZERO_NET_ALWBL_CR_LOSS_AMT,
		TFACT.AF_ZERO_NET_ALWBL_CR_LOSS_AMT AS AF_ZERO_NET_ALWBL_CR_LOSS_AMT,
		(CAST(ROUND(TFACT.LGD_FLRD_RPTG_RTO*100,6) AS DECIMAL(15,6)))||'%' AS LGD_FINAL_RPTG_RTO_TEXT,
(CAST(ROUND(TFACT.EAD_FLRD_RPTG_RTO*100,6) AS DECIMAL(15,6)))||'%' AS EAD_FINAL_RPTG_RTO_TEXT,
		'' AS EAD_PC,
		TFACT.CRNCY_CD,
		TFACT.PRTL_WRITE_OFF_AMT,
		TFACT.UNCONDTNLY_CNCLBL AS UNCONDTNLY_CNCLBL,
		TFACT.ACCR_INTR_AMT,
		TFACT.WGHTD_DLGD_RTO, TFACT.LTV_PERCENTAGE, TFACT.OBLIGORS,
		TFACT.TRNST_NUM,TFACT.PRD_ID,TFACT.EGL_DEPRTMNT,/*adding for bcar_ccar combine file */
		TFACT.RNTL_PRPTY_F, TFACT.CURRENCY_MISMATCH_F, TFACT.TOT_EXPSR_ABOVE_1500K_LMT_F, 
		TFACT.ORIG_AMT_LOAN, TFACT.TRANSACTOR_FLAG_QRR,
		CASE WHEN TFACT.PD_90_DAY_F = 'T' THEN 'TRUE' ELSE 'FALSE' END AS PD_90_DAY_F,
		(CAST(ROUND(TFACT.UNINSURED_FLRD_LGD_RTO*100,6) AS DECIMAL(15,6)))||'%' AS UNINSURED_FLRD_LGD_RTO,	
		TFACT.UNINSURED_DLGD_RTO,
		TFACT.CLP_FLAG,
		TFACT.PERIOD_IND,
		TFACT.ECL_Drawn_1,
		TFACT.ECL_Drawn_2,
		TFACT.ECL_Drawn_3,
		TFACT.ECL_Undrawn_1,
		TFACT.ECL_Undrawn_2,
		TFACT.ECL_Undrawn_3,
		TFACT.ECL_Drawn_PostSec_1,
		TFACT.ECL_Drawn_PostSec_2,
		TFACT.ECL_Drawn_PostSec_3,
		NULL AS INSRT_PROCESS_TMSTMP,
		NULL AS UPDT_PROCESS_TMSTMP,
		TFACT.PMI,
		TFACT.BASEL_ACCT_ID
FROM &net_db..BASEL_CCAR_EXPSR_FACT_ACAP tFACT 
WHERE (tFACT.LEGAL_ENTITY IN ( 'DOM-SUB-TNG' ) and tFACT.PERIOD_IND = 'CURR'
		AND (tFACT.BEFR_ZERO_NET_ADJ_OS_BAL_AMT <> 0 OR tFACT.BEFORE_ZERO_NET_UNDRAWN_AMT <> 0) 
		AND tFACT.MTH_TM_ID=&MTH_TM_ID )
OR
	(tFACT.LEGAL_ENTITY IN ('DOM-SUB-TNG_PREV') and tFACT.PERIOD_IND = 'PREV' 
	AND tFACT.MTH_TM_ID=&MTH_TM_ID-40 ));
DISCONNECT FROM NZCON;
 QUIT;

