%rrap_autoexec(RRAPENV=REVOLVING_CREDIT);

%let datetime_start = %sysfunc(TIME()) ;
%put >>> START TIME: %sysfunc(datetime(),datetime14.);

%PUT MTH_TM_ID IS &MTH_TM_ID;

/* Update values to zero for previous month */
PROC SQL NOPRINT;
CONNECT USING NZRRAP AS NZCON;
EXECUTE(UPDATE &net_db..BASEL_CCAR_EXPSR_FACT_ACAP
SET BEFR_ZERO_NET_ADJ_OS_BAL_AMT = 0 ,
AF_ZERO_NET_ADJUSTED_OS_BAL_AMT = 0 ,
BEFORE_ZERO_NET_UNDRAWN_AMT = 0 ,
AF_ZERO_NET_UNDRAWN_AMT = 0 ,
BEFR_ZERO_NET_ALWBL_CR_LOSS_AMT = 0 ,
AF_ZERO_NET_ALWBL_CR_LOSS_AMT = 0 ,
PRTL_WRITE_OFF_AMT = 0 ,
ACCR_INTR_AMT = 0
where period_ind = 'PREV'
)BY NZCON  ;
quit;

/* Delete existing data in target table */
PROC SQL NOPRINT;
CONNECT USING NZRRAP AS NZCON;
EXECUTE(Truncate &net_db..BASEL_CCAR_EXPSR_EXTR_ACAP immediate)BY NZCON  ;
quit;

/* Add data to target table */
PROC SQL NOPRINT;
CONNECT TO DB2 AS NZCON(DATABASE=&IIASDB authdomain="IIAS_Auth");
	CREATE TABLE WORK.TEMP1 AS
	SELECT * FROM CONNECTION TO NZCON
	(SELECT DISTINCT
(SELECT TM_LVL_END_DT FROM &net_db..TM_DIM WHERE TM_ID=&MTH_TM_ID) AS 
		MTH_END_DT,
		FACT.LEGAL_ENTITY,
		FACT.CCAR_BASEL_PRD_TP_NM,
		FACT.PD_BAND,
		'DR_A'||LPAD(ROW_NUMBER() OVER (PARTITION BY '' ORDER BY FACT.LEGAL_ENTITY, FACT.CCAR_BASEL_PRD_TP_NM, FACT.PD_BAND ASC, FACT.PMI DESC),7,'0') AS UNQ_RECD_ID,
			FACT.PD_BASEL_SEG_NUM,
		CASE WHEN FACT.LGD_BASEL_SEG_NUM=-1 THEN NULL ELSE FACT.LGD_BASEL_SEG_NUM END AS LGD_BASEL_SEG_NUM,
		CASE WHEN FACT.EAD_BASEL_SEG_NUM=-1 THEN NULL ELSE FACT.EAD_BASEL_SEG_NUM END AS EAD_BASEL_SEG_NUM,
		CASE WHEN FACT.DEFAULT_F = 'T' THEN 'TRUE' ELSE 'FALSE' END AS DEFAULT_F,
		FACT.BEFR_ZERO_NET_ADJ_OS_BAL_AMT,
		FACT.AF_ZERO_NET_ADJUSTED_OS_BAL_AMT,
		(CAST(ROUND(FACT.EXPCTD_LOSS_RTO*100,6) AS DECIMAL(15,6)))||'%' AS EXPCTD_LOSS_RTO_TEXT,
		FACT.BEFORE_ZERO_NET_UNDRAWN_AMT,
		FACT.AF_ZERO_NET_UNDRAWN_AMT,
		FACT.BEFR_ZERO_NET_ALWBL_CR_LOSS_AMT,
		FACT.AF_ZERO_NET_ALWBL_CR_LOSS_AMT,
		(CAST(ROUND(FACT.LGD_FLRD_RPTG_RTO*100,6) AS DECIMAL(15,6)))||'%' AS LGD_FINAL_RPTG_RTO_TEXT,
		(CAST(ROUND(FACT.EAD_FLRD_RPTG_RTO*100,6) AS DECIMAL(15,6)))||'%' AS EAD_FINAL_RPTG_RTO_TEXT,
		'' AS EAD_PC,
		FACT.CRNCY_CD,
		FACT.PRTL_WRITE_OFF_AMT,
		FACT.UNCONDTNLY_CNCLBL,
		FACT.ACCR_INTR_AMT,
		FACT.INSUR_F,
		FACT.WGHTD_DLGD_RTO, FACT.LTV_PERCENTAGE, FACT.OBLIGORS,
		FACT.TRNST_NUM,FACT.PRD_ID,FACT.EGL_DEPRTMNT,/*adding for bcar_ccar combine file */
		FACT.RNTL_PRPTY_F, FACT.CURRENCY_MISMATCH_F, FACT.TOT_EXPSR_ABOVE_1500K_LMT_F, 
		FACT.ORIG_AMT_LOAN, FACT.TRANSACTOR_FLAG_QRR,
		CASE WHEN FACT.PD_90_DAY_F = 'T' THEN 'TRUE' ELSE 'FALSE' END AS PD_90_DAY_F,
		(CAST(ROUND(FACT.UNINSURED_FLRD_LGD_RTO*100,6) AS DECIMAL(15,6)))||'%' AS UNINSURED_FLRD_LGD_RTO,		
		FACT.UNINSURED_DLGD_RTO,
		FACT.CLP_FLAG,
		FACT.PERIOD_IND,
		FACT.ECL_Drawn_1,
		FACT.ECL_Drawn_2,
		FACT.ECL_Drawn_3,
		FACT.ECL_Undrawn_1,
		FACT.ECL_Undrawn_2,
		FACT.ECL_Undrawn_3,
		FACT.ECL_Drawn_PostSec_1,
		FACT.ECL_Drawn_PostSec_2,
		FACT.ECL_Drawn_PostSec_3,
		'' AS INSRT_PROCESS_TMSTMP,
		'' AS UPDT_PROCESS_TMSTMP,
		FACT.PMI,
		FACT.BASEL_ACCT_ID
/*hadi*/
FROM &net_db..BASEL_CCAR_EXPSR_FACT_ACAP FACT WHERE FACT.LEGAL_ENTITY = 'DOM-SUB-DUNDEE' and FACT.PERIOD_IND = 'CURR'
AND (FACT.BEFR_ZERO_NET_ADJ_OS_BAL_AMT <> 0 OR FACT.BEFORE_ZERO_NET_UNDRAWN_AMT <> 0) AND FACT.MTH_TM_ID=&MTH_TM_ID);
DISCONNECT FROM NZCON;
quit;

