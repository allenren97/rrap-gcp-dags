/*----------------------------------------------------------------------------
 * PART II:
 * Beginning the process of transforming the house_index_jan_2013_calc table
 * into the housing_index table used in the TNG model process.  Logic 
 * provided by Leon H.
 *----------------------------------------------------------------------------*/


data housing;
   set nz_frg.HOUSE_INDEX_JAN_2013_CALC;
   format month_end_dt date9.0;
   format month date9.0;
   tera_date2=catt('',tera_date1);
   yr_=substr(tera_date2,1,4)*1;
   mth=substr(tera_date2,5,2)*1;
   month=mdy(mth,1,yr_);
   month_end_dt=intnx('month', month, 0, 'end');
run;



data House_ON (keep= month month_end_dt region index);
   set housing; 
   format region $26.;
   index=ONT ;
   region='ON';
run;

data House_AB (keep= month month_end_dt region index);
   set housing; 
   format region $26.;
   index=AB ;
   region='AB';
run;

data House_BC (keep= month month_end_dt region index);
   set housing; 
   format region $26.;
   index=BC ;
   region='BC';
run;

data House_NS (keep= month month_end_dt region index);
   set housing; 
   format region $26.;
   index=NS ;
   region='NS';
run;

data House_QC (keep= month month_end_dt region index);
   set housing; 
   format region $26.;
   index=QC ;
   region='QC';
run;

data House_MB (keep= month month_end_dt region index);
   set housing; 
   format region $26.;
   index= MB;
   region='MB';
run;

data House_Composite_11 (keep= month month_end_dt region index);
   set housing; format region $26.;
   index= Composite_11;
   region='Composite_11';
run;

data House_Toronto_t (keep= month month_end_dt region index);
   set housing; 
   format region $26.;
   index= Toronto_t;
   region='Toronto_t';
run;

data House_Ottawa_t (keep= month month_end_dt region index);
   set housing; 
   format region $26.;
   index=Ottawa_t ;
   region='Ottawa_t';
run;

data House_Montreal_t (keep= month month_end_dt region index);
   set housing; 
   format region $26.;
   index=Montreal_t ;
   region='Montreal_t';
run;

data House_Quebec_t (keep= month month_end_dt region index);
   set housing; 
   format region $26.;
   index= Quebec_t;
   region='Quebec_t';
run;

data House_Halifax_t (keep= month month_end_dt region index);
   set housing; 
   format region $26.;
   index=Halifax_t ;
   region='Halifax_t';
run;


data House_Victoria_t (keep= month month_end_dt region index);
   set housing; 
   format region $26.;
   index= Victoria_t;
   region='Victoria_t';
run;

data House_Vancouver_t (keep= month month_end_dt region index);
   set housing; 
   format region $26.;
   index= Vancouver_t;
   region='Vancouver_t';
run;

data House_Calgary_t (keep= month month_end_dt region index);
   set housing; 
   format region $26.;
   index= Calgary_t;
   region='Calgary_t';
run;

data House_Edmonton_t (keep= month month_end_dt region index);
   set housing; 
   format region $26.;
   index= Edmonton_t;
   region='Edmonton_t';
run;

data House_Hamilton_t (keep= month month_end_dt region index);
   set housing; 
   format region $26.;
   index= Hamilton_t;
   region='Hamilton_t';
run;

data House_Winnipeg_t (keep= month month_end_dt region index);
   set housing; 
   format region $26.;
   index= Winnipeg_t;
   region='Winnipeg_t';
run;

data source.housing_index;
   set House_Toronto_t
       House_Ottawa_t
       House_Montreal_t
       House_Quebec_t
       House_Halifax_t
       House_AB
       House_BC
       House_ON
       House_NS
       House_QC
       House_MB
       House_Composite_11
       House_Victoria_t
       House_Vancouver_t
       House_Calgary_t
       House_Edmonton_t
       House_Hamilton_t
       House_Winnipeg_t;
run;

