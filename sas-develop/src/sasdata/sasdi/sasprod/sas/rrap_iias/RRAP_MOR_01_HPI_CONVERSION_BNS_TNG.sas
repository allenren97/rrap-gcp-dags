data work.temp123;
   set nzrrap.teranet_house_prc_index ;
 
   if upcase(label_1) = 'COMPOSITE' then mapped_var = cats(label_1, '_', label_2);
   else if upcase(label_2) = 'OTTAWA_GATINEAU' then mapped_var = 'Ottawa_t';
   else mapped_var = cats(propcase(label_2), '_t');
 
run;

data work.drop;
   set work.temp123;
   if label_1='ON' and label_2='OTTAWA_GATINEAU' then delete;
run;

proc sql;
   create table work.city_index as
      select *
      from work.drop
      order by mth_tm_id;
quit;



proc transpose data=work.city_index out=work.city_index_trans;
   id mapped_var;
   var index;
   by mth_tm_id;
run;

proc sql noprint;
   create table work.city_index2 (drop=_name_ _label_) as
   select a.*,
          b.tm_lvl_end_dt as month_end_dt,
          cats(put(b.tm_lvl_end_dt, yymms.)) as  date2
   from work.city_index_trans as a
        left join
        nzuser.tm_dim as b
        on (a.mth_tm_id = b.tm_id)
   where month_end_dt >= '30NOV2013'd
   order by mth_tm_id
 ;
quit;


proc sql noprint;
   create table work.province_data as
   select a.mth_tm_id,
          a.prov_cd,
          a.house_index_rto,
          cats(put(b.tm_lvl_end_dt, eurdfmy5.)) as tera_date length=5,
          input(put(b.tm_lvl_end_dt,yymmn.),best28.)  as tera_date1,
          cats(put(b.tm_lvl_end_dt, eurdfmy5.)) as statcan_date length=5,
          cats(put(b.tm_lvl_end_dt, yymms.)) as date length=7
   from nzrrap.provncl_house_index_sum as a
        left join
        nzuser.tm_dim as b
        on (a.mth_tm_id = b.tm_id)
   where b.tm_lvl_end_dt GE '30-NOV-2013'd
   order by mth_tm_id;
quit;
 
 
proc transpose data=work.province_data out=work.province_data1 (drop = _name_ _label_);
   by mth_tm_id tera_date tera_date1 statcan_date date;
   id prov_cd;
run;
 

proc sql;
   create table results.house_index (drop= date2 month_end_dt mth_tm_id) as
   select a.*,
          b.bc,
          b.mb,
          b.qc,
          b.on as ont,
          b.co,
          b.ns,
          b.ab,
          b.tera_date,
          b.tera_date1,
          b.date,
          b.statcan_date,
          . as composite_11_calc
      from work.city_index2 as a,
           work.province_data1 as b
      where a.date2=b.date;
quit;

/*----------------------------------------------------------------
 * Deleting the previous month data from the table because 
 * the current data is actually a copy of the data from 2 months
 * ago.  
 *
 * Inserting the new previous months data.
 *----------------------------------------------------------------*/

proc sql noprint;
   connect using nzuser as nzcon;
  execute ( 
      delete from frg_user_data.house_index_jan_2013_calc
      where date=%nrbquote('&prev_month_date');
     ) by nzcon;
   disconnect from nzcon; 
quit;

proc sql;
   insert into nzuser.house_index_jan_2013_calc 
      select a.ont,
             a.date, 
             a.statcan_date, 
             a.composite_6,
             a.composite_11, 
             a.victoria_t, 
             a.vancouver_t, 
             a.calgary_t, 
             a.edmonton_t, 
             a.winnipeg_t, 
             a.hamilton_t, 
             a.toronto_t, 
             a.ottawa_t,
             a.montreal_t, 
             a.quebec_t, 
             a.halifax_t, 
             a.ab, 
             a.bc,  
             a.ns,  
             a.qc, 
             a.mb, 
             a.tera_date,
             a.tera_date1,
             a.composite_11_calc
      from results.house_index as a
      where trim(a.date)="&prev_month_date";
quit;


/*--------------------------------------------------------
 * Taking the previous months data and renaming it to the 
 * current months run.
 *--------------------------------------------------------*/

proc sql noprint;
   create table work.prev_month as
   select a.*
   from results.house_index as a
   where date="&prev_month_date";
quit;

data work.curr_month;
   set work.prev_month;
   date="&current_month";
   statcan_date="&curr_month_stat_can";
   tera_date="&curr_month_tera_date";
   tera_date1=&curr_month_tera_date1;
run;

proc sql noprint;
   connect using nzuser as nzcon;
   execute (
      delete from frg_user_data.house_index_jan_2013_calc
      where date=%nrbquote('&current_month')
      ) by nzcon;
   disconnect from nzcon;
quit;

proc print data=results.house_index; where date in ("&current_month","&prev_month_date" ); run;

proc sql;
   insert into nzuser.house_index_jan_2013_calc 
      select a.ont,
             a.date, 
             a.statcan_date, 
             a.composite_6,
             a.composite_11, 
             a.victoria_t, 
             a.vancouver_t, 
             a.calgary_t, 
             a.edmonton_t, 
             a.winnipeg_t, 
             a.hamilton_t, 
             a.toronto_t, 
             a.ottawa_t,
             a.montreal_t, 
             a.quebec_t, 
             a.halifax_t, 
             a.ab, 
             a.bc,  
             a.ns,  
             a.qc, 
             a.mb, 
             a.tera_date,
             a.tera_date1,
             a.composite_11_calc
      from work.curr_month as a
      where a.date="&current_month";
quit;

