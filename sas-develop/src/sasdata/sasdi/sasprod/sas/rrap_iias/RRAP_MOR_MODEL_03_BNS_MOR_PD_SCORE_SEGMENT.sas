SELECT INTNX('MONTH',MAX(PROCESS_DATE),-12,'E') INTO :DEL_TIME_KEY FROM RESULTS.SCORED_SEGMENTED_ACCTS ; /*WHERE PROCESS_DATE = '31MAY2019'D */
QUIT;

DATA NZFORMATS;
FORMAT NZSRC NZTGT YYMMDD10.;
NZFORMAT="'"||"&TIME_KEY_12MTH"||"'";
CALL SYMPUT('PRIOR12MTH',NZFORMAT);
NZSRC=&SRC_TIME_KEY;
NZTGT=&TGT_TIME_KEY;
CALL SYMPUT('SRC_TIME_NZ',"'"||PUT(&SRC_TIME_KEY,YYMMDD10.)||"'");
CALL SYMPUT('TGT_TIME_NZ',"'"||PUT(&TGT_TIME_KEY,YYMMDD10.)||"'");
RUN;

%PUT SRC_TIME_KEY=&SRC_TIME_KEY;
%PUT TGT_TIME_KEY=&TGT_TIME_KEY;
%PUT TIME_KEY_12MTH=&TIME_KEY_12MTH;
%PUT DEL_TIME_KEY=&DEL_TIME_KEY;
%PUT PRIOR12MTH=&PRIOR12MTH;
%PUT SRC_TIME_NZ=&SRC_TIME_NZ;
%PUT TGT_TIME_NZ=&TGT_TIME_NZ;

%MEND ANTQ_FETCH_DATES;


%MACRO CR69_HIST_MAINTAIN;

%GLOBAL PRIOR12MTH;
%GLOBAL SRC_TIME_NZ;
%GLOBAL TGT_TIME_NZ;
%GLOBAL TGT_TIME_KEY;
%GLOBAL SRC_TIME_KEY;
%GLOBAL TIME_KEY_12MTH;
%GLOBAL DEL_TIME_KEY;

%ANTQ_FETCH_DATES;

/*SCORED_SEGMENTED_ACCTS TABLE STEPS START*/

/*BRING ONLY 13 MONTHS OF SAS DATA TO NZ TEMP TABLE - DROP THIS TABLE AFTER USING IT*/

%delete_table(NZUSER.SCORED_SEGMENTED_ACCTS_TMP);

DATA NZUSER.SCORED_SEGMENTED_ACCTS_TMP (Bulkload=YES BL_METHOD=CLILOAD);
     SET RESULTS.SCORED_SEGMENTED_ACCTS;
     WHERE PROCESS_DATE>=&DEL_TIME_KEY; 
RUN;

/* Sudhir --> May2019 test run:

SCORED_SEGMENTED_ACCTS_TMP --> last 12 months data (may2018-may2019)

a. delete from SCORED_SEGMENTED_ACCTS ( before may2018)
b. update from SCORED_SEGMENTED_ACCTS_TMP  to SCORED_SEGMENTED_ACCTS 
   (from may2018-may2019)
c. delete from SCORED_SEGMENTED_ACCTS = may2019
d. Insert may 2019 into SCORED_SEGMENTED_ACCTS (may2018 to apr2019 updated and new may2019) 

update SCORED_SEGMENTED_ACCTS_ANTQ (from may2018 to apr2019) from SCORED_SEGMENTED_ACCTS 
if new month data then insert new month data to SCORED_SEGMENTED_ACCTS_ANTQ from SCORED_SEGMENTED_ACCTS */


/*ACCT TABLE NEEDS TO MAINTAIN 13 MONTHS INSTEAD OF FULL VOLUME*/
/*LOGIC FOR GENERATION OF THIS TABLE HASNT BEEN MODIFIED YET TO GENERATE ONLY 13 MONTHS BECAUSE DOWNSTREAM MIGHT BE AFFECTED.*/
/*UNTIL A REQUIREMENT FOR DOWNSTREAM IS RECEIVED THE SOURCE TABLES WILL CONTINUE TO HAEV FULL VOLUME*/

/*DELETE OLDEST MONTH - 13TH MONTH FROM ACCT TABLE */

PROC SQL NOPRINT;
CONNECT USING NZUSER AS NZCON;
EXECUTE(DELETE FROM &target_lib3..SCORED_SEGMENTED_ACCTS WHERE PROCESS_DATE<&PRIOR12MTH) BY NZCON;
DISCONNECT FROM NZCON;
QUIT;

/*UPDATE THE 12 MONTHS*/

PROC SQL NOPRINT;
CONNECT USING NZUSER AS NZCON;
EXECUTE (UPDATE &target_lib3..SCORED_SEGMENTED_ACCTS A
SET DEFAULT_DATE=B.DEFAULT_DATE, DEFAULT_BAL=B.DEFAULT_BAL, DEFAULT_IND=B.DEFAULT_IND
FROM &target_lib3..SCORED_SEGMENTED_ACCTS_TMP B
WHERE
A.MORTGAGE_NO = B.MORTGAGE_NO AND 
A.PROCESS_DATE = B.PROCESS_DATE AND
A.PROCESS_DATE>=&PRIOR12MTH ) BY NZCON;
DISCONNECT FROM NZCON;
QUIT;

/*INCASE OF RERUN - DELETE THE NEWEST MONTH - CURRENT MONTH*/
PROC SQL NOPRINT;
CONNECT USING NZUSER AS NZCON;
EXECUTE(DELETE FROM &target_lib3..SCORED_SEGMENTED_ACCTS WHERE PROCESS_DATE>=&SRC_TIME_NZ) BY NZCON;
DISCONNECT FROM NZCON;
QUIT;

/*INSERT THE NEWEST MONTH - CURRENT MONTH*/
PROC SQL NOPRINT;
CONNECT USING NZUSER AS NZCON;
EXECUTE(INSERT INTO &target_lib3..SCORED_SEGMENTED_ACCTS SELECT * FROM &target_lib3..SCORED_SEGMENTED_ACCTS_TMP WHERE PROCESS_DATE>=&SRC_TIME_NZ) BY NZCON;
DISCONNECT FROM NZCON;
QUIT;

%delete_table(NZUSER.SCORED_SEGMENTED_ACCTS_TMP);

/*SCORED_SEGMENTED_ACCTS TABLE STEPS END*/

