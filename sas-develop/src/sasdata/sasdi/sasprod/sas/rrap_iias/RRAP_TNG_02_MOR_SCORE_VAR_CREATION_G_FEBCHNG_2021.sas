/*NOTE: housing price data must be pulled from teranet and then joined to the data. */


options compress= yes;
proc sql noprint;
   create table work.temp5_2 as
      select a.*,
             b.index as monthly_HPI 
         from work.temp5 as a 
              left join  &_housing_input_tbl as b
         on a.month_end_dt=b.month_end_dt and a.teranet_region=b.region;
quit;

%delwrk(tbl=temp5);

proc sql noprint ;
   create table work.temp5_3 as
      select a.*,
             b.index as Appraisal_HPI
         from temp5_2 as a 
              left join  &_housing_input_tbl as b
         on a.prop_val_date=b.month_end_dt and a.teranet_region=b.region;
quit;

%delwrk(tbl=temp5_2);

/* setting index for earliest time point if index unavailable*/

data temp5_4;
   set temp5_3;
   if  teranet_region='Victoria_t' and (Appraisal_HPI=0 or Appraisal_HPI=.) then Appraisal_HPI_2=45.97;
      else if  teranet_region='Vancouver_t' and (Appraisal_HPI=0 or Appraisal_HPI=.) then Appraisal_HPI_2=55.36;
