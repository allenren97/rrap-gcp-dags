/* Run the following join to filter out records which were needed for lookback
   calculations but not intended to be loaded.  Data that was not in both the 
   relationship table and the Deli file are most likely to removed from this 
   step.  The goal is to match record counts that are found in the 
*/

%delete_table(nzuser.SCRD_VAR_STATS_SPL_CUST_FILTERED);

/*options sastrace=',,,d' sastraceloc=saslog;*/

 
proc sql noprint ;
connect using nzuser as nzcon;
execute(

        create table &FRG_DB..SCRD_VAR_STATS_SPL_CUST_FILTERED as (
        select  r.*
          
        from ( select * from &RRAP_DB..BASEL_PSNL_LOAN_CUST_DRVD_VARS
               where mth_tm_id between &start_period_tm_key and &end_period_tm_key) as b
		  inner join
             &FRG_DB..SCRD_VAR_STATS_SPL_CUST as r
        on b.basel_cust_id=r.basel_cust_id and
           b.mth_tm_id=r.mth_tm_id
		    
		  order by b.mth_tm_id ) WITH DATA;
 
        ) by nzcon;
quit;

