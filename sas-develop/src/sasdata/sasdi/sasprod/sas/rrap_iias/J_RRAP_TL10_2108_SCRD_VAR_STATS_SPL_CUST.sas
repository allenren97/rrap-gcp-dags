         %macro create_var_stat(table_name,id,time_key);
         
            data _null_;
               starttime1 = datetime();
               call symputx('starttime1', starttime1, 'g');
            run;
         
            options validvarname=any;
         
            proc sort data=&table_name;
               by &id. &time_key.;
            run;
         
            proc contents data=&table_name 
               out=col_list(where=(type=1 and format not in ('DATE' 'DATETIME')) keep=NAME TYPE FORMAT) noprint;
            run;
         
            data col_list;
               set col_list(where=(lowcase(name) not in ("&time_key." "&id.")));
               name2=compress(name,'_');
               if length(name2)<=30 then do;
                  output;
               end;
            run;
         
            proc sql noprint;
         
               select count(name) into :nvar trimmed
               from col_list;
         
            quit;
         
            %put number of variables = &nvar;
         
            %if %eval(&nvar < 1) %then
            %do;
               data &table_name._stat;
                  set &table_name.;
               run;
         
               %goto out;
            %end;
            %else %do;
               proc sql noprint;
         
                  select name into :keep_list separated by ' '
                  from col_list;
         
                  select name into :var1 - :var&nvar
                  from col_list;
         
               quit;
         
               proc transpose data=&table_name out=work.tdata(rename=(_name_=name col1=value));
                  by &id. &time_key.;
                  var &keep_list;
               run; 
         
               
               proc sort data=work.tdata;
                  by &id. name &time_key.;
               run;
         
               %let maxlag = 23;
               
               data tdata2(keep=&id. name &time_key.
                                    valavg3 valavg6 valavg24
                                    min3 min6 min24
                                    max3 max6 max12 max24
                                    valsum3 valsum6 valsum24
         	                        slp3 slp6
                                    valavg6_orig
                                    );
                  set work.tdata;
                  by &id. name &time_key.;
                  retain mcounter;
                  if first.name then mcounter = 1;
                  else mcounter + 1; 
                  vmm1 = value;
                  %do ii = 1 %to &maxlag;
                     %let jj = %eval(&ii. + 1); 
                     lagval&ii. = lag&ii.(value);
                     if mcounter >= &jj then 
                     vmm&jj. = lagval&ii.;
                     else vmm&jj. = .;   
                  %end;
         
                  valsum3 = sum(of vmm1-vmm3);
                  min3 = min(of vmm1-vmm3);
                  max3 = max(of vmm1-vmm3);
                  /* Customer fields need to convert null values to 0 so that the mean function divides by the correct value */
                  /* Original code:  valavg3 = mean(of vmm1-vmm3); */
         		   /* If there is a non-null in the 3 month period, use the coalesce function to ensure the mean function 
         		      considers all three values in the denominator of the calculation.  This function ignores null values */
                  if max3=. then
         		      valavg3=.;
         		   else 
                     valavg3 = mean(coalesce(vmm1,0), coalesce(vmm2,0), coalesce(vmm3,0));
                 
                  valsum6 = sum(of vmm1-vmm6);
         		   min6 = min(of vmm1-vmm6);
                  max6 = max(of vmm1-vmm6);
                  /* Customer fields need to convert null values to 0 so that the mean function divides by the correct value */
                  /* Original code: valavg6 = mean(of vmm1-vmm6);*/   
                  /* If there is a non-null in the 6 month period, use the coalesce function to ensure the mean function 
         		      considers all three values in the denominator of the calculation.  This function ignores null values */ 
         		   if max6=. then
         		      valavg6=.;
         	      else
                     valavg6 = mean(coalesce(vmm1,0), coalesce(vmm2,0), coalesce(vmm3,0), coalesce(vmm4,0),coalesce(vmm5,0), coalesce(vmm6,0));
         
				
                  /* 06Jul2015
                     CR41 - AT34avg6M now requries that averages ignore null values.  Therefore - calculating an average without coalesce. 
                     Coding for all time periods for consistency.  This value is used for AT34 downstream.  */
                  valavg6_orig = mean(of vmm1-vmm6);
          			
         
                  valsum12 = sum(of vmm1-vmm12);
         		   min12 = min(of vmm1-vmm12);
                  max12 = max(of vmm1-vmm12);
         		   /* Customer fields need to convert null values to 0 so that the mean function divides by the correct value */
                  /* Original code: valavg12 = mean(of vmm1-vmm12); */
         		   /* If there is a non-null in the 12 month period, use the coalesce function to ensure the mean function 
         		      considers all three values in the denominator of the calculation.  This function ignores null values */ 
                  if max12=. then
         		      valavg12=.;
                  else
                     valavg12 = mean(coalesce(vmm1,0), coalesce(vmm2,0), coalesce(vmm3,0), coalesce(vmm4,0),coalesce(vmm5,0), coalesce(vmm6,0), 
                                     coalesce(vmm7,0), coalesce(vmm8,0), coalesce(vmm9,0), coalesce(vmm10,0),coalesce(vmm11,0), coalesce(vmm12,0));
       
                  
                  
                    
                  valsum24 = sum(of vmm1-vmm24);
				  
         		   min24 = min(of vmm1-vmm24);
                  max24 = max(of vmm1-vmm24);
         		   /* Customer fields need to convert null values to 0 so that the mean function divides by the correct value */
                  /* valavg24 = mean(of vmm1-vmm24); */
         		   /* If there is a non-null in the 24 month period, use the coalesce function to ensure the mean function 
         		      considers all three values in the denominator of the calculation.  This function ignores null values */ 
                  if max24=. then
         		      valavg24=.;
                  else
                     valavg24 = mean(coalesce(vmm1,0), coalesce(vmm2,0), coalesce(vmm3,0), coalesce(vmm4,0),coalesce(vmm5,0), coalesce(vmm6,0), 
                                  coalesce(vmm7,0), coalesce(vmm8,0), coalesce(vmm9,0), coalesce(vmm10,0),coalesce(vmm11,0), coalesce(vmm12,0),
                                  coalesce(vmm13,0), coalesce(vmm14,0), coalesce(vmm15,0), coalesce(vmm16,0),coalesce(vmm17,0), coalesce(vmm18,0),
                                  coalesce(vmm19,0), coalesce(vmm20,0), coalesce(vmm21,0), coalesce(vmm22,0),coalesce(vmm23,0), coalesce(vmm24,0));
         
                        
         
                  
                  if mcounter = 1 then
                  do;
                     chg1 = .;
                     chg3 = .;
                     chg6 = .;
                     slp1 = .;
                     slp3 = .;
                     slp6 = .;
                  end;
                  else if mcounter < 3 then
                  do;
                     if vmm2 ne 0 then chg1 = (vmm1 - vmm2)/vmm2;
                     if vmm2 ne 0 then chg3 = (vmm1 - vmm2)/vmm2;
                     if vmm2 ne 0 then chg6 = (vmm1 - vmm2)/vmm2;
                     slp1 = (vmm1 - vmm2);
                     slp3 = (vmm1 - vmm2)/(mcounter-1);
                     slp6 = (vmm1 - vmm2)/(mcounter-1);
                  end;    
                  else if mcounter < 6 then
                  do;
                     if vmm2 ne 0 then chg1 = (vmm1 - vmm2)/vmm2;
                     if vmm3 ne 0 then chg3 = (vmm1 - vmm3)/vmm3;
                     %do kk = 3 %to 5;
                        if mcounter = &kk and vmm&kk. ne 0 then chg6 = (vmm1 - vmm&kk.)/vmm&kk.;
                        if mcounter = &kk then slp6 = (vmm1 - vmm&kk.)/(mcounter-1);
                     %end;
                     slp1 = (vmm1 - vmm2);
                     slp3 = (vmm1 - vmm3)/ 2;
                  end;
                  else
                  do;
                     if vmm2 ne 0 then chg1 = (vmm1 - vmm2)/vmm2;
                     if vmm3 ne 0 then chg3 = (vmm1 - vmm3)/vmm3;
                     if vmm6 ne 0 then chg6 = (vmm1 - vmm6)/vmm6;
                     slp1 = (vmm1 - vmm2);
                     slp3 = (vmm1 - vmm3)/ 2;
                     slp6 = (vmm1 - vmm6)/ 5;
                  end; 
               run;
            %end;
         
         	proc sql;
         	drop table tdata;
         	quit;
         	
         
            /* JD - May 30, 2015
            Adding where= to discard lookback data that is no longer needed 
