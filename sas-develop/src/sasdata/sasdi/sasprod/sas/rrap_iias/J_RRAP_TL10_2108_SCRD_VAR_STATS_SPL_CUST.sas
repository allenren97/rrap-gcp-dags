                  %end; 
               %end; 
               %else 
                  %put %sysfunc(sysmsg()); 
            %end; 
         %end; 
         %let rc = %sysfunc(close(&etls_dsid)); 
      %end; 
   %end; 
%mend etls_loopRCCheck; 

