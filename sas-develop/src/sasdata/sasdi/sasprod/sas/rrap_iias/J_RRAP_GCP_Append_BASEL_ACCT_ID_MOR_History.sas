A.CRNT_BAL_AMT,A.INTR_ACCR_AMT,A.TOTAL_BAL,A.PD_OFF_F,A.PD_OFF_DT,A.FRCLSR_F,
A.TOT_SUSP_BAL_AMT,A.STATUS1,A.DEFAULT_DATE,A.DEFAULT_BAL,A.DEFAULT_IND,A.LTV,
