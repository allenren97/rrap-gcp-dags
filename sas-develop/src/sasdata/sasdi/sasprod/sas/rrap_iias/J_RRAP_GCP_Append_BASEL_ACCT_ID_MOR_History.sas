%RRAP_MOR_TNG_AUTOEXEC();

%RRAP_MOR_TNG_AUTOEXEC();

 %get_model_period_dates(product=mor);

/*   %let start_period_dt=31OCT2016;*/

      data _null_;
           set nzrrap.tm_dim;
           where tm_lvl_end_dt = "&start_period_dt"d and tm_lvl='Month';
           call symputx('mth_tm_id',put(tm_id,5.));
           call symputx('mth_end_dt',put(tm_lvl_end_dt,date9.));
           call symputx('mth_end_dt_nz',put(tm_lvl_end_dt,yymmdd10.));
           call symputx('yrmth',put(tm_lvl_end_dt,yymmn6.));
           call symputx('yrmth_prev',put(intnx('Month',tm_lvl_end_dt,-1,'e'),yymmn6.));
     run;

*################ TABLE1:		AIRB_MORT_MTH_SNAPSHOT_LGD		###########################*;
%macro automate_36;
%do MTH_TM_ID=6158 %to 19996 %by 40; 
%put &MTH_TM_ID start load;

proc sql;
connect using nz_frg as iiascon;
execute(delete from &FRG_DB..AIRB_MORT_MTH_SNAPSHOT_LGD where tm_id = &mth_tm_id.;) by iiascon;
execute(commit;) by iiascon;
quit;


proc sql;
connect using nz_frg as iiascon;
execute(INSERT into &FRG_DB..AIRB_MORT_MTH_SNAPSHOT_LGD 
(TM_ID,MTH_END_DT,BASEL_ACCT_ID,MORT_NUM,AMORT,OP_FIELD,LEND_VALUE,
PROPERTY_ADDR_1,PROPERTY_ADDR_2,PROPERTY_ADDR_3,PROP_PROV,PREPAY_YTD,
AUTH_AMT,CAB,DLQNT_MTH,EFF_TMSTMP,FLOAT_IND,INEREST_ACCR_AMT,
INTR_ADJ_DT,MADE_DT,MAT_DT,PD_OFF_F,PRIM_CUST_ID,STEP_F,
TOT_ADVNC_AMT,TRNST,UNPAID_MTH_PAY_DT,UNPAID_WKLY_PAY_DT,CLASS,
FUND_CD,SECURITY_TYPE,CRNT_BAL,FRCLSR_F,PD_OFF_DT,TOT_SUSP_BAL,
TNIF_RGN_CD,COMM_TP,INSUR_GRP,LRA_STAT,DLQNT_DAY,GL_ACCT_NUM,
GL_TRNST_NUM,PRD_GRP_CD,UNIT_CNT,CRNCY_CD,INSRT_PROCESS_TMSTMP
,IBMREPL_SITE,IBMREPL_KEY) 
(SELECT 
A.TM_ID,A.MTH_END_DT,B.BASEL_ACCT_ID,A.MORT_NUM,A.AMORT,A.OP_FIELD,A.LEND_VALUE,
A.PROPERTY_ADDR_1,A.PROPERTY_ADDR_2,A.PROPERTY_ADDR_3,A.PROP_PROV,A.PREPAY_YTD,
A.AUTH_AMT,A.CAB,A.DLQNT_MTH,A.EFF_TMSTMP,A.FLOAT_IND,A.INEREST_ACCR_AMT,
A.INTR_ADJ_DT,A.MADE_DT,A.MAT_DT,A.PD_OFF_F,A.PRIM_CUST_ID,A.STEP_F,
A.TOT_ADVNC_AMT,A.TRNST,A.UNPAID_MTH_PAY_DT,A.UNPAID_WKLY_PAY_DT,A.CLASS,
A.FUND_CD,A.SECURITY_TYPE,A.CRNT_BAL,A.FRCLSR_F,A.PD_OFF_DT,A.TOT_SUSP_BAL,
A.TNIF_RGN_CD,A.COMM_TP,A.INSUR_GRP,A.LRA_STAT,A.DLQNT_DAY,A.GL_ACCT_NUM,
A.GL_TRNST_NUM,A.PRD_GRP_CD,A.UNIT_CNT,A.CRNCY_CD,A.INSRT_PROCESS_TMSTMP
,A.IBMREPL_SITE,A.IBMREPL_KEY
from &FRG_DB..AIRB_MORT_MTH_SNAPSHOT  A
LEFT JOIN
(SELECT ACCT_NUM, MAX(BASEL_ACCT_ID) AS BASEL_ACCT_ID FROM &RRAP_DB..BASEL_ACCT_DIM
WHERE
TRIM(SRC_APP_CD) = 'MO'
GROUP BY ACCT_NUM) B ON A.MORT_NUM = TRIM(B.acct_NUM) 
WHERE A.TM_ID =&mth_tm_id.);) by iiascon;
execute(CALL SYSPROC.ADMIN_CMD (%nrbquote('RUNSTATS ON TABLE &FRG_DB..AIRB_MORT_MTH_SNAPSHOT_LGD on KEY COLUMNS and INDEXES ALL'));) by iiascon;
execute(COMMIT;) by iiascon;
quit;




*################ TABLE2:		BNSMORT_ACCT_LVL_DATA_LGD		###########################*;

proc sql;
