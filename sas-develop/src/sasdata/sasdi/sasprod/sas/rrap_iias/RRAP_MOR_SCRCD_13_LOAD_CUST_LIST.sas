            from  &target_lib3..SCORECARD_VARS_MOR3  ) WITH DATA ) by nzcon;
		*execute (generate statistics on &target_lib3..SCORECARD_VARS_MOR3_CUST) by nzcon;
		execute(CALL SYSPROC.ADMIN_CMD (%nrbquote('RUNSTATS
				ON TABLE ) %nrbquote(&target_lib3..SCORECARD_VARS_MOR3_CUST)
					%nrbquote(ON KEY COLUMNS and INDEXES ALL'))) by nzcon; 
 
	execute (
		create
 			table &target_lib3..SCORECARD_VARS_CUST_LIST_TMP as (
		select
   			mortgage_no,
   			time_key,
			   cis_tm_id,
   			cid,
