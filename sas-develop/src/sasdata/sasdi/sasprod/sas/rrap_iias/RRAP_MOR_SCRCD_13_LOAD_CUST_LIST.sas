proc sql;
	connect USING NZUSER as nzcon ;
	
   execute ( create table &target_lib3..SCORECARD_VARS_MOR3_CUST as (
             select 
       		mortgage_no,
       		time_key,
            cis_tm_id,
       coalesce(cid, cid_last) as cid, 
       coalesce(cust_base_key, cust_base_key_last) as cust_base_key
       /*max(cid) over (partition by mortgage_no order by mortgage_no, time_key RANGE BETWEEN
           UNBOUNDED PRECEDING AND UNBOUNDED FOLLOWING) as cid,*/
	  /*max(cust_base_key) over (partition by mortgage_no order by mortgage_no, time_key RANGE BETWEEN
