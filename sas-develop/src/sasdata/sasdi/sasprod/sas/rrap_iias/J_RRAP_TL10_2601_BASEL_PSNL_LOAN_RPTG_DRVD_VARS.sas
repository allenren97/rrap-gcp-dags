               %put %sysfunc(sysmsg()); 
            %else 
            %do; 
               %let rc = %sysfunc(fetchobs(&etls_dsid, &row)); 
               %if (&rc ne 0) %then 
                  %put %sysfunc(sysmsg()); 
               %else 
               %do; 
                  %let etls_varnum = %sysfunc(varnum(&etls_dsid,&handleVariable)); 
                  %if (&etls_varnum > 0) %then 
                     %sysfunc(getvarc(&etls_dsid,&etls_varnum)); 
                  %else 
                     %put %sysfunc(sysmsg()); 
               %end; 
               %let rc = %sysfunc(close(&etls_dsid)); 
            %end; 
