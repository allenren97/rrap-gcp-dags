%let AIRB_MORT_PIT_STATUS=
select 
		 cast(A.MORT_NUM as bigint) as MORT_NUM
		,cast(A.MTH_END_DT as date) as MTH_END_DT
		,cast('A' as varchar(1)) as CONSM_PRD_TREATMNT_CD
		,cast('N' as varchar(1)) as SML_BUS_F
		,cast('N' as varchar(1)) as TRNST_EXCLSN_F
		,cast(B.STATUS1 as varchar(3)) as PIT_STAT_CD

		from &FRG_DB..AIRB_MORT_MTH_SNAPSHOT A
		LEFT JOIN &FRG_DB..SCORED_SEGMENTED_ACCTS B
		ON A.MORT_NUM = B.MORTGAGE_NO AND A.MTH_END_DT = B.PROCESS_DATE
		where tm_id=&mth_tm_id.	
;

%put AIRB_MORT_PIT_STATUS=&AIRB_MORT_PIT_STATUS.;

proc sql;			
connect using nzuser as nzcon;	
create table WORK.BASEL_MORT_INSTRMNT_ADJ_TEMP as 
select * from connection to nzcon(	

WITH 
AIRB_MORT_PIT_STATUS as (&AIRB_MORT_PIT_STATUS.),
TOTAL_BY_GL as 
		(
		select 
			 a.gl_acct_num
			,a.gl_trnst_num
			,a.mth_end_dt
			,a.crncy_cd
			,a.AIRB_Adj_Coa_Amt as Adj_Amt
					  ,sum(Case when c.pit_stat_cd = 'CUR' then abs(b.CRNT_BAL) else 0 end) as GL_CRNT_BAL_SUM_CUR
					  ,sum(Case when c.pit_stat_cd = 'DEF' then abs(b.CRNT_BAL) else 0 end) as GL_CRNT_BAL_SUM_DEF
					  ,sum(abs(b.CRNT_BAL)) as GL_CRNT_BAL_SUM_ALL
		from 
			&RRAP_DB..AIRB_RECON_APRVD_SNAPSHOT a,
			&FRG_DB..AIRB_MORT_MTH_SNAPSHOT b,
			AIRB_MORT_PIT_STATUS c 
		WHERE 
			a.gl_acct_num=b.gl_acct_num
		and a.gl_trnst_num=b.gl_trnst_num
		and a.mth_end_dt=b.mth_end_dt
		and a.src_sys_cd = 'MO'
		and a.crncy_cd = b.crncy_cd
		and b.MORT_NUM = c.mort_num and b.MTH_END_DT = c.mth_end_dt
		and c.consm_prd_treatmnt_cd = 'A' and c.pit_stat_cd in ('CUR', 'DEF') and c.sml_bus_f = 'N' and trnst_exclsn_f = 'N'
		and b.crncy_cd = 'CAD' 
		and a.src_sys_cd = 'MO'
		and b.GL_TRNST_NUM is not null
		and a.mth_end_dt=%nrbquote('&nz_rundate.')

		group by a.gl_acct_num, a.gl_trnst_num,a.mth_end_dt,a.crncy_cd, a.AIRB_Adj_Coa_Amt
		)
select 
	 b.tm_id as mth_tm_id 
	,basel_acct_id 
	,cast(b.mort_num as character varying(7)) as mort_num  
	,a.gl_acct_num
	,a.gl_trnst_num
	,b.crnt_bal as OS_BAL_AMT 
	,'Adjustments' as AUTO_GENRTD_CMNT
		  ,case 
				when c.pit_stat_cd = 'DEF' and a.GL_CRNT_BAL_SUM_ALL = a.GL_CRNT_BAL_SUM_DEF and a.GL_CRNT_BAL_SUM_CUR = 0 then round((abs(b.crnt_bal)/a.GL_CRNT_BAL_SUM_DEF),6)*a.Adj_Amt
				when c.pit_stat_cd = 'DEF' and a.GL_CRNT_BAL_SUM_ALL <> a.GL_CRNT_BAL_SUM_DEF then 0
		   Else round((abs(b.crnt_bal)/a.GL_CRNT_BAL_SUM_CUR),6)*a.Adj_Amt
		  end as GENL_LEDGER_BAL_ADJ_AMT
	/*,GENL_LEDGER_BAL_ADJ_AMT + OS_BAL_AMT as AF_ADJ_OS_BAL_AMT */
	,now() as INSRT_PROCESS_TMSTMP
	,now() as UPDT_PROCESS_TMSTMP

from 
	TOTAL_by_GL a,
	&FRG_DB..AIRB_MORT_MTH_SNAPSHOT b,
	AIRB_MORT_PIT_STATUS c,
	&RRAP_DB..BASEL_ACCT_DIM d
WHERE 
	a.gl_acct_num=b.gl_acct_num
and a.gl_trnst_num=b.gl_trnst_num
and a.mth_end_dt=b.mth_end_dt
and a.crncy_cd = b.crncy_cd
and b.MORT_NUM = c.mort_num and b.MTH_END_DT = c.mth_end_dt
and c.consm_prd_treatmnt_cd = 'A' and c.pit_stat_cd in ('CUR', 'DEF') and c.sml_bus_f = 'N' and trnst_exclsn_f = 'N'
and b.crncy_cd = 'CAD' 
and lpad(b.mort_num,23,'0') = d.acct_num
and d.src_app_cd = 'MO'
and b.GL_TRNST_NUM is not null
and d.src_sys_del_dt='9999-12-31 00:00:00'
and d.SRC_SYS_DEL_F = 'N' 
and a.mth_end_dt=%nrbquote('&nz_rundate.')
		 
);
quit;	


proc sql;

create table WORK.BASEL_MORT_INSTRMNT_ADJ as 
      select a.*,
           GENL_LEDGER_BAL_ADJ_AMT + OS_BAL_AMT as AF_ADJ_OS_BAL_AMT  
      from WORK.BASEL_MORT_INSTRMNT_ADJ_TEMP  as a;
quit;

proc sql;			
connect using nzuser as nzcon;	
execute(delete from &FRG_DB..BASEL_MORT_INSTRMNT_ADJ where mth_tm_id=&mth_tm_id.) by nzcon;
DISCONNECT FROM NZCON;
quit;

proc append base=nzuser.BASEL_MORT_INSTRMNT_ADJ (bulkload=yes BL_METHOD=CLILOAD) 
            data=WORK.BASEL_MORT_INSTRMNT_ADJ force; run;


