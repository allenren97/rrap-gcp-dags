PROC SQL NOPRINT ;
CONNECT USING EDRRAPT AS DB3CON;
/*DOM-SUB-DUNDEE LOAD*/
EXECUTE(
delete from  EDRRAPT.BASEL_ACAP_EXPSR_EXTR where MTH_END_DT=(SELECT TM_LVL_END_DT FROM EDRTLRT.TM_DIM WHERE TM_ID=&MTH_TM_ID)
)
BY DB3CON;
DISCONNECT FROM DB3CON;					   
quit;

%PUT MTH_TM_ID IS &MTH_TM_ID;

PROC SQL NOPRINT;
CONNECT USING EDRRAPT AS DB3CON;
/*DOM-SUB-DUNDEE LOAD*/
EXECUTE(
INSERT INTO EDRRAPT.BASEL_ACAP_EXPSR_EXTR 
(MTH_END_DT,
LEGAL_ENTITY,
CCAR_BASEL_PRD_TP_NM,
PD_BAND,
TRNST_NUM,
PRD_ID,
UNQ_RECD_ID,
PD_BASEL_SEG_NUM,
LGD_BASEL_SEG_NUM,
EAD_BASEL_SEG_NUM,
PD_90_DAY_F,
BEFR_ZERO_NET_ADJ_OS_BAL_AMT,
AF_ZERO_NET_ADJUSTED_OS_BAL_AMT,
EXPCTD_LOSS_RTO_TEXT,
BEFORE_ZERO_NET_UNDRAWN_AMT,
AF_ZERO_NET_UNDRAWN_AMT,
BEFR_ZERO_NET_ALWBL_CR_LOSS_AMT,
AF_ZERO_NET_ALWBL_CR_LOSS_AMT,
LGD_FINAL_RPTG_RTO_TEXT,
EAD_FINAL_RPTG_RTO_TEXT,
EAD_PC,
CRNCY_CD,
PRTL_WRITE_OFF_AMT,
UNCONDTNLY_CNCLBL,
ACCR_INTR_AMT,
INSRT_PROCESS_TMSTMP,
UPDT_PROCESS_TMSTMP,
INSUR_F,
WGHTD_DLGD_RTO)

SELECT DISTINCT
(SELECT TM_LVL_END_DT FROM EDRTLRT.TM_DIM WHERE TM_ID=&MTH_TM_ID) AS 
		MTH_END_DT,
		FACT.LEGAL_ENTITY,
		FACT.CCAR_BASEL_PRD_TP_NM,
		FACT.PD_BAND,
		FACT.TRNST_NUM,
		FACT.PRD_ID,
		'DR_A'||LPAD(ROW_NUMBER() OVER (ORDER BY FACT.LEGAL_ENTITY, FACT.CCAR_BASEL_PRD_TP_NM, FACT.PD_BAND ASC),6,'0') AS UNQ_RECD_ID,
		FACT.PD_BASEL_SEG_NUM,
		CASE WHEN FACT.LGD_BASEL_SEG_NUM=-1 THEN NULL ELSE FACT.LGD_BASEL_SEG_NUM END AS LGD_BASEL_SEG_NUM,
		CASE WHEN FACT.EAD_BASEL_SEG_NUM=-1 THEN NULL ELSE FACT.EAD_BASEL_SEG_NUM END AS EAD_BASEL_SEG_NUM,
		CASE WHEN FACT.PD_90_DAY_F = 'T' THEN 'TRUE' ELSE 'FALSE' END AS PD_90_DAY_F,
		FACT.BEFR_ZERO_NET_ADJ_OS_BAL_AMT,
		FACT.AF_ZERO_NET_ADJUSTED_OS_BAL_AMT,
		TO_CHAR(CAST(ROUND(FACT.EXPCTD_LOSS_RTO*100,6) AS DECIMAL(15,6)))||'%' AS EXPCTD_LOSS_RTO_TEXT,
		FACT.BEFORE_ZERO_NET_UNDRAWN_AMT,
		FACT.AF_ZERO_NET_UNDRAWN_AMT,
		FACT.BEFR_ZERO_NET_ALWBL_CR_LOSS_AMT,
		FACT.AF_ZERO_NET_ALWBL_CR_LOSS_AMT,
		TO_CHAR(CAST(ROUND(FACT.LGD_FINAL_RPTG_RTO*100,6) AS DECIMAL(15,6)))||'%' AS LGD_FINAL_RPTG_RTO_TEXT,
		TO_CHAR(CAST(ROUND(FACT.EAD_FINAL_RPTG_RTO*100,6) AS DECIMAL(15,6)))||'%' AS EAD_FINAL_RPTG_RTO_TEXT,
		'' AS EAD_PC,
		FACT.CRNCY_CD,
		FACT.PRTL_WRITE_OFF_AMT,
		FACT.UNCONDTNLY_CNCLBL,
		FACT.ACCR_INTR_AMT,
		CURRENT_TIMESTAMP AS INSRT_PROCESS_TMSTMP,
		CURRENT_TIMESTAMP AS UPDT_PROCESS_TMSTMP,
		FACT.INSUR_F,
		FACT.WGHTD_DLGD_RTO

FROM EDRRAPT.BASEL_ACAP_EXPSR_FACT FACT WHERE FACT.LEGAL_ENTITY = 'DOM-SUB-DUNDEE'
AND (FACT.BEFR_ZERO_NET_ADJ_OS_BAL_AMT <> 0 OR FACT.BEFORE_ZERO_NET_UNDRAWN_AMT <> 0) AND FACT.MTH_TM_ID=&MTH_TM_ID.
) BY DB3CON;
DISCONNECT FROM DB3CON;					   
quit;

