ACCR_INTR_AMT,
WGHTD_DLGD_RTO,

INSRT_PROCESS_TMSTMP,
UPDT_PROCESS_TMSTMP
)
SELECT DISTINCT
(SELECT TM_LVL_END_DT FROM EDRTLRT.TM_DIM WHERE TM_ID=&MTH_TM_ID) AS MTH_END_DT,
		TFACT.LEGAL_ENTITY,
		TFACT.CCAR_BASEL_PRD_TP_NM,
		TFACT.PD_BAND,
		TFACT.TRNST_NUM,
		TFACT.PRD_ID,
		'DR_A'||LPAD(ROW_NUMBER() OVER (ORDER BY TFACT.LEGAL_ENTITY, 
		TFACT.CCAR_BASEL_PRD_TP_NM, TFACT.PD_BAND ASC),6,'0') AS UNQ_RECD_ID,
		TFACT.INSUR_F,
		PD_BASEL_SEG_NUM,
		(case when LGD_BASEL_SEG_NUM=-1 then null else LGD_BASEL_SEG_NUM end) as LGD_BASEL_SEG_NUM,
		(case when EAD_BASEL_SEG_NUM=-1 then null else EAD_BASEL_SEG_NUM end) as  EAD_BASEL_SEG_NUM,
		CASE WHEN TFACT.PD_90_DAY_F = 'T' THEN 'TRUE' ELSE 'FALSE' END AS PD_90_DAY_F,
		BEFR_ZERO_NET_ADJ_OS_BAL_AMT,
		AF_ZERO_NET_ADJUSTED_OS_BAL_AMT,
		TO_CHAR(CAST(ROUND(TFACT.EXPCTD_LOSS_RTO*100,6) AS DECIMAL(15,6)))||'%' AS EXPCTD_LOSS_RTO_TEXT,
		 BEFORE_ZERO_NET_UNDRAWN_AMT,
		AF_ZERO_NET_UNDRAWN_AMT,
		TFACT.BEFR_ZERO_NET_ALWBL_CR_LOSS_AMT AS BEFR_ZERO_NET_ALWBL_CR_LOSS_AMT,
		TFACT.AF_ZERO_NET_ALWBL_CR_LOSS_AMT AS AF_ZERO_NET_ALWBL_CR_LOSS_AMT,
		TO_CHAR(CAST(ROUND(TFACT.LGD_FINAL_RPTG_RTO*100,6) AS DECIMAL(15,6)))||'%' AS LGD_FINAL_RPTG_RTO_TEXT,
		TO_CHAR(CAST(ROUND(TFACT.EAD_FINAL_RPTG_RTO*100,6) AS DECIMAL(15,6)))||'%' AS EAD_FINAL_RPTG_RTO_TEXT,
		'' AS EAD_PC,
		TFACT.CRNCY_CD,
		TFACT.PRTL_WRITE_OFF_AMT,
		TFACT.UNCONDTNLY_CNCLBL AS UNCONDTNLY_CNCLBL,
		TFACT.ACCR_INTR_AMT,
		TFACT.WGHTD_DLGD_RTO,

		CURRENT_TIMESTAMP AS INSRT_PROCESS_TMSTMP,
		CURRENT_TIMESTAMP AS UPDT_PROCESS_TMSTMP
FROM EDRRAPT.BASEL_ACAP_EXPSR_FACT tFACT WHERE tFACT.LEGAL_ENTITY IN ( 'DOM-SUB-TNG' )
AND (tFACT.BEFR_ZERO_NET_ADJ_OS_BAL_AMT <> 0 OR tFACT.BEFORE_ZERO_NET_UNDRAWN_AMT <> 0) AND tFACT.MTH_TM_ID=&MTH_TM_ID)
 BY DB3CON;
						
QUIT;


