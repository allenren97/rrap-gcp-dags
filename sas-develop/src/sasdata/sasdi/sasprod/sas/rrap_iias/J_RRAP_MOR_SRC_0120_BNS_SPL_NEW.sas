%macro load_SPL();
%do i = 1 %to 2;
	data output&i. ; 
	   infile "&outpath./bns/incoming/SPL&i."
	          lrecl = 1640
	          delimiter = '	'
	          dsd
	          missover
	          firstobs = 1
	; 
		
	input &columns. ;
	
	LENGTH DEALER DFC INTEREST_RATE_ADJUSTMENT $5 PRODUCT_TYPE $2;
	if missing(loan_no) then delete;
	cif_cust_id=compress(CIF_CUST_ID,'!@#$%^&*()_+-={}|:;<>/,.?`~',"kfd");

/*	if substr(cif_cust_id,1,1) = byte(167) and substr(cif_cust_id,3,1) = byte(233) then do;*/
