/*		xx=tranwrd(compress(x),byte(233),'');*/
/*		cif_cust_id=substr(xx,3);*/
/*		drop x xx;*/
/*	end;*/
	run;
	
	%if &i EQ 1 %then %do;
		proc sql;
		create table &_output. like output1;
		quit;
	%end;
	
	proc append base=&_output.  data=output&i. force; run;
%end;
%mend load_SPL;
