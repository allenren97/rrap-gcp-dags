			FROM &target_lib3..SCORECARD_VARS_MO_SQL_TMP a ) WITH DATA ORGANIZE BY ROW) BY NZCON; */

     Execute ( Delete FROM (SELECT ROW_NUMBER() OVER (PARTITION BY &cust_key., MORT_NUM, EFF_TMSTMP) AS RID
