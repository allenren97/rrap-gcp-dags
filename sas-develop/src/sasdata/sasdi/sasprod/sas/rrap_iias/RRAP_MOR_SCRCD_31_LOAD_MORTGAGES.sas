options sastrace=off;
%delete_table(nzuser.SCORECARD_VARS_MO_SQL);
/* Step 31 get all mortgages from customers		      																*/
proc sql;
	connect USING NZUSER as nzcon ;
/*	execute( drop table &target_lib..SCORECARD_VARS_MO_SQL) by nzcon;*/
	execute (
	create table &target_lib3..SCORECARD_VARS_MO_SQL as (
			select
				a.&cust_key., 
				b.mort_num,
/*				b.eff_tm_id,*/
				b.MTH_END_DT as EFF_TMSTMP,
				b.Crnt_Bal,
				b.Auth_Amt,
				b.dlqnt_day,
				b.Inerest_accr_Amt,
				b.Crnt_Bal+b.Inerest_accr_Amt as osbal, 
				b.comm_tp,
				b.frclsr_F,
				b.pd_off_f,
				b.lra_stat,
				'MOR' as system,

             /* CASE WHEN comm_tp='Residential' and pd_off_f='N' and Crnt_Bal <> 0 and dlqnt_day <=90 and
				   frclsr_F <>  'Y' and lra_stat <>  'Y' then 'CUR'
				WHEN comm_tp='Residential' and pd_off_f='N' and Crnt_Bal <> 0 and 
				   (frclsr_F = 'Y' or lra_stat ='Y') then 'CHG'
				WHEN comm_tp='Residential' and pd_off_f='N' and Crnt_Bal <> 0 and 
				   (dlqnt_day >90 and frclsr_F <>  'Y' and lra_stat <>  'Y') then 'DEF'
				ELSE '???' END as select_stat_new_a,  */

		   	    CASE WHEN (comm_tp='Residential' and pd_off_f='N' and Crnt_Bal <> 0 and dlqnt_day <=90 and
				   frclsr_F <>  'Y' and lra_stat <>  'Y') THEN b.Crnt_Bal+b.Inerest_accr_Amt 
				ELSE 0 END as bal_cur,
				
				CASE WHEN (comm_tp='Residential' and pd_off_f='N' and Crnt_Bal <> 0 and 
				   (dlqnt_day >90 and frclsr_F <>  'Y' and lra_stat <>  'Y')) THEN b.Crnt_Bal+b.Inerest_accr_Amt
				ELSE 0 END as bal_def,
				
				CASE WHEN (comm_tp='Residential' and pd_off_f='N' and Crnt_Bal <> 0 and 
				   (frclsr_F = 'Y' or lra_stat ='Y')) THEN b.Crnt_Bal+b.Inerest_accr_Amt
				ELSE 0 END as bal_chg,

				'MO' as ltv_type,
               /* osbal as acct_limit, */
				b.Crnt_Bal+b.Inerest_accr_Amt as acct_limit,
			    dlqnt_day as dlqdays_mo,
				1 as mo_count
			from 	&target_lib3..SCORECARD_VARS_CUST_PRODS as a
				left join &target_lib3..AIRB_MORT_MTH_SNAPSHOT as b on 
					to_number(a.MORT_NO,'999999999999999')=to_number(b.MORT_NUM,'999999999999999') 
					and date_trunc('day',b.MTH_END_DT)>=a.from_dt and date_trunc('day',b.MTH_END_DT)<=a.to_dt  and a.system='MOR' 
					and crnt_bal<>0 and pd_off_f = 'N' and comm_tp='Residential'
					where mort_num is not null  ) WITH DATA ) by nzcon;
				*	execute (generate statistics on &target_lib3..SCORECARD_VARS_MO_SQL ) by nzcon;
					execute(CALL SYSPROC.ADMIN_CMD (%nrbquote('RUNSTATS
								ON TABLE ) %nrbquote(&target_lib3..SCORECARD_VARS_MO_SQL)
											%nrbquote(ON KEY COLUMNS and INDEXES ALL'))) by nzcon;

   /* execute (grant select, insert, update, delete on table &target_lib3...mo_sql to role frg_user) by nzcon; */

	disconnect from nzcon;
quit;


