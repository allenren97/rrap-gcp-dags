/*-----------------------------------------------
 * Calculates the default rates by segment
 *-----------------------------------------------*/ 
%macro create_bns_mor_realized_dr(_in_data =, _out_data=);

   proc summary data = &_in_data nway missing;

      /* BRD (pg 17): only CURRENT at obs period */
      where upcase(status1) = 'CUR';
      var default_ind;

      /* Aggregate by observation start date and segment */
      class process_date window_end_dt node;
      output out = work.dr_components (drop = _TYPE_ rename = (_freq_ = current_count))
      sum = default_ind;
   run;

   proc sql noprint;
      create table &_out_data as
      select a.node,
             a.process_date,
             a.window_end_dt,
             a.current_count,
             a.default_ind,
             (case
               when a.current_count NE . and a.default_ind NE . then a.default_ind/a.current_count
               when a.current_count NE . and a.default_ind EQ . then .
               when a.current_count EQ . and a.default_ind NE . then .
               else .
             end) as segment_dr
      from work.dr_components as a;
   quit;

%mend create_bns_mor_realized_dr;
%create_bns_mor_realized_dr(_in_data = results.scored_segmented_accts,
                            _out_data = results.bns_mor_realized_dr);


		/*Updates raw data table with new qrt end data - CV Nov18 2015*/

   /*----------------------------------------------------
    * Checks to see if the date is in raw data NZ table
    *----------------------------------------------------*/ 
%macro update_raw_data;
    proc sql noprint;
       select count(*) 
       into :date_count trimmed
       from results.bns_mor_realized_dr
       where process_date in (select distinct process_date 
							  from results.bns_mor_realized_dr
                              where month(process_date) in (1,4,7,10)) ;
    quit;   

	
	%put Date_count is &date_count;

	  
   /*---------------------------------------------
    * If data already exists for the data being 
    * loaded, delete it from the target table
	* and insert new data
    *---------------------------------------------*/  

   %if %eval(&date_count) > 0 %then
   %do;
 
		proc sql;
			delete from nzuser.bns_dr_raw_historical
			where process_date in (select distinct process_date 
									from results.bns_mor_realized_dr
									where month(process_date) in (1,4,7,10));
            
			insert into nzuser.bns_dr_raw_historical
				select *
				from results.bns_mor_realized_dr
				where month(process_date) in (1,4,7,10);
			quit;
	%end;   
   %mend;
   
%update_raw_data;


/* Sort data for next steps and add start_date column - CV 18NOV2015*/

proc sql;
	create table work.bns_dr_raw_hist_sorted as
	select *,
			min(process_date) as start_date format=date9.
	from nzuser.bns_dr_raw_historical
	order by node, process_date;
quit;

/* Delete old BNS_MOR_HISTORICAL_DR table */
%delete_table(results.BNS_MOR_HISTORICAL_DR);

/* Re-calculates Qtr Averages with new data that was added and creates historical table with history*/

	data results.BNS_MOR_HISTORICAL_DR (keep= node start_date end_date avg_segment_dr);
	set work.bns_dr_raw_hist_sorted (rename=(process_date=end_date));
	retain new_segment_dr;
	by node;
	if first.node then do;
		counter = 0;	
		new_segment_dr = 0;
	end;
	counter + 1;		
	new_segment_dr=sum(new_segment_dr,segment_dr);
	avg_segment_dr=(new_segment_dr/counter);
	format end_date date9. start_date date9.;
run;


