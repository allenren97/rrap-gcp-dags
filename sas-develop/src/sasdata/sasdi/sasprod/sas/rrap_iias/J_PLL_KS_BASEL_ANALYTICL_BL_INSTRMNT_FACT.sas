PROC SQL;
	CONNECT USING NZRRAP AS NZCON;
	create table BASEL_REVLVING_CR_MTH as
			select *              
			from connection to NZCON
				( SELECT DISTINCT
					SS.MTH_TM_ID, 
					'KS' as SRC_SYS_CD0,
					date(to_date('2016-11-01','YYYY-MM-DD')) as DLGD_F_DT,
					SS.BASEL_ACCT_ID, 
					SS.PRIM_BASEL_CUST_ID, 
					CIF_KEY BASEL_CIF_KEY0,
					SS.STEP_PLN_SNAPSHOT_ID, 
					SS.ACCT_NUM, 
					SS.TRNST_OU_ID,
					oud.TRNST_NUM AS v_RGNL_OFFC_TRNST_NUM, 
					SS.SUB_PRD_CD AS SUB_PRD_CD0, 
					SS.TRNST_NUM, 
					0.000 AS ADVNC_AMT,
					SS.PRD_CD, 
					BDV.HELOC_F,
					SS.ACCT_OPND_DT, SS.ACCT_OPND_DT ACCT_ODT,
					SS.LAST_ACTY_DT, 
					round(SS.CR_LMT_AMT,8) as CR_LMT_AMT0, 
					SS.LAST_PYMT_DT, SS.TOT_NEW_BAL_AMT,
					SS.TOT_NEW_BAL_AMT as OS_BAL_AMT, 
					SS.TOT_NEW_BAL_AMT AS DRAWN_AMT, 
					SS.BNS_DLQNT_DAY as DLQNT_DAY_CNT, 
					SS.SCRTY_TP_CD, 
					SS.PRIM_CUST_CID,
					CDV.LOAN_TO_VAL_WITHOUT_INDEX_RTO AS CDV_LOAN_TO_VAL_WITHOUT_INDEX_R,
					BDV.PIT_STAT_VER_2_CD AS BDV_PIT_STAT_VER_2_CD,
					BDV.PIT_STAT_VER_2_CD as PIT_STAT_CD,
					CDV.UTLTN_RTO AS UTLTN_RTO,
					BDV.REVISED_EXPSR_AMT AS BDV_REVISED_EXPSR_AMT,
					BDV.REVISED_EXPSR_AMT AS REVISED_EXPSR_AMT,
					STEPSS.APRSD_VAL AS ORIG_PRPTY_VAL_AMT,
					STEPSS.INSURER_CD AS STEPSS_INSURER_CD,
					CDV.APRSD_VAL_TERANET_INDEXED_AMT AS CDV_APRSD_VAL_TERANET_INDEXED_AM,
					CDV.APRSD_VAL_TERANET_INDEXED_AMT AS INDEXED_PRPTY_VAL_AMT,
					CDV.LOAN_TO_VAL_WITH_TERANET_INDEX_RTO AS CDV_LOAN_TO_VAL_WITH_TERANET_IN,
					CDV.LOAN_TO_VAL_WITH_TERANET_INDEX_RTO AS INDEXED_LOAN_TO_VAL_RTO,
					CDV.CONS_DFT_MTH_CNT AS CONS_DFT_MTH_CNT,
					BDV.CONSM_PRD_TREATMNT_CD AS CONSM_PRD_TREATMNT_CD,
					BDV.STEP_CD AS STEP_F0,
					BDV.TRNST_EXCLSN_F AS TRNST_EXCLSN_F,
				(Case 
					when LTRIM(RTRIM(BDV.SML_BUS_F))='N' 
					AND LTRIM(RTRIM(BDV.CONSM_PRD_TREATMNT_CD))='A' 
					AND LTRIM(RTRIM(BDV.PIT_STAT_VER_2_CD)) in ('CUR', 'DEF') then '0405'
					else null 
				end)
			as NCR_LTV_KEY_VAL0,
				BDV.SML_BUS_F as BDV_SML_BUS_F,
			(case 
				when LTRIM(RTRIM(BDV.SML_BUS_F))='N' then 'CA' || '0201' || ss.ACCT_NUM
				else null 
			end)
		AS UNQ_ACCT_ID0,
			(case 
				when LTRIM(RTRIM(BDV.SML_BUS_F))='N' then '0201' 
				else null 
			end)
		AS NCR_RT_SYS_KEY_VAL,				
			BDV.HELOC_F AS BDV_HELOC_F,
			BDV.BASEL_PRD_CD AS BDV_BASEL_PRD_CD,
			LTV.METRPL_AREA_NM0 AS V_METRPL_AREA_NM,
			LTV.CRNT_METRPL_TERANET_INDEX, 
			LTV.PREV_12_QTR_METRPL_TERANET_HOUSE, 
			LTV.APPRSL_DT_PRPTY_VAL_AMT, 
			LTV.CRNT_PRPTY_VAL_AMT, 
			LTV.PREV_12_QTR_PRPTY_VAL_AMT as PREV_12_QTR_PRPTY_VAL_AMT0, 
			ST.ACCT_SENRTY_CD as lkp_ACCT_SENRTY_CD, 
			ST.MAX_ACCT_BAL_AMT as lkp_MAX_ACCT_BAL_AMT, 
			ST.EXPSR_AT_DFT_RTO as LKP_EXPSR_AT_DFT_RTO, 
			ST.CRNT_LTV_RTO as LKP_CRNT_LTV_RTO, 
			ST.INDEXED_CCLTV_RTO as LKP_INDEXED_CCLTV_RTO,
			(CASE WHEN LTV.PREV_12_QTR_PRPTY_VAL_AMT IS NULL or  LTV.CRNT_PRPTY_VAL_AMT =0 or LTV.CRNT_PRPTY_VAL_AMT IS NULL THEN  null
					ELSE (1- LTV.PREV_12_QTR_PRPTY_VAL_AMT/LTV.CRNT_PRPTY_VAL_AMT) end) AS v_PROPERTY_VAL_RATIO,
			DLGD.METRPL_AREA_NM,
			COALESCE(DLGD.METRPL_BREACH_F, DLGD2.METRPL_BREACH_F) AS METRPL_BREACH_F,TT.tm_lvl_ST_dt,TT.tm_lvl_end_dT,
			TT.tm_lvl_end_dT as v_PROCESSING_DATE,
			SUBSTR(TT.tm_lvl_end_dT,1,4)||LPAD(SUBSTR(TT.tm_lvl_end_dT,6,2),2,'0') AS v_PROCESSING_DATE_FINAL,
                  TRANSACTOR_F_QRR.ASST_CL_DESC as ASST_CL_DESC_QRR

		FROM
			(SELECT *  FROM &net_db_P1D..BASEL_REVLVNG_CR_MTH_SNAPSHOT 
		WHERE MTH_TM_ID=&MTH_TM_ID. 
			) SS

		LEFT JOIN 	&net_db_P1D..TM_DIM TT ON SS.MTH_TM_ID=TT.TM_ID
		
		LEFT JOIN 	&net_db_P1D..BASEL_CUST_DIM CDM ON 	CDM.BASEL_CUST_ID = SS.PRIM_BASEL_CUST_ID	

		LEFT JOIN 	&net_db_P1D..ORG_UNIT_DIM  oud ON  SS.TRNST_OU_ID=OUD.ORG_UNIT_ID
			
		LEFT OUTER JOIN &net_db_P1D..BASEL_REVLVNG_CR_ACCT_DRVD_VARS_CMA CDV
			ON
			SS.BASEL_ACCT_ID=CDV.BASEL_ACCT_ID
			AND CDV.MTH_TM_ID =&MTH_TM_ID.

		LEFT OUTER JOIN &net_db_P1D..BASEL_REVLVNG_CR_BASE_DRVD_VARS BDV
		ON
			SS.BASEL_ACCT_ID=BDV.BASEL_ACCT_ID
			AND BDV.MTH_TM_ID =&MTH_TM_ID.

		LEFT OUTER JOIN &net_db_P1D..BASEL_STEP_PLN_MTH_SNAPSHOT STEPSS
			ON
			SS.STEP_PLN_SNAPSHOT_ID=STEPSS.STEP_PLN_SNAPSHOT_ID
			and STEPSS.MTH_TM_ID  =&MTH_TM_ID.
					
		left outer Join (
			SELECT SL.MTH_TM_ID,
				SL.METRPL_AREA_NM as METRPL_AREA_NM0, 
				SL.CRNT_METRPL_TERANET_INDEX as CRNT_METRPL_TERANET_INDEX, 
				SL.PREV_12_QTR_METRPL_TERANET_HOUSE_INDEX as PREV_12_QTR_METRPL_TERANET_HOUSE, 
				SL.APPRSL_DT_PRPTY_VAL_AMT as APPRSL_DT_PRPTY_VAL_AMT, 
				SL.CRNT_PRPTY_VAL_AMT as CRNT_PRPTY_VAL_AMT, 
				SL.PREV_12_QTR_PRPTY_VAL_AMT as PREV_12_QTR_PRPTY_VAL_AMT, 
				SL.STEP_PLN_SNAPSHOT_ID as STEP_PLN_SNAPSHOT_ID 
			FROM &net_db_P1D..BASEL_STEP_LTV_DRVD_VARS_CMA SL
			WHERE SL.MTH_TM_ID =&MTH_TM_ID.) LTV 
			on SS.STEP_PLN_SNAPSHOT_ID=LTV.STEP_PLN_SNAPSHOT_ID and SS.MTH_TM_ID=LTV.MTH_TM_ID 

		LEFT OUTER JOIN (
			SELECT DISTINCT METRPL_BREACH_F, 
				upper(TRIM(METRPL_AREA_NM)) AS METRPL_AREA_NM 
				FROM &net_db_P1D..DLGD_SCRI_QTR_DRVD_VARS  
				where MTH_TM_ID=( SELECT MAX(TM_ID) FROM &net_db_P1D..TM_DIM WHERE FNCL_QTR_KEY = (SELECT FNCL_QTR_KEY FROM &net_db_P1D..TM_DIM WHERE TM_LVL='Month' and TM_ID=&MTH_TM_ID.) )
				) DLGD on upper(LTV.METRPL_AREA_NM0)=DLGD.METRPL_AREA_NM 
		/* RRMSS-1557 map new CMAs as '11' for breach flag  */
				LEFT OUTER JOIN &net_db_P1D..DLGD_SCRI_QTR_DRVD_VARS DLGD2 ON TRIM(DLGD2.METRPL_AREA_NM)='11' 
					AND DLGD2.MTH_TM_ID=( SELECT MAX(TM_ID) FROM &net_db_P1D..TM_DIM WHERE FNCL_QTR_KEY = (SELECT FNCL_QTR_KEY FROM &net_db_P1D..TM_DIM WHERE TM_LVL='Month' and TM_ID=&MTH_TM_ID.) )
					AND DLGD.METRPL_AREA_NM IS NULL 

		/* RRMSS-1590 */
		/* RRMSS-2087 */
        LEFT JOIN 
			(SELECT D.MTH_TM_ID,D.BASEL_ACCT_ID,TRIM(C.ASST_CL_DESC) AS ASST_CL_DESC FROM 
				(SELECT A.BASEL_ACCT_ID,A.MTH_TM_ID,A.TOTAL_EXPSR_ABOVE_LMT_F  
				,A.HELOC_F, TRIM(A.BASEL_PRD_CD) BASEL_PRD_CD,B.PRD_CD,B.SUB_PRD_CD
				,A.CONSM_PRD_TREATMNT_CD,A.SML_BUS_F,A.TRNST_EXCLSN_F 
				FROM &net_db_P1D..BASEL_REVLVNG_CR_BASE_DRVD_VARS A 
				INNER JOIN &net_db_P1D..BASEL_REVLVNG_CR_MTH_SNAPSHOT B
					ON A.MTH_TM_ID=B.MTH_TM_ID AND A.BASEL_ACCT_ID=B.BASEL_ACCT_ID
				WHERE A.MTH_TM_ID=&MTH_TM_ID. AND A.TOTAL_EXPSR_ABOVE_LMT_F IN ('Y', 'N')) D 				
				LEFT JOIN &net_db_P1D..RPTG_PRD_LKP_KS C
					ON D.PRD_CD=C.PRD_CD AND D.SUB_PRD_CD=C.SUB_PRD_CD
					AND D.TOTAL_EXPSR_ABOVE_LMT_F=C.REVISED_EXPSR_OV_125K_F
					AND D.HELOC_F=C.HELOC_F AND D.BASEL_PRD_CD=C.BASEL_PRD_CD
					AND C.SRC_SYS_CD='KS' AND &YRMTH. BETWEEN C.EFF_FROM_YR_MTH AND C.EFF_TO_YR_MTH
			) TRANSACTOR_F_QRR
			ON TRANSACTOR_F_QRR.BASEL_ACCT_ID=SS.BASEL_ACCT_ID
				AND TRANSACTOR_F_QRR.MTH_TM_ID=SS.MTH_TM_ID

		left outer join
				( SELECT 
					ACCT_SENRTY_CD as ACCT_SENRTY_CD, 
					MAX_ACCT_BAL_AMT as MAX_ACCT_BAL_AMT, 
					EXPSR_AT_DFT_RTO as EXPSR_AT_DFT_RTO, 
					CRNT_LTV_RTO as CRNT_LTV_RTO, 
					INDEXED_CCLTV_RTO as INDEXED_CCLTV_RTO, 
					BASEL_ACCT_ID as BASEL_ACCT_ID, 
					STEP_PLN_SNAPSHOT_ID as STEP_PLN_SNAPSHOT_ID 
					FROM 
					&net_db_P1D..BASEL_ACCT_LTV_DRVD_VARS_CMA
					WHERE MTH_TM_ID=&MTH_TM_ID.
					and ACCT_SENRTY_CD in (2, 4)
					) ST

					on ss.BASEL_ACCT_ID = st.BASEL_ACCT_ID AND ss.STEP_PLN_SNAPSHOT_ID = st.STEP_PLN_SNAPSHOT_ID
			ORDER BY SS.BASEL_ACCT_ID

