PROC SQL;
	CONNECT USING DB2RRAP AS NZCON;
	create table ORG_UNIT_HIERARCHY_DIM as
		select *              
			from connection to NZCON
				( SELECT TRNST_NUM, RGNL_OFFC_TRNST_NUM,RGNL_OFFC_CD FROM EDEDW.ORG_UNIT_HIERARCHY_DIM
					WHERE ( select 	tm_lvl_end_dt from 	EDEDW.TM_DIM where tm_id = &MTH_TM_ID.) BETWEEN EFF_FROM_TMSTMP AND EFF_TO_TMSTMP
				);

create table REVLVNG_CR_RPTG_DRVD_VAR as
		select *              
			from connection to NZCON
				( SELECT DISTINCT
					RPTG.BASEL_ACCT_ID, 
					RPTG.MTH_TM_ID, 
					LTRIM(RTRIM(RPTG.NCR_EXPSR_CL_KEY_VAL)) AS NCR_EXPSR_CL_KEY_VAL, 
					LTRIM(RTRIM(RPTG.NCR_RT_KEY_VAL)) AS NCR_RT_KEY_VAL,
					RPTG.DLQNT_ID, 
					NCR_DLQNT_CD,
					DD.NCR_DLQNT_CD as NCR_DLQNT_BCKT_KEY_VAL,
					RPTG.NCR_EXPSR_SIZE_ID, 
					RPTG.NCR_PD_BAND_ID, 
					RPTG.NCR_GEO_ID, 
					RPTG.REVISED_EXPSR_OV_125K_F, 
					RPTG.ASST_CL_NUM, 
					RPTG.ASST_CL_DESC AS ASST_CL_DESC0, 
					RPTG.BASEL_PRD_ABR,
/*					ncrpd.NCR_PD_BAND_KEY_VAL as o_NCR_PD_BAND_KEY_VAL,
					ncrpd.NCR_PD_BAND_KEY_VAL as NCR_PD_BAND_KEY_VAL,
*/					NULL as o_NCR_PD_BAND_KEY_VAL, NULL as NCR_PD_BAND_KEY_VAL,
					ncrex.NCR_KEY_VAL as  o_NCR_EXPSR_SIZE_KEY_VAL,
					ncrex.NCR_KEY_VAL as  NCR_EXPSR_SIZE_KEY_VAL,
					NCRGE.NCR_GEO_KEY_VAL as  o_NCR_GEO_KEY_VAL,
					NCRGE.NCR_GEO_KEY_VAL as  NCR_GEO_KEY_VAL,
					GENL_LEDGER_BAL_ADJ_AMT GENL_LEDGER_BALCNG_ADJ_AMT,
					0.000 AS UNADJUSTED_ADD_ON_BAL_AMT,
					ab.AF_ADJ_OS_BAL_AMT AS AF_ADJ_OS_BAL_AMT,
					round(ab.AF_ADJ_OS_BAL_AMT,8)	AS vADJUSTED_OS_BAL_AMT, 
				(CASE 
					WHEN round(ab.AF_ADJ_OS_BAL_AMT,8) < 0 THEN 0 
					ELSE round(ab.AF_ADJ_OS_BAL_AMT,8) 
				END)
			AS AF_ZERO_NET_DRAWN_AMT,
				BEC.CCAR_EXPSR_CL_NM,				
			/*	NBD.PD_BAND,     Derived after PD values are floored.*/
				NULL as PD_BAND,
				dd.DLQNT_CYCL_CD DLQNT_STG0,
				b.SECRTZTN_OS_ADJ_FACTR v_SECURITIZATION_FACTOR,
				b.BASEL_ACCT_ID_CCAR_MATCHED  
				,B.SECRTZTN_TP_CD
			FROM
				(SELECT * FROM &DM_SCH..BASEL_REVLVNG_CR_RPTG_DRVD_VAR WHERE MTH_TM_ID=&MTH_TM_ID. 
				) RPTG
					left join  ededw.TM_DIM TDM on RPTG.MTH_TM_ID=TDM.TM_ID
					left join 
						(	SELECT a.BASEL_ACCT_ID_CCAR_MATCHED as BASEL_ACCT_ID_CCAR_MATCHED ,
							a.SECRTZTN_TP_CD AS SECRTZTN_TP_CD  , 
							SECRTZTN_OS_ADJ_FACTR
						FROM &DM_SCH..BASEL_CC_SEC_ACCT_MTH_SNAP a
							left join &DM_SCH..BASEL_SEC_ADJ_FACTR_MTH_SNAP s on a.SECRTZTN_TP_CD=s.SECRTZTN_TP_CD
								and s.mth_tm_id= a.MTH_TM_ID
							WHERE a.BASEL_ACCT_ID_CCAR_MATCHED IS NOT NULL
								AND a.MTH_TM_ID=&MTH_TM_ID. ) b 
								on RPTG.BASEL_ACCT_ID=b.BASEL_ACCT_ID_CCAR_MATCHED
							LEFT JOIN &DM_SCH..BASEL_EXPSR_CL_DIM BEC ON &yearm. BETWEEN bec.EFF_FROM_YR_MTH AND bec.EFF_TO_YR_MTH 
								AND 	LTRIM(RTRIM(RPTG.NCR_EXPSR_CL_KEY_VAL)) = LTRIM(RTRIM(BEC.NCR_EXPSR_CL_KEY_VAL))
							LEFT JOIN &DM_SCH..BASEL_NCR_PD_BAND_DIM NBD ON &yearm. BETWEEN NBD.EFF_FROM_YR_MTH AND NBD.EFF_TO_YR_MTH and RPTG.NCR_PD_BAND_ID = NBD.NCR_PD_BAND_ID	
							left Join
								&DM_SCH..BASEL_NCR_PD_BAND_DIM ncrpd on RPTG.NCR_PD_BAND_ID=ncrpd.NCR_PD_BAND_ID
								and &yearm. BETWEEN ncrpd.EFF_FROM_YR_MTH AND ncrpd.EFF_TO_YR_MTH
							left join &DM_SCH..BASEL_NCR_EXPSR_SIZE_DIM ncrex on RPTG.NCR_EXPSR_SIZE_ID = ncrex.NCR_EXPSR_SIZE_ID
								and &yearm. BETWEEN ncrex.EFF_FROM_YR_MTH AND ncrex.EFF_TO_YR_MTH
							left join &DM_SCH..BASEL_NCR_GEO_DIM NCRGE on RPTG.NCR_GEO_ID= NCRGE.NCR_GEO_ID
								and &yearm. BETWEEN NCRGE.EFF_FROM_YR_MTH AND NCRGE.EFF_TO_YR_MTH
							left join &DM_SCH..DLQNT_DIM dd on RPTG.DLQNT_ID = dd.DLQNT_ID
								and TDM.tm_lvl_end_dt BETWEEN EFF_FROM_DT AND EFF_TO_DT
							LEFT JOIN (
								SELECT BASEL_REVLVNG_CR_INSTRMNT_ADJ.AF_ADJ_OS_BAL_AMT as AF_ADJ_OS_BAL_AMT, 
									GENL_LEDGER_BAL_ADJ_AMT as GENL_LEDGER_BAL_ADJ_AMT,
									BASEL_REVLVNG_CR_INSTRMNT_ADJ.BASEL_ACCT_ID as BASEL_ACCT_ID 
								FROM &DM_SCH..BASEL_REVLVNG_CR_INSTRMNT_ADJ BASEL_REVLVNG_CR_INSTRMNT_ADJ 
									WHERE BASEL_REVLVNG_CR_INSTRMNT_ADJ.MTH_TM_ID=&MTH_TM_ID.
						) ab ON  RPTG.BASEL_ACCT_ID=ab.BASEL_ACCT_ID
							ORDER BY RPTG.BASEL_ACCT_ID
								);
	disconnect from NZCON;
quit;

