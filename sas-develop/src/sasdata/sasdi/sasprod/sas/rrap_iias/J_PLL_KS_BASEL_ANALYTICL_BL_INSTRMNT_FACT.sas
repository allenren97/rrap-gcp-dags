OS_PRNCPL_BAL_AMT=round(TOT_NEW_BAL_AMT - (vADJUSTED_OS_BAL_AMT*v_SECURITIZATION_FACTOR),.00000001); END;
ELSE DO; OS_PRNCPL_BAL_AMT=round(TOT_NEW_BAL_AMT, .00000001); END;


