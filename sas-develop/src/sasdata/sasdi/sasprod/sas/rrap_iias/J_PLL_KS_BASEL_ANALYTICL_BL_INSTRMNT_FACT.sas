quit;

PROC SQL;
	CONNECT USING DB2RRAP AS NZCON;
	create table RPTG_PRD_LKP1 as
		select *              
			from connection to NZCON
				( 	SELECT 
					TRIM(BASEL_PRD_TP_CD) AS BASEL_PRD_TP_CD,
					TRIM(PRD_ID) AS PRD_ID,
					TRIM(BASEL_SUB_PRD_NM) AS BASEL_SUB_PRD_NM,
					TRIM(BCAR_SCHED_NUM) AS BCAR_SCHED_NUM,
					TRIM(CCAR_BASEL_PRD_TP_NM) AS CCAR_BASEL_PRD_TP_NM0,
					TRIM(SCRTY_TP_CD) AS LKP_SCRTY_TP_CD,
					TRIM(PL.PRD_CD) AS PRD_CD,
					TRIM(SUB_PRD_CD) AS SUB_PRD_CD0,
					TRIM(REVISED_EXPSR_OV_125K_F) AS REVISED_EXPSR_OV_125K_F,
					TRIM(HELOC_F) AS HELOC_F,
					TRIM(BASEL_PRD_CD) AS BASEL_PRD_CD,
					LTRIM(RTRIM(EGL_DEPRTMNT)) as EGL_DEPRTMNT
				FROM &DBSCHEMA..BASEL_RPTG_PRD_LKP PL
					left join &DBSCHEMA..BASEL_EGL_LKP egl on LTRIM(RTRIM(PL.PRD_ID))=LTRIM(RTRIM(egl.PRD_CD))
						WHERE	  TRIM(SRC_SYS_CD)='KS'  AND &yearm. between eff_from_yr_mth AND eff_to_yr_mth 
				);
	create table NCR_LTV_DIM1 as
		select *              
			from connection to NZCON
				( SELECT 
					BASEL_NCR_LTV_DIM.NCR_LTV_KEY_VAL as NCR_LTV_KEY_VAL ,
					BASEL_NCR_LTV_DIM.LTV_RTO_MIN_VAL as LTV_RTO_MIN_VAL, 
					BASEL_NCR_LTV_DIM.LTV_RTO_MAX_VAL as LTV_RTO_MAX_VAL
				FROM &DBSCHEMA..BASEL_NCR_LTV_DIM BASEL_NCR_LTV_DIM
					WHERE &yearm. BETWEEN EFF_FROM_YR_MTH AND EFF_TO_YR_MTH

				);
	disconnect from NZCON;
quit;

PROC SQL NOPRINT;
         CONNECT USING NZRRAP AS NZCON;
         CREATE TABLE ACCT_PRFM AS
         	SELECT * FROM CONNECTION TO NZCON (
			 SELECT distinct mth_tm_id,
					'CA0201'||LPAD(ACCT_NUM,23,'0') AS uq_acct_id, 
					BASEL_ACCT_ID,
					LTV_BCKT_CD AS LTV_BUCKET,
					RNTL_INCM_DPNDCY_F AS RNTL_PRPTY_F,
					TRNSCTR_IND AS Transactor_F,
					CURRENCY_MISMATCH_F,
					TOT_EXPSR_ABOVE_1500K_LMT_F,
					CLP_FLAG 
			FROM &net_db_P1D..BASEL_ACCT_PRFM_FACT 
			WHERE mth_tm_id=&MTH_TM_ID. AND src_sys_cd='KQ'
		);

		CREATE TABLE PIT_90_180 AS
         	SELECT * FROM CONNECTION TO NZCON 
		(select 	BASEL_ACCT_ID, 
					BDV.CONSM_SCORECRD_EXCLSN_F as BDV_CONSM_SCORECRD_EXCLSN_F, 
					BDV.PIT_STAT_VER_2_CD180,
					BDV.PIT_STAT_VER_2_CD90
		from &net_db_P1D..BASEL_REVLVNG_CR_BASE_DRVD_VARS BDV
		where MTH_TM_ID=&MTH_TM_ID.
		order by BASEL_ACCT_ID);
     QUIT;

PROC SQL ;
CREATE TABLE MERG0 AS 
SELECT *
FROM BASEL_REVLVING_CR_MTH CM
LEFT JOIN PIT_90_180 p ON CM.BASEL_ACCT_ID=p.BASEL_ACCT_ID;
quit;

PROC SQL ;
CREATE TABLE MERG01 AS 
SELECT cm.*,
		LD.NCR_LTV_KEY_VAL as NCR_LTV_KEY_VAL1, 
		LD.LTV_RTO_MIN_VAL,LD.LTV_RTO_MAX_VAL,
		OU.RGNL_OFFC_CD
FROM MERG0 CM
LEFT JOIN ORG_UNIT_HIERARCHY_DIM OU ON CM.TRNST_NUM=OU.TRNST_NUM 
left join NCR_LTV_DIM1 LD on LD.LTV_RTO_MIN_VAL LE CM.CDV_LOAN_TO_VAL_WITHOUT_INDEX_R 
AND LD.LTV_RTO_MAX_VAL GT CM.CDV_LOAN_TO_VAL_WITHOUT_INDEX_R ;
quit;


PROC SQL ;
CREATE TABLE MERG02a AS
select *
from MERG01 CM
LEFT JOIN LXREF L ON CM.BASEL_ACCT_ID=L.BASEL_ACCT_ID and cm.mth_tm_id=l.MTH_TM_ID;
CREATE TABLE MERG02b AS
select *
from MERG02a CM
LEFT JOIN PXREF P ON CM.BASEL_ACCT_ID=P.BASEL_ACCT_ID  and cm.mth_tm_id=p.MTH_TM_ID;
CREATE TABLE MERG02 AS
select *
from MERG02b CM
LEFT JOIN EXREF E ON CM.BASEL_ACCT_ID=E.BASEL_ACCT_ID  and cm.mth_tm_id=e.MTH_TM_ID ;
quit;

PROC SQL;
CREATE TABLE MERG03 AS 
SELECT 	cm.*,
		dv.*,
		PL1.BASEL_PRD_TP_CD,
		PL1.PRD_ID,
		PL1.BASEL_SUB_PRD_NM as SRC_PRD_DESC,
		PL1.BCAR_SCHED_NUM,
		PL1.CCAR_BASEL_PRD_TP_NM0,
		PL1.LKP_SCRTY_TP_CD,
		PL1.EGL_DEPRTMNT,
        CASE WHEN CM.ASST_CL_DESC_QRR='QRR' THEN COALESCE(AP.Transactor_F,'N')
		 ELSE ''
		END AS TRANSACTOR_FLAG_QRR,
         ap.*
FROM MERG02 CM
LEFT JOIN REVLVNG_CR_RPTG_DRVD_VAR DV ON CM.BASEL_ACCT_ID=DV.BASEL_ACCT_ID AND CM.MTH_TM_ID=DV.MTH_TM_ID
left join RPTG_PRD_LKP1 PL1 ON CM.PRD_CD = PL1.PRD_CD AND CM.SUB_PRD_CD0 = PL1.SUB_PRD_CD0 
AND DV.REVISED_EXPSR_OV_125K_F = PL1.REVISED_EXPSR_OV_125K_F AND cm.HELOC_F = PL1.HELOC_F AND BDV_BASEL_PRD_CD = PL1.BASEL_PRD_CD
left join ACCT_PRFM ap on CM.BASEL_ACCT_ID=ap.BASEL_ACCT_ID and CM.MTH_TM_ID=ap.MTH_TM_ID;
QUIT;

