IF AF_ZERO_NET_UNDRAWN_AMT LT 0 THEN DO; AF_ZERO_NET_UNDRAWN_AMT=0; END; ELSE DO; AF_ZERO_NET_UNDRAWN_AMT=AF_ZERO_NET_UNDRAWN_AMT; END;

AUTH_AMT=CR_LMT_AMT0;
IF STRIP(BASEL_PRD_TP_CD)='HELOC' AND STRIP(STEPSS_INSURER_CD) NE '' AND STRIP(STEPSS_INSURER_CD) NE '' THEN DO; INSUR_F= 'YES'; END ;
