		SELECT BASEL_ACCT_ID AS BASEL_ACCT_ID_I,TOT_NEW_BAL_AMT FROM NZRRAP.BASEL_REVLVNG_CR_MTH_SNAPSHOT WHERE MTH_TM_ID=&MTH_TM_ID.;
QUIT;

PROC SQL;
	CREATE TABLE JOINED AS
		SELECT * FROM IIAS I
			LEFT JOIN
				DB2 D
				ON I.BASEL_ACCT_ID_I=D.BASEL_ACCT_ID;
QUIT;

PROC SQL;
	CREATE TABLE REVLVNG_CR_RPTG_DRVD_VAR AS
		SELECT t1.BASEL_ACCT_ID, 
			t1.MTH_TM_ID, 
			t1.NCR_EXPSR_CL_KEY_VAL, 
			t1.NCR_RT_KEY_VAL, 
			t1.DLQNT_ID, 
			t1.NCR_DLQNT_CD, 
			t1.NCR_DLQNT_BCKT_KEY_VAL, 
			t1.NCR_EXPSR_SIZE_ID, 
			t1.NCR_PD_BAND_ID, 
			t1.NCR_GEO_ID, 
			t1.REVISED_EXPSR_OV_125K_F, 
			t1.ASST_CL_NUM, 
			t1.ASST_CL_DESC0, 
			t1.BASEL_PRD_ABR, 
			t1.O_NCR_PD_BAND_KEY_VAL, 
			t1.NCR_PD_BAND_KEY_VAL, 
			t1.O_NCR_EXPSR_SIZE_KEY_VAL, 
			t1.NCR_EXPSR_SIZE_KEY_VAL, 
			t1.O_NCR_GEO_KEY_VAL, 
			t1.NCR_GEO_KEY_VAL, 
			t1.GENL_LEDGER_BALCNG_ADJ_AMT, 
			t1.UNADJUSTED_ADD_ON_BAL_AMT, 
			SUM(T2.TOT_NEW_BAL_AMT,T2.GENL_LEDGER_BAL_ADJ_AMT) AS AF_ADJ_OS_BAL_AMT, 
			round(CALCULATED AF_ADJ_OS_BAL_AMT,0.00000001) AS VADJUSTED_OS_BAL_AMT, 
			t1.AF_ZERO_NET_DRAWN_AMT, 
			t1.CCAR_EXPSR_CL_NM, 
			t1.PD_BAND, 
			t1.DLQNT_STG0, 
			t1.V_SECURITIZATION_FACTOR, 
			t1.BASEL_ACCT_ID_CCAR_MATCHED, 
			t1.SECRTZTN_TP_CD
		FROM REVLVNG_CR_RPTG_DRVD_VAR T1
			LEFT JOIN JOINED T2
				ON T1.BASEL_ACCT_ID = T2.BASEL_ACCT_ID_I;
QUIT;

