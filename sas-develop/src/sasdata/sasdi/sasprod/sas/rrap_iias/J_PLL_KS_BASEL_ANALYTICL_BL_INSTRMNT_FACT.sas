/*v_DLGD_RPTG_RTO_PLUS_max_min= IIF(v_DLGD_RPTG_RTO_PLUS_max>=1.0, 1.0,  v_DLGD_RPTG_RTO_PLUS_max)    */

IF v_DLGD_RPTG_RTO_PLUS_max GE 1.0 THEN do; v_DLGD_RPTG_RTO_PLUS_max_min=  1.0; END; ELSE DO; v_DLGD_RPTG_RTO_PLUS_max_min=  v_DLGD_RPTG_RTO_PLUS_max; END;

