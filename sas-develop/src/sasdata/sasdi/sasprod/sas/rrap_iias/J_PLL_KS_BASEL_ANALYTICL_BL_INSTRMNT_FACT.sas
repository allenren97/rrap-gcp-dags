	then do;PD_90_day_F ='True'; end;
	Else do; PD_90_day_F='False'; end;
end;

Else If CONSM_PRD_TREATMNT_CD = 'A' and 
((TRIM(BDV_BASEL_PRD_CD) ='CC' and TRIM(BDV_HELOC_F) ne 'N') or TRIM(BDV_BASEL_PRD_CD) NE 'CC' )   then do;
  If pd_final_rptg_rto >= 1 then do;PD_90_day_F ='True'; end;
