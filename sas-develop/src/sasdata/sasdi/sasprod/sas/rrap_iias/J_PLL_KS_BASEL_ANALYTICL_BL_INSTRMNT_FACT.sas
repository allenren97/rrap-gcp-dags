PROC SQL;
	CREATE TABLE DB2 AS
		SELECT BASEL_ACCT_ID,GENL_LEDGER_BAL_ADJ_AMT,OS_BAL_AMT FROM DB2RRAP.BASEL_REVLVNG_CR_INSTRMNT_ADJ WHERE MTH_TM_ID=&MTH_TM_ID.;
QUIT;

PROC SQL;
