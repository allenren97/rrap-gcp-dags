	,(avg(wrough)) format=best6. as avg_of_wrough
	,(avg(rextraclean)) format=best6. as avg_of_rextraclean
	,(avg(rclean)) format=best6. as avg_of_rclean
	,(avg(raverage)) format=best6. as avg_of_raverage
