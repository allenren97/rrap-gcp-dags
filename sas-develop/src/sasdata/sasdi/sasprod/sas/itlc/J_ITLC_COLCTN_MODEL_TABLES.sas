data spl_3m;
SET spl_3m_temp;
lag_acct_id=lag(risk_acct_id);
lag_amt=lag(prncpl_bal_amt);
lag_arrs=lag(advnc_arrs_amt);

balchag3m=.;
arrearslp3m=.;

if risk_acct_id=lag_acct_id and min_dt ne max_dt and min_dt eq &min_ti_3m_hist. then do;
	arrearslp3m  =(advnc_arrs_amt - lag_arrs)/2;
end;

if risk_acct_id=lag_acct_id and min_dt ne max_dt and min_dt eq &min_ti_3m_hist. and lag_amt ne 0 then do;
	balchag3m =  (prncpl_bal_amt - lag_amt)/lag_amt;
end;

if eff_tm_id= max_dt;
run;


/**Output for SPL DAILY;*/
proc sql;
create table daily_spl as select
	t1.*
	,t2.min_advnc_arrs_amt as arrears_min12m
	,balchag3m
	,arrearslp3m
from spl_hist t1, spl_12m t2, spl_3m t3
where  (t1.risk_acct_id = t2.risk_acct_id and t1.eff_tm_id = t3.eff_tm_id and t1.eff_tm_id = t2.eff_tm_id and t1.risk_acct_id = t3.risk_acct_id);
