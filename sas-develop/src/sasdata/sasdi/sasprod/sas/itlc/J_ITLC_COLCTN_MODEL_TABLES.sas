/*******creation of date and date id macro variables*******/
/*********************************************************;*/
data dt_macro;
	today=&dt_run.;
	call symput("dt_today",put(today,date9.0));

	lday= "&max_dt_spl."d;
	call symput("dt_lday",put(lday,date9.0));
	p00mb = intnx("month","&max_dt_spl."d,0,"b");
	call symput("dt_p00mb",put(p00mb,date9.0));
	p00me = intnx("month","&max_dt_spl."d,0,"e");
	call symput("dt_p00me",put(p00me,date9.0));
	p01mb = intnx("month","&max_dt_spl."d,-1,"b");
	call symput("dt_p01mb",put(p01mb,date9.0));
	p01me = intnx("month","&max_dt_spl."d,-1,"e");
	call symput("dt_p01me ",put(p01me,date9.0));
	p03md = intnx("month","&max_dt_spl."d,-3,"sameday");
	call symput("dt_p03md",put(p03md,date9.0));
	p12md = intnx("month","&max_dt_spl."d,-12,"sameday");
	call symput("dt_p12md",put(p12md,date9.0));

	lme_cb = "&max_dt_cb"d;
	call symput("dt_lme_cb",put(lme_cb,date9.0));
	p03me_cb = intnx("month","&max_dt_cb"d,-2,"e");
	call symput("dt_p03me_cb",put(p03me_cb,date9.0));
	p12me_cb = intnx("month","&max_dt_cb"d,-11,"e");
	call symput("dt_p12me_cb",put(p12me_cb,date9.0));

/*	**/
/*	lday = last daily*/
/*	b	= begin*/
/*	d 	= day*/
/*	e	= end*/
/*	l 	= lastest*/
/*	m	= month*/
/*	p	= previous*/
/*	q	= quarter*/
/*	y 	= year*/
/*	;*/
run;

