%macro rcrd(no,table,dataset,dt_var,dt_tp,key);
proc sql;
create table rcrd_tbl&no. as select
	&no. as no,
	"&table." as table format=$5.
	,input("&dataset.",$30.) as dataset
	,max(&dt_var.) as &dt_tp.
 	,count(&key.) as nb_record
from &dataset.
group by &dt_var.;
quit;
%mend rcrd;

%rcrd(1,spl,spl_dlq_accts,eff_tm_id,max_ti,risk_acct_id);
%rcrd(3,pb,probe_mth,eff_tmstmp,max_dt,risk_acct_id);
%rcrd(4,bb,month_bb_ranked,mth_tm_id,max_ti,risk_acct_id);
%rcrd(2,sd,month_spl_drvd_var,mth_tm_id,max_ti,risk_acct_id);
%rcrd(5,rs,month_spl_acct_cust,mth_tm_id,max_ti,risk_acct_id);
%rcrd(6,cb,cb_final,mth_tm_id,max_ti,risk_cust_id);


data rcrd_tbl;
set rcrd_tbl1 - rcrd_tbl6;
run;


proc sql;
create table cntrl_date as select
	no,
	t1.table
    ,t1.max_ti
	,(input(t1.max_dt,date9.0)) format=DATE9. as max_dt
    ,t2.dataset
    ,t2.nb_record 
	,t2.max_ti as max_ti_run
    ,datepart(t2.max_dt) as max_dt_run format=date9.
    ,(max((t1.max_ti=t2.max_ti),((input(t1.max_dt,date9.0))=datepart(t2.max_dt)))) as chk_date
	,(case when nb_record le 0 then (compress(t1.table) || " has zero record") else "" end) as mess_rcrd
	,(case when calculated chk_date eq 0 then (compress(t1.table) || " " || "has a wrong date") else "" end) as mess_dt
from max_dt_tbl t1
left join rcrd_tbl t2 on (t1.table = t2.table)
order by no;
quit;


