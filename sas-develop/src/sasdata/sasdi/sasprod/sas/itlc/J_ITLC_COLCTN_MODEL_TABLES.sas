/**extraction of actual delq accounts;*/
proc sql;
create table spl_dlq_accts as select
	eff_tm_id
	,risk_acct_id
	,risk_cust_id
	,compress(put(scrty_cd,4.)) as scrty_cd_char
	,substr(compress(calculated scrty_cd_char),lengthc(compress(calculated scrty_cd_char)),1) as last_digit_sc_cd
	,(substr(acct_num,3,21)) as acct_num21
from modeldb2.psnl_loan_dly_snapshot
where eff_tm_id eq &dti_lday.
	and day_overdue between 1 and 89 
	and (compress(commercial_loan_cd) eq "0") 
	and (compress(recd_stat_cd) in ("4")) 
	and (prncpl_bal_amt+accr_intr_amt) > 0 
	and calculated scrty_cd_char ne "18" 
	and	calculated last_digit_sc_cd in ("7","8");
quit;

/**extract hist for actual delq accounts;*/
proc sql;
create table spl_hist as select
	t1.eff_tm_id
	,t1.risk_acct_id
	,t1.risk_cust_id
	,t1.day_overdue
	,t1.prncpl_bal_amt
	,t1.accr_intr_amt
    ,t1.advnc_arrs_amt
    ,t1.acct_num
	,t1.cab
    ,t1.loan_num
	,t1.product_type
	,t1.scrty_cd
 	,t1.scrty_1_yr 
    ,t1.scrty_1_desc 
    ,t1.scrty_1_new_f 
    ,t1.scrty_1_serial_num 
 	,upcase((substr(scrty_1_serial_num,1,8))) as vin
	,put(scrty_1_yr,vin_year.) as bb_vin_year 
    ,(substr(t1.acct_num,3,21)) as acct_num21
    ,(case when eff_tm_id ge &dti_p12md. then 1 else 0 end) as flag12m
    ,(case when eff_tm_id ge &dti_p03md. then 1 else 0 end) as flag3m
    ,compress(put(scrty_cd,4.)) as scrty_cd_char
	,substr(compress(calculated scrty_cd_char),lengthc(compress(calculated scrty_cd_char)),1) as last_digit_sc_cd
	,t1.commercial_loan_cd
    ,t1.recd_stat_cd
	,t2.day_dt
	,t2.fncl_mth_key as time_key
	,t2.tm_lvl_end_dt
from modeldb2.psnl_loan_dly_snapshot t1
	inner join modeldb2.tm_dim t2 on (t1.eff_tm_id = t2.tm_id)
	where t1.eff_tm_id between &dti_p12md. and  &dti_lday. 
	and t1.risk_acct_id in (select risk_acct_id from spl_dlq_accts); 
quit;



data	spl_hist;
set 	spl_hist;

format 	status $10.;
format 	daysover_cat $10.;

spl_udt_bal=prncpl_bal_amt+accr_intr_amt;
recstat_code=recd_stat_cd;

	if day_overdue<=0 and spl_udt_bal>0 and recstat_code in (4) then do; 
			status='cur'; 
			daysover_cat='0';
		end;
	if recstat_code in (9) then do; 
			status='paid off';
			daysover_cat='0';
		end;
	if day_overdue>0 and day_overdue<30 and recstat_code not in (5,6,8) then do;
			daysover_cat='1-29'; 
			status= '1-29';
		end;
	if day_overdue>29 and day_overdue<60 and recstat_code not in (5,6,8) then do;
			daysover_cat='30-59'; 
			status= '30-59';
		end;
	if day_overdue>59 and day_overdue<90 and recstat_code not in (5,6,8) then do;
			daysover_cat='60-89';  
			status= '60-89';
		end;
	if day_overdue=0 and recstat_code in (5,6) then do;
			daysover_cat='0'; 
			status= '90+';
		end;
	if day_overdue>0 and day_overdue<30 and recstat_code in (5,6) then do;
			daysover_cat='1-29'; 
			status= '90+';
		end;
	if day_overdue>29 and day_overdue<60 and recstat_code in (5,6) then do;
			daysover_cat='30-59'; 
			status= '90+';
		end;
	if day_overdue>59 and day_overdue<90 and recstat_code in (5,6) then do;
			daysover_cat='60-89';
			status= '90+';
		end;
	if day_overdue>89 and recstat_code ne 8 then do;
			daysover_cat='90+' ; 
			status= '90+';
		end;
	if recstat_code in (7,8) then do;
			daysover_cat='0';
			status='wor';
		end;
run;

/**derived last 12 months variables;*/
proc sql;
create table spl_12m as select 
	risk_acct_id
	,max(eff_tm_id) as eff_tm_id
	,min(eff_tm_id) as min_eff_tm_id
	,(min(advnc_arrs_amt)) as min_advnc_arrs_amt
from spl_hist
where flag12m = 1
group by risk_acct_id;
quit;

/**derived last 3 months variables;*/

proc sql;
create table spl_3m_select as select
	eff_tm_id
	,risk_acct_id
	,prncpl_bal_amt
	,advnc_arrs_amt
	,tm_lvl_end_dt
from spl_hist
where flag3m = 1
order by risk_acct_id, eff_tm_id;
quit;

proc sql;
create table spl_3m_temp as select
	eff_tm_id
	,risk_acct_id
	,prncpl_bal_amt
	,advnc_arrs_amt
	,tm_lvl_end_dt
	,min(eff_tm_id) as min_dt		  
	,max(eff_tm_id) as max_dt
from spl_3m_select
group by risk_acct_id
having (eff_tm_id=calculated min_dt or eff_tm_id=calculated max_dt)
order by risk_acct_id, eff_tm_id;;
quit;


