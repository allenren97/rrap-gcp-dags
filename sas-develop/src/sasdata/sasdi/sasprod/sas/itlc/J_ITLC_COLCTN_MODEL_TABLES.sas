%macro rank (model,source,score);
proc sql;
   create table rank_&model. as 
   select eff_tm_id, 
          risk_acct_id, 
          model, 
          &score.
      from &source.
where model="&model.";
quit;

proc sql;
	create view sort_&model. as
		select *
	from rank_&model.
;
quit;

proc rank data = sort_&model.
	groups=10
	ties=mean
	out=work.ranked_&model.;
	var &score.;
ranks rank ;
run; quit;

proc sql;
   create table rpt_rank_&model. as 
   select rank, 
          (min(&score.)) as min_score, 
          (max(&score.)) as max_score, 
          (count(risk_acct_id)) as nb
      from ranked_&model.
      group by rank;
quit;

%mend rank;

