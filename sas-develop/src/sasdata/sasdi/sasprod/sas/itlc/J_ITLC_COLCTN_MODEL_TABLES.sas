ODS PDF file="&itlc_dir/data/itlc/control_report_&dt_run_rpt..pdf" startpage=no;
%rpt_delq;
proc print noobs data= rpt01_no_match;
proc print noobs data=dt_id;
proc print noobs data=cntl_cust_loaded;
proc print noobs data=cntl_score_loaded;
proc print noobs data=cntl_drvd_loaded;
proc print noobs data=rpt_rank_itlc_b01;
proc print noobs data=rpt_rank_itlc_b02;
proc print noobs data=rpt_rank_itlc_r01;
run;
ODS PDF close;

filename mymail email 
to=(&ITLC_TO_LIST)
cc=(&ITLC_CC_LIST)
Subject="Indirect loans collection models report";

DATA _NULL_;
FILE mymail;
PUT "Hi" //;
PUT "Please find the attached copy of the ITLC report as &dt_run_rpt.";
PUT '!EM_ATTACH! ("&itlc_dir/data/itlc/control_report_&dt_run_rpt..pdf")';
RUN;

%mend email;



%macro error;
ODS PDF file="&itlc_dir/data/itlc/control_report_error.pdf" startpage=no;
proc print noobs data= ctl_var_error;
proc print noobs data=ctl_rcrd_dt_error;
ODS PDF close;

filename mymail email 
to=(&ITLC_TO_LIST &FAILURE_TO_LIST)
cc=(&ITLC_CC_LIST)
Subject='Error - Indirect loans collection models';

DATA _NULL_;
FILE mymail;
PUT "Hi"//;
PUT "Please find the attached copy of the ITLC errors report as &dt_run_rpt.";
PUT '!EM_ATTACH! ("&itlc_dir/data/itlc/control_report_error.pdf")';
RUN;
%mend error;


%macro load;
 %if &err1. ge 1 or &err2. ge 1 %then %do;
                %error;
     %end;
  %else %do; 
        /* %error; this is the addition to existing logic*/
        %load_cust;
        %load_drvd;
        %load_score;
        %rpt_load;
        %email;
  %end; 
%mend load;

%load;


/*---- End of User Written Code  ----*/ 

%rcSet(&syserr); 
%rcSet(&sqlrc); 
%rcSet(&syscc); 



/**  Step end ERROR_OR_LOAD **/

%let etls_endTime = %sysfunc(datetime(),datetime.);

