/**acct and customer relationship;*/
proc sql;
create table month_spl_acct_cust as select distinct
	t1.risk_acct_id
	,t1.risk_cust_id
	,t1.mth_tm_id
	,t2.cust_cid
from	modeldb2.risk_cust_acct_rltnp_snapshot t1
	inner join modeldb2.risk_cust_dim t2 on (t1.risk_cust_id=t2.risk_cust_id)
where	t1.mth_tm_id = &max_ti_rs.
		and t1.prim_cust_f = 'Y' 
		and t1.risk_acct_id in (select risk_acct_id from spl_dlq_accts);
QUIT;


/**need to extract latest date from CB table and calculate the previous 3 or 12 mnths dates;*/

/**extract monthly hist CB information;*/
proc sql;
create table cb as select
	mth_tm_id
 	,risk_cust_id
	,cust_cid
	,cif_key
	,mth_since_oldst_trade_opnd_cnt
	,mth_since_most_recnt_dlqnt_cnt
	,dergtry_pub_recd_cnt
	,tot_utltn_bnk_revlvng_crd_amt
	,inqry_cnt
	,inqry_past_6_mth_cnt
	,colctn_inqr_cnt
	,mth_since_last_60_day_dlqnt_cnt
	,tot_colctn_bal_amt
	,tot_pd_amt
	,actv_trds_cnt
	,actv_trade_with_amt_pd_cnt
	,(case when mth_tm_id ge &mti_p12me_cb. then 1 else 0 end) as flag12m
	,(case when mth_tm_id ge &mti_p03me_cb. then 1 else 0 end) as flag3m
from modeldb2.risk_cr_bureau_deli_mth_snapshot
where mth_tm_id ge &mti_p12me_cb. 
		and mth_tm_id le &mti_lme_cb.
		and risk_cust_id in (select risk_cust_id from month_spl_acct_cust);
quit;


/**derived CB last 12 mos variables;*/
proc sql;
create table cb_12m as select 
	max(mth_tm_id) as mth_tm_id,
	min(mth_tm_id) as min_tm_id
	,risk_cust_id
	,flag12m
	,(max(mth_since_most_recnt_dlqnt_cnt)) format=4. as max_of_mth_since_most_recnt_dlqn
	,(max(actv_trade_with_amt_pd_cnt)) format=4. as max_of_actv_trade_with_amt_pd_cn
from cb
where flag12m eq 1
group by risk_cust_id,
         flag12m;
quit;


/**derived CB last 3 mos variables;*/
proc sql;
create table cb_3m_temp as select 
	max(mth_tm_id) as mth_tm_id
	,risk_cust_id
	,flag3m
	,count(risk_cust_id) as nb_obs
	,count(tot_utltn_bnk_revlvng_crd_amt) as nb_nmiss
	,(max(tot_colctn_bal_amt)) format=8. as max_of_tot_colctn_bal_amt
	,sum(tot_utltn_bnk_revlvng_crd_amt) as sum_tot_utl_bnk_revlv_crd_amt
	,(max(tot_pd_amt)) format=8. as max_of_tot_pd_amt
	,(max(mth_since_last_60_day_dlqnt_cnt)) as max_of_mth_since_last_60_day_dlq
from cb
where flag3m eq 1
group by risk_cust_id,
         flag3m;
quit;

proc sql;
create table cb_3m_exist as select 
	max(mth_tm_id) as mth_tm_id
	,(case when min(mth_tm_id) lt &mti_p03me_cb. then 1 else 0 end) as ind_exist
	,risk_cust_id
	,sum(flag12m) as nb_12m
	,sum(flag3m) as nb_3m
from cb
group by risk_cust_id;
quit;


proc sql;
create table cb_3m as select 
	t1.mth_tm_id
	,t1.risk_cust_id
	,t1.nb_obs 
	,t1.nb_nmiss 
	,t1.max_of_tot_colctn_bal_amt 
	,t1.sum_tot_utl_bnk_revlv_crd_amt
	,t1.max_of_tot_pd_amt
	,t1.max_of_mth_since_last_60_day_dlq
	,(case when t2.ind_exist eq 1 then sum_tot_utl_bnk_revlv_crd_amt/3 else 
	sum_tot_utl_bnk_revlv_crd_amt/nb_obs end) as avg_of_tot_utltn_bnk_revlvng_crd
from cb_3m_temp t1, cb_3m_exist t2
where (t1.mth_tm_id = t2.mth_tm_id and t1.risk_cust_id = t2.risk_cust_id);
quit;

proc sql;
   create table work.cb_final as 
   select t2.mth_tm_id, 
          t2.risk_cust_id, 
          t2.cust_cid, 
          t2.cif_key, 
          t2.mth_since_oldst_trade_opnd_cnt, 
          t2.mth_since_most_recnt_dlqnt_cnt, 
          t2.dergtry_pub_recd_cnt, 
          t2.tot_utltn_bnk_revlvng_crd_amt, 
          t2.inqry_cnt, 
          t2.inqry_past_6_mth_cnt, 
          t2.colctn_inqr_cnt, 
          t2.mth_since_last_60_day_dlqnt_cnt, 
          t2.tot_colctn_bal_amt, 
          t2.tot_pd_amt, 
          t2.actv_trds_cnt, 
          t2.actv_trade_with_amt_pd_cnt, 
          t2.flag12m, 
          t2.flag3m, 
          t3.max_of_mth_since_most_recnt_dlqn, 
          t3.max_of_actv_trade_with_amt_pd_cn, 
          t4.nb_obs, 
          t4.nb_nmiss, 
          t4.max_of_tot_colctn_bal_amt, 
          t4.sum_tot_utl_bnk_revlv_crd_amt, 
          t4.max_of_tot_pd_amt, 
          t4.max_of_mth_since_last_60_day_dlq, 
          t4.avg_of_tot_utltn_bnk_revlvng_crd
      from cb t2, cb_12m t3, cb_3m t4
      where (t2.risk_cust_id = t3.risk_cust_id and t2.mth_tm_id = t3.mth_tm_id and t2.mth_tm_id = t4.mth_tm_id and 
           t2.risk_cust_id = t4.risk_cust_id);
quit;


proc sql;
create table month_cb as select distinct 
	t1.mth_tm_id
	,t1.risk_acct_id
	,t1.risk_cust_id
	,t1.cust_cid
	,t2.mth_since_oldst_trade_opnd_cnt
	,t2.mth_since_most_recnt_dlqnt_cnt
	,t2.dergtry_pub_recd_cnt
	,t2.tot_utltn_bnk_revlvng_crd_amt
	,t2.inqry_cnt
	,t2.inqry_past_6_mth_cnt
	,t2.colctn_inqr_cnt
	,t2.mth_since_last_60_day_dlqnt_cnt
	,t2.tot_colctn_bal_amt
	,t2.tot_pd_amt
	,t2.actv_trds_cnt
	,t2.actv_trade_with_amt_pd_cnt
	,(t2.inqry_cnt - t2.colctn_inqr_cnt) as go_clean
	,t2.max_of_actv_trade_with_amt_pd_cn as at18_max12m
	,t2.max_of_mth_since_most_recnt_dlqn as at36_max12m
	,t2.max_of_tot_colctn_bal_amt as pr11_max3m
	,t2.max_of_tot_pd_amt as at84_max3m
	,t2.avg_of_tot_utltn_bnk_revlvng_crd as br34_avg3m
	,t2.max_of_mth_since_last_60_day_dlq as at86_max3m
	,(case when t2.risk_cust_id is not missing then 1 else 0 end) as ind_cb_exist
from month_spl_acct_cust t1
left join cb_final t2 on (t1.risk_cust_id=t2.risk_cust_id);
quit;

