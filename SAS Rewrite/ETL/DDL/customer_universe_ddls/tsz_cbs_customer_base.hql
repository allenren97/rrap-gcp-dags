    RETAIL_IND                      VARCHAR(1),
    PRIME_IND                       VARCHAR(1),
    SECONDARY_IND                   VARCHAR(1),
    PRIME_IND_LEND                  VARCHAR(1),
    SECONDARY_IND_LEND              VARCHAR(1),
    NUM_NONLEND_PRODS_ACT           VARCHAR(100),
    NUM_NONLEND_PRODS_PND_CLSR      VARCHAR(10),
    NUM_NONLEND_PRODS_DOR           VARCHAR(100),
