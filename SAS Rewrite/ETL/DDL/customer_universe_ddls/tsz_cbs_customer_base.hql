    NUM_LEND_PRODS_WRT_OFF          VARCHAR(100),
    NUM_LEND_PRODS_COMM             VARCHAR(100),
    NUM_LEND_PRODS_COMM_CUR         VARCHAR(100),
    NUM_LEND_PRODS_COMM_CLSD        VARCHAR(100),
    NUM_LEND_PRODS_COMM_CHRG_OFF    VARCHAR(100),
