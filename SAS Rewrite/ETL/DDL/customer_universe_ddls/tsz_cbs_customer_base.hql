TBLPROPERTIES ('orc.compress' = 'SNAPPY')
;

ALTER TABLE tsz_b9xf_rrap.cbs_customer_base
ADD IF NOT EXISTS PARTITION (businesseffectivedate='${businesseffectivedate}')
LOCATION '/data/lz/int/tsz/b9xf_rrap/cbs_customer_base/businesseffectivedate=${businesseffectivedate}';

