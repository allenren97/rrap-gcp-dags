    NON_LEND_PRODS_ACT          VARCHAR(100),
    NON_LEND_PRODS_PEND_CLSD    VARCHAR(100),
    NON_LEND_PRODS_DOR          VARCHAR(100),
    NON_LEND_PRODS_INACT        VARCHAR(100),
