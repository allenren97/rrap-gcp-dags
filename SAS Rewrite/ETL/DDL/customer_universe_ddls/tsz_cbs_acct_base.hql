    PD_OFF_F_MORT               VARCHAR(1),
    MTH_IN_ARRS_CNT_MORT        VARCHAR(100),
    LIFE_INSUR_CD_MORT          VARCHAR(20),
    SOURCE_CD                   VARCHAR(20),
    ACCT_STAT_CD                VARCHAR(20),
    CR_LMT_AMT                  VARCHAR(100),
