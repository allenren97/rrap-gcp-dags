    ACCOUNT_NUM                 VARCHAR(30),
    PRIMARY_CUST_FLAG           VARCHAR(1),
    RELATION_CODE               VARCHAR(10),
    EMPLOYEE_IND                VARCHAR(1),
    MORT_NUM                    VARCHAR(30),
    LOAN_NUM                    VARCHAR(30),
    FILE_DATE                   VARCHAR(50),
