PARTITIONED BY( BUSINESSEFFECTIVEDATE DATE)
STORED AS ORC
LOCATION '/data/lz/int/tsz/b9xf_rrap/CBS_ACCT_BASE'
TBLPROPERTIES ('orc.compress' = 'SNAPPY')
;
ALTER TABLE tsz_b9xf_rrap.cbs_acct_base
ADD IF NOT EXISTS PARTITION (businesseffectivedate='${businesseffectivedate}')
LOCATION '/data/lz/int/tsz/b9xf_rrap/cbs_acct_base/businesseffectivedate=${businesseffectivedate}';

