    NUM_OF_LEND_PRODS           VARCHAR(100),
    CID_NUM                     VARCHAR(30),
    MORT_IND                    VARCHAR(1),
    SPL_IND                     VARCHAR(1),
    REV_IND                     VARCHAR(1),
    SSL_IND                     VARCHAR(1),
    LEND_PRODS_CUR              VARCHAR(100),
    LEND_PRODS_CLSD             VARCHAR(100),
    LEND_PRODS_BNKRPT           VARCHAR(100),
    LEND_PRODS_DEF              VARCHAR(100),
    LEND_PRODS_CHRG_OFF         VARCHAR(100),
    LEND_PRODS_WRT_OFF          VARCHAR(100),
    LEND_PRODS_COMM             VARCHAR(100),
    LEND_PRODS_COMM_CUR         VARCHAR(100),
    LEND_PRODS_COMM_CLSD        VARCHAR(100),
    LEND_PRODS_COMM_DEF         VARCHAR(100),
    LEND_PRODS_COMM_CHRG_OFF    VARCHAR(100),
